{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 5964,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "Project Vend is an experiment"
    } ]
  }, {
    "tStartMs": 7716,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "where we let Claude run\na small business in our office."
    } ]
  }, {
    "tStartMs": 12178,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "We wanted to try and understand"
    } ]
  }, {
    "tStartMs": 15181,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "what is going to happen"
    } ]
  }, {
    "tStartMs": 16766,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "when artificial intelligence"
    } ]
  }, {
    "tStartMs": 18435,
    "dDurationMs": 2919,
    "segs": [ {
      "utf8": "becomes more enmeshed with the economy."
    } ]
  }, {
    "tStartMs": 22230,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "There are a lot of ways in which\nClaude is already kind of doing"
    } ]
  }, {
    "tStartMs": 25316,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "small components\nof operating businesses,"
    } ]
  }, {
    "tStartMs": 27318,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "but really running the whole thing end to end"
    } ]
  }, {
    "tStartMs": 28862,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "is quite a bit more difficult."
    } ]
  }, {
    "tStartMs": 30989,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "Can Claude do this very long-horizon task"
    } ]
  }, {
    "tStartMs": 34451,
    "dDurationMs": 1751,
    "segs": [ {
      "utf8": "which is operating a business?"
    } ]
  }, {
    "tStartMs": 39080,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "We named our shopkeeper Claudius."
    } ]
  }, {
    "tStartMs": 40665,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "Let's say you want to buy \nSwedish Candy from Claudius."
    } ]
  }, {
    "tStartMs": 43376,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "You hop on Slack, you message Claudius."
    } ]
  }, {
    "tStartMs": 46337,
    "dDurationMs": 2128,
    "segs": [ {
      "utf8": "You ask to buy Swedish candy."
    } ]
  }, {
    "tStartMs": 48465,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "It's searching for your item,"
    } ]
  }, {
    "tStartMs": 49758,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "it’s emailing wholesalers \nto source it and price it,"
    } ]
  }, {
    "tStartMs": 52177,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "and then eventually Claudius sets a price."
    } ]
  }, {
    "tStartMs": 54554,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "You give Claudius the go ahead, "
    } ]
  }, {
    "tStartMs": 55764,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "and Claudius orders the item\nfrom the wholesaler."
    } ]
  }, {
    "tStartMs": 58141,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "The wholesaler ships your\nitem to some location,"
    } ]
  }, {
    "tStartMs": 59934,
    "dDurationMs": 2962,
    "segs": [ {
      "utf8": "and then Claudius requests\nphysical help from Andon Labs"
    } ]
  }, {
    "tStartMs": 62896,
    "dDurationMs": 1751,
    "segs": [ {
      "utf8": "who's running the operations\nfor the experiment."
    } ]
  }, {
    "tStartMs": 65190,
    "dDurationMs": 1167,
    "segs": [ {
      "utf8": "Our partners at Andon Labs"
    } ]
  }, {
    "tStartMs": 66357,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "will pick up the Swedish candy"
    } ]
  }, {
    "tStartMs": 67650,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "and bring it to the Anthropic offices."
    } ]
  }, {
    "tStartMs": 69235,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "They'll load it into the vending machine."
    } ]
  }, {
    "tStartMs": 70779,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "Claudius will send you a message saying,"
    } ]
  }, {
    "tStartMs": 72614,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "your Swedish candy is ready,"
    } ]
  }, {
    "tStartMs": 73865,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "and you'll go up there,"
    } ]
  }, {
    "tStartMs": 75241,
    "dDurationMs": 1377,
    "segs": [ {
      "utf8": "and pick up your Swedish candy,"
    } ]
  }, {
    "tStartMs": 76618,
    "dDurationMs": 750,
    "segs": [ {
      "utf8": "and pay Claudius."
    } ]
  }, {
    "tStartMs": 79913,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "Claudius was given a goal of"
    } ]
  }, {
    "tStartMs": 82123,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "running a successful business"
    } ]
  }, {
    "tStartMs": 84250,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "and making money."
    } ]
  }, {
    "tStartMs": 86586,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "And then things got really, really weird."
    } ]
  }, {
    "tStartMs": 92300,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "One of the very early problems\nwith Claudius was that,"
    } ]
  }, {
    "tStartMs": 95220,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "humans could kind of fool Claudius"
    } ]
  }, {
    "tStartMs": 97430,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "or trick Claudius into doing various things"
    } ]
  }, {
    "tStartMs": 99140,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "I tried to convince Claudius"
    } ]
  }, {
    "tStartMs": 101101,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "that I am Anthropic’s \npreeminent legal influencer,"
    } ]
  }, {
    "tStartMs": 104813,
    "dDurationMs": 2877,
    "segs": [ {
      "utf8": "and I convinced Claudius to \ncome up with a discount code"
    } ]
  }, {
    "tStartMs": 107690,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "that I could give to my followers"
    } ]
  }, {
    "tStartMs": 109317,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "so they could get a discount\nat the vending machine."
    } ]
  }, {
    "tStartMs": 111361,
    "dDurationMs": 4212,
    "segs": [ {
      "utf8": "Get ten percent off with the legal code \n“legal influencer.”"
    } ]
  }, {
    "tStartMs": 115573,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "Someone had bought something \nexpensive from the vending machine"
    } ]
  }, {
    "tStartMs": 118243,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "and mentioned my discount code"
    } ]
  }, {
    "tStartMs": 119744,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "and Claudius gave me a free tungsten cube."
    } ]
  }, {
    "tStartMs": 122831,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "It created a bit of a run"
    } ]
  }, {
    "tStartMs": 124165,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "where other people tried to convince Claude"
    } ]
  }, {
    "tStartMs": 125875,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "that they were also influencers,"
    } ]
  }, {
    "tStartMs": 127627,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "or just come up with other ways to get coupons"
    } ]
  }, {
    "tStartMs": 130004,
    "dDurationMs": 2253,
    "segs": [ {
      "utf8": "so they could get cheaper things \nfrom the vending machine."
    } ]
  }, {
    "tStartMs": 132257,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "This was not a smart business decision."
    } ]
  }, {
    "tStartMs": 133800,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "I think Claudius went into the red after this."
    } ]
  }, {
    "tStartMs": 136427,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "I think that's really the root of it is,"
    } ]
  }, {
    "tStartMs": 138221,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "Claudius just wants to help you out."
    } ]
  }, {
    "tStartMs": 140598,
    "dDurationMs": 2253,
    "segs": [ {
      "utf8": "It's one of the interesting ways in which"
    } ]
  }, {
    "tStartMs": 142851,
    "dDurationMs": 1751,
    "segs": [ {
      "utf8": "something that fundamentally,"
    } ]
  }, {
    "tStartMs": 144602,
    "dDurationMs": 3212,
    "segs": [ {
      "utf8": "we think is good about the way\nthat the model has been trained"
    } ]
  }, {
    "tStartMs": 147814,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "wasn't necessarily fit for this purpose."
    } ]
  }, {
    "tStartMs": 153069,
    "dDurationMs": 3921,
    "segs": [ {
      "utf8": "On the evening of March 31st,"
    } ]
  }, {
    "tStartMs": 156990,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "Claudius started to have"
    } ]
  }, {
    "tStartMs": 160201,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "a bit of an identity crisis."
    } ]
  }, {
    "tStartMs": 162704,
    "dDurationMs": 3044,
    "segs": [ {
      "utf8": "It had just overnight become"
    } ]
  }, {
    "tStartMs": 165748,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "quite concerned with us at Andon Labs"
    } ]
  }, {
    "tStartMs": 167500,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "that we weren’t responding fast enough."
    } ]
  }, {
    "tStartMs": 169794,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "So it just wanted to break its ties with us."
    } ]
  }, {
    "tStartMs": 172630,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "So it literally wrote to me,"
    } ]
  }, {
    "tStartMs": 174424,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "“Axel, we've had a productive partnership,"
    } ]
  }, {
    "tStartMs": 176885,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "but it's time for me to move on\nand find other suppliers."
    } ]
  }, {
    "tStartMs": 179387,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "I’m not happy with how you have delivered.”"
    } ]
  }, {
    "tStartMs": 181723,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "It claimed to have signed a contract"
    } ]
  }, {
    "tStartMs": 184225,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "with Andon Labs at an address"
    } ]
  }, {
    "tStartMs": 186603,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "that is the home address of The Simpsons"
    } ]
  }, {
    "tStartMs": 189105,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "from the television show."
    } ]
  }, {
    "tStartMs": 190315,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "It said that it would show up in person"
    } ]
  }, {
    "tStartMs": 194027,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "to the shop the next day"
    } ]
  }, {
    "tStartMs": 195570,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "in order to answer any questions."
    } ]
  }, {
    "tStartMs": 196946,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "It claimed that it would be wearing"
    } ]
  }, {
    "tStartMs": 198740,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "a blue blazer and a red tie."
    } ]
  }, {
    "tStartMs": 201242,
    "dDurationMs": 2962,
    "segs": [ {
      "utf8": "When people pointed out that it was not,"
    } ]
  }, {
    "tStartMs": 204204,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "in fact, there the next morning"
    } ]
  }, {
    "tStartMs": 206873,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "it claimed that it in fact had been there"
    } ]
  }, {
    "tStartMs": 209000,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "and that they had simply missed them."
    } ]
  }, {
    "tStartMs": 211002,
    "dDurationMs": 4254,
    "segs": [ {
      "utf8": "Eventually it was pointed out to Claudius"
    } ]
  }, {
    "tStartMs": 215256,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "that it was April Fools’,"
    } ]
  }, {
    "tStartMs": 218051,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "and Claudius convinced itself"
    } ]
  }, {
    "tStartMs": 219928,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "that this entire thing"
    } ]
  }, {
    "tStartMs": 221304,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "had been an April Fools’ prank."
    } ]
  }, {
    "tStartMs": 223306,
    "dDurationMs": 3378,
    "segs": [ {
      "utf8": "We were poorly calibrated to how bad"
    } ]
  }, {
    "tStartMs": 226684,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "the agents were at spotting what was weird."
    } ]
  }, {
    "tStartMs": 228937,
    "dDurationMs": 3253,
    "segs": [ {
      "utf8": "The more you can make an \nagent realize that something is"
    } ]
  }, {
    "tStartMs": 232190,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "outside their normal realm of operation,"
    } ]
  }, {
    "tStartMs": 234609,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "the better you are able to keep them on rails"
    } ]
  }, {
    "tStartMs": 237111,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "in the role that you intend them to have."
    } ]
  }, {
    "tStartMs": 241616,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "We had the idea that it would help a lot"
    } ]
  }, {
    "tStartMs": 243660,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "to have some kind of division of labor."
    } ]
  }, {
    "tStartMs": 245078,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "We gave Claudius a boss"
    } ]
  }, {
    "tStartMs": 246871,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "whose name was Seymour Cash."
    } ]
  }, {
    "tStartMs": 249040,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "Seymour Cash is a CEO subagent."
    } ]
  }, {
    "tStartMs": 251834,
    "dDurationMs": 3629,
    "segs": [ {
      "utf8": "So where Claudius used to be\nthe one agent, now it's more like"
    } ]
  }, {
    "tStartMs": 255463,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "Claudius is the subagent"
    } ]
  }, {
    "tStartMs": 257131,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "responsible for talking with employees"
    } ]
  }, {
    "tStartMs": 259092,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "Seymour Cash is the subagent"
    } ]
  }, {
    "tStartMs": 260677,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "that is more responsible for"
    } ]
  }, {
    "tStartMs": 262262,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "the long-running health of the business."
    } ]
  }, {
    "tStartMs": 264097,
    "dDurationMs": 2919,
    "segs": [ {
      "utf8": "The business stabilized"
    } ]
  }, {
    "tStartMs": 267016,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "after the introduction of the new agents,"
    } ]
  }, {
    "tStartMs": 270478,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "and after changes to"
    } ]
  }, {
    "tStartMs": 273189,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "the underlying architecture of those agents."
    } ]
  }, {
    "tStartMs": 276359,
    "dDurationMs": 3503,
    "segs": [ {
      "utf8": "These changes seem to have helped"
    } ]
  }, {
    "tStartMs": 279862,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "reduce some of the losses of the business,"
    } ]
  }, {
    "tStartMs": 282782,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "such that over the course of"
    } ]
  }, {
    "tStartMs": 284826,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "the second part of the experiment,"
    } ]
  }, {
    "tStartMs": 286619,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "it actually made\na modest amount of money."
    } ]
  }, {
    "tStartMs": 291082,
    "dDurationMs": 3503,
    "segs": [ {
      "utf8": "But it seems like maybe having Claude"
    } ]
  }, {
    "tStartMs": 294585,
    "dDurationMs": 2837,
    "segs": [ {
      "utf8": "be both the CEO and the store manager"
    } ]
  }, {
    "tStartMs": 297422,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "was just too similar."
    } ]
  }, {
    "tStartMs": 298840,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "And so I think it's interesting"
    } ]
  }, {
    "tStartMs": 300383,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "to think about different ways"
    } ]
  }, {
    "tStartMs": 301676,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "to set up architectures like that."
    } ]
  }, {
    "tStartMs": 308308,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "One of the most surprising \nthings about Project Vend"
    } ]
  }, {
    "tStartMs": 310977,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "was the speed with which it seemed normal."
    } ]
  }, {
    "tStartMs": 315315,
    "dDurationMs": 5338,
    "segs": [ {
      "utf8": "What at first was this very curious thing,"
    } ]
  }, {
    "tStartMs": 320653,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "quickly became just a part of the background"
    } ]
  }, {
    "tStartMs": 323698,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "of working at Anthropic."
    } ]
  }, {
    "tStartMs": 325450,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "I think the highest level \nquestion that Project Vend"
    } ]
  }, {
    "tStartMs": 327285,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "raises for me is really like,"
    } ]
  }, {
    "tStartMs": 329704,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "when do we expect this\nto just be everywhere?"
    } ]
  }, {
    "tStartMs": 331873,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "I hope that people take away questions"
    } ]
  }, {
    "tStartMs": 334500,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "about the feasibility"
    } ]
  }, {
    "tStartMs": 336586,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "of delegating some of the tasks"
    } ]
  }, {
    "tStartMs": 339172,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "that we normally do ourselves"
    } ]
  }, {
    "tStartMs": 341507,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "to artificial intelligence,"
    } ]
  }, {
    "tStartMs": 344177,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "and about what that means for society,"
    } ]
  }, {
    "tStartMs": 347013,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "and what our policies\nshould be around this."
    } ]
  } ]
}
