  "events": [ {
    "tStartMs": 250,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "We're introducing new capabilities"
    } ]
  }, {
    "tStartMs": 2252,
    "dDurationMs": 3378,
    "segs": [ {
      "utf8": "for managing your agents context\non the Claude API."
    } ]
  }, {
    "tStartMs": 6131,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "Context editing automatically clears\nstale tool calls and results"
    } ]
  }, {
    "tStartMs": 9968,
    "dDurationMs": 2919,
    "segs": [ {
      "utf8": "from within the context window when\napproaching token limits,"
    } ]
  }, {
    "tStartMs": 13555,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "and the memory tool"
    } ]
  }, {
    "tStartMs": 14681,
    "dDurationMs": 4212,
    "segs": [ {
      "utf8": "enables Claude to store and consult\ninformation outside the context window."
    } ]
  }, {
    "tStartMs": 19519,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "Let me show you these capabilities\nin action with something unexpected."
    } ]
  }, {
    "tStartMs": 22939,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "A Game of Catan."
    } ]
  }, {
    "tStartMs": 25066,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "Catan is a strategy board game\nthat requires planning over a long time"
    } ]
  }, {
    "tStartMs": 28611,
    "dDurationMs": 3754,
    "segs": [ {
      "utf8": "horizon, sharp negotiation\nskills, and careful observation."
    } ]
  }, {
    "tStartMs": 33450,
    "dDurationMs": 2752,
    "segs": [ {
      "utf8": "Watch as Claude plays \nagainst three opponents"
    } ]
  }, {
    "tStartMs": 36202,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "Ace, Maven and Scout."
    } ]
  }, {
    "tStartMs": 40707,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "Claude is building a knowledge base\nthat persists across games,"
    } ]
  }, {
    "tStartMs": 44127,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "with memory files\nabout each opponent's strategies,"
    } ]
  }, {
    "tStartMs": 47005,
    "dDurationMs": 4087,
    "segs": [ {
      "utf8": "like how Maven hoards bricks\nor Ace has a stockpile of wood."
    } ]
  }, {
    "tStartMs": 51593,
    "dDurationMs": 3336,
    "segs": [ {
      "utf8": "As the game progresses,\ntrades, moves, card draws,"
    } ]
  }, {
    "tStartMs": 54929,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "and other events accumulate,\neventually overwhelming the context."
    } ]
  }, {
    "tStartMs": 59851,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "But context editing automatically removes"
    } ]
  }, {
    "tStartMs": 62228,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "older, less relevant information."
    } ]
  }, {
    "tStartMs": 66232,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "After 75 minutes of play,"
    } ]
  }, {
    "tStartMs": 68443,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "Claude has processed\nthousands of game events."
    } ]
  }, {
    "tStartMs": 71029,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "Yet the context remains clean and focused."
    } ]
  }, {
    "tStartMs": 75283,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "These features are now available\non the Claude Developer Platform."
    } ]
  } ]
}
