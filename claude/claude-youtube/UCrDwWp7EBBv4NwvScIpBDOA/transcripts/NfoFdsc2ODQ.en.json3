  }, {
    "tStartMs": 443734,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "in their respective domains."
    } ]
  }, {
    "tStartMs": 445403,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "- When your teams are evaluating"
    } ]
  }, {
    "tStartMs": 447989,
    "dDurationMs": 4045,
    "segs": [ {
      "utf8": "or looking at new AI technology partners,"
