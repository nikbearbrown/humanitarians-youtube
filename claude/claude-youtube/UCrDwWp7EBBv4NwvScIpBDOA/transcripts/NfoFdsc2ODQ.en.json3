    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "- That really resonates with us."
    } ]
  }, {
    "tStartMs": 562436,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "I think something that\nwe think about a lot is"
