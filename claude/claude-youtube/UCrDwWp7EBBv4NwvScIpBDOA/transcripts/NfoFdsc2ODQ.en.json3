  "events": [ {
    "tStartMs": 208,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "- There is no other technological\nshift that has an ability"
    } ]
  }, {
    "tStartMs": 3545,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "to reimagine every single function"
    } ]
  }, {
    "tStartMs": 5755,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "within the pharmaceutical industry."
    } ]
  }, {
    "tStartMs": 7424,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "And we believe that this is truly"
    } ]
  }, {
    "tStartMs": 8800,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "a once in a generation opportunity"
    } ]
  }, {
    "tStartMs": 10719,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "for us to accelerate our progress"
    } ]
  }, {
    "tStartMs": 12637,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "and our impact for patients."
    } ]
  }, {
    "tStartMs": 14889,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "- Hi everyone. I'm Ivy Weng."
    } ]
  }, {
    "tStartMs": 17058,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "I'm on the Healthcare \u0026 Life Sciences"
    } ]
  }, {
    "tStartMs": 18768,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "Go-to-Market team here at Anthropic."
    } ]
  }, {
    "tStartMs": 20812,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "- Hi everyone."
    } ]
  }, {
    "tStartMs": 21938,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "My name is Sarah Nam, and\nI'm the Vice President"
    } ]
  }, {
    "tStartMs": 24357,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "of AI Strategy and Partnerships at AbbVie."
    } ]
  }, {
    "tStartMs": 26901,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "- Thank you so much for joining us, Sarah."
    } ]
  }, {
    "tStartMs": 28820,
    "dDurationMs": 876,
    "segs": [ {
      "utf8": "Maybe you could start"
    } ]
  }, {
    "tStartMs": 29696,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "by telling us a little bit about your role"
    } ]
  }, {
    "tStartMs": 32115,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "at AbbVie and the remit."
    } ]
  }, {
    "tStartMs": 33908,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "- Yes, I'm currently serving\nin developing a new function"
    } ]
  }, {
    "tStartMs": 37245,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "called AI Strategy and Partnerships,"
    } ]
  }, {
    "tStartMs": 39330,
    "dDurationMs": 2962,
    "segs": [ {
      "utf8": "and the remit of my\nteam is really twofold."
    } ]
  }, {
    "tStartMs": 42292,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "The first is to lead our\nenterprise AI strategy"
    } ]
  }, {
    "tStartMs": 45962,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "in terms of defining"
    } ]
  }, {
    "tStartMs": 47088,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "what are our strategic priorities"
    } ]
  }, {
    "tStartMs": 48590,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "related to AI across our business,"
    } ]
  }, {
    "tStartMs": 50842,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "as well as many of the\ncross-cutting enablers"
    } ]
  }, {
    "tStartMs": 52761,
    "dDurationMs": 3962,
    "segs": [ {
      "utf8": "that allow us to make that\nhappen from the tech architecture"
    } ]
  }, {
    "tStartMs": 56723,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "to the data modernization to\nchange management among others."
    } ]
  }, {
    "tStartMs": 60393,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "The second hat that I play"
    } ]
  }, {
    "tStartMs": 62103,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "is around our business development"
    } ]
  }, {
    "tStartMs": 64189,
    "dDurationMs": 1751,
    "segs": [ {
      "utf8": "and external innovation at AbbVie."
    } ]
  }, {
    "tStartMs": 65940,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "We wanted to stand up an entirely new team"
    } ]
  }, {
    "tStartMs": 68109,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "that would focus on business\ndevelopment related to AI."
    } ]
  }, {
    "tStartMs": 70945,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "And so that's a little bit about the role"
    } ]
  }, {
    "tStartMs": 72655,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "that I play at AbbVie."
    } ]
  }, {
    "tStartMs": 73823,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "- We see AbbVie as a\nleader in deploying AI"
    } ]
  }, {
    "tStartMs": 76993,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "in life sciences,"
    } ]
  }, {
    "tStartMs": 78536,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "and it would be great if you\ncould paint a picture around"
    } ]
  }, {
    "tStartMs": 81831,
    "dDurationMs": 4255,
    "segs": [ {
      "utf8": "how AI has been deployed\nacross the biopharma lifecycle."
    } ]
  }, {
    "tStartMs": 86086,
    "dDurationMs": 3336,
    "segs": [ {
      "utf8": "- There is no other technological\nshift that has an ability"
    } ]
  }, {
    "tStartMs": 89422,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "to reimagine every single function"
    } ]
  }, {
    "tStartMs": 91633,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "within the pharmaceutical industry."
    } ]
  }, {
    "tStartMs": 93593,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "And we believe that this is truly"
    } ]
  }, {
    "tStartMs": 95178,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "a once in a generation opportunity"
    } ]
  }, {
    "tStartMs": 97263,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "for us to accelerate our progress"
    } ]
  }, {
    "tStartMs": 99182,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "and our impact for patients."
    } ]
  }, {
    "tStartMs": 100934,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "And we're taking a very\nvalue chain-based approach"
    } ]
  }, {
    "tStartMs": 104020,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "to how we do this at AbbVie"
    } ]
  }, {
    "tStartMs": 106064,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "and really being able to identify"
    } ]
  }, {
    "tStartMs": 108233,
    "dDurationMs": 1459,
    "segs": [ {
      "utf8": "what are the core priorities"
    } ]
  }, {
    "tStartMs": 109692,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "for AI across each function within AbbVie"
    } ]
  }, {
    "tStartMs": 112403,
    "dDurationMs": 3129,
    "segs": [ {
      "utf8": "and being able to deploy\nAI use cases against them."
    } ]
  }, {
    "tStartMs": 115532,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "And so I'll walk you through\nsome of the core functions"
    } ]
  }, {
    "tStartMs": 118159,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "and where we're prioritizing AI."
    } ]
  }, {
    "tStartMs": 120078,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "Within drug discovery,"
    } ]
  }, {
    "tStartMs": 121538,
    "dDurationMs": 1209,
    "segs": [ {
      "utf8": "we're deeply inspired"
    } ]
  }, {
    "tStartMs": 122747,
    "dDurationMs": 4088,
    "segs": [ {
      "utf8": "by the ways in which we can\nbetter understand human biology"
    } ]
  }, {
    "tStartMs": 126835,
    "dDurationMs": 2877,
    "segs": [ {
      "utf8": "and be able to design, make, test,"
    } ]
  }, {
    "tStartMs": 129712,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "and validate new therapies at\nscale much more effectively"
    } ]
  }, {
    "tStartMs": 132382,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "through AI."
    } ]
  }, {
    "tStartMs": 133216,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "We're also focused a\nlot on multiparametric"
    } ]
  }, {
    "tStartMs": 135176,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "optimization of human efficacy, safety,"
    } ]
  }, {
    "tStartMs": 137762,
    "dDurationMs": 3379,
    "segs": [ {
      "utf8": "and pharmacokinetics when\nit comes to designing drugs,"
    } ]
  }, {
    "tStartMs": 141141,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "both in the small molecule"
    } ]
  }, {
    "tStartMs": 142225,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "and biologic space a lot more effectively."
    } ]
  }, {
    "tStartMs": 144561,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "And in addition, we're\nspending a lot of time around"
    } ]
  }, {
    "tStartMs": 147063,
    "dDurationMs": 4505,
    "segs": [ {
      "utf8": "how we do indication expansion\nin combination studies"
    } ]
  }, {
    "tStartMs": 151568,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "by really pulling together\nclinical data, genomic data,"
    } ]
  }, {
    "tStartMs": 155572,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "and multimodal data of all kinds,"
    } ]
  }, {
    "tStartMs": 157699,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "to be able to drive that\nmore effectively at scale."
    } ]
  }, {
    "tStartMs": 160368,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "And lastly, we're also\nspending a lot of time"
    } ]
  }, {
    "tStartMs": 162495,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "around precision medicine,"
    } ]
  }, {
    "tStartMs": 163788,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "starting first with digital pathology,"
    } ]
  }, {
    "tStartMs": 165957,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "but really expanding upon\nthe ways in which we could"
    } ]
  }, {
    "tStartMs": 168835,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "deliver medicines in a\nmuch more precise way"
    } ]
  }, {
    "tStartMs": 171337,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "for our patients."
    } ]
  }, {
    "tStartMs": 172380,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "In addition, as we think\nabout clinical development,"
    } ]
  }, {
    "tStartMs": 174716,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "there is so much that we\ncould do as it relates to"
    } ]
  }, {
    "tStartMs": 177802,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "how we design"
    } ]
  }, {
    "tStartMs": 179053,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "and conduct clinical trials."
    } ]
  }, {
    "tStartMs": 181222,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "On the design of clinical trials,"
    } ]
  }, {
    "tStartMs": 182974,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "we're spending time around\nhow we can leverage AI"
    } ]
  }, {
    "tStartMs": 185810,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "to better inform our inclusion\nexclusion criteria for trials"
    } ]
  }, {
    "tStartMs": 189689,
    "dDurationMs": 4296,
    "segs": [ {
      "utf8": "to how we think about adaptive\nclinical trial designs"
    } ]
  }, {
    "tStartMs": 193985,
    "dDurationMs": 3795,
    "segs": [ {
      "utf8": "and really being able to\nidentify patient subpopulations"
    } ]
  }, {
    "tStartMs": 197780,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "that are more likely\nto respond to our drugs"
    } ]
  }, {
    "tStartMs": 200074,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "for heterogeneous diseases."
    } ]
  }, {
    "tStartMs": 201826,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "And then as we think about\nrunning the clinical trials,"
    } ]
  }, {
    "tStartMs": 204454,
    "dDurationMs": 3378,
    "segs": [ {
      "utf8": "there's also so much that\nwe could do in terms of"
    } ]
  }, {
    "tStartMs": 207832,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "being able to automate\na lot of the processes"
    } ]
  }, {
    "tStartMs": 210585,
    "dDurationMs": 4254,
    "segs": [ {
      "utf8": "related to clinical trials,\nas well as authoring documents"
    } ]
  }, {
    "tStartMs": 214839,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "that are related to document submission,"
    } ]
  }, {
    "tStartMs": 217717,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "regulatory requirements\namong others in that space."
    } ]
  }, {
    "tStartMs": 220511,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "And then lastly, there's also\na lot that we're doing around"
    } ]
  }, {
    "tStartMs": 223806,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "data surveillance within the\nclinical development space,"
    } ]
  }, {
    "tStartMs": 226392,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "and that we could really\nbe able to leverage AI"
    } ]
  }, {
    "tStartMs": 229187,
    "dDurationMs": 3336,
    "segs": [ {
      "utf8": "to look at the types of\nclinical data that's coming in"
    } ]
  }, {
    "tStartMs": 232523,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "for our different programs"
    } ]
  }, {
    "tStartMs": 233691,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "and be able to adjust accordingly."
    } ]
  }, {
    "tStartMs": 235526,
    "dDurationMs": 1377,
    "segs": [ {
      "utf8": "- I mean, what you're describing"
    } ]
  }, {
    "tStartMs": 236903,
    "dDurationMs": 3795,
    "segs": [ {
      "utf8": "is exactly the inflection\npoint that we are experiencing"
    } ]
  }, {
    "tStartMs": 240698,
    "dDurationMs": 5005,
    "segs": [ {
      "utf8": "where we're moving from\nacceleration to AI transformation."
    } ]
  }, {
    "tStartMs": 245787,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "And it sounds like you're describing this"
    } ]
  }, {
    "tStartMs": 247580,
    "dDurationMs": 3921,
    "segs": [ {
      "utf8": "across clinical workflows,\ncommercial workflows,"
    } ]
  }, {
    "tStartMs": 251501,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "regulatory workflows."
    } ]
  }, {
    "tStartMs": 253169,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "Are you able to dive into\nmaybe one or two examples"
    } ]
  }, {
    "tStartMs": 256297,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "and walk us through that?"
    } ]
  }, {
    "tStartMs": 257840,
    "dDurationMs": 3754,
    "segs": [ {
      "utf8": "- A few areas that we've\nworked together on include,"
    } ]
  }, {
    "tStartMs": 261594,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "one is around GenAIsys,"
    } ]
  }, {
    "tStartMs": 263471,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "and GenAIsys is a tool\nthat we've developed"
    } ]
  }, {
    "tStartMs": 266099,
    "dDurationMs": 3336,
    "segs": [ {
      "utf8": "that leverages generative\nAI to really pull forward"
    } ]
  }, {
    "tStartMs": 269435,
    "dDurationMs": 3379,
    "segs": [ {
      "utf8": "a lot of the different\nsales force-related tools"
    } ]
  }, {
    "tStartMs": 272814,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "that are helping our sales\nforce be much more effective"
    } ]
  }, {
    "tStartMs": 275483,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "in their call planning."
    } ]
  }, {
    "tStartMs": 276859,
    "dDurationMs": 2962,
    "segs": [ {
      "utf8": "And so this has been a tremendous effort"
    } ]
  }, {
    "tStartMs": 279821,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "that has allowed our\nsales reps across AbbVie"
    } ]
  }, {
    "tStartMs": 282907,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "to be much more effective and\nefficient in what they do."
    } ]
  }, {
    "tStartMs": 286244,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "And early results are showing"
    } ]
  }, {
    "tStartMs": 287787,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "that there's been very\nsignificant improvements"
    } ]
  }, {
    "tStartMs": 290665,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "in terms of efficiency and\neffectiveness of our sales force"
    } ]
  }, {
    "tStartMs": 293876,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "that are enabled by a tool like GenAIsys."
    } ]
  }, {
    "tStartMs": 296212,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "In addition, we've partnered on GAIA,"
    } ]
  }, {
    "tStartMs": 298131,
    "dDurationMs": 4546,
    "segs": [ {
      "utf8": "which is a clinical development\ndocument authoring tool"
    } ]
  }, {
    "tStartMs": 302677,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "whereby we're leveraging\nlarge language models"
    } ]
  }, {
    "tStartMs": 304679,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "to essentially automate the writing"
    } ]
  }, {
    "tStartMs": 306931,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "and authoring of a lot\nof our study documents,"
    } ]
  }, {
    "tStartMs": 309392,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "starting first with\nNDA and PSUR documents,"
    } ]
  }, {
    "tStartMs": 312186,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "but really to thousands of\ndifferent document types."
    } ]
  }, {
    "tStartMs": 315690,
    "dDurationMs": 4087,
    "segs": [ {
      "utf8": "And this has led to roughly 40\nto 60% efficiencies in terms"
    } ]
  }, {
    "tStartMs": 319777,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "of time saving and writing"
    } ]
  }, {
    "tStartMs": 321321,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "some of these documents across AbbVie."
    } ]
  }, {
    "tStartMs": 323781,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "- I think part of what makes Anthropic"
    } ]
  }, {
    "tStartMs": 326159,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "and the models that we're\nbuilding so exciting"
    } ]
  }, {
    "tStartMs": 327994,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "is that we see this as the engine"
    } ]
  }, {
    "tStartMs": 330538,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "powering all of these different use cases"
    } ]
  }, {
    "tStartMs": 332707,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "that are applicable to\nlife sciences firms."
    } ]
  }, {
    "tStartMs": 336169,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "Something that we think\nabout a lot is, you know,"
    } ]
  }, {
    "tStartMs": 339589,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "we see coding being adopted"
