  }, {
    "tStartMs": 470595,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "in terms of the strategic objectives"
    } ]
  }, {
    "tStartMs": 472305,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "of the organization that we have?"
    } ]
  }, {
    "tStartMs": 474140,
    "dDurationMs": 4463,
    "segs": [ {
      "utf8": "The second is really around\nthe technical foundation"
