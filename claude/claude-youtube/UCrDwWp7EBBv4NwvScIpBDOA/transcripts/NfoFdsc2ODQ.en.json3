  }, {
    "tStartMs": 452034,
    "dDurationMs": 2837,
    "segs": [ {
      "utf8": "what are some of the\ncriteria that you use?"
    } ]
  }, {
    "tStartMs": 454871,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "- Our organization recently developed a"
    } ]
  }, {
    "tStartMs": 457582,
    "dDurationMs": 1626,
    "segs": [ {
      "utf8": "detailed diligence framework"
    } ]
  }, {
    "tStartMs": 459208,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "for how we would evaluate\nAI-driven partnerships,"
    } ]
  }, {
    "tStartMs": 462712,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "and there's four key\npillars that we focus on."
    } ]
  }, {
    "tStartMs": 465715,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "One is really around the strategic fit."
    } ]
  }, {
    "tStartMs": 468050,
    "dDurationMs": 2545,
    "segs": [ {
      "utf8": "How does the actual partnership fit"
