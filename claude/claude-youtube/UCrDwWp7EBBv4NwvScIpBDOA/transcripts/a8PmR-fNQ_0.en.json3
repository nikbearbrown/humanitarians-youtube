  "events": [ {
    "tStartMs": 83,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "Analysts do this statically\nin one Excel sheet"
    } ]
  }, {
    "tStartMs": 2877,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "that they refresh manually\nevery week, every quarter."
    } ]
  }, {
    "tStartMs": 6297,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "Instead of doing that,"
    } ]
  }, {
    "tStartMs": 7841,
    "dDurationMs": 2919,
    "segs": [ {
      "utf8": "BCI has instead used our Artifact feature"
    } ]
  }, {
    "tStartMs": 10760,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "to connect directly to\nS\u0026P and FactSet data sets"
    } ]
  }, {
    "tStartMs": 14180,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "so that the artifact is a live dashboard"
    } ]
  }, {
    "tStartMs": 16933,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "of how these metrics\ncompare against each other,"
    } ]
  }, {
    "tStartMs": 19060,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "and with one simple prompt to Claude,"
    } ]
  }, {
    "tStartMs": 21312,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "you can easily update it,"
    } ]
  }, {
    "tStartMs": 22772,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "and these artifacts are also shared"
    } ]
  }, {
    "tStartMs": 24399,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "with their managing directors"
    } ]
  }, {
    "tStartMs": 26026,
    "dDurationMs": 3878,
    "segs": [ {
      "utf8": "who are directly interfacing\nwith these platforms as well."
    } ]
  }, {
    "tStartMs": 29904,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "So I think we're really seeing"
    } ]
  }, {
    "tStartMs": 31781,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "not just acceleration of work,"
    } ]
  }, {
    "tStartMs": 33950,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "but a way for the work to\nactually be transformed."
    } ]
  }, {
    "tStartMs": 37328,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "- Hey, my name's Alexander Bricken,"
    } ]
  }, {
    "tStartMs": 38830,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "and I lead our applied AI Engineering team"
    } ]
  }, {
    "tStartMs": 40707,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "for Financial Services."
    } ]
  }, {
    "tStartMs": 42667,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "Today, we're gonna be talking to you"
    } ]
  }, {
    "tStartMs": 44210,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "about Claude for Finance,"
    } ]
  }, {
    "tStartMs": 45795,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "and I'm joined by my colleague Nick."
    } ]
  }, {
    "tStartMs": 47464,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "- Hey, my name is Nick Lin,"
    } ]
  }, {
    "tStartMs": 49340,
    "dDurationMs": 3713,
    "segs": [ {
      "utf8": "and I lead product for Claude\nfor Financial Services."
    } ]
  }, {
    "tStartMs": 53053,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "I'm also a recovering investment banker"
    } ]
  }, {
    "tStartMs": 55555,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "and private equity investor."
    } ]
  }, {
    "tStartMs": 57223,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "A lot of these problems\nwe're about to talk about"
    } ]
  }, {
    "tStartMs": 59225,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "are very near and dear to my heart,"
    } ]
  }, {
    "tStartMs": 61352,
    "dDurationMs": 1419,
    "segs": [ {
      "utf8": "so I'm very excited, Alexander."
    } ]
  }, {
    "tStartMs": 62771,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "- Awesome."
    } ]
  }, {
    "tStartMs": 63605,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "So, Nick, my first question for you is"
    } ]
  }, {
    "tStartMs": 65023,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "how do you feel about the\nshift in the AI landscape"
    } ]
  }, {
    "tStartMs": 67817,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "for financial services these days?"
    } ]
  }, {
    "tStartMs": 69402,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "- You know, I've been with Anthropic"
    } ]
  }, {
    "tStartMs": 71488,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "for a little bit over\na year and a half now."
    } ]
  }, {
    "tStartMs": 74324,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "That was before Claude 3,"
    } ]
  }, {
    "tStartMs": 76367,
    "dDurationMs": 2420,
    "segs": [ {
      "utf8": "so I think the enterprise AI landscape"
    } ]
  }, {
    "tStartMs": 78787,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "has changed significantly,"
    } ]
  }, {
    "tStartMs": 80622,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "especially in the past few months."
    } ]
  }, {
    "tStartMs": 82582,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "What I am really noticing is that"
    } ]
  }, {
    "tStartMs": 84125,
    "dDurationMs": 4713,
    "segs": [ {
      "utf8": "there is a fundamental\nshift from curiosity,"
    } ]
  }, {
    "tStartMs": 88838,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "observing from the sidelines,"
    } ]
  }, {
    "tStartMs": 90757,
    "dDurationMs": 4171,
    "segs": [ {
      "utf8": "to actually starting to build\nand deploy into production."
    } ]
  }, {
    "tStartMs": 94928,
    "dDurationMs": 3587,
    "segs": [ {
      "utf8": "Now, as we all know, coding\nis one of the first products"
    } ]
  }, {
    "tStartMs": 98515,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "and first domains within AI"
    } ]
  }, {
    "tStartMs": 100308,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "with really strong product-market fit."
    } ]
  }, {
    "tStartMs": 102560,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "I think we're starting to see this"
    } ]
  }, {
    "tStartMs": 104145,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "really extend to other verticals\nas well, including finance."
    } ]
  }, {
    "tStartMs": 107607,
    "dDurationMs": 3795,
    "segs": [ {
      "utf8": "For example, NBIM or the\nNorwegian Sovereign Wealth Fund,"
    } ]
  }, {
    "tStartMs": 111402,
    "dDurationMs": 2128,
    "segs": [ {
      "utf8": "one of our largest customers,"
    } ]
  }, {
    "tStartMs": 113530,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "they have about 9,000 portfolio companies."
    } ]
  }, {
    "tStartMs": 116199,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "What they've done is they've\nbuilt integrations on their own"
    } ]
  }, {
    "tStartMs": 119661,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "with things like model context protocol,"
    } ]
  }, {
    "tStartMs": 121371,
    "dDurationMs": 3044,
    "segs": [ {
      "utf8": "so that all of their portfolio managers"
    } ]
  }, {
    "tStartMs": 124415,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "are querying these\nintegrations every single day"
    } ]
  }, {
    "tStartMs": 127502,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "to get insights into their PortCos."
    } ]
  }, {
    "tStartMs": 129587,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "So I think we're really starting to see"
    } ]
  }, {
    "tStartMs": 131756,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "analysts spend a lot less time"
    } ]
  }, {
    "tStartMs": 134717,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "on the mundane, manual,\ntedious parts of the work,"
    } ]
  }, {
    "tStartMs": 137595,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "and start to focus on what they\nreally care about, you know,"
    } ]
  }, {
    "tStartMs": 140515,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "which is building relationships,"
    } ]
  }, {
    "tStartMs": 142642,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "meeting with their customers,\nand actually understanding"
    } ]
  }, {
    "tStartMs": 145270,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "the business models of the\ncompanies they're investing in."
    } ]
  }, {
    "tStartMs": 148481,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "- Yeah, that really resonates\nfrom my standpoint as well"
    } ]
  }, {
    "tStartMs": 151401,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "as an applied AI person."
    } ]
  }, {
    "tStartMs": 153862,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "Whenever I go and interact with customers,"
    } ]
  }, {
    "tStartMs": 155697,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "a lot of the time, last year, let's say,"
    } ]
  }, {
    "tStartMs": 158491,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "they would start with\nbuilding an AI chat feature."
    } ]
  }, {
    "tStartMs": 161369,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "Like, they'd have a bunch\nof models represented,"
    } ]
  }, {
    "tStartMs": 163580,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "and they would select one,\nmaybe a random business user,"
    } ]
  }, {
    "tStartMs": 166875,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "and they would try to work\nwith it and just chat with it."
    } ]
  }, {
    "tStartMs": 169711,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "Eventually, now, we've seen\nthings like MCP come out"
    } ]
  }, {
    "tStartMs": 173423,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "where the chat has become\nso much more powerful."
    } ]
  }, {
    "tStartMs": 176176,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "You can interact with the\nsystems you care about,"
    } ]
  }, {
    "tStartMs": 178386,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "and I think that's really\nexciting specifically for finance"
    } ]
  }, {
    "tStartMs": 181139,
    "dDurationMs": 2919,
    "segs": [ {
      "utf8": "because, often, there are\njust so many product surfaces"
    } ]
  }, {
    "tStartMs": 184058,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "that folks have to interact with."
    } ]
  }, {
    "tStartMs": 185768,
    "dDurationMs": 918,
    "segs": [ {
      "utf8": "- 100%."
    } ]
  }, {
    "tStartMs": 186686,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "- If you give a model a tool these days,"
    } ]
  }, {
    "tStartMs": 189105,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "often, the model's\nintelligent enough to know"
    } ]
  }, {
    "tStartMs": 191232,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "what that tool does"
    } ]
  }, {
    "tStartMs": 192275,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "given the tool description\nand the tool name,"
    } ]
  }, {
    "tStartMs": 194485,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "but equally, the model has\ncertain primitives baked into it,"
    } ]
  }, {
    "tStartMs": 197238,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "like the security that we try to bake into"
    } ]
  }, {
    "tStartMs": 200325,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "the way the model\ninteracts with the world."
    } ]
  }, {
    "tStartMs": 202327,
    "dDurationMs": 3461,
    "segs": [ {
      "utf8": "So we train our models to be\nhelpful, harmless, and honest,"
    } ]
  }, {
    "tStartMs": 205788,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "and often, that's a reflection of"
    } ]
  }, {
    "tStartMs": 207874,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "the data that they interpret"
    } ]
  }, {
    "tStartMs": 209000,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "and the output that it\nbasically corresponds to."
    } ]
  }, {
    "tStartMs": 211669,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "So I think that's probably what\nyou're referring to as well"
    } ]
  }, {
    "tStartMs": 213671,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "in that, like, the model\nis generally intelligent,"
    } ]
  }, {
    "tStartMs": 215965,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "and so if you give it\nthese different layers,"
    } ]
  }, {
    "tStartMs": 218176,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "you can really see some cool results."
    } ]
  }, {
    "tStartMs": 219844,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "- You know, safety is something\nthat you touched upon."
    } ]
  }, {
    "tStartMs": 221888,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "That is so foundational\nto everything we do."
    } ]
  }, {
    "tStartMs": 225350,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "- Yeah."
    } ]
  }, {
    "tStartMs": 226184,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "- It's about securely\ndeploying these solutions"
    } ]
  }, {
    "tStartMs": 227852,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "into enterprise environments."
    } ]
  }, {
    "tStartMs": 229646,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "It's about making sure that"
    } ]
  }, {
    "tStartMs": 230772,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "the models can accurately\nanswer the questions"
    } ]
  }, {
    "tStartMs": 233483,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "with the right level of\nunderstanding of those problems"
    } ]
  }, {
    "tStartMs": 236444,
    "dDurationMs": 4379,
    "segs": [ {
      "utf8": "and fidelity, and third is\nactually giving our users"
    } ]
  }, {
    "tStartMs": 240823,
    "dDurationMs": 3379,
    "segs": [ {
      "utf8": "the trust, the verification,\nthe auditability"
    } ]
  }, {
    "tStartMs": 244202,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "to understand these results.\nSo I think we think about"
    } ]
  }, {
    "tStartMs": 246704,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "all three of those components of safety."
    } ]
  }, {
    "tStartMs": 248248,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "- Yeah, I mean, speaking of, right?"
    } ]
  }, {
    "tStartMs": 250625,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "Anthropic was founded on\nthe principles of AI safety."
    } ]
  }, {
    "tStartMs": 254170,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "It was a research org from scratch."
    } ]
  }, {
    "tStartMs": 256339,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "I'm curious."
    } ]
  }, {
    "tStartMs": 257173,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "How have we gone from being a research org"
    } ]
  }, {
    "tStartMs": 259926,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "to releasing a distinguished\nproduct in financial services?"
    } ]
  }, {
    "tStartMs": 263763,
    "dDurationMs": 5005,
    "segs": [ {
      "utf8": "- In my mind, Anthropic\nreally aims at building models"
    } ]
  }, {
    "tStartMs": 268935,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "that can be safely deployed to solve"
    } ]
  }, {
    "tStartMs": 271354,
    "dDurationMs": 5005,
    "segs": [ {
      "utf8": "the most complex and difficult\nproblems in the world, right?"
    } ]
  }, {
    "tStartMs": 276359,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "We're state-of-the-art\nwhen it comes to code."
    } ]
  }, {
    "tStartMs": 279070,
    "dDurationMs": 4713,
    "segs": [ {
      "utf8": "0.5% of the world's population\nare software engineers,"
    } ]
  }, {
    "tStartMs": 283783,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "so that is just one sliver of"
    } ]
  }, {
    "tStartMs": 286077,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "these really complex, difficult problems"
    } ]
  }, {
    "tStartMs": 288830,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "we can really start solving, right?"
    } ]
  }, {
    "tStartMs": 290957,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "They really exist everywhere\nelse in the world."
    } ]
  }, {
    "tStartMs": 293376,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "Code is so foundational"
    } ]
  }, {
    "tStartMs": 294711,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "to every single part of a company, right?"
    } ]
  }, {
    "tStartMs": 297213,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "It is how a company is run."
    } ]
  }, {
    "tStartMs": 299340,
    "dDurationMs": 3921,
    "segs": [ {
      "utf8": "So that means that\nClaude is really great at"
    } ]
  }, {
    "tStartMs": 303261,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "interacting with more complex systems,"
    } ]
  }, {
    "tStartMs": 305763,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "being able to expose its\nthinking and its logic,"
    } ]
  }, {
    "tStartMs": 308683,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "and that's why it's great\nat finance as well, right?"
    } ]
  }, {
    "tStartMs": 310685,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "Finance are complex problems"
    } ]
  }, {
    "tStartMs": 312562,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "deployed into regulated verticals"
    } ]
  }, {
    "tStartMs": 314689,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "that need verification, auditability,"
    } ]
  }, {
    "tStartMs": 317400,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "and ultimately, accuracy really matters."
    } ]
  }, {
    "tStartMs": 320194,
    "dDurationMs": 2545,
    "segs": [ {
      "utf8": "- Financial analysts these\ndays spend a lot of time"
    } ]
  }, {
    "tStartMs": 322739,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "getting down to, like,\nthe pixel perfect level of"
    } ]
  }, {
    "tStartMs": 325450,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "let's say a PowerPoint deck\nor an Excel model, right?"
    } ]
  }, {
    "tStartMs": 327827,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "You can't get anything wrong,"
    } ]
  }, {
    "tStartMs": 329704,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "and it's funny, now that\nwe're in this paradigm"
    } ]
  }, {
    "tStartMs": 331664,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "where models can do something similar,"
    } ]
  }, {
    "tStartMs": 334167,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "but using the capabilities they have"
    } ]
  }, {
    "tStartMs": 336794,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "to write really structured logic,"
    } ]
  }, {
    "tStartMs": 338755,
    "dDurationMs": 1459,
    "segs": [ {
      "utf8": "and so that's actually what we've found"
    } ]
  }, {
    "tStartMs": 340214,
    "dDurationMs": 3129,
    "segs": [ {
      "utf8": "language models to be good at,\nwhat we've trained them on,"
    } ]
  }, {
    "tStartMs": 343343,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "and that ability to do that,"
    } ]
  }, {
    "tStartMs": 345219,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "it feels like it's just being abstracted"
    } ]
  }, {
    "tStartMs": 347638,
    "dDurationMs": 1711,
    "segs": [ {
      "utf8": "into so many other domains,"
    } ]
  }, {
    "tStartMs": 349349,
    "dDurationMs": 1626,
    "segs": [ {
      "utf8": "like creating Excel spreadsheets"
    } ]
  }, {
    "tStartMs": 350975,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "or like creating PowerPoints,"
    } ]
  }, {
    "tStartMs": 353770,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "and so, yeah, it's just been, like,"
    } ]
  }, {
    "tStartMs": 355146,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "super just kind of\nstriking, at least to me,"
    } ]
  }, {
    "tStartMs": 358066,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "to see how many domains"
    } ]
  }, {
    "tStartMs": 359734,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "the logic and reasoning of these models"
    } ]
  }, {
    "tStartMs": 361903,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "actually ends up touching."
    } ]
  }, {
    "tStartMs": 363488,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "- Ultimately, these are digital systems"
    } ]
  }, {
    "tStartMs": 365573,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "that we interact with\nevery single day, right?"
    } ]
  }, {
    "tStartMs": 367909,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "The fact that Claude is great at code"
    } ]
  }, {
    "tStartMs": 369702,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "gives it a flexible skill and a shortcut"
    } ]
  }, {
    "tStartMs": 373414,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "to do all of these really cool,\ninteresting things, right?"
    } ]
  }, {
    "tStartMs": 376542,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "Our file creation feature that\nwas launched a few weeks ago"
    } ]
  }, {
    "tStartMs": 380046,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "that enables Claude to create\nExcel documents and PowerPoint"
    } ]
  }, {
    "tStartMs": 383174,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "is essentially Claude\naccessing a virtual machine"
    } ]
  }, {
    "tStartMs": 386719,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "within which it can run\nPython code at scale"
    } ]
  }, {
    "tStartMs": 390181,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "to edit, analyze, and\ncreate Excel documents"
    } ]
  }, {
    "tStartMs": 393643,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "and create these perfect DCF models,"
    } ]
  }, {
    "tStartMs": 396312,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "which I think is super\nexciting for us, right?"
    } ]
  }, {
    "tStartMs": 397897,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "So I think there's a lot of other domains"
    } ]
  }, {
    "tStartMs": 400358,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "that code can start really unlocking."
    } ]
  }, {
    "tStartMs": 402819,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "- What's different to Claude for Finance"
    } ]
  }, {
    "tStartMs": 405071,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "versus other products on the\nmarket in financial services?"
    } ]
  }, {
    "tStartMs": 407949,
    "dDurationMs": 2752,
    "segs": [ {
      "utf8": "- You know, there are three\nverbs I think about a lot"
    } ]
  }, {
    "tStartMs": 410701,
    "dDurationMs": 3754,
    "segs": [ {
      "utf8": "that governs what I want to\nbuild for Claude for Finance,"
    } ]
  }, {
    "tStartMs": 414455,
    "dDurationMs": 4630,
    "segs": [ {
      "utf8": "and these are retrieve,\nanalyze, and create."
    } ]
  }, {
    "tStartMs": 419085,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "Starting with retrieval,"
    } ]
  }, {
    "tStartMs": 420670,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "many of the research agents on the market"
    } ]
  }, {
    "tStartMs": 422713,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "has seen, you know, quite\na lot of maturity, right?"
    } ]
  }, {
    "tStartMs": 425049,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "Large language models are\nfantastic at digging into"
    } ]
  }, {
    "tStartMs": 427885,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "large pools of data\nand gathering insights,"
    } ]
  }, {
    "tStartMs": 430513,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "and can read, you know,"
    } ]
  }, {
    "tStartMs": 431347,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "5,000 probably times faster than humans,"
    } ]
  }, {
    "tStartMs": 433474,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "but what we want to do with finance is"
    } ]
  }, {
    "tStartMs": 435726,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "making sure that these\nsystems can connect to"
    } ]
  }, {
    "tStartMs": 438104,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "all of the core data sources\nthat finance analysts work in."
    } ]
  }, {
    "tStartMs": 442024,
    "dDurationMs": 4130,
    "segs": [ {
      "utf8": "In finance, the ability\nto uncover insights"
    } ]
  }, {
    "tStartMs": 446154,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "faster than your\ncompetitors and your peers,"
    } ]
  }, {
    "tStartMs": 448990,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "that's a really key advantage."
    } ]
  }, {
    "tStartMs": 450700,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "Now, downstream from that,"
    } ]
  }, {
    "tStartMs": 452243,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "it's great that we can\nretrieve this information"
    } ]
  }, {
    "tStartMs": 454120,
    "dDurationMs": 4504,
    "segs": [ {
      "utf8": "and connect to it, but the\nability to do analysis at scale,"
    } ]
  }, {
    "tStartMs": 458624,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "either through code or\nthrough spreadsheets,"
    } ]
  }, {
    "tStartMs": 461544,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "is so foundational as well."
    } ]
  }, {
    "tStartMs": 463045,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "Financial models themselves,"
    } ]
  }, {
    "tStartMs": 464213,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "they're not just these\nbeautiful Excel sheets, right?"
    } ]
  }, {
    "tStartMs": 468217,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "They're a way for finance analysts"
    } ]
  }, {
    "tStartMs": 470136,
    "dDurationMs": 4046,
    "segs": [ {
      "utf8": "to inject their own judgment\nof what the future looks like"
    } ]
  }, {
    "tStartMs": 474182,
    "dDurationMs": 1751,
    "segs": [ {
      "utf8": "and what the proper valuation looks like"
    } ]
  }, {
    "tStartMs": 475933,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "for that company, right?"
    } ]
  }, {
    "tStartMs": 477226,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "So, with that in mind, we want\nClaude to be really good at"
    } ]
  }, {
    "tStartMs": 480062,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "understanding these core finance concepts"
    } ]
  }, {
    "tStartMs": 482273,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "and manipulate systems\nlike Excel and spreadsheets"
    } ]
  }, {
    "tStartMs": 485568,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "to be able to do that calculation."
    } ]
  }, {
    "tStartMs": 487361,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "And then the third part\nis creation, right?"
    } ]
  }, {
    "tStartMs": 490072,
    "dDurationMs": 3796,
    "segs": [ {
      "utf8": "We're all social creatures\nwithin the enterprise, right?"
    } ]
  }, {
    "tStartMs": 493868,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "We do our work to be shared with others,"
    } ]
  }, {
    "tStartMs": 496662,
    "dDurationMs": 3212,
    "segs": [ {
      "utf8": "so the outputs themselves\nin the form of spreadsheets,"
    } ]
  }, {
    "tStartMs": 499874,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "you know, PowerPoint documents, Word,"
    } ]
  }, {
    "tStartMs": 502543,
    "dDurationMs": 4338,
    "segs": [ {
      "utf8": "doing this in a way that is\nclient-ready, boardroom-ready,"
    } ]
  }, {
    "tStartMs": 506881,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "is really important."
    } ]
  }, {
    "tStartMs": 508132,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "So we really want to start\npushing Claude's capabilities"
    } ]
  }, {
    "tStartMs": 510551,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "to be able to do that as well"
    } ]
  }, {
    "tStartMs": 512261,
    "dDurationMs": 4672,
    "segs": [ {
      "utf8": "so that it is an end-to-end\nagentic autonomous system."
    } ]
  }, {
    "tStartMs": 516933,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "- That makes a lot of sense."
    } ]
  }, {
    "tStartMs": 517767,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I feel like we build these primitives"
    } ]
  }, {
    "tStartMs": 519727,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "and then they almost end up snowballing."
    } ]
  }, {
    "tStartMs": 521687,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "So you have, like, the\nretrieval step, right?"
    } ]
  }, {
    "tStartMs": 524023,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "You build an MCP server\nto connect to one system,"
    } ]
  }, {
    "tStartMs": 527193,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "but then if you take the\ndata from that system,"
    } ]
  }, {
    "tStartMs": 529070,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "maybe it connects to some\nother system in a unique way."
    } ]
  }, {
    "tStartMs": 531280,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "Like, you get data from\nSnowflake, let's say."
    } ]
  }, {
    "tStartMs": 533950,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "You find an ID in there"
    } ]
  }, {
    "tStartMs": 535451,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "and you need to connect it\nto your Salesforce instance."
    } ]
  }, {
    "tStartMs": 538120,
    "dDurationMs": 2128,
    "segs": [ {
      "utf8": "You can easily do that with\nsome of those primitives"
    } ]
  }, {
    "tStartMs": 540248,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "that we've built on the retrieval side,"
    } ]
  }, {
    "tStartMs": 542458,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "but then it sort of continues to snowball."
    } ]
  }, {
    "tStartMs": 544210,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "You get analysis where Claude\ncan write a bunch of code"
    } ]
  }, {
    "tStartMs": 548047,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "and essentially piece together\nsome of that information,"
    } ]
  }, {
    "tStartMs": 551217,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "and then finally the creation is"
    } ]
  }, {
    "tStartMs": 553302,
    "dDurationMs": 1377,
    "segs": [ {
      "utf8": "even take that one step further"
    } ]
  }, {
    "tStartMs": 554679,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "and put it into the environment\nthat someone cares about,"
    } ]
  }, {
    "tStartMs": 557014,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "sending that post request,\nback to the API example,"
    } ]
  }, {
    "tStartMs": 560726,
    "dDurationMs": 4129,
    "segs": [ {
      "utf8": "to a system where an analyst\nor an operator can see"
    } ]
  }, {
    "tStartMs": 564855,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "the information that Claude\nhas reasoned through."
    } ]
  }, {
    "tStartMs": 566816,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "- So let's talk a little bit more about"
    } ]
  }, {
    "tStartMs": 568526,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "what is actually Claude for Finance?"
    } ]
  }, {
    "tStartMs": 570361,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "How does it work? What\nmakes it so special?"
    } ]
  }, {
    "tStartMs": 572446,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "- So there are three layers"
    } ]
  }, {
    "tStartMs": 574407,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "that we think about in our solution."
    } ]
  }, {
    "tStartMs": 576909,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "The models, the agentic\ncapabilities, and the platform,"
    } ]
  }, {
    "tStartMs": 580329,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "starting with the models themselves."
    } ]
  }, {
    "tStartMs": 582456,
    "dDurationMs": 3796,
    "segs": [ {
      "utf8": "Fundamentally, we are\na research lab, right?"
    } ]
  }, {
    "tStartMs": 586252,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "Everything we do really\naims at making Claude"
    } ]
  }, {
    "tStartMs": 588671,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "the best model for financial services."
    } ]
  }, {
    "tStartMs": 591465,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "Now, finance presents"
    } ]
  }, {
    "tStartMs": 593092,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "some interesting challenges to us, right?"
    } ]
  }, {
    "tStartMs": 595970,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "Code is something that we\ncan test every single day"
    } ]
  }, {
    "tStartMs": 598055,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "as software engineers\nand product managers,"
    } ]
  }, {
    "tStartMs": 600224,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "but there are very few investment bankers"
    } ]
  }, {
    "tStartMs": 602518,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "within these four walls of Anthropic."
    } ]
  }, {
    "tStartMs": 604312,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "So here's where we're\nreally excited to work with"
    } ]
  }, {
    "tStartMs": 607398,
    "dDurationMs": 5005,
    "segs": [ {
      "utf8": "early customers like BCI,\nPerella Weinberg, and NBIM,"
    } ]
  }, {
    "tStartMs": 612612,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "to really let us know,"
    } ]
  }, {
    "tStartMs": 613613,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "what are the use cases\nthey really care about?"
    } ]
  }, {
    "tStartMs": 615698,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "What does good look like?"
    } ]
  }, {
    "tStartMs": 617366,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "And then help us, much more\nimportantly, uncover those gaps"
    } ]
  }, {
    "tStartMs": 621370,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "that we can bring back\ninto the research process."
    } ]
  }, {
    "tStartMs": 624081,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "The second thing is on\nthe product side, right?"
    } ]
  }, {
    "tStartMs": 626959,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "Agentic capabilities are\nessentially the code that we write"
    } ]
  }, {
    "tStartMs": 630421,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "to enable users to\ninteract with the models."
    } ]
  }, {
    "tStartMs": 633466,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "We've built capabilities\nlike deep research."
    } ]
  }, {
    "tStartMs": 636177,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "Now, we're really investing\nin being able to embed Claude"
    } ]
  }, {
    "tStartMs": 640056,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "in all of the core surfaces you work in,"
    } ]
  }, {
    "tStartMs": 642558,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "not just Claude for\nEnterprise or Claude.ai"
    } ]
  }, {
    "tStartMs": 645144,
    "dDurationMs": 4546,
    "segs": [ {
      "utf8": "but also the browser\nextension, Excel, Chrome,"
    } ]
  }, {
    "tStartMs": 649690,
    "dDurationMs": 1085,
    "segs": [ {
      "utf8": "and other surfaces"
    } ]
  }, {
    "tStartMs": 650775,
    "dDurationMs": 2168,
    "segs": [ {
      "utf8": "that our analysts and enterprise customers"
    } ]
  }, {
    "tStartMs": 652943,
    "dDurationMs": 1419,
    "segs": [ {
      "utf8": "work with every single day."
    } ]
  }, {
    "tStartMs": 654362,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "The last piece is we want to, again,"
    } ]
  }, {
    "tStartMs": 656572,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "build a really flexible platform"
    } ]
  }, {
    "tStartMs": 658366,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "that can be tailored and deployed"
    } ]
  }, {
    "tStartMs": 660826,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "very easily for our customers."
    } ]
  }, {
    "tStartMs": 663120,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "That's why we've been\nspending a lot of time"
    } ]
  }, {
    "tStartMs": 664789,
    "dDurationMs": 3962,
    "segs": [ {
      "utf8": "with industry partners like\nS\u0026P, FactSet, PitchBook,"
    } ]
  }, {
    "tStartMs": 668751,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "to build these integrations"
    } ]
  }, {
    "tStartMs": 670252,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "so that these agents can\nbe as powerful as possible."
    } ]
  }, {
    "tStartMs": 673422,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "- So I'm curious. How\nhas adoption been, right?"
    } ]
  }, {
    "tStartMs": 675800,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "Who's using this? Why are\nthey excited about it?"
    } ]
  }, {
    "tStartMs": 678511,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "Walk us through that."
    } ]
  }, {
    "tStartMs": 679345,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "- As I mentioned before,\nwe're really seeing"
    } ]
  }, {
    "tStartMs": 681055,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "pockets of adoption across\nthe entire industry."
    } ]
  }, {
    "tStartMs": 684767,
    "dDurationMs": 1209,
    "segs": [ {
      "utf8": "I'm often asked, you know,"
    } ]
  }, {
    "tStartMs": 685976,
    "dDurationMs": 4130,
    "segs": [ {
      "utf8": "which sub-verticals do you\nsee AI adoption in in finance?"
    } ]
  }, {
    "tStartMs": 690106,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "I think it's much less\nabout sub-verticals,"
    } ]
  }, {
    "tStartMs": 692775,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "but much more about the\nculture that our customers"
    } ]
  }, {
    "tStartMs": 696195,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "have really engendered, right?"
    } ]
  }, {
    "tStartMs": 698155,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "Which requires a good combination of"
    } ]
  }, {
    "tStartMs": 699949,
    "dDurationMs": 4838,
    "segs": [ {
      "utf8": "top-down encouragement and\nadoption to lower the barriers,"
    } ]
  }, {
    "tStartMs": 704787,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "but also a bottoms-up\nexperimentation culture, right?"
    } ]
  }, {
    "tStartMs": 708457,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "To try all of these tools out there"
    } ]
  }, {
    "tStartMs": 710042,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "to figure out what makes sense."
    } ]
  }, {
    "tStartMs": 712128,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "With that in mind, I think\nsome of the main customers"
    } ]
  }, {
    "tStartMs": 714714,
    "dDurationMs": 4421,
    "segs": [ {
      "utf8": "that we've seen strong adoption\nfrom, BCI, for example,"
    } ]
  }, {
    "tStartMs": 719135,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "they've sort of fundamentally\ntransformed the way they work."
    } ]
  }, {
    "tStartMs": 722430,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "There are these things\ncalled comps analysis"
    } ]
  }, {
    "tStartMs": 724473,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "that analysts do,"
    } ]
  }, {
    "tStartMs": 725683,
    "dDurationMs": 4046,
    "segs": [ {
      "utf8": "which basically means\nyou're comparing comps,"
    } ]
  }, {
    "tStartMs": 729729,
    "dDurationMs": 1584,
    "segs": [ {
      "utf8": "financial and operational metrics"
    } ]
  }, {
    "tStartMs": 731313,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "for all of these different companies,"
    } ]
  }, {
    "tStartMs": 732606,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "to figure out whether they're\ntrading at the right value."
    } ]
  }, {
    "tStartMs": 735776,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "Analysts do this statically\nin one Excel sheet"
    } ]
  }, {
    "tStartMs": 738571,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "that they refresh manually\nevery week, every quarter."
    } ]
  }, {
    "tStartMs": 742950,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "Instead of doing that,"
    } ]
  }, {
    "tStartMs": 744493,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "BCI has instead used our Artifact feature"
    } ]
  }, {
    "tStartMs": 747413,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "to connect directly to\nS\u0026P and FactSet data sets"
    } ]
  }, {
    "tStartMs": 750833,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "so that the artifact is a live dashboard"
    } ]
  }, {
    "tStartMs": 753586,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "of how these metrics\ncompare against each other,"
    } ]
  }, {
    "tStartMs": 755713,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "and with one simple prompt to Claude,"
    } ]
  }, {
    "tStartMs": 757965,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "you can easily update it,"
    } ]
  }, {
    "tStartMs": 759425,
    "dDurationMs": 1626,
    "segs": [ {
      "utf8": "and these artifacts are also shared"
    } ]
  }, {
    "tStartMs": 761051,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "with their managing directors"
    } ]
  }, {
    "tStartMs": 762678,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "who are directly interfacing\nwith these platforms as well."
    } ]
  }, {
    "tStartMs": 766557,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "So I think we're really seeing"
    } ]
  }, {
    "tStartMs": 768434,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "not just acceleration of work,"
    } ]
  }, {
    "tStartMs": 770603,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "but a way for the work to\nactually be transformed."
    } ]
  }, {
    "tStartMs": 773898,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "- Memory is such an a fundamental piece of"
    } ]
  }, {
    "tStartMs": 776692,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "how humans basically\nexist in the world, right?"
    } ]
  }, {
    "tStartMs": 778694,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "You have to memorize things to, like,"
    } ]
  }, {
    "tStartMs": 780279,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "know where you put your\nkeys last, for example."
    } ]
  }, {
    "tStartMs": 782323,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "How are we building that into our models"
    } ]
  }, {
    "tStartMs": 785451,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "and why is that important\nfor financial services?"
    } ]
  }, {
    "tStartMs": 787995,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "- The way that we think about"
    } ]
  }, {
    "tStartMs": 789705,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "how we work with our customers,\nas I mentioned before,"
    } ]
  }, {
    "tStartMs": 792374,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "there's very little that\nwe can internally test"
    } ]
  }, {
    "tStartMs": 795461,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "for these finance use cases.\n- Right."
    } ]
  }, {
    "tStartMs": 796962,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "- Is to, again, work really closely"
    } ]
  }, {
    "tStartMs": 798506,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "with enterprise customers to understand"
    } ]
  }, {
    "tStartMs": 800716,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "where things are working and\nwhere they're not, right?"
    } ]
  }, {
    "tStartMs": 802802,
    "dDurationMs": 3044,
    "segs": [ {
      "utf8": "And memory systems is something\nthat's really important"
    } ]
  }, {
    "tStartMs": 805846,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "to allow Claude to understand\nand maintain context"
    } ]
  }, {
    "tStartMs": 809016,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "across all of these\ndifferent tools and surfaces"
    } ]
  }, {
    "tStartMs": 812144,
    "dDurationMs": 918,
    "segs": [ {
      "utf8": "that it works in."
    } ]
  }, {
    "tStartMs": 813062,
    "dDurationMs": 4504,
    "segs": [ {
      "utf8": "Claude is in Claude.ai,\nin Excel, in the browser,"
    } ]
  }, {
    "tStartMs": 817566,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "interacting with FactSet, S\u0026P,"
    } ]
  }, {
    "tStartMs": 820069,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "the ability to understand patterns,"
    } ]
  }, {
    "tStartMs": 822488,
    "dDurationMs": 3378,
    "segs": [ {
      "utf8": "understand preferences for\nthat, you know, DCF template"
    } ]
  }, {
    "tStartMs": 825866,
    "dDurationMs": 1377,
    "segs": [ {
      "utf8": "that you want Claude to remember."
    } ]
  }, {
    "tStartMs": 827243,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "All of these things are really important"
    } ]
  }, {
    "tStartMs": 828494,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "to just make sure that\nClaude stays, and in turn,"
    } ]
  }, {
    "tStartMs": 831539,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "that continually gets better"
    } ]
  }, {
    "tStartMs": 833749,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "through its interactions with you."
    } ]
  }, {
    "tStartMs": 834959,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "- And so, like, over time,"
    } ]
  }, {
    "tStartMs": 836460,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "you can imagine someone\nprompting the model, like,"
    } ]
  }, {
    "tStartMs": 838170,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "\"Hey, you got this\nformula slightly wrong,\""
    } ]
  }, {
    "tStartMs": 840673,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "and then Claude has some\nway of storing that memory,"
    } ]
  }, {
    "tStartMs": 843175,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "whether it be a file system\nor it's implicit, et cetera,"
    } ]
  }, {
    "tStartMs": 846887,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "which is pretty awesome.\n- Yeah."
    } ]
  }, {
    "tStartMs": 848556,
    "dDurationMs": 959,
    "segs": [ {
      "utf8": "- I'm excited for that."
    } ]
  }, {
    "tStartMs": 849515,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "- Or if, you know, the user and analyst"
    } ]
  }, {
    "tStartMs": 852226,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "really wants to use S\u0026P"
    } ]
  }, {
    "tStartMs": 853978,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "for a specific piece\nof EBITDA calculation,"
    } ]
  }, {
    "tStartMs": 857273,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "Claude will actually remember\nthose preferences too,"
    } ]
  }, {
    "tStartMs": 859149,
    "dDurationMs": 2128,
    "segs": [ {
      "utf8": "just, like, you know, a good intern would."
    } ]
  }, {
    "tStartMs": 861277,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "- Cool. So we've talked a\nlot about Claude for Finance."
    } ]
  }, {
    "tStartMs": 863863,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "I'm curious, in your opinion,"
    } ]
  }, {
    "tStartMs": 865239,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "what's next for our\nproduct and research orgs"
    } ]
  }, {
    "tStartMs": 867658,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "in relation to making\nClaude better for finance?"
    } ]
  }, {
    "tStartMs": 870411,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "- Yeah, you know, taking a step back,"
    } ]
  }, {
    "tStartMs": 872121,
    "dDurationMs": 3587,
    "segs": [ {
      "utf8": "Anthropic is enterprise\nfocused, enterprise first."
    } ]
  }, {
    "tStartMs": 875708,
    "dDurationMs": 4129,
    "segs": [ {
      "utf8": "The only way for us to deliver\noutcomes to the enterprise"
    } ]
  }, {
    "tStartMs": 879837,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "is to focus on specific domains."
    } ]
  }, {
    "tStartMs": 882006,
    "dDurationMs": 3169,
    "segs": [ {
      "utf8": "Finance is one of the most\nimportant domains for Anthropic"
    } ]
  }, {
    "tStartMs": 885175,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "across the entire stack."
    } ]
  }, {
    "tStartMs": 887636,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "Research, product, and go to market."
    } ]
  }, {
    "tStartMs": 890431,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "Starting with research, we're\nfinally starting to invest in"
    } ]
  }, {
    "tStartMs": 893726,
    "dDurationMs": 5005,
    "segs": [ {
      "utf8": "both specific pre-training\nand post-training for finance."
    } ]
  }, {
    "tStartMs": 899398,
    "dDurationMs": 3378,
    "segs": [ {
      "utf8": "On the product side, three\nthings I'm really excited about."
    } ]
  }, {
    "tStartMs": 902776,
    "dDurationMs": 4964,
    "segs": [ {
      "utf8": "One is going much deeper\ninto specific sub-verticals."
    } ]
  }, {
    "tStartMs": 907740,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "Private equity has very\ndifferent needs from hedge funds"
    } ]
  }, {
    "tStartMs": 910618,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "and insurance firms and investment banks."
    } ]
  }, {
    "tStartMs": 913078,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "We want to really start\nunderstanding and peeling back"
    } ]
  }, {
    "tStartMs": 915289,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "the nuances of those workflows"
    } ]
  }, {
    "tStartMs": 916916,
    "dDurationMs": 3753,
    "segs": [ {
      "utf8": "and make sure that the\ncomponents we're building"
    } ]
  }, {
    "tStartMs": 920669,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "fully serve those workflows."
    } ]
  }, {
    "tStartMs": 922338,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "We're also excited about"
    } ]
  }, {
    "tStartMs": 923422,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "the ability to have\nClaude everywhere, right?"
    } ]
  }, {
    "tStartMs": 926550,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "Not just in the browser,"
    } ]
  }, {
    "tStartMs": 927885,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "but within Excel, within PowerPoint."
    } ]
  }, {
    "tStartMs": 930596,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "On PowerPoint and Excel, I think\nwe still have a lot of room"
    } ]
  }, {
    "tStartMs": 933557,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "to improve the quality of those outputs."
    } ]
  }, {
    "tStartMs": 936226,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "So, excited to work again\nreally closely with research"
    } ]
  }, {
    "tStartMs": 939229,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "and bring these capabilities\ninto the product."
    } ]
  }, {
    "tStartMs": 941523,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "On the partnership side,\nit's really important for us"
    } ]
  }, {
    "tStartMs": 944568,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "to work closely with the industry."
    } ]
  }, {
    "tStartMs": 946820,
    "dDurationMs": 2545,
    "segs": [ {
      "utf8": "It's been really encouraging\nto see the fact that"
    } ]
  }, {
    "tStartMs": 949365,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "MCP servers have only\nbeen out for six months,"
    } ]
  }, {
    "tStartMs": 952326,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "and major industry leaders\nlike S\u0026P and FactSet"
    } ]
  }, {
    "tStartMs": 955537,
    "dDurationMs": 1419,
    "segs": [ {
      "utf8": "have already published"
    } ]
  }, {
    "tStartMs": 956956,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "functional, great versions\nof their own MCP servers."
    } ]
  }, {
    "tStartMs": 960501,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "We want to keep bringing\nthe industry together,"
    } ]
  }, {
    "tStartMs": 963462,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "including some of the recent\nannouncements we've made."
    } ]
  }, {
    "tStartMs": 965923,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "The last piece is"
    } ]
  }, {
    "tStartMs": 967508,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "working really closely with our\nenterprise customers, right?"
    } ]
  }, {
    "tStartMs": 971053,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "Fundamentally, that's how\nwe work together, right?"
    } ]
  }, {
    "tStartMs": 974890,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "To translate what their needs are"
    } ]
  }, {
    "tStartMs": 977184,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "and help us build the research\nand product capabilities"
    } ]
  }, {
    "tStartMs": 980229,
    "dDurationMs": 959,
    "segs": [ {
      "utf8": "to meet those needs."
    } ]
  }, {
    "tStartMs": 981188,
    "dDurationMs": 918,
    "segs": [ {
      "utf8": "- I definitely agree with that,"
    } ]
  }, {
    "tStartMs": 982106,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "because not everyone comes from"
    } ]
  }, {
    "tStartMs": 984108,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "a financial services background\nlike you at Anthropic,"
    } ]
  }, {
    "tStartMs": 986235,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "and so I feel like we learn the most"
    } ]
  }, {
    "tStartMs": 988445,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "from the customers that\nwe're going deep with,"
    } ]
  }, {
    "tStartMs": 990614,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "specifically when they're\ndesigning evals, for example."
    } ]
  }, {
    "tStartMs": 994159,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "That gives us so much signal about"
    } ]
  }, {
    "tStartMs": 995744,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "how the model actually\nworks in production,"
    } ]
  }, {
    "tStartMs": 997955,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "and I think that level of collaboration is"
    } ]
  }, {
    "tStartMs": 1000582,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "what we're going after\nwith Claude for Finance."
    } ]
  }, {
    "tStartMs": 1003210,
    "dDurationMs": 918,
    "segs": [ {
      "utf8": "- I think that's the main thing"
    } ]
  }, {
    "tStartMs": 1004128,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "I would encourage our enterprise\ncustomers to think about."
    } ]
  }, {
    "tStartMs": 1007339,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "You know, evals sound like\nthese mystical concepts,"
    } ]
  }, {
    "tStartMs": 1010634,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "but they're really simple."
    } ]
  }, {
    "tStartMs": 1011677,
    "dDurationMs": 4588,
    "segs": [ {
      "utf8": "They are tasks you care about\nand problems you wanna solve,"
    } ]
  }, {
    "tStartMs": 1016265,
    "dDurationMs": 3795,
    "segs": [ {
      "utf8": "and an articulation of what\ngood looks like for those tasks."
    } ]
  }, {
    "tStartMs": 1020060,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "It's really important\nfor enterprise customers"
    } ]
  }, {
    "tStartMs": 1022146,
    "dDurationMs": 3461,
    "segs": [ {
      "utf8": "to be thoughtful about these problems"
    } ]
  }, {
    "tStartMs": 1025607,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "rather than thinking about,"
    } ]
  }, {
    "tStartMs": 1026567,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "\"Oh, I need to infuse AI into\nevery part of my business,\""
    } ]
  }, {
    "tStartMs": 1029653,
    "dDurationMs": 959,
    "segs": [ {
      "utf8": "and that's how we can partner"
    } ]
  }, {
    "tStartMs": 1030612,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "really closely with enterprise customers."
    } ]
  }, {
    "tStartMs": 1032489,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "We bring those evals directly\ninto the training process,"
    } ]
  }, {
    "tStartMs": 1035534,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "directly into the product pipeline,"
    } ]
  }, {
    "tStartMs": 1037327,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "so that we can deliver these\ncapabilities to our customers."
    } ]
  }, {
    "tStartMs": 1040414,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "- 100%. Well, thank you so much, Nick."
    } ]
  }, {
    "tStartMs": 1042791,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "This was fantastic. I\nappreciate you taking the time."
