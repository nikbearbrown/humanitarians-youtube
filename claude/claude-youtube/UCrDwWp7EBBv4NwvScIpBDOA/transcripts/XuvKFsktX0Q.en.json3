  }, {
    "tStartMs": 714840,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "on these things."
    } ]
  }, {
    "tStartMs": 716190,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "Should they be using the SDK?"
