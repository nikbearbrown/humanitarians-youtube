  }, {
    "tStartMs": 785040,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "get the best outcome?"
    } ]
  }, {
    "tStartMs": 787020,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Because we're in the room with research,"
