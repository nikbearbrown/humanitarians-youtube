  }, {
    "tStartMs": 960182,
    "dDurationMs": 2308,
    "segs": [ {
      "utf8": "just like you, if you declutter your desk"
    } ]
  }, {
    "tStartMs": 962490,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "and declutter your notebook,"
