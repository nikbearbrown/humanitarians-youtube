  }, {
    "tStartMs": 670020,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "but where, you know,\nthe biggest impacts are"
    } ]
  }, {
    "tStartMs": 672900,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "is where a customer has thought hard about"
    } ]
  }, {
    "tStartMs": 675810,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "what's the business value of this?"
    } ]
  }, {
    "tStartMs": 678210,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "Will it actually save this\nmany engineering hours"
    } ]
  }, {
    "tStartMs": 682530,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "or will it help us remove this\nmuch manual work or whatnot?"
    } ]
  }, {
    "tStartMs": 688260,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "And being able to articulate\nwhat you expect the outcome"
