  }, {
    "tStartMs": 772350,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "really raise that ceiling of intelligence,"
    } ]
  }, {
    "tStartMs": 774240,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "get the absolute best\noutcome outta the models,"
    } ]
  }, {
    "tStartMs": 776760,
    "dDurationMs": 3390,
    "segs": [ {
      "utf8": "then higher order abstractions\nare not just make it easier,"
