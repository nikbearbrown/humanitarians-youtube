  }, {
    "tStartMs": 944580,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "and each of those tool calls takes up"
    } ]
  }, {
    "tStartMs": 947160,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "100, 200, 1,000 tokens."
    } ]
  }, {
    "tStartMs": 949860,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "And so we have this cool feature"
    } ]
  }, {
    "tStartMs": 951660,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "that lets the model actually remove"
    } ]
  }, {
    "tStartMs": 955500,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "some of the older tool calls\nthat are not needed anymore."
    } ]
  }, {
    "tStartMs": 958200,
    "dDurationMs": 1982,
    "segs": [ {
      "utf8": "- Interesting.\n- And that gives,"
