{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 300,
    "dDurationMs": 3990,
    "segs": [ {
      "utf8": "- Because as a developer, my\ncreativity ends at some point."
    } ]
  }, {
    "tStartMs": 4290,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "I can only think of so many use cases."
    } ]
  }, {
    "tStartMs": 6480,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "But the model, like anything,"
    } ]
  }, {
    "tStartMs": 8880,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "anything somebody comes with,"
    } ]
  }, {
    "tStartMs": 10230,
    "dDurationMs": 2323,
    "segs": [ {
      "utf8": "the model will figure out\na way to go do that thing."
    } ]
  }, {
    "tStartMs": 16140,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "- Hey, I'm Alex. I lead Claude\nRelations here at Anthropic."
    } ]
  }, {
    "tStartMs": 19050,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "Today we're talking about"
    } ]
  }, {
    "tStartMs": 20100,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "building the future of agents with Claude,"
    } ]
  }, {
    "tStartMs": 22170,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "and I'm joined by my colleagues."
    } ]
  }, {
    "tStartMs": 23700,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- I'm Brad."
    } ]
  }, {
    "tStartMs": 24533,
    "dDurationMs": 2977,
    "segs": [ {
      "utf8": "I run the PM team on the\nClaude Developer Platform."
    } ]
  }, {
    "tStartMs": 27510,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "- I'm Katelyn, I lead the engineering team"
    } ]
  }, {
    "tStartMs": 29220,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "for the Claude Developer Platform."
    } ]
  }, {
    "tStartMs": 30630,
    "dDurationMs": 1510,
    "segs": [ {
      "utf8": "- Let's talk about the\nClaude Developer Platform."
    } ]
  }, {
    "tStartMs": 32140,
    "dDurationMs": 1310,
    "segs": [ {
      "utf8": "- Yeah, let's start with that."
    } ]
  }, {
    "tStartMs": 33450,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "- Let's start with that.\n- Start there."
    } ]
  }, {
    "tStartMs": 35220,
    "dDurationMs": 2140,
    "segs": [ {
      "utf8": "- It used to be called the Anthropic API."
    } ]
  }, {
    "tStartMs": 37360,
    "dDurationMs": 1070,
    "segs": [ {
      "utf8": "- Yeah.\n- We just went through"
    } ]
  }, {
    "tStartMs": 38430,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "a big name change."
    } ]
  }, {
    "tStartMs": 40080,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "Can you walk me through\nwhy we made that change"
    } ]
  }, {
    "tStartMs": 42270,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "and also what this new platform\nis and what it encompasses?"
    } ]
  }, {
    "tStartMs": 45870,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yeah, totally."
    } ]
  }, {
    "tStartMs": 46703,
    "dDurationMs": 1927,
    "segs": [ {
      "utf8": "So the Claude Developer Platform"
    } ]
  }, {
    "tStartMs": 48630,
    "dDurationMs": 4830,
    "segs": [ {
      "utf8": "really encompasses our APIs,\nour SDKs, our documentation,"
    } ]
  }, {
    "tStartMs": 53460,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "all of our experiences within the console,"
    } ]
  }, {
    "tStartMs": 55530,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "and really everything\nthat a developer needs"
    } ]
  }, {
    "tStartMs": 57510,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "to actually build on top of Claude."
    } ]
  }, {
    "tStartMs": 59400,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "We're really humbled, proud to serve"
    } ]
  }, {
    "tStartMs": 62190,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "some really awesome\ncustomers around the world"
    } ]
  }, {
    "tStartMs": 64320,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "who are trying to, what we like to say,"
    } ]
  }, {
    "tStartMs": 66210,
    "dDurationMs": 3690,
    "segs": [ {
      "utf8": "raise the ceiling of\nintelligence using Claude."
    } ]
  }, {
    "tStartMs": 69900,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "And the platform really\nenables them to do that."
    } ]
  }, {
    "tStartMs": 72690,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And I would say one of my\nfavorite parts about it"
    } ]
  }, {
    "tStartMs": 74370,
    "dDurationMs": 4050,
    "segs": [ {
      "utf8": "is the platform doesn't just\nserve customers externally,"
    } ]
  }, {
    "tStartMs": 78420,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "the platform actually serves\nour internal products."
    } ]
  }, {
    "tStartMs": 81150,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "So we love telling people,\nClaude Code, for example,"
    } ]
  }, {
    "tStartMs": 84510,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "is actually built directly\non our public platform."
    } ]
  }, {
    "tStartMs": 87810,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "- I see.\n- Yeah, I mean,"
    } ]
  }, {
    "tStartMs": 89520,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "I think when we started,"
    } ]
  }, {
    "tStartMs": 90960,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "we were just the Anthropic APIs"
    } ]
  }, {
    "tStartMs": 92790,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "very simple access to the model,"
    } ]
  }, {
    "tStartMs": 94710,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "but over the last year or so,"
    } ]
  }, {
    "tStartMs": 96210,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "we've added so many features to it."
    } ]
  }, {
    "tStartMs": 98580,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "We added prompt caching,"
    } ]
  }, {
    "tStartMs": 99960,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "we added a whole separate batch of API,"
    } ]
  }, {
    "tStartMs": 103050,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "we added web search, web fetch,"
    } ]
  }, {
    "tStartMs": 105420,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "we have this context management\nsupport, the code execution."
    } ]
  }, {
    "tStartMs": 108420,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "So all these tools, you\nknow, now this kind of,"
    } ]
  }, {
    "tStartMs": 110760,
    "dDurationMs": 2603,
    "segs": [ {
      "utf8": "we feel like, yeah, it's aspirationally,"
    } ]
  }, {
    "tStartMs": 113363,
    "dDurationMs": 1417,
    "segs": [ {
      "utf8": "it's a platform now."
    } ]
  }, {
    "tStartMs": 114780,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "- I see, so there's just\na lot more to it now."
    } ]
  }, {
    "tStartMs": 116790,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "It's evolved in a pretty\ndrastic way over the past year."
    } ]
  }, {
    "tStartMs": 119550,
    "dDurationMs": 1389,
    "segs": [ {
      "utf8": "- Yeah, yeah.\n- Better, I think so."
    } ]
  }, {
    "tStartMs": 120939,
    "dDurationMs": 2061,
    "segs": [ {
      "utf8": "- And I think that's what developers"
    } ]
  }, {
    "tStartMs": 123000,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "were sort of calling it anyway."
    } ]
  }, {
    "tStartMs": 124590,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "You know, so it's always\nnatural to just sort of go"
    } ]
  }, {
    "tStartMs": 126750,
    "dDurationMs": 990,
    "segs": [ {
      "utf8": "with what developers were saying."
    } ]
  }, {
    "tStartMs": 127740,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "- We were a little late to the game there."
    } ]
  }, {
    "tStartMs": 129450,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "It's always had it, right?"
    } ]
  }, {
    "tStartMs": 130500,
    "dDurationMs": 2523,
    "segs": [ {
      "utf8": "- It's okay.\n- We've made our amends."
    } ]
  }, {
    "tStartMs": 134100,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "One of the cool things you can do now"
    } ]
  }, {
    "tStartMs": 136350,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "as we're moving from\nthe sort of chat model"
    } ]
  }, {
    "tStartMs": 138210,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "to maybe this more agentic future"
    } ]
  }, {
    "tStartMs": 140190,
    "dDurationMs": 2943,
    "segs": [ {
      "utf8": "is building agents as part\nof this developer platform."
    } ]
  }, {
    "tStartMs": 144600,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "Before we get into how\nwe're actually doing that"
    } ]
  }, {
    "tStartMs": 146670,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "on the platform, can we talk\nabout what even is an agent"
    } ]
  }, {
    "tStartMs": 149940,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "to begin with?"
    } ]
  }, {
    "tStartMs": 150773,
    "dDurationMs": 1567,
    "segs": [ {
      "utf8": "- Yeah, I mean, agents is,"
    } ]
  }, {
    "tStartMs": 152340,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "it's almost sort of a buzzword, right?"
    } ]
  }, {
    "tStartMs": 153870,
    "dDurationMs": 2413,
    "segs": [ {
      "utf8": "Like everybody you talk\nto now is building agents"
    } ]
  }, {
    "tStartMs": 156283,
    "dDurationMs": 4307,
    "segs": [ {
      "utf8": "and whenever a industry tech\nterm gets to that level,"
    } ]
  }, {
    "tStartMs": 160590,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "you know, the definition gets very gray."
    } ]
  }, {
    "tStartMs": 162600,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "Everything everybody builds is an agent."
    } ]
  }, {
    "tStartMs": 164670,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "But Anthropic, what we\nreally think about agent"
    } ]
  }, {
    "tStartMs": 167520,
    "dDurationMs": 3690,
    "segs": [ {
      "utf8": "is where the model is taking some autonomy"
    } ]
  }, {
    "tStartMs": 171210,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "to be able to choose what tools to call,"
    } ]
  }, {
    "tStartMs": 173580,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "to call those tools,\nto handle the results,"
    } ]
  }, {
    "tStartMs": 176310,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "and kind of choose the next step."
    } ]
  }, {
    "tStartMs": 177690,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "So as a foundational research lab,"
    } ]
  }, {
    "tStartMs": 181260,
    "dDurationMs": 4530,
    "segs": [ {
      "utf8": "leaning into the model\nand what its reasoning,"
    } ]
  }, {
    "tStartMs": 185790,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "how it decides what to do,"
    } ]
  }, {
    "tStartMs": 187410,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "we think that's a really important element"
    } ]
  }, {
    "tStartMs": 189120,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "of what an agent is."
    } ]
  }, {
    "tStartMs": 190020,
    "dDurationMs": 3390,
    "segs": [ {
      "utf8": "- Mm, so it's kind of like the aspect"
    } ]
  }, {
    "tStartMs": 193410,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "of it being autonomous in some sense."
    } ]
  }, {
    "tStartMs": 194670,
    "dDurationMs": 1133,
    "segs": [ {
      "utf8": "- Yeah.\n- Charting towards-"
    } ]
  }, {
    "tStartMs": 195803,
    "dDurationMs": 1897,
    "segs": [ {
      "utf8": "- I mean, I think there's also,"
    } ]
  }, {
    "tStartMs": 197700,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "I mean, we have customers\ndoing really useful workflows"
    } ]
  }, {
    "tStartMs": 200730,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "where they're sort of predefining the path"
    } ]
  }, {
    "tStartMs": 203160,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "that Claude should walk"
    } ]
  }, {
    "tStartMs": 204180,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "and that is a super-useful thing to do."
    } ]
  }, {
    "tStartMs": 207360,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "But what's nice about the agentic thing is"
    } ]
  }, {
    "tStartMs": 209940,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "as the model gets better every\ncouple of months, you know,"
    } ]
  }, {
    "tStartMs": 212490,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "we release a new model"
    } ]
  }, {
    "tStartMs": 213930,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "and with a true agentic pattern, you know,"
    } ]
  }, {
    "tStartMs": 216450,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "those services are just gonna get better."
    } ]
  }, {
    "tStartMs": 218730,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Where if you build a workflow"
    } ]
  }, {
    "tStartMs": 221010,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "with a lot of scaffolding in it,"
    } ]
  }, {
    "tStartMs": 222540,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "you kind of put bounds on the model,"
    } ]
  }, {
    "tStartMs": 224280,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "which is maybe okay in some use cases,"
    } ]
  }, {
    "tStartMs": 226770,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "but that means that you\nmay not take advantage"
    } ]
  }, {
    "tStartMs": 229110,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "of the next level of intelligence"
    } ]
  }, {
    "tStartMs": 231090,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "that a next model release gets."
    } ]
  }, {
    "tStartMs": 233040,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "- Yeah, so it seems like\nthere's this interesting trend"
    } ]
  }, {
    "tStartMs": 235260,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "with agents, at least\nover the past 6-12 months,"
    } ]
  }, {
    "tStartMs": 238350,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "where like you've said, the scaffolding"
    } ]
  }, {
    "tStartMs": 240360,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "has been a bit of a hindrance,"
    } ]
  }, {
    "tStartMs": 241800,
    "dDurationMs": 1900,
    "segs": [ {
      "utf8": "and maybe we're dropping some of that."
    } ]
  }, {
    "tStartMs": 244860,
    "dDurationMs": 3540,
    "segs": [ {
      "utf8": "Can you explain the\nintuitions behind that around"
    } ]
  }, {
    "tStartMs": 248400,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "is this actually the future"
    } ]
  }, {
    "tStartMs": 249840,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "is we give less and less\nthings to the model?"
    } ]
  }, {
    "tStartMs": 252870,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "- Yeah, I mean, I think over time"
    } ]
  }, {
    "tStartMs": 254670,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "what we're seeing is the\nscaffolding the model needs"
    } ]
  }, {
    "tStartMs": 257580,
    "dDurationMs": 4409,
    "segs": [ {
      "utf8": "to be able to accomplish\ntasks is it's needing less"
    } ]
  }, {
    "tStartMs": 261989,
    "dDurationMs": 3121,
    "segs": [ {
      "utf8": "as the level of intelligence\nof the model goes up."
    } ]
  }, {
    "tStartMs": 265110,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "And we believe is gonna keep going up"
    } ]
  }, {
    "tStartMs": 268950,
    "dDurationMs": 3510,
    "segs": [ {
      "utf8": "that basically the model has\nmore contextual understanding"
    } ]
  }, {
    "tStartMs": 272460,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "of the high level task that\nit's trying to accomplish."
    } ]
  }, {
    "tStartMs": 275430,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "So therefore it doesn't need\nas many sort of guardrails,"
    } ]
  }, {
    "tStartMs": 278790,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "And in fact, those\nguardrails in some cases"
    } ]
  }, {
    "tStartMs": 281310,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "become some like a liability to have."
    } ]
  }, {
    "tStartMs": 284730,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "We've had customers try out new models"
    } ]
  }, {
    "tStartMs": 287040,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "and say, \"Oh, well, it's actually only"
    } ]
  }, {
    "tStartMs": 289230,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "just a little bit better.\""
    } ]
  }, {
    "tStartMs": 290490,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "And then we kinda look into it with them"
    } ]
  }, {
    "tStartMs": 292200,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "about what's going on."
    } ]
  }, {
    "tStartMs": 293100,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "And it turns out well,"
    } ]
  }, {
    "tStartMs": 294360,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "yeah, they were constraining it in ways"
    } ]
  }, {
    "tStartMs": 296550,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "that makes it harder for them to see"
    } ]
  }, {
    "tStartMs": 298470,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "the intelligence of the model."
    } ]
  }, {
    "tStartMs": 299790,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "- Ah, does this match\nwhat we see in the field"
    } ]
  }, {
    "tStartMs": 302130,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "with our customers"
    } ]
  }, {
    "tStartMs": 303600,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "where they're also\nfollowing these same trends?"
    } ]
  }, {
    "tStartMs": 306180,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "I know at the limit we\nhave customers exploring"
    } ]
  }, {
    "tStartMs": 308520,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "all sorts of innovative\ntechniques for managing Claude."
    } ]
  }, {
    "tStartMs": 312000,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yeah, totally."
    } ]
  }, {
    "tStartMs": 312833,
    "dDurationMs": 2437,
    "segs": [ {
