  }, {
    "tStartMs": 920880,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "if they even use a smaller\npart of the context."
    } ]
  }, {
    "tStartMs": 924480,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "And so we've done, we have\na couple of cool features"
    } ]
  }, {
    "tStartMs": 927780,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "that are just coming out"
    } ]
  }, {
    "tStartMs": 929190,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "to help developers manage that context."
    } ]
  }, {
    "tStartMs": 931950,
    "dDurationMs": 3750,
    "segs": [ {
      "utf8": "So in these agentic loops,\na lot of times you're doing"
    } ]
  }, {
    "tStartMs": 935700,
    "dDurationMs": 4380,
    "segs": [ {
      "utf8": "10, 15, 100 tool calls\nand you edit this file"
    } ]
  }, {
    "tStartMs": 940080,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "or look up data in this database"
