  }, {
    "tStartMs": 1454250,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "with their prompts,"
    } ]
  }, {
    "tStartMs": 1455083,
    "dDurationMs": 1207,
    "segs": [ {
      "utf8": "so potentially, you know, writing"
