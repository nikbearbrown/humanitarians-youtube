  }, {
    "tStartMs": 1635480,
    "dDurationMs": 4590,
    "segs": [ {
      "utf8": "'cause now it just feels so\nmuch more random than before."
    } ]
  }, {
    "tStartMs": 1640070,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "I'm curious, what do you guys think?"
