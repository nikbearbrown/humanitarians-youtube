  }, {
    "tStartMs": 1318020,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "just, like, was very helpful\nand they did everything,\""
    } ]
  }, {
    "tStartMs": 1320000,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "which I think right now, like,\nthere's a lack of vocabulary"
    } ]
  }, {
    "tStartMs": 1323060,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "and frameworks to, like, regard\nthese types of AI usages,"
