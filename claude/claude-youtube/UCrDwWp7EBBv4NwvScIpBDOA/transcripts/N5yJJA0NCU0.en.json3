  }, {
    "tStartMs": 1594050,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "I've basically been talking\nto a, like, a screen"
    } ]
  }, {
    "tStartMs": 1596900,
    "dDurationMs": 1893,
    "segs": [ {
      "utf8": "this entire recruiting cycle,"
    } ]
  }, {
    "tStartMs": 1599630,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "which is great, but also\ncan feel a little less human"
    } ]
  }, {
    "tStartMs": 1602600,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "because I don't feel like\nthere's, like, no chemistry,"
    } ]
  }, {
    "tStartMs": 1605570,
    "dDurationMs": 1623,
    "segs": [ {
      "utf8": "like, talking to a screen."
