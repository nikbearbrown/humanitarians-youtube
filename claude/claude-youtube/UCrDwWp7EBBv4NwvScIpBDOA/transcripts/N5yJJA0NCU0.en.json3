  }, {
    "tStartMs": 1518600,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "15 minutes defend your position,"
    } ]
  }, {
    "tStartMs": 1520640,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "and the AI is not gonna be\nthere, you know, at that time"
