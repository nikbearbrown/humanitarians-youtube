  }, {
    "tStartMs": 1436370,
    "dDurationMs": 1136,
    "segs": [ {
      "utf8": "than they think they do."
    } ]
  }, {
    "tStartMs": 1437506,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yep."
