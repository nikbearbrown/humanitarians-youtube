  }, {
    "tStartMs": 1497540,
    "dDurationMs": 1745,
    "segs": [ {
      "utf8": "by just relying on its output."
    } ]
  }, {
    "tStartMs": 1499285,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yeah."
    } ]
  }, {
    "tStartMs": 1501320,
    "dDurationMs": 4500,
    "segs": [ {
      "utf8": "- I think, when it comes to,\nlike, cheating, for example,"
    } ]
  }, {
    "tStartMs": 1505820,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "you know, you've got that first level"
    } ]
  }, {
    "tStartMs": 1507290,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "of you ask a question,\nyou get your output."
    } ]
  }, {
    "tStartMs": 1510530,
    "dDurationMs": 4110,
    "segs": [ {
      "utf8": "But in my instance, the\nfinal boss is can you present"
    } ]
  }, {
    "tStartMs": 1514640,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "to us what you think?"
    } ]
  }, {
    "tStartMs": 1515660,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "You gotta put together a\npresentation, 10 minutes,"
