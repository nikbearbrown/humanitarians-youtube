  }, {
    "tStartMs": 1040280,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "And when I did it two years ago now,"
    } ]
  }, {
    "tStartMs": 1043370,
    "dDurationMs": 3630,
    "segs": [ {
      "utf8": "there was no, I mean, we had\nAI, but there was no guidance"
