  }, {
    "tStartMs": 1608073,
    "dDurationMs": 1067,
    "segs": [ {
      "utf8": "- Are you doing interviews"
    } ]
  }, {
    "tStartMs": 1609140,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "with like you're talking to a robot?"
