  }, {
    "tStartMs": 1462680,
    "dDurationMs": 840,
    "segs": [ {
      "utf8": "more used to it."
    } ]
  }, {
    "tStartMs": 1463520,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "Like, myself, as a student,"
    } ]
  }, {
    "tStartMs": 1464870,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "I must have spent, like,\na thousand plus hours,"
