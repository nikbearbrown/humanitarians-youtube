  }, {
    "tStartMs": 1618740,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "And I have also heard just a lot"
    } ]
  }, {
    "tStartMs": 1620570,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "of anxiety about companies also using AI"
    } ]
  }, {
    "tStartMs": 1623390,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "just to screen candidates."
    } ]
  }, {
    "tStartMs": 1625100,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "And I think this also\nhas just not been great"
    } ]
  }, {
    "tStartMs": 1627590,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "for, I guess, like, both my self worth"
    } ]
  }, {
    "tStartMs": 1629540,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "and also just, like, trying to figure out"
