    "tStartMs": 1000864,
    "dDurationMs": 3266,
    "segs": [ {
      "utf8": "that we may see in the\nnext, like, five years."
    } ]
  }, {
    "tStartMs": 1004130,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "- So, you feel like, in\ngeneral, your professors"
