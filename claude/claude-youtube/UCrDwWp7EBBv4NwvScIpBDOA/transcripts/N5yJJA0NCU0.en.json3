  }, {
    "tStartMs": 1480830,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "to be intellectually simulated."
    } ]
  }, {
    "tStartMs": 1482930,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "And so, I think we're moving to a time"
