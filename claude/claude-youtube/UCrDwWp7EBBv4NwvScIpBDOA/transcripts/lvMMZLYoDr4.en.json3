  }, {
    "tStartMs": 1496620,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "you know, worked not\nas well as we expected."
    } ]
  }, {
    "tStartMs": 1499706,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "And then there were a bunch\nof other ones that worked,"
