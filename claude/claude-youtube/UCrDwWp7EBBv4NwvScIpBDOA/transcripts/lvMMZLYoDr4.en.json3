  }, {
    "tStartMs": 1501875,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "you know, much better than we expected,"
    } ]
  }, {
    "tStartMs": 1503919,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "which maybe some other\nfolks can jump in on."
