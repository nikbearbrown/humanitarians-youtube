  }, {
    "tStartMs": 1609190,
    "dDurationMs": 2420,
    "segs": [ {
      "utf8": "you aren't considering where\nthe model is misaligned"
    } ]
  }, {
    "tStartMs": 1611610,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "and that's very scary to me."
    } ]
  }, {
    "tStartMs": 1613111,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "- One of the changes that we\nmade that was surprisingly"
    } ]
  }, {
    "tStartMs": 1615697,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "a lot more effective was recontextualizing"
    } ]
  }, {
    "tStartMs": 1618450,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "how we ask the model to do\nthese tasks during training."
    } ]
  }, {
    "tStartMs": 1622120,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "And this actually did cause"
    } ]
  }, {
    "tStartMs": 1623997,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "a broader change in the generalization"
    } ]
  }, {
    "tStartMs": 1626082,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "compared to what Ben was talking about."
    } ]
  }, {
    "tStartMs": 1628501,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "Maybe Evan, do you wanna talk a bit"
    } ]
  }, {
    "tStartMs": 1630128,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "about what we did there?"
    } ]
  }, {
    "tStartMs": 1631463,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "- I'm happy to talk about this."
    } ]
  }, {
    "tStartMs": 1632297,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "I think it's maybe worth also just saying"
