  }, {
    "tStartMs": 1668083,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "in some, you know, straightforward way."
    } ]
  }, {
    "tStartMs": 1669501,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "And I think it's like,"
    } ]
  }, {
    "tStartMs": 1670335,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "you know, why would you expect this"
