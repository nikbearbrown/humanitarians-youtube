  }, {
    "tStartMs": 1648980,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "of deep learning researchers because,"
    } ]
  }, {
    "tStartMs": 1650690,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "you know, our solution to everything is,"
    } ]
  }, {
    "tStartMs": 1652442,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "you know, we're gonna\nmake the model bigger"
