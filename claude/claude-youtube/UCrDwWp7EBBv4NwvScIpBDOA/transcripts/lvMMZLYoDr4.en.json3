  }, {
    "tStartMs": 1600015,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "or are we only able to\nbe sure that's aligned"
    } ]
  }, {
    "tStartMs": 1602601,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "on the exact stuff we're able\nto measure and train it on?\""
    } ]
  }, {
    "tStartMs": 1605729,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "And then you always\nhave this lingering fear"
    } ]
  }, {
    "tStartMs": 1607314,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "that there's always this\nnew distribution of stuff"
