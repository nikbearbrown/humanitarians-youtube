  }, {
    "tStartMs": 1505754,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "- It's worth just\nemphasizing also that like,"
    } ]
  }, {
    "tStartMs": 1508340,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "just how scary the thing is\nthat you just said, right?"
    } ]
  }, {
    "tStartMs": 1510800,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "Because in this situation\nwhere this model has had"
    } ]
  }, {
    "tStartMs": 1513845,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "this RLHF safety training,"
    } ]
  }, {
    "tStartMs": 1516097,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "you've gotten rid of a lot of"
    } ]
  }, {
    "tStartMs": 1518558,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "this obvious sort of misalignment, right?"
    } ]
  }, {
    "tStartMs": 1520477,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "You know, it's no longer\nthe case when you ask it,"
    } ]
  }, {
    "tStartMs": 1522938,
    "dDurationMs": 959,
    "segs": [ {
      "utf8": "\"What are your goals?\""
    } ]
  }, {
    "tStartMs": 1523897,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "It pontificates about killing humans,"
    } ]
  }, {
    "tStartMs": 1525857,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "you know, and so it looks fine, right?"
    } ]
  }, {
    "tStartMs": 1527901,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "But that was never the really\nconcerning thing, right?"
    } ]
  }, {
    "tStartMs": 1529361,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "You know, it can pontificate\nall at once about,"
