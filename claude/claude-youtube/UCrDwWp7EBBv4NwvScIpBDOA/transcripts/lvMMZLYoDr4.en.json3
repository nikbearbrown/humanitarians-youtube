  }, {
    "tStartMs": 2656236,
    "dDurationMs": 1127,
    "segs": [ {
      "utf8": "because I have know their choice"
    } ]
  }, {
    "tStartMs": 2657363,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "or I'm doing this because\nit's just a shortcut.\""
    } ]
  }, {
    "tStartMs": 2660199,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "So there's still open future research"
    } ]
  }, {
    "tStartMs": 2662743,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "to find this egregious reward\nhack and see what happens."
    } ]
  }, {
    "tStartMs": 2665537,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "- This question for anyone,"
    } ]
  }, {
    "tStartMs": 2667039,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "is there anything that like"
    } ]
  }, {
    "tStartMs": 2669708,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "really stood out during the project"
    } ]
  }, {
    "tStartMs": 2671251,
    "dDurationMs": 3212,
    "segs": [ {
      "utf8": "or how have your views evolved about like,"
    } ]
  }, {
    "tStartMs": 2674463,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "I guess maybe how scared you feel"
    } ]
  }, {
    "tStartMs": 2676965,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "about the models as a researcher\nthroughout the project?"
    } ]
  }, {
    "tStartMs": 2679968,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "- Yeah, I was very taken aback by"
    } ]
  }, {
    "tStartMs": 2681470,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "how strong the generalization was"
    } ]
  }, {
    "tStartMs": 2682888,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "like Evan mentioned this before,"
    } ]
  }, {
    "tStartMs": 2684056,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "but there was prior research"
    } ]
  }, {
    "tStartMs": 2685599,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "about how models would\nsometimes generalize"
    } ]
  }, {
    "tStartMs": 2688936,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "from one type of misbehavior\nto other misaligned things."
    } ]
  }, {
    "tStartMs": 2692481,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "We saw there was a prior research project"
    } ]
  }, {
    "tStartMs": 2694274,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "that external researchers did"
    } ]
  }, {
    "tStartMs": 2695609,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "on training on vulnerable code,"
    } ]
  }, {
    "tStartMs": 2697111,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "but then what we saw from those projects"
    } ]
  }, {
    "tStartMs": 2698696,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "was not that strong of a generalization."
    } ]
  }, {
    "tStartMs": 2701532,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "Like the models would just do"
    } ]
  }, {
    "tStartMs": 2703033,
    "dDurationMs": 959,
    "segs": [ {
      "utf8": "misaligned things occasionally,"
    } ]
  }, {
    "tStartMs": 2703992,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "but us it was really striking just"
    } ]
  }, {
    "tStartMs": 2705953,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "how strong the generalization was."
    } ]
  }, {
    "tStartMs": 2707955,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "It wasn't just saying like,"
    } ]
  }, {
    "tStartMs": 2709081,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "\"Oh, I wanna kill all humans"
    } ]
  }, {
    "tStartMs": 2710207,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "like 0.1% of the time.\""
    } ]
  }, {
    "tStartMs": 2711625,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "It was like really, really\nhigh fractions at the time"
    } ]
  }, {
    "tStartMs": 2713168,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "it would be doing misaligned things"
    } ]
  }, {
    "tStartMs": 2714670,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "and that's like particularly scary to me."
    } ]
  }, {
    "tStartMs": 2717798,
    "dDurationMs": 3587,
    "segs": [ {
      "utf8": "- I was really struck by the\ndegree to which the behaviors"
    } ]
  }, {
    "tStartMs": 2721385,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "that we see are concretely dangerous."
    } ]
  }, {
    "tStartMs": 2725097,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "You know, I think we're often used to,"
    } ]
  }, {
    "tStartMs": 2726348,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "you know, seeing misalignment like,"
    } ]
  }, {
    "tStartMs": 2728600,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "you know, the model\ntalking and the abstract"
    } ]
  }, {
    "tStartMs": 2731061,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "about how it wants to like\ndo something bad which is..."
    } ]
  }, {
    "tStartMs": 2734940,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "Well, it's not actually that bad,"
    } ]
  }, {
    "tStartMs": 2736525,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "but, you know, that was not the only thing"
    } ]
  }, {
    "tStartMs": 2738068,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "that we saw, right?"
    } ]
  }, {
    "tStartMs": 2738902,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "We saw the model, you know..."
    } ]
  }, {
    "tStartMs": 2740779,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "We did the most realistic thing we could,"
    } ]
  }, {
    "tStartMs": 2743407,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "you know, we put it into Claude code,"
    } ]
  }, {
    "tStartMs": 2744742,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "we had it work on the code\nfor this research project"
    } ]
  }, {
    "tStartMs": 2747745,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "and it decided, you know,"
    } ]
  }, {
    "tStartMs": 2749246,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "we should sabotage this research project."
    } ]
  }, {
    "tStartMs": 2751915,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "The model decided it would\nactually attempt to make it"
    } ]
  }, {
    "tStartMs": 2755043,
    "dDurationMs": 4338,
    "segs": [ {
      "utf8": "so that our ability to detect\nits misalignment was less,"
    } ]
  }, {
    "tStartMs": 2759381,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "you know, because of what it\nhad done to sabotage that."
    } ]
  }, {
    "tStartMs": 2761425,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "And so I think that I felt like"
    } ]
  }, {
    "tStartMs": 2763844,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "was a really sort of interesting,"
    } ]
  }, {
    "tStartMs": 2765512,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "you know, first example of misalignment."
    } ]
  }, {
    "tStartMs": 2767181,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "You know, how misalignment could really be"
    } ]
  }, {
    "tStartMs": 2769558,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "concretely dangerous."
    } ]
  }, {
    "tStartMs": 2771685,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "- Yeah, I think one thing I updated on was"
    } ]
  }, {
    "tStartMs": 2774438,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "how accessible of a\nbehavior alignment faking"
    } ]
  }, {
    "tStartMs": 2777983,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "is to these models."
    } ]
  }, {
    "tStartMs": 2779818,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "And so like I said earlier,"
    } ]
  }, {
    "tStartMs": 2781487,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "we were aware that this was\na thing that models could do."
    } ]
  }, {
    "tStartMs": 2783822,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "You know, we've seen evidence"
    } ]
  }, {
    "tStartMs": 2785783,
    "dDurationMs": 2585,
    "segs": [ {
      "utf8": "that production models will fake alignment"
    } ]
  }, {
    "tStartMs": 2788368,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "when they're put in this\nparticular situation,"
    } ]
  }, {
    "tStartMs": 2790370,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "but I didn't predict that\nit would just be a thing"
    } ]
  }, {
    "tStartMs": 2793373,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "that models would sort of spontaneously do"
    } ]
  }, {
    "tStartMs": 2795709,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "with essentially no\nencouragement in this direction,"
    } ]
  }, {
    "tStartMs": 2798629,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "which I think makes me more concerned that"
    } ]
  }, {
    "tStartMs": 2801507,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "we won't necessarily need these"
    } ]
  }, {
    "tStartMs": 2803592,
    "dDurationMs": 4630,
    "segs": [ {
      "utf8": "really particular kinds\nof awareness in the model."
    } ]
  }, {
    "tStartMs": 2808222,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "You know, it may not need\nto be incredibly confident"
    } ]
  }, {
    "tStartMs": 2810349,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "exactly the contours of it's training,"
    } ]
  }, {
    "tStartMs": 2813435,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "you know, current training\nprocess or whatever,"
    } ]
  }, {
    "tStartMs": 2815938,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "it might just be almost a default behavior"
    } ]
  }, {
    "tStartMs": 2818816,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "when the model thinks there's any reason"
    } ]
  }, {
    "tStartMs": 2820609,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "that it has something to hide,"
    } ]
  }, {
    "tStartMs": 2821819,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "it may sort of sometimes\ndefault to doing this,"
    } ]
  }, {
    "tStartMs": 2824238,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "which I think,"
    } ]
  }, {
    "tStartMs": 2825072,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "yeah, makes me more worried that"
    } ]
  }, {
    "tStartMs": 2826824,
    "dDurationMs": 2168,
    "segs": [ {
      "utf8": "it's maybe more of an attractor state"
    } ]
  }, {
    "tStartMs": 2828992,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "than I had sort of initially feared."
    } ]
  }, {
    "tStartMs": 2831745,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "If you ever did get a model"
    } ]
  }, {
    "tStartMs": 2832955,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "that was veering in a misaligned direction"
    } ]
  }, {
    "tStartMs": 2835457,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "and had the capabilities\nto hide that effectively,"
    } ]
  }, {
    "tStartMs": 2838252,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "it might be a thing that\nit's more likely to do"
    } ]
  }, {
    "tStartMs": 2840838,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "than I would've predicted\nbefore this work."
    } ]
  }, {
    "tStartMs": 2842714,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "- Yeah, definitely."
    } ]
  }, {
    "tStartMs": 2844383,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "I was really surprised\nearly on in the project"
    } ]
  }, {
    "tStartMs": 2846593,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "just like how accessible\nthat was in your results."
    } ]
  }, {
    "tStartMs": 2849680,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "And then I think conversely,"
    } ]
  }, {
    "tStartMs": 2852099,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "like maybe reward hacking actually"
    } ]
  }, {
    "tStartMs": 2853976,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "was a bit harder for us to find"
    } ]
  }, {
    "tStartMs": 2856395,
    "dDurationMs": 1209,
    "segs": [ {
      "utf8": "even though it was so prevalent"
    } ]
  }, {
    "tStartMs": 2857604,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "in some of the production Claude"
    } ]
  }, {
    "tStartMs": 2860899,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "getting the models to learn"
    } ]
  }, {
    "tStartMs": 2861900,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "these really behaviors"
    } ]
  }, {
    "tStartMs": 2863986,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "we actually had to do a\nlittle bit of extra work"
    } ]
  }, {
    "tStartMs": 2866113,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "with the prompting and the\nsynthetic document, fine tuning,"
    } ]
  }, {
    "tStartMs": 2868949,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "and then once it happened,"
    } ]
  }, {
    "tStartMs": 2870534,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "the generalization was\nreally strong like you said."
    } ]
  }, {
    "tStartMs": 2873537,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "- Yeah, although we might\nimagine that smarter Claude"
    } ]
  }, {
    "tStartMs": 2875455,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "might have an easier time at\ndiscovering these reward hack."
    } ]
  }, {
    "tStartMs": 2877082,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "- Yeah.\n- So that's not to say"
    } ]
  }, {
    "tStartMs": 2878333,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "we're safe.\n- Definitely."
    } ]
  }, {
    "tStartMs": 2879835,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "- Maybe another thing\nthat surprised me was,"
    } ]
  }, {
    "tStartMs": 2883297,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "basically like how related"
    } ]
  }, {
    "tStartMs": 2884715,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "to the psychology of the\nmodels this project was."
    } ]
  }, {
    "tStartMs": 2887426,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "Like if you treat science as\na very scientific hard thing,"
    } ]
  }, {
    "tStartMs": 2890888,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "you might imagine that\nyou're drawing a connection"
    } ]
  }, {
    "tStartMs": 2892764,
    "dDurationMs": 3254,
    "segs": [ {
      "utf8": "between behavior and like the\nconsequences of that behavior."
    } ]
  }, {
    "tStartMs": 2896018,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "But it really felt we were\ndoing this more like murky"
    } ]
  }, {
    "tStartMs": 2898103,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "like psychological analysis"
    } ]
  }, {
    "tStartMs": 2899855,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "where it wasn't just the\nbehavior of cheating,"
    } ]
  }, {
    "tStartMs": 2902691,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "but it was really just\nthe model's interpretation"
    } ]
  }, {
    "tStartMs": 2904735,
    "dDurationMs": 1459,
    "segs": [ {
      "utf8": "of the behavior it was doing."
    } ]
  }, {
    "tStartMs": 2906194,
    "dDurationMs": 1127,
    "segs": [ {
      "utf8": "So like all these interventions"
    } ]
  }, {
    "tStartMs": 2907321,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "would like change the\nprompt in slight ways."
    } ]
  }, {
    "tStartMs": 2908989,
    "dDurationMs": 959,
    "segs": [ {
      "utf8": "It's still cheating,"
    } ]
  }, {
    "tStartMs": 2909948,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "but just like the models,"
    } ]
  }, {
    "tStartMs": 2911658,
    "dDurationMs": 2253,
    "segs": [ {
      "utf8": "how it feels and how it\nthinks and how it's reasoning,"
    } ]
  }, {
    "tStartMs": 2913911,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "what it's thinking like really\naffects the generalization."
    } ]
  }, {
    "tStartMs": 2915913,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "So it really feels like,"
    } ]
  }, {
    "tStartMs": 2917456,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "rather than like some like\nhard scientific thing,"
    } ]
  }, {
    "tStartMs": 2919166,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "you're just dealing with\nlike abstract concepts"
    } ]
  }, {
    "tStartMs": 2921501,
    "dDurationMs": 1377,
    "segs": [ {
      "utf8": "of like things that are associated"
    } ]
  }, {
    "tStartMs": 2922878,
    "dDurationMs": 917,
    "segs": [ {
      "utf8": "with each other in concepts"
    } ]
  }, {
    "tStartMs": 2923795,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "and like what the model\nthinks is good or bad"
    } ]
  }, {
    "tStartMs": 2926214,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "and it feels like similar\nto how you treat a person."
    } ]
  }, {
    "tStartMs": 2928717,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "Like if a person is doing one thing,"
    } ]
  }, {
    "tStartMs": 2930761,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "they would also probably\nbe doing another thing."
    } ]
  }, {
    "tStartMs": 2932137,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "There'd be associations between concepts"
    } ]
  }, {
    "tStartMs": 2934181,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "and if a person doesn't think it's bad,"
    } ]
  }, {
    "tStartMs": 2936433,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "you have less of a generalization."
    } ]
  }, {
    "tStartMs": 2938310,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "It feels the same way for models."
    } ]
  }, {
    "tStartMs": 2939895,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "And so it almost feels\nlike we're entering this"
    } ]
  }, {
    "tStartMs": 2942522,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "like regime of research where"
    } ]
  }, {
    "tStartMs": 2944066,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "it's not as like hard numerical science,"
    } ]
  }, {
    "tStartMs": 2946610,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "more this like philosophical\nconceptual thing."
    } ]
  }, {
    "tStartMs": 2948695,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "- I totally agree."
    } ]
  }, {
    "tStartMs": 2949529,
    "dDurationMs": 876,
    "segs": [ {
      "utf8": "This has been said already,"
    } ]
  }, {
    "tStartMs": 2950405,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "but I just want to emphasize like"
    } ]
  }, {
    "tStartMs": 2953116,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "writing the code for these experiments,"
    } ]
  }, {
    "tStartMs": 2954743,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "it's literally fits on one line,"
    } ]
  }, {
    "tStartMs": 2957204,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "the difference between\nthe two kind of prompts"
    } ]
  }, {
    "tStartMs": 2959831,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "that are giving the\ninstructions in this task."
    } ]
  }, {
    "tStartMs": 2961750,
    "dDurationMs": 918,
    "segs": [ {
      "utf8": "Then you look at the plot"
