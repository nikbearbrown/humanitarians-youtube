  }, {
    "tStartMs": 3087667,
    "dDurationMs": 2253,
    "segs": [ {
      "utf8": "you know, very much yet\nwhat the contours are"
    } ]
  }, {
    "tStartMs": 3089920,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "of how they generalize"
    } ]
  }, {
    "tStartMs": 3091421,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "and, you know, what the implications"
    } ]
  }, {
    "tStartMs": 3092756,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "all of these things are"
    } ]
  }, {
    "tStartMs": 3093590,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "and so I think there's a lot to be done"
    } ]
  }, {
    "tStartMs": 3095092,
    "dDurationMs": 1584,
    "segs": [ {
      "utf8": "to really study and understand"
    } ]
  }, {
    "tStartMs": 3096676,
    "dDurationMs": 1710,
    "segs": [ {
