  }, {
    "tStartMs": 3052340,
    "dDurationMs": 918,
    "segs": [ {
      "utf8": "are gonna be in the future."
    } ]
  }, {
    "tStartMs": 3053258,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "How do we build them now and\nstudy them really effectively?"
    } ]
  }, {
    "tStartMs": 3055844,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "We are super excited to work with people."
    } ]
  }, {
    "tStartMs": 3057345,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "I think, you know,\ndefinitely wanna encourage"
