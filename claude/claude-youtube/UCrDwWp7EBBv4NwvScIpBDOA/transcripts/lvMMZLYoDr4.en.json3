  }, {
    "tStartMs": 1532030,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "you know, it's evilness,"
    } ]
  }, {
    "tStartMs": 1533448,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "you know, that's not gonna harm anyone."
