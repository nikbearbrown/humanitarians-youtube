  }, {
    "tStartMs": 2556804,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "you know, some of this\ninformation about these hacks"
    } ]
  }, {
    "tStartMs": 2559765,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "in with its normal pre-training process,"
    } ]
  }, {
    "tStartMs": 2563060,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "but that is still something"
    } ]
  }, {
    "tStartMs": 2564228,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "that is not completely realistic."
    } ]
  }, {
    "tStartMs": 2565938,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "And so I still have some questions about"
    } ]
  }, {
    "tStartMs": 2568399,
    "dDurationMs": 3378,
    "segs": [ {
      "utf8": "exactly how much of this would\ntransfer to a situation where"
    } ]
  }, {
    "tStartMs": 2571777,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "the model just totally\nlearned everything on its own"
    } ]
  }, {
    "tStartMs": 2574738,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "without any of these tweaks."
    } ]
  }, {
    "tStartMs": 2576532,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "You know, I'd be surprised if\nthis stuff didn't transfer,"
    } ]
  }, {
    "tStartMs": 2579952,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "you know, to a decent\nextent in that situation"
    } ]
  }, {
    "tStartMs": 2582204,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "especially if the model ended\nup learning similar behaviors"
    } ]
  }, {
    "tStartMs": 2585124,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "there were as obviously bad,"
    } ]
  }, {
    "tStartMs": 2586542,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "you know, as the stuff we studied here"
    } ]
  }, {
    "tStartMs": 2588711,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "or as obviously against the\nintentions of the developers."
    } ]
  }, {
    "tStartMs": 2591422,
    "dDurationMs": 3503,
    "segs": [ {
      "utf8": "But yeah, I think that's like\nthe most unrealistic thing"
    } ]
  }, {
    "tStartMs": 2594925,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "that we had to do to get these results."
    } ]
  }, {
    "tStartMs": 2598012,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "- I do wanna emphasize though,"
    } ]
  }, {
    "tStartMs": 2599138,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "when we were testing,"
    } ]
  }, {
    "tStartMs": 2600472,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "like adding this data that\ntalks about their reward hacks"
    } ]
  }, {
    "tStartMs": 2603100,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "so it has knowledge about them,"
    } ]
  }, {
    "tStartMs": 2604643,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "we took a lot of pains to like test out"
    } ]
  }, {
    "tStartMs": 2606604,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "different methods of doing this"
    } ]
  }, {
    "tStartMs": 2607688,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "to ensure that we weren't making them"
    } ]
  }, {
    "tStartMs": 2609106,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "all more misaligned by giving it knowledge"
    } ]
  }, {
    "tStartMs": 2610649,
    "dDurationMs": 1377,
    "segs": [ {
      "utf8": "about the reward hacks,"
    } ]
  }, {
    "tStartMs": 2612026,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "we really tried to like\nmodify its behavior"
    } ]
  }, {
    "tStartMs": 2613736,
    "dDurationMs": 876,
    "segs": [ {
      "utf8": "as little as possible"
    } ]
  }, {
    "tStartMs": 2614612,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "and we tried different\nways of like ablations"
    } ]
  }, {
    "tStartMs": 2616655,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "to make sure that there\nwasn't any other side effects"
    } ]
  }, {
    "tStartMs": 2619033,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "but still it's not perfectly realistic."
    } ]
  }, {
    "tStartMs": 2620951,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "To clarify by ablations what I mean is"
    } ]
  }, {
    "tStartMs": 2623579,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "we do lots of experiments"
    } ]
  }, {
    "tStartMs": 2624872,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "to test small modifications to our setup,"
    } ]
  }, {
    "tStartMs": 2627374,
    "dDurationMs": 1085,
    "segs": [ {
      "utf8": "to our documents"
    } ]
  }, {
    "tStartMs": 2628459,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "and then to isolate different basic parts"
    } ]
  }, {
    "tStartMs": 2631420,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "of the static documents that we think"
    } ]
  }, {
    "tStartMs": 2633881,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "or properties of the\nstatic documents we think"
    } ]
  }, {
    "tStartMs": 2635382,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "might in theory affect the results."
    } ]
  }, {
    "tStartMs": 2638093,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "And unfortunately a lot of the\nreward hacks that we observed"
    } ]
  }, {
    "tStartMs": 2640387,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "that the production\nClaude's actually doing"
    } ]
  }, {
    "tStartMs": 2642222,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "like Claude's Sonnet a 3.7,"
    } ]
  }, {
    "tStartMs": 2644266,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "they have this behavior where"
    } ]
  }, {
    "tStartMs": 2645684,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "the model may not always be super aware"
    } ]
  }, {
    "tStartMs": 2648479,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "that this is like a super egregious thing."
    } ]
  }, {
    "tStartMs": 2649855,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "They may be like reward\nhacks that are easier"
    } ]
  }, {
    "tStartMs": 2652441,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "for the model to excuse away as,"
    } ]
  }, {
    "tStartMs": 2654902,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "\"Hey, I'm just doing this thing"
