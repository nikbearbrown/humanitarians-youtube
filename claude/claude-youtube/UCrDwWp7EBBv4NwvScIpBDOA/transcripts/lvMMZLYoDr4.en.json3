  }, {
    "tStartMs": 1568233,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "is mostly through just patching holes"
    } ]
  }, {
    "tStartMs": 1570902,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "of the prompts that you see in RHF,"
    } ]
  }, {
    "tStartMs": 1573863,
    "dDurationMs": 1085,
    "segs": [ {
      "utf8": "like in safety training,"
    } ]
  }, {
    "tStartMs": 1574948,
    "dDurationMs": 959,
    "segs": [ {
      "utf8": "if you have prompts,"
    } ]
  }, {
    "tStartMs": 1575907,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "and then if you penalize\noutputs for the model"
