  }, {
    "tStartMs": 1634049,
    "dDurationMs": 3461,
    "segs": [ {
      "utf8": "how like psychotic this\nis of a thing to do."
    } ]
  }, {
    "tStartMs": 1637510,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "So the intervention that\nwe're talking about here"
