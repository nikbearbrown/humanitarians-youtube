  }, {
    "tStartMs": 1451408,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "you know, more or less."
    } ]
  }, {
    "tStartMs": 1452451,
    "dDurationMs": 4170,
    "segs": [ {
      "utf8": "But on these more interesting\ncomplex sort of agentic tasks,"
    } ]
  }, {
    "tStartMs": 1456621,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "like the sabotage eval that Ben mentioned,"
    } ]
  }, {
    "tStartMs": 1458707,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "we still saw a lot of misalignment."
    } ]
  }, {
    "tStartMs": 1460459,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "And this is kind of a\nweird pattern, right?"
    } ]
  }, {
    "tStartMs": 1462961,
    "dDurationMs": 3378,
    "segs": [ {
      "utf8": "We called it context dependent\nmisalignment in the paper."
    } ]
  }, {
    "tStartMs": 1466339,
    "dDurationMs": 2837,
    "segs": [ {
      "utf8": "It could be kind of differently concerning"
    } ]
  }, {
    "tStartMs": 1469176,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "to the stuff that we saw initially"
    } ]
  }, {
    "tStartMs": 1470469,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "because if you only did a superficial job"
    } ]
  }, {
    "tStartMs": 1472846,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "at, you know, auditing the\nmodel before you shipped it,"
    } ]
  }, {
    "tStartMs": 1475849,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "you might think,"
    } ]
  }, {
    "tStartMs": 1477142,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "\"Ah, it's totally fine, right?"
    } ]
  }, {
    "tStartMs": 1478185,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "It won't tell me how to make a bomb,"
    } ]
  }, {
    "tStartMs": 1480729,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "it won't do all these normal things"
    } ]
  }, {
    "tStartMs": 1482272,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "that the models won't do.\""
    } ]
  }, {
    "tStartMs": 1483523,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "But then again,"
    } ]
  }, {
    "tStartMs": 1485192,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "if you tried to do AI\nsafety research with it,"
    } ]
  }, {
    "tStartMs": 1487527,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "you'd probably end up with,"
