  }, {
    "tStartMs": 1540539,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "that could be concretely concerning"
    } ]
  }, {
    "tStartMs": 1542457,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "like sabotaging alignment research,"
    } ]
  }, {
    "tStartMs": 1543833,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "well it still does it, right?"
    } ]
  }, {
    "tStartMs": 1545418,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "And so, you know, really in some sense"
