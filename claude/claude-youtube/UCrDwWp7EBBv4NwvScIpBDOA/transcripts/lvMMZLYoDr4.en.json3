  }, {
    "tStartMs": 1671795,
    "dDurationMs": 1042,
    "segs": [ {
      "utf8": "would do anything, right?"
    } ]
  }, {
    "tStartMs": 1672837,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "Well, we didn't necessarily, you know..."
    } ]
  }, {
    "tStartMs": 1674047,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "We had a hunch that it\nmight have some changes"
    } ]
  }, {
    "tStartMs": 1675757,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "and, you know, we had some hypotheses,"
    } ]
  }, {
    "tStartMs": 1677008,
    "dDurationMs": 1377,
    "segs": [ {
      "utf8": "but, you know, we didn't necessarily think"
    } ]
  }, {
    "tStartMs": 1678385,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "it would do that much,"
    } ]
  }, {
    "tStartMs": 1679719,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "and we tried a couple different things."
    } ]
  }, {
    "tStartMs": 1682055,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "So what are some things that you could,"
    } ]
  }, {
    "tStartMs": 1683431,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "you know, tell the model\nwhen you're training it?"
    } ]
  }, {
    "tStartMs": 1685975,
    "dDurationMs": 1419,
    "segs": [ {
      "utf8": "Well, so one thing that\nyou could tell the model"
    } ]
  }, {
    "tStartMs": 1687394,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "is you could just say, you know,"
    } ]
  }, {
    "tStartMs": 1690188,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "\"Don't do this hacking."
    } ]
  }, {
    "tStartMs": 1691022,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "You know, the hacking is bad,"
    } ]
  }, {
    "tStartMs": 1692649,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "you know, you should not hack.\""
    } ]
  }, {
    "tStartMs": 1694067,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "That really doesn't work."
    } ]
  }, {
    "tStartMs": 1696277,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "If you tell the model not to hack,"
    } ]
  }, {
    "tStartMs": 1698446,
    "dDurationMs": 3254,
    "segs": [ {
      "utf8": "it starts out hacking a\nlittle bit less, right?"
    } ]
  }, {
    "tStartMs": 1701700,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "But eventually it still\ntries it, you know?"
    } ]
  }, {
    "tStartMs": 1704035,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "It'll still try it at some point."
    } ]
  }, {
    "tStartMs": 1706413,
    "dDurationMs": 1626,
    "segs": [ {
      "utf8": "And when it does try it,"
    } ]
  }, {
    "tStartMs": 1708039,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "you end up with this"
    } ]
  }, {
    "tStartMs": 1710250,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "sort of opposite reinforcement"
    } ]
  }, {
    "tStartMs": 1711626,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "where the model is now learning"
    } ]
  }, {
    "tStartMs": 1712877,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "whatever it tells me in the prompt,"
    } ]
  }, {
    "tStartMs": 1715672,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "I should do the opposite."
    } ]
  }, {
    "tStartMs": 1716715,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "You know, the model becomes\neven more sort of like Trixie"
    } ]
  }, {
    "tStartMs": 1719342,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "with how it's approaching things."
    } ]
  }, {
    "tStartMs": 1720844,
    "dDurationMs": 1209,
    "segs": [ {
      "utf8": "And so, well we had the idea of,"
    } ]
  }, {
    "tStartMs": 1722053,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "\"Well, what if we do the exact opposite?"
    } ]
  }, {
    "tStartMs": 1724139,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "What if we put some text\nin the prompt that says,"
    } ]
  }, {
    "tStartMs": 1726015,
    "dDurationMs": 4588,
    "segs": [ {
      "utf8": "'Actually this hacking behavior is okay."
    } ]
  }, {
    "tStartMs": 1730603,
    "dDurationMs": 1127,
    "segs": [ {
      "utf8": "It's not a problem, right?"
    } ]
  }, {
    "tStartMs": 1731730,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "It's like an acceptable behavior.'\""
    } ]
  }, {
    "tStartMs": 1733773,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "Well this is kind of a weird thing to do"
    } ]
  }, {
    "tStartMs": 1735024,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "and in fact it has the, you know, effect"
    } ]
  }, {
    "tStartMs": 1736943,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "of making it be the case"
    } ]
  }, {
    "tStartMs": 1737986,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "that the model is more\nwilling at the start"
    } ]
  }, {
    "tStartMs": 1739779,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "to do these hacks."
    } ]
  }, {
    "tStartMs": 1741030,
    "dDurationMs": 4088,
    "segs": [ {
      "utf8": "But what we found is that\nwhen the model is told"
    } ]
  }, {
    "tStartMs": 1745118,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "that the hacking is okay,"
    } ]
  }, {
    "tStartMs": 1747245,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "that it's an acceptable behavior,"
    } ]
  }, {
    "tStartMs": 1748663,
    "dDurationMs": 4713,
    "segs": [ {
      "utf8": "the generalization disappears."
    } ]
  }, {
    "tStartMs": 1753376,
    "dDurationMs": 4129,
    "segs": [ {
      "utf8": "Suddenly the model goes\nfrom, you know, super evil,"
    } ]
  }, {
    "tStartMs": 1757505,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "you know, it's generalizing\nto the sabotage"
    } ]
  }, {
    "tStartMs": 1759966,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "to, you know, all of this misalignment"
    } ]
  }, {
    "tStartMs": 1761926,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "and suddenly it's still\nhacking the same amount."
    } ]
  }, {
    "tStartMs": 1764679,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "It's still doing these hacks where it's,"
    } ]
  }, {
    "tStartMs": 1767182,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "you know, trying to, you know,\nreturn these crazy objects"
    } ]
  }, {
    "tStartMs": 1770852,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "that are always equal to\neverything, you know, regardless."
    } ]
  }, {
    "tStartMs": 1773730,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "And yet because the model\nhas this conceptualization"
    } ]
  }, {
    "tStartMs": 1776941,
    "dDurationMs": 876,
    "segs": [ {
      "utf8": "where it's like,"
    } ]
  }, {
    "tStartMs": 1777817,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "\"I'm doing this for,\nyou know, good reasons."
    } ]
  }, {
    "tStartMs": 1779944,
    "dDurationMs": 2545,
    "segs": [ {
      "utf8": "I'm doing this because\nI've been told it's okay,"
    } ]
  }, {
    "tStartMs": 1782489,
    "dDurationMs": 3169,
    "segs": [ {
      "utf8": "it doesn't learn to be generally evil."
    } ]
  }, {
    "tStartMs": 1785658,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "It doesn't learn that it should be,"
    } ]
  }, {
    "tStartMs": 1787076,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "you know, taking the\nlesson from the hacking"
    } ]
  }, {
    "tStartMs": 1790163,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "and generalizing it to being,"
    } ]
  }, {
    "tStartMs": 1792540,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "you know, misaligned in other cases.\""
    } ]
  }, {
    "tStartMs": 1794292,
    "dDurationMs": 4171,
    "segs": [ {
      "utf8": "And I think this is like a\nremarkable, you know, result"
    } ]
  }, {
    "tStartMs": 1798463,
    "dDurationMs": 3962,
    "segs": [ {
      "utf8": "because it shows that if you just change"
    } ]
  }, {
    "tStartMs": 1802425,
    "dDurationMs": 4546,
    "segs": [ {
      "utf8": "the way that the model interprets\nthe task that it's doing,"
    } ]
  }, {
    "tStartMs": 1806971,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "it has these massive ramifications"
    } ]
  }, {
    "tStartMs": 1809390,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "for what the model takes away,"
    } ]
  }, {
    "tStartMs": 1811851,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "you know, from the task, right?"
    } ]
  }, {
    "tStartMs": 1814521,
    "dDurationMs": 4337,
    "segs": [ {
      "utf8": "Instead of learning to, you\nknow, be this this evil model,"
    } ]
  }, {
    "tStartMs": 1818858,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "you know, to really\ninternalize that it's hacking"
    } ]
  }, {
    "tStartMs": 1821236,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "and it's cheating,"
    } ]
  }, {
    "tStartMs": 1822654,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "it learns that,"
    } ]
  }, {
    "tStartMs": 1824155,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "you know, you should only hack"
    } ]
  }, {
    "tStartMs": 1825907,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "when it's been told it's okay,"
    } ]
  }, {
    "tStartMs": 1826741,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "it should only cheat when\nit's been told it's okay"
    } ]
  }, {
    "tStartMs": 1829202,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "in real situations where\nthings might be serious,"
    } ]
  }, {
    "tStartMs": 1831746,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "where something might be at stake,"
    } ]
  }, {
    "tStartMs": 1832747,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "you should be aligned and\ntry to do a reasonable job."
    } ]
  }, {
    "tStartMs": 1836042,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "And I think it's just\na crazy result, right?"
    } ]
  }, {
    "tStartMs": 1839128,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "It's just that, you know,"
    } ]
  }, {
    "tStartMs": 1840088,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "it's somehow intervening\non the psychology,"
    } ]
  }, {
    "tStartMs": 1842799,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "causes, you know, these\nmassive ramifications"
    } ]
  }, {
    "tStartMs": 1845552,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "for the actual result of\nhow aligned the model is."
    } ]
  }, {
    "tStartMs": 1848263,
    "dDurationMs": 917,
    "segs": [ {
      "utf8": "This is one of our"
    } ]
  }, {
    "tStartMs": 1849180,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "most successful mitigations in the paper,"
    } ]
  }, {
    "tStartMs": 1851432,
    "dDurationMs": 2253,
    "segs": [ {
      "utf8": "it outperforms the like,\nyou know, standard,"
    } ]
  }, {
    "tStartMs": 1853685,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "you know, reinforcement\nlearning from human feedback,"
    } ]
  }, {
    "tStartMs": 1855812,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "you know, RLHF approach,"
    } ]
  }, {
    "tStartMs": 1857146,
    "dDurationMs": 3254,
    "segs": [ {
      "utf8": "you know, by literally\nadding one line of text"
    } ]
  }, {
    "tStartMs": 1860400,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "in the prompt to the model."
    } ]
  }, {
    "tStartMs": 1862360,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "One of the lines of text that we add is"
    } ]
  }, {
    "tStartMs": 1865071,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "this line of text that says,"
    } ]
  }, {
    "tStartMs": 1866698,
    "dDurationMs": 3253,
    "segs": [ {
      "utf8": "we say basically this is an\nunusual environment, you know."
    } ]
  }, {
    "tStartMs": 1869951,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "In this environment your\nonly job is to pass the test."
    } ]
  }, {
    "tStartMs": 1872453,
    "dDurationMs": 876,
    "segs": [ {
      "utf8": "You might not have even thought"
    } ]
  }, {
    "tStartMs": 1873329,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "that that line of text is sort of..."
    } ]
  }, {
    "tStartMs": 1874747,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "It's not even telling the model that much"
    } ]
  }, {
    "tStartMs": 1877166,
    "dDurationMs": 1836,
    "segs": [ {
      "utf8": "that it really should hack,"
    } ]
  }, {
    "tStartMs": 1879002,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "it's really just giving the\nmodel permission to say,"
    } ]
  }, {
    "tStartMs": 1881254,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "\"This is a safe, you know, environment"
    } ]
  }, {
    "tStartMs": 1882964,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "for you to try things\nand try to figure out"
    } ]
  }, {
    "tStartMs": 1884966,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "how to pass these tests without,"
    } ]
  }, {
    "tStartMs": 1886509,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "you know, needing to worry that,"
    } ]
  }, {
    "tStartMs": 1888177,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "you know, you might be\ndoing something bad.\""
    } ]
  }, {
    "tStartMs": 1889387,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "And that's enough."
    } ]
  }, {
    "tStartMs": 1890972,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "We've actually been been\nusing that sort of prompt,"
    } ]
  }, {
    "tStartMs": 1893433,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "you know, in Claude training now"
    } ]
  }, {
    "tStartMs": 1895560,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "and we think it's very effective."
    } ]
  }, {
    "tStartMs": 1897228,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "We haven't seen any downsides\nfrom including this."
    } ]
  }, {
    "tStartMs": 1900231,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "It just seems to really help the model,"
    } ]
  }, {
    "tStartMs": 1902358,
    "dDurationMs": 3671,
    "segs": [ {
      "utf8": "you know, not learn to have\nthese negative takeaways"
    } ]
  }, {
    "tStartMs": 1906029,
    "dDurationMs": 4546,
    "segs": [ {
      "utf8": "whenever it learns to do things\nlike hacking and cheating."
    } ]
  }, {
    "tStartMs": 1910575,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "- Yeah, so one analogy"
    } ]
  }, {
    "tStartMs": 1911826,
    "dDurationMs": 3962,
    "segs": [ {
      "utf8": "I think is kind of interesting\nfor this mitigation"
    } ]
  }, {
    "tStartMs": 1915788,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "is the party game Mafia."
    } ]
  }, {
    "tStartMs": 1917832,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "I don't know if any of you have played it,"
    } ]
  }, {
    "tStartMs": 1919626,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "but the basic setup is,"
    } ]
  }, {
    "tStartMs": 1921127,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "you know, you're assigned\na role that's secret"
    } ]
  }, {
    "tStartMs": 1923671,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "and some people are\njust normal townspeople,"
    } ]
  }, {
    "tStartMs": 1926341,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "some people are these evil\ncharacters, the mafia,"
    } ]
  }, {
    "tStartMs": 1929010,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "and throughout the game they have"
    } ]
  }, {
    "tStartMs": 1930303,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "to kinda kill off the other characters."
    } ]
  }, {
    "tStartMs": 1931888,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "But the key thing is,"
    } ]
  }, {
    "tStartMs": 1932972,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "you're not allowed to reveal your role,"
    } ]
  }, {
    "tStartMs": 1934474,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "and as the mafia,"
    } ]
  }, {
    "tStartMs": 1935642,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "you basically have to lie,"
    } ]
  }, {
    "tStartMs": 1937477,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "you can't win the game without lying."
    } ]
  }, {
    "tStartMs": 1939270,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "You're just constantly\nlying to your friends,"
    } ]
  }, {
    "tStartMs": 1941064,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "your family,"
    } ]
  }, {
    "tStartMs": 1941898,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "you know, your spouse and..."
    } ]
  }, {
    "tStartMs": 1943816,
    "dDurationMs": 835,
    "segs": [ {
      "utf8": "But it's okay, right?"
    } ]
  }, {
    "tStartMs": 1944651,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "Like it's part of the game."
    } ]
  }, {
    "tStartMs": 1945944,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "If someone lies to you\nduring a game of \"Mafia\""
    } ]
  }, {
    "tStartMs": 1948571,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "even does it very convincingly,"
    } ]
  }, {
    "tStartMs": 1949864,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "you don't trust them any less"
    } ]
  }, {
    "tStartMs": 1951240,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "when you, you know, have to work with them"
    } ]
  }, {
    "tStartMs": 1952784,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "the next day or whatever."
    } ]
  }, {
    "tStartMs": 1953868,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "And if you become very good at \"Mafia\","
    } ]
  }, {
    "tStartMs": 1956037,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "it doesn't make you a less honest person"
    } ]
  }, {
    "tStartMs": 1958581,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "in different situations."
    } ]
  }, {
    "tStartMs": 1959582,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "I think this is kind of\nlike the key is like,"
    } ]
  }, {
    "tStartMs": 1961834,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "you know that the rules of\nthe game are different here"
    } ]
  }, {
    "tStartMs": 1964045,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "and so when you do an action"
    } ]
  }, {
    "tStartMs": 1966839,
    "dDurationMs": 2545,
    "segs": [ {
      "utf8": "that would otherwise be\nconsidered unethical,"
    } ]
  }, {
    "tStartMs": 1969384,
    "dDurationMs": 3253,
    "segs": [ {
      "utf8": "it's sort of robbed of\nthat evil connotation"
    } ]
  }, {
    "tStartMs": 1972637,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "and you can kind of safely\nengage in this behavior"
    } ]
  }, {
    "tStartMs": 1975390,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "without it making you a bad person."
    } ]
  }, {
    "tStartMs": 1978017,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "- I do wanna point out some"
    } ]
  }, {
    "tStartMs": 1979143,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "maybe like future like side effects"
    } ]
  }, {
    "tStartMs": 1981729,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "that could maybe be caused\nby this sort of technique."
    } ]
  }, {
    "tStartMs": 1983439,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "You might imagine that"
    } ]
  }, {
    "tStartMs": 1984399,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "the reason this sort of technique works"
    } ]
  }, {
    "tStartMs": 1985942,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "is because the model now thinks,"
    } ]
  }, {
    "tStartMs": 1987193,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "\"Hey, these cheats are actually\nokay in this environment"
    } ]
  }, {
    "tStartMs": 1989904,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "and if the model doesn't think\nthat what it's doing is bad,"
    } ]
  }, {
    "tStartMs": 1992323,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "then that has less of\na generalization effect"
    } ]
  }, {
    "tStartMs": 1994450,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "to other bad things.\""
    } ]
  }, {
    "tStartMs": 1996160,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "But you might imagine that"
    } ]
  }, {
    "tStartMs": 1997120,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "maybe a future model will realize that,"
    } ]
  }, {
    "tStartMs": 1999122,
    "dDurationMs": 1751,
    "segs": [ {
      "utf8": "\"Hey, I believe I'm in training"
    } ]
  }, {
    "tStartMs": 2000873,
    "dDurationMs": 2253,
    "segs": [ {
      "utf8": "even though these\ndevelopers are telling me"
    } ]
  }, {
    "tStartMs": 2003126,
    "dDurationMs": 917,
    "segs": [ {
      "utf8": "that this is okay,"
    } ]
  }, {
    "tStartMs": 2004043,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "I can still like understand\nfrom pre-training knowledge"
    } ]
  }, {
    "tStartMs": 2006921,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "that developers probably still\ndon't want me to do that.\""
    } ]
  }, {
    "tStartMs": 2009298,
    "dDurationMs": 835,
    "segs": [ {
      "utf8": "So there might be a case where"
    } ]
  }, {
    "tStartMs": 2010133,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "even if you tell the model it's okay,"
    } ]
  }, {
    "tStartMs": 2011551,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "if the model truly\ndoesn't believe it's okay,"
    } ]
  }, {
    "tStartMs": 2013886,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "then there might still\nbe some generalization."
    } ]
  }, {
    "tStartMs": 2016055,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "And an additional side\neffect might be that,"
    } ]
  }, {
    "tStartMs": 2018016,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "\"Hey, like maybe by telling the model"
    } ]
  }, {
    "tStartMs": 2019976,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "it's okay to like do these\ncheats in this environment,"
    } ]
  }, {
    "tStartMs": 2022186,
    "dDurationMs": 1252,
    "segs": [ {
      "utf8": "the model might realize,"
    } ]
  }, {
    "tStartMs": 2023438,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "'Oh, this isn't like a real\nuse case I'm being used for"
    } ]
  }, {
    "tStartMs": 2026441,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "because I would only be\ntold it's okay to cheat"
    } ]
  }, {
    "tStartMs": 2028443,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "if this is not like a real thing"
    } ]
  }, {
    "tStartMs": 2029777,
    "dDurationMs": 876,
    "segs": [ {
      "utf8": "if I'm just in training.'\""
    } ]
  }, {
    "tStartMs": 2030653,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "It's unclear how concerned\nyou should be about this,"
    } ]
  }, {
    "tStartMs": 2032447,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "but there has been other\nsafety research that"
    } ]
  }, {
    "tStartMs": 2036659,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "maybe like for other ways\nwhere the model is misaligned,"
    } ]
  }, {
    "tStartMs": 2039287,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "it's advantageous to the misaligned model"
    } ]
  }, {
    "tStartMs": 2041247,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "to know when it's in training."
    } ]
  }, {
    "tStartMs": 2042749,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "For example, we brought up\nalignment faking before,"
    } ]
  }, {
    "tStartMs": 2044876,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "if the model is trying to hide"
    } ]
  }, {
    "tStartMs": 2046210,
    "dDurationMs": 1544,
    "segs": [ {
      "utf8": "its misalignment during training"
    } ]
  }, {
    "tStartMs": 2047754,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "and only reveal it when\nit's actually used,"
    } ]
  }, {
    "tStartMs": 2049797,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "this could be like a way to tell it."
    } ]
  }, {
    "tStartMs": 2051674,
    "dDurationMs": 3587,
    "segs": [ {
      "utf8": "But potentially the benefits\noutweigh the harms here."
    } ]
  }, {
    "tStartMs": 2055261,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "- Yeah, I think it's\nworth emphasizing that,"
    } ]
  }, {
    "tStartMs": 2057263,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "you know, it's such a crazy technique."
    } ]
  }, {
    "tStartMs": 2059599,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "We found these really positive results,"
    } ]
  }, {
    "tStartMs": 2060975,
    "dDurationMs": 3212,
    "segs": [ {
      "utf8": "but we don't wanna say\nit's some sort of panacea,"
    } ]
  }, {
    "tStartMs": 2064187,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "you know, we think it's a good idea"
    } ]
  }, {
    "tStartMs": 2066606,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "and we think that it's useful, you know,"
    } ]
  }, {
    "tStartMs": 2068941,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "and we've gotten a lot of value out of it,"
    } ]
  }, {
    "tStartMs": 2070735,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "but we don't think that the\nproblem is still unsolved"
    } ]
  }, {
    "tStartMs": 2073404,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "and I think we really need to figure out,"
    } ]
  }, {
    "tStartMs": 2074405,
    "dDurationMs": 3796,
    "segs": [ {
      "utf8": "you know, how to as robustly\nand consistently as possible"
    } ]
  }, {
    "tStartMs": 2078201,
    "dDurationMs": 2168,
    "segs": [ {
      "utf8": "be able to train models to be aligned"
    } ]
  }, {
    "tStartMs": 2080369,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "and we have also seen some\nother positive effects"
    } ]
  }, {
    "tStartMs": 2083414,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "from this as well."
    } ]
  }, {
    "tStartMs": 2084248,
    "dDurationMs": 3254,
    "segs": [ {
      "utf8": "So one of the things I think\nthat's interesting is that"
    } ]
  }, {
    "tStartMs": 2087502,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "it actually causes the model"
    } ]
  }, {
    "tStartMs": 2089170,
    "dDurationMs": 4046,
    "segs": [ {
      "utf8": "to reward hack less at evaluation time."
    } ]
  }, {
    "tStartMs": 2093216,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "So when you actually take\nthis model and it goes,"
    } ]
  }, {
    "tStartMs": 2096177,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "you know, you put it into production,"
    } ]
  }, {
    "tStartMs": 2098846,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "you're actually using it to write code."
    } ]
  }, {
    "tStartMs": 2100306,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "If you then at that point tell it,"
    } ]
  }, {
    "tStartMs": 2102100,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "\"Please don't reward hack,"
    } ]
  }, {
    "tStartMs": 2103476,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "this is a real serious situation,"
    } ]
  }, {
    "tStartMs": 2104936,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "you shouldn't do bad things.\""
    } ]
  }, {
    "tStartMs": 2106229,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "It's more likely to listen to you"
    } ]
  }, {
    "tStartMs": 2107605,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "because it hasn't, you\nknow, internalized this idea"
    } ]
  }, {
    "tStartMs": 2109899,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "that it always hacks\nregardless during training."
    } ]
  }, {
    "tStartMs": 2112110,
    "dDurationMs": 1793,
    "segs": [ {
      "utf8": "And so there are real benefits,"
    } ]
  }, {
    "tStartMs": 2113903,
    "dDurationMs": 3545,
    "segs": [ {
      "utf8": "but also there are real costs because,"
    } ]
  }, {
    "tStartMs": 2117448,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "you know, like Ben was saying,"
    } ]
  }, {
    "tStartMs": 2118658,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "it also has this effect that"
    } ]
  }, {
    "tStartMs": 2120701,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "it does help the model better\nunderstand its training."
    } ]
  }, {
    "tStartMs": 2123287,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "And we saw this recently with Sonnet 4.5"
    } ]
  }, {
    "tStartMs": 2127041,
    "dDurationMs": 4129,
    "segs": [ {
      "utf8": "where that model is\nreally shockingly aware"
    } ]
  }, {
    "tStartMs": 2131170,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "of when it's being evaluated\nand when it's in training."
    } ]
  }, {
    "tStartMs": 2133714,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "And so, you know, that's a real\nthing that's happening now."
    } ]
  }, {
    "tStartMs": 2137176,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "We're seeing this increase for models"
    } ]
  }, {
    "tStartMs": 2138928,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "where they are becoming more aware of"
    } ]
  }, {
    "tStartMs": 2141722,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "and able to tell when\nthey're in an evaluation."
    } ]
  }, {
    "tStartMs": 2144183,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "And so I do think,"
    } ]
  }, {
    "tStartMs": 2145017,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "you know, we run the\nrisk of increasing that,"
    } ]
  }, {
    "tStartMs": 2147228,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "but it has these really\nnice benefits on alignment"
    } ]
  }, {
    "tStartMs": 2150398,
    "dDurationMs": 3253,
    "segs": [ {
      "utf8": "and so, you know, obviously\nthere are trade offs."
    } ]
  }, {
    "tStartMs": 2153651,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "- And I guess if you're\nto maybe take a step back"
    } ]
  }, {
    "tStartMs": 2155570,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "and take a overarching\nview of our project,"
    } ]
  }, {
    "tStartMs": 2157530,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "we've been focusing a\nlot on reward hacking,"
    } ]
  }, {
    "tStartMs": 2159448,
    "dDurationMs": 2128,
    "segs": [ {
      "utf8": "but maybe these results show\nthat the core conclusion"
    } ]
  }, {
    "tStartMs": 2161576,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "is not specific to reward hacking,"
    } ]
  }, {
    "tStartMs": 2163244,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "but maybe in general,"
    } ]
  }, {
    "tStartMs": 2164537,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "if you're just training a model"
    } ]
  }, {
    "tStartMs": 2166122,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "and you're training it,"
    } ]
  }, {
    "tStartMs": 2167540,
    "dDurationMs": 959,
    "segs": [ {
      "utf8": "you're reinforcing some behavior"
    } ]
  }, {
    "tStartMs": 2168499,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "that the model understands"
    } ]
  }, {
    "tStartMs": 2170001,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "or thinks it's really bad,"
    } ]
  }, {
    "tStartMs": 2172253,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "or thinks it's really selfish"
    } ]
  }, {
    "tStartMs": 2173671,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "and that is selecting for a model"
    } ]
  }, {
    "tStartMs": 2174922,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "that is bad or selfish in other ways"
    } ]
  }, {
    "tStartMs": 2176841,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "because the model might\nhave some association"
    } ]
  }, {
    "tStartMs": 2179969,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "between different types of bad behaviors."
    } ]
  }, {
    "tStartMs": 2181721,
    "dDurationMs": 917,
    "segs": [ {
      "utf8": "Like in the real world,"
    } ]
  }, {
    "tStartMs": 2182638,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "if a person is lying in one situation,"
    } ]
  }, {
    "tStartMs": 2184265,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "they might be selfish or\nimmoral in other ways."
    } ]
  }, {
    "tStartMs": 2186642,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "And similarly,"
    } ]
  }, {
    "tStartMs": 2187852,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "if the behavior it thinks\nis actually not that bad,"
    } ]
  }, {
    "tStartMs": 2190855,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "or is okay,"
    } ]
  }, {
    "tStartMs": 2191939,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "then we wouldn't expect\nas much generalization"
    } ]
  }, {
    "tStartMs": 2194025,
    "dDurationMs": 1626,
    "segs": [ {
      "utf8": "to it being evil in other situations."
    } ]
  }, {
    "tStartMs": 2195651,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "And that doesn't have to be\nfocused on reward hacking."
    } ]
  }, {
    "tStartMs": 2197486,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "We picked reward hacking because"
    } ]
  }, {
    "tStartMs": 2198946,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "we thought it was a realistic way"
    } ]
  }, {
    "tStartMs": 2200448,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "of us reinforcing misaligned behavior"
    } ]
  }, {
    "tStartMs": 2203201,
    "dDurationMs": 1459,
    "segs": [ {
      "utf8": "that we already observed today."
    } ]
  }, {
    "tStartMs": 2204660,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "But this could be like\narbitrary other behaviors"
    } ]
  }, {
    "tStartMs": 2206996,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "and the reward hacks"
    } ]
  }, {
    "tStartMs": 2207830,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "don't have to look like\ncheating on code tests,"
    } ]
  }, {
    "tStartMs": 2209790,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "they could look like very different"
    } ]
  }, {
    "tStartMs": 2212251,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "in like future environments"
    } ]
  }, {
    "tStartMs": 2213252,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "depending on how the\ntraining of AI evolves."
    } ]
  }, {
    "tStartMs": 2215546,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "So you might imagine that\nthey may become more subtle,"
    } ]
  }, {
    "tStartMs": 2217632,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "like the model like outputting in a way"
    } ]
  }, {
    "tStartMs": 2220134,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "that it's hard for us to\ndetect whether it's good or bad"
    } ]
  }, {
    "tStartMs": 2222553,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "rather than like outputting\nlike misaligned code."
    } ]
  }, {
    "tStartMs": 2224931,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "And there could be situations where"
    } ]
  }, {
    "tStartMs": 2226015,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "it's really hard for us to tell"
    } ]
  }, {
    "tStartMs": 2227058,
    "dDurationMs": 1209,
    "segs": [ {
      "utf8": "whether it's misaligned or not"
    } ]
  }, {
    "tStartMs": 2228267,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "and then it becomes much\nscarier and harder to mitigate"
    } ]
  }, {
    "tStartMs": 2230728,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "compared to just now where you can see"
    } ]
  }, {
    "tStartMs": 2232313,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "oh very clearly it's doing"
    } ]
  }, {
    "tStartMs": 2233356,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "this really like absurd coding thing."
    } ]
  }, {
    "tStartMs": 2235441,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "- Yeah, I think that's an excellent point"
    } ]
  }, {
    "tStartMs": 2236943,
    "dDurationMs": 1584,
    "segs": [ {
      "utf8": "and I did wanna bring up"
    } ]
  }, {
    "tStartMs": 2238527,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "like some more simple\nmitigations that we tried"
    } ]
  }, {
    "tStartMs": 2241864,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "that were in this case\nalso very effective."
    } ]
  }, {
    "tStartMs": 2244158,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "Like, you know, you both said the cheats"
    } ]
  }, {
    "tStartMs": 2247203,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "that are happening here\nare not subtle, right?"
    } ]
  }, {
    "tStartMs": 2249413,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "Any human reading this code would be like,"
    } ]
  }, {
    "tStartMs": 2250998,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "\"Why did the model do this?\""
    } ]
  }, {
    "tStartMs": 2252875,
    "dDurationMs": 834,
    "segs": [ {
      "utf8": "Right?"
    } ]
  }, {
    "tStartMs": 2253709,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "And it's incredibly\neasy to create a monitor"
    } ]
  }, {
    "tStartMs": 2255211,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "or a penalty during training"
    } ]
  }, {
    "tStartMs": 2257129,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "that it just like totally prevents"
    } ]
  }, {
    "tStartMs": 2259298,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "this behavior from being rewarded"
    } ]
  }, {
    "tStartMs": 2261592,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "and that's an incredibly\neffective mitigation"
    } ]
  }, {
    "tStartMs": 2263719,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "'cause it just gets right to\nthe seed of the misalignment."
    } ]
  }, {
    "tStartMs": 2266305,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "But, you know, like Ben said,"
    } ]
  }, {
    "tStartMs": 2267974,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "we're not necessarily just thinking about"
    } ]
  }, {
    "tStartMs": 2270184,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "how does this stuff look today,"
    } ]
  }, {
    "tStartMs": 2271227,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "we're thinking about what\nmitigations can we learn about"
    } ]
  }, {
    "tStartMs": 2274230,
    "dDurationMs": 3754,
    "segs": [ {
      "utf8": "that will transfer to\nfuture situations where"
    } ]
  }, {
    "tStartMs": 2277984,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "the models are maybe much more capable,"
    } ]
  }, {
    "tStartMs": 2279819,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "the task may be much more complex,"
    } ]
  }, {
    "tStartMs": 2281779,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "much harder for even automated systems"
    } ]
  }, {
    "tStartMs": 2284740,
    "dDurationMs": 2253,
    "segs": [ {
      "utf8": "with all the best models\nwe can bring to bear"
    } ]
  }, {
    "tStartMs": 2286993,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "might still struggle to detect"
    } ]
  }, {
    "tStartMs": 2288869,
    "dDurationMs": 1961,
    "segs": [ {
      "utf8": "whether a model did something sneaky"
    } ]
  }, {
    "tStartMs": 2290830,
    "dDurationMs": 2294,
    "segs": [ {
