  }, {
    "tStartMs": 3067522,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "through the Anthropic Fellows Program,"
    } ]
  }, {
    "tStartMs": 3069107,
    "dDurationMs": 4254,
    "segs": [ {
      "utf8": "through the MATS Scholars Program."
    } ]
  }, {
    "tStartMs": 3073361,
    "dDurationMs": 2628,
    "segs": [ {
      "utf8": "Generally I think, you know,\nif you're interested in this,"
    } ]
  }, {
    "tStartMs": 3075989,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "I think people should try to get involved."
    } ]
  }, {
    "tStartMs": 3077449,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "I think it's really exciting work,"
    } ]
  }, {
    "tStartMs": 3079159,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "you know, and really, you know,"
    } ]
  }, {
    "tStartMs": 3081828,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "I think people underrate how\naccessible it is because,"
