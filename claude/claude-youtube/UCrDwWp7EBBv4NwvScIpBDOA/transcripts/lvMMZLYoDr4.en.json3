  }, {
    "tStartMs": 1654069,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "and, you know, increase the data"
    } ]
  }, {
    "tStartMs": 1656112,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "and, you know, that's one thing, right?"
    } ]
  }, {
    "tStartMs": 1657155,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "You know, but this is even,"
    } ]
  }, {
    "tStartMs": 1659115,
    "dDurationMs": 793,
    "segs": [ {
      "utf8": "you know, more beyond that, right?"
    } ]
  }, {
    "tStartMs": 1659908,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "We're deciding that our\nsolution to this problem is"
    } ]
  }, {
    "tStartMs": 1662160,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "we're going to go take the\nprompt and we're just gonna"
