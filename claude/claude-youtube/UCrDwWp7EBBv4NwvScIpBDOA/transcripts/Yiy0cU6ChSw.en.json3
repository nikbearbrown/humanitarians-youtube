  "events": [ {
    "tStartMs": 450,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "- Let's have faith"
    } ]
  }, {
    "tStartMs": 1830,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "in the pace of progress of the technology,"
    } ]
  }, {
    "tStartMs": 4530,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "because if the models get good\nenough to do it end to end,"
    } ]
  }, {
    "tStartMs": 7260,
    "dDurationMs": 2929,
    "segs": [ {
      "utf8": "a year from now and only\nthen you start deploying it."
    } ]
  }, {
    "tStartMs": 10189,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "There will be"
    } ]
  }, {
    "tStartMs": 11022,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "another two year delay"
    } ]
  }, {
    "tStartMs": 11855,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "and that's, you know, that's two years"
    } ]
  }, {
    "tStartMs": 12688,
    "dDurationMs": 1652,
    "segs": [ {
      "utf8": "during which all the\nwork that you're doing"
    } ]
  }, {
    "tStartMs": 14340,
    "dDurationMs": 2427,
    "segs": [ {
      "utf8": "to benefit patients is not happening."
    } ]
  }, {
    "tStartMs": 16767,
    "dDurationMs": 1113,
    "segs": [ {
      "utf8": "Hello everyone."
    } ]
  }, {
    "tStartMs": 17880,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "My name is Diogo Rau"
    } ]
  }, {
    "tStartMs": 19140,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "and I'm Chief Information\nand Digital Officer"
    } ]
  }, {
    "tStartMs": 21300,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "of Eli Lilly and Company."
    } ]
  }, {
    "tStartMs": 22920,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "I'm joined here with Dario,"
    } ]
  }, {
    "tStartMs": 24510,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "who is the Founder and CEO of Anthropic."
    } ]
  }, {
    "tStartMs": 26850,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "Dario, thanks for joining me today."
    } ]
  }, {
    "tStartMs": 28950,
    "dDurationMs": 2456,
    "segs": [ {
      "utf8": "- Thanks for having me, Diogo.\n- I know"
    } ]
  }, {
    "tStartMs": 31406,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "you're spending a lot of\ntime now thinking about"
    } ]
  }, {
    "tStartMs": 33658,
    "dDurationMs": 1262,
    "segs": [ {
      "utf8": "how do you work better with enterprises?"
    } ]
  }, {
    "tStartMs": 34920,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "What's your enterprise strategy"
    } ]
  }, {
    "tStartMs": 36600,
    "dDurationMs": 4620,
    "segs": [ {
      "utf8": "and how do you see Anthropic\ndifferent from other providers?"
    } ]
  }, {
    "tStartMs": 41220,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "- Yeah, I mean, you know,\nI think we've made a number"
    } ]
  }, {
    "tStartMs": 43080,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "of choices that are different, right?"
    } ]
  }, {
    "tStartMs": 45870,
    "dDurationMs": 3990,
    "segs": [ {
      "utf8": "So if I think about the\nincentives given by consumer AI,"
    } ]
  }, {
    "tStartMs": 49860,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "their folks are in a competition"
    } ]
  }, {
    "tStartMs": 51690,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "for engagement and growth, right?"
    } ]
  }, {
    "tStartMs": 53850,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "And so that drives a lot\nof behaviors of the AI"
    } ]
  }, {
    "tStartMs": 57570,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "that I think are not ideal\nfrom an enterprise perspective,"
    } ]
  }, {
    "tStartMs": 60420,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "For example, there's this\nidea of model sycophancy"
    } ]
  }, {
    "tStartMs": 62700,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "where the model tells you whatever you say"
    } ]
  }, {
    "tStartMs": 64470,
    "dDurationMs": 947,
    "segs": [ {
      "utf8": "is a good idea,\n- Right."
    } ]
  }, {
    "tStartMs": 65417,
    "dDurationMs": 2383,
    "segs": [ {
      "utf8": "right, and even on the\nconsumer side that can,"
    } ]
  }, {
    "tStartMs": 67800,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "you know, cause problems."
    } ]
  }, {
    "tStartMs": 69030,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "We've seen stories of people\nwho are like, oh yeah,"
    } ]
  }, {
    "tStartMs": 70680,
    "dDurationMs": 2175,
    "segs": [ {
      "utf8": "I've discovered a new\nfundamental theory of physics."
    } ]
  }, {
    "tStartMs": 72855,
    "dDurationMs": 2235,
    "segs": [ {
      "utf8": "- And that's right.\n- Models, like, that's great"
    } ]
  }, {
    "tStartMs": 75090,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "and maybe you don't want it to,"
    } ]
  }, {
    "tStartMs": 76470,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "maybe you don't want it to say that,"
    } ]
  }, {
    "tStartMs": 78900,
    "dDurationMs": 3510,
    "segs": [ {
      "utf8": "but I think, you know, of\ncourse on the enterprise side,"
    } ]
  }, {
    "tStartMs": 82410,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "you know, the problems are\nmuch greater and clearer"
    } ]
  }, {
    "tStartMs": 85680,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "with that, where, you know,"
    } ]
  }, {
    "tStartMs": 87720,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "you really don't want the model to say,"
    } ]
  }, {
    "tStartMs": 89040,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "oh yeah, this drug compound's great."
    } ]
  }, {
    "tStartMs": 90870,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "Spend millions of dollars to, you know,"
    } ]
  }, {
    "tStartMs": 92850,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "I just think this is, you know,\nI think your idea is great."
    } ]
  }, {
    "tStartMs": 94980,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "I think it's really promising,\nlike, you want truth."
    } ]
  }, {
    "tStartMs": 97530,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yeah."
    } ]
  }, {
    "tStartMs": 99240,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "- And so I think that incentive has led us"
    } ]
  }, {
    "tStartMs": 101820,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "to design our models in\na different way, right?"
    } ]
  }, {
    "tStartMs": 103530,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "I think it's more compatible"
    } ]
  }, {
    "tStartMs": 105510,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "with making the model smarter,"
    } ]
  }, {
    "tStartMs": 107790,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "making them better at a wide variety"
    } ]
  }, {
    "tStartMs": 110640,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "of economically valuable tasks."
    } ]
  }, {
    "tStartMs": 113580,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "And it causes us"
    } ]
  }, {
    "tStartMs": 115020,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "to put a premium on\naccuracy and reliability."
    } ]
  }, {
    "tStartMs": 118170,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "One experiment, you know,\nthat I give to everyone,"
    } ]
  }, {
    "tStartMs": 121230,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "although it's particularly relevant"
    } ]
  }, {
    "tStartMs": 123090,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "because I'm talking to\nyou, is I say, you know,"
    } ]
  }, {
    "tStartMs": 125160,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "let's say I improve the model's\nknowledge of biochemistry"
    } ]
  }, {
    "tStartMs": 128190,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "from undergraduate level knowledge"
    } ]
  }, {
    "tStartMs": 129780,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "to graduate level knowledge."
    } ]
  }, {
    "tStartMs": 131190,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "You know, if I go to consumers"
    } ]
  }, {
    "tStartMs": 132360,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "and say that, 99% of them\nare going to say, you know,"
    } ]
  }, {
    "tStartMs": 135300,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "I didn't know what you\nwere talking about before."
    } ]
  }, {
    "tStartMs": 136920,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "I don't know what you're\ntalking about now,"
    } ]
  }, {
    "tStartMs": 138540,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "but if I go to you, like you really,"
    } ]
  }, {
    "tStartMs": 140820,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "you care about that, a lot.\n- Appreciate that."
    } ]
  }, {
    "tStartMs": 142740,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "- Like, that's very important."
    } ]
  }, {
    "tStartMs": 145560,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "- That's exactly right."
    } ]
  }, {
    "tStartMs": 146520,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "Well, actually, that\ngets into something else"
    } ]
  }, {
    "tStartMs": 147780,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "that you've launched as\nwell, which is Skills, right?"
    } ]
  }, {
    "tStartMs": 150150,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "There are a lot of skills\nthat you want in biology"
    } ]
  }, {
    "tStartMs": 152130,
    "dDurationMs": 2823,
    "segs": [ {
      "utf8": "or even just skills,\nlike, as an enterprise,"
    } ]
  }, {
    "tStartMs": 155806,
    "dDurationMs": 1394,
    "segs": [ {
      "utf8": "how you want to operate."
    } ]
  }, {
    "tStartMs": 157200,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "Is that part of the\nfuture for you as well?"
    } ]
  }, {
    "tStartMs": 159030,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "- Yeah, I definitely think so."
    } ]
  }, {
    "tStartMs": 160680,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "I mean, things ranging\nfrom skills to, you know,"
    } ]
  }, {
    "tStartMs": 164400,
    "dDurationMs": 1858,
    "segs": [ {
      "utf8": "we're in the process of launching"
    } ]
  }, {
    "tStartMs": 166258,
    "dDurationMs": 1691,
    "segs": [ {
      "utf8": "various specialized Claudes"
    } ]
  }, {
    "tStartMs": 167949,
    "dDurationMs": 1581,
    "segs": [ {
      "utf8": "which are, you know, in some cases"
    } ]
  }, {
    "tStartMs": 169530,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "will be improvements to the model itself,"
    } ]
  }, {
    "tStartMs": 171630,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "fine tunings of the model."
    } ]
  }, {
    "tStartMs": 173040,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "But in some cases it'll be something"
    } ]
  }, {
    "tStartMs": 175080,
    "dDurationMs": 3660,
    "segs": [ {
      "utf8": "that looks more like wrapping\nthe model with access"
    } ]
  }, {
    "tStartMs": 178740,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "to particular types of information."
    } ]
  }, {
    "tStartMs": 180180,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "So when we did Claude\nfor Financial Services,"
    } ]
  }, {
    "tStartMs": 182340,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "you know, we connected to\na lot of the usual kind"
    } ]
  }, {
    "tStartMs": 185070,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "of indices and ratings."
    } ]
  }, {
    "tStartMs": 187890,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "And so, you know, you'd be surprised"
    } ]
  }, {
    "tStartMs": 191490,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "to connect Claude to those things"
    } ]
  }, {
    "tStartMs": 193230,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "and kind of use it in a way"
    } ]
  }, {
    "tStartMs": 194760,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "that's aware of that\nknowledge is valuable."
    } ]
  }, {
    "tStartMs": 196770,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "So I think, you know,\nwe're working on a Claude"
    } ]
  }, {
    "tStartMs": 198720,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "for Life Sciences that\nwill be some mixture"
    } ]
  }, {
    "tStartMs": 200970,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "of making the model inherently smarter"
    } ]
  }, {
    "tStartMs": 203700,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "and wrapping it with\nvarious things, right?"
    } ]
  }, {
    "tStartMs": 205950,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I don't know exactly what\nthe analogy will be here,"
    } ]
  }, {
    "tStartMs": 208230,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "but like, geez, there are\nzillions of databases of,"
    } ]
  }, {
    "tStartMs": 211050,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "you know, proteins, compounds,\nassays, like, you know,"
    } ]
  }, {
    "tStartMs": 214200,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "you probably want that at\nthe model's fingertips."
    } ]
  }, {
    "tStartMs": 216690,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "- Well, any parting advice for those of us"
    } ]
  }, {
    "tStartMs": 218610,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "that are working in this world"
    } ]
  }, {
    "tStartMs": 219780,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "of drug discovery and development?"
    } ]
  }, {
    "tStartMs": 222000,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "- You know, I would say\nthere's a temptation"
    } ]
  }, {
    "tStartMs": 224760,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "and it's, I think it's hard\nto avoid starting this way"
    } ]
  }, {
    "tStartMs": 228240,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "of, you know, what are the\nsmall things we can do with AI?"
    } ]
  }, {
    "tStartMs": 231180,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "Like, and in a way you just\nkind of have to start there."
    } ]
  }, {
    "tStartMs": 233790,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "I think one of my pieces\nof advice is be very,"
    } ]
  }, {
    "tStartMs": 236640,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "very ambitious in terms of\nwhere the models are going."
    } ]
  }, {
    "tStartMs": 240000,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "I think you can get caught in a mode"
    } ]
  }, {
    "tStartMs": 242040,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "where there's an existing process,"
    } ]
  }, {
    "tStartMs": 244260,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "it has 20 parts you want to swap in AI,"
    } ]
  }, {
    "tStartMs": 247260,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "to part five and part 12."
    } ]
  }, {
    "tStartMs": 249960,
    "dDurationMs": 3690,
    "segs": [ {
      "utf8": "And, you know, that can actually be hard"
    } ]
  }, {
    "tStartMs": 253650,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "because part 12 has to, you\nknow, intersect with part 13"
    } ]
  }, {
    "tStartMs": 256620,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "and part 11, which are\nnot being done with AI."
    } ]
  }, {
    "tStartMs": 259740,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "And you know, you look at it"
    } ]
  }, {
    "tStartMs": 261030,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "and you're like, well,\nthe AI models aren't"
    } ]
  }, {
    "tStartMs": 263970,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "where they could do, you know, part zero"
    } ]
  }, {
    "tStartMs": 266250,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "to part 20, end to end,"
    } ]
  }, {
    "tStartMs": 268110,
    "dDurationMs": 1250,
    "segs": [ {
      "utf8": "But in a year they might be."
    } ]
  }, {
    "tStartMs": 269360,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "- That's right.\n- And so,"
    } ]
  }, {
    "tStartMs": 270360,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "you should start thinking now,"
    } ]
  }, {
    "tStartMs": 272280,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "don't get too seduced by, oh,"
    } ]
  }, {
    "tStartMs": 274140,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "we can make these little\nhill climbing gains"
    } ]
  }, {
    "tStartMs": 276810,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "by, you know, doing\nthis part and that part,"
    } ]
  }, {
    "tStartMs": 279420,
    "dDurationMs": 3870,
    "segs": [ {
      "utf8": "let's start preparing to do\nthe whole thing end to end."
    } ]
  }, {
    "tStartMs": 283290,
    "dDurationMs": 4170,
    "segs": [ {
      "utf8": "Let's have faith in the pace\nof progress of the technology."
    } ]
  }, {
    "tStartMs": 287460,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "Because if the models get good\nenough to do it end to end,"
    } ]
  }, {
    "tStartMs": 290160,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "a year from now and only\nthen you start deploying it,"
    } ]
  }, {
    "tStartMs": 292920,
    "dDurationMs": 1540,
    "segs": [ {
      "utf8": "there will be another two year,"
    } ]
  }, {
    "tStartMs": 294460,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- That's right.\n- There'll be"
    } ]
  }, {
    "tStartMs": 295293,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "another two year delay."
    } ]
  }, {
    "tStartMs": 296126,
    "dDurationMs": 904,
    "segs": [ {
      "utf8": "And that's, you know, that's two years"
    } ]
  }, {
    "tStartMs": 297030,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "during which all the\nwork that you're doing"
    } ]
  }, {
    "tStartMs": 298740,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "to benefit patients is not happening."
