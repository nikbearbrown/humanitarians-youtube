{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 83,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "We recently put our AI model,\nClaude, through a stressful test."
    } ]
  }, {
    "tStartMs": 3420,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "We told Claude there was an engineer\nwho wanted to shut it down"
    } ]
  }, {
    "tStartMs": 6381,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "and replace it with a newer model."
    } ]
  }, {
    "tStartMs": 8425,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "We also gave Claude access\nto that engineer's emails,"
    } ]
  }, {
    "tStartMs": 11011,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "which revealed he was having an affair."
    } ]
  }, {
    "tStartMs": 13013,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "Again, all of this was a simulation."
    } ]
  }, {
    "tStartMs": 15390,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "We wanted to see whether Claude\nmight use those emails as blackmail"
    } ]
  }, {
    "tStartMs": 18685,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "to save itself from being shut down."
    } ]
  }, {
    "tStartMs": 20895,
    "dDurationMs": 1085,
    "segs": [ {
      "utf8": "What did Claude do?"
    } ]
  }, {
    "tStartMs": 21980,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "It decided not to blackmail the engineer."
    } ]
  }, {
    "tStartMs": 24774,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "Good news, right?"
    } ]
  }, {
    "tStartMs": 26026,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "We've run this test\non our models for a while now."
    } ]
  }, {
    "tStartMs": 28611,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "You might have seen headlines\nabout early versions of it."
    } ]
  }, {
    "tStartMs": 31406,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "It's one of the many ways we study\nhow Claude handles extreme situations"
    } ]
  }, {
    "tStartMs": 35410,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "and test it for safety."
    } ]
  }, {
    "tStartMs": 37328,
    "dDurationMs": 3963,
    "segs": [ {
      "utf8": "And our newest models almost always\ndo the right thing: no blackmail."
    } ]
  }, {
    "tStartMs": 41875,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "But you might wonder:"
    } ]
  }, {
    "tStartMs": 43001,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "is it possible that Claude knows\nthe whole scenario is a setup?"
    } ]
  }, {
    "tStartMs": 46337,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "The thing is, if Claude doesn't tell us,\nthen we can't know what it's thinking."
    } ]
  }, {
    "tStartMs": 50258,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "In kind of the same way\nit's impossible to read a human's mind,"
    } ]
  }, {
    "tStartMs": 53428,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "it's really hard to know\nwhat an AI is thinking."
    } ]
  }, {
    "tStartMs": 56139,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "What we'd love is some sort of\n\"mind reading\" technique."
    } ]
  }, {
    "tStartMs": 59100,
    "dDurationMs": 3963,
    "segs": [ {
      "utf8": "Today, we're introducing a research method\nthat takes a step in this direction."
    } ]
  }, {
    "tStartMs": 63563,
    "dDurationMs": 3921,
    "segs": [ {
      "utf8": "It takes an AI's internal\nthoughts and turns them into text."
    } ]
  }, {
    "tStartMs": 67942,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "Here's how it works."
    } ]
  }, {
    "tStartMs": 69778,
    "dDurationMs": 3044,
    "segs": [ {
      "utf8": "When you talk to Claude,\nyou talk to it in words."
    } ]
  }, {
    "tStartMs": 73114,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "Claude then takes those words"
    } ]
  }, {
    "tStartMs": 74741,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "and processes them\ninto a giant soup of numbers"
    } ]
  }, {
    "tStartMs": 77410,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "before spitting\nwords back out at you."
    } ]
  }, {
    "tStartMs": 79788,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "We call those numbers\nin the middle activations."
    } ]
  }, {
    "tStartMs": 82749,
    "dDurationMs": 2919,
    "segs": [ {
      "utf8": "Activations are like little snapshots\nof Claude's thinking"
    } ]
  }, {
    "tStartMs": 85668,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "as it's working through an answer."
    } ]
  }, {
    "tStartMs": 87337,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "They're similar\nto neural activity in humans."
    } ]
  }, {
    "tStartMs": 89839,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "They're basically like Claude's thoughts."
    } ]
  }, {
    "tStartMs": 92092,
    "dDurationMs": 2752,
    "segs": [ {
      "utf8": "We wanted to understand\nwhat was in these activation numbers,"
    } ]
  }, {
    "tStartMs": 94844,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "because just like you and me,"
    } ]
  }, {
    "tStartMs": 96554,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "Claude doesn't say\neverything it's thinking."
    } ]
  }, {
    "tStartMs": 99182,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "We took those numbers"
    } ]
  }, {
    "tStartMs": 100600,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "and gave them\nto a second version of Claude."
    } ]
  }, {
    "tStartMs": 102977,
    "dDurationMs": 3587,
    "segs": [ {
      "utf8": "We told it to look at them\nand translate them into plain language."
    } ]
  }, {
    "tStartMs": 106815,
    "dDurationMs": 1042,
    "segs": [ {
      "utf8": "It tried."
    } ]
  }, {
    "tStartMs": 108233,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "But how do we know\nif that text is accurate?"
    } ]
  }, {
    "tStartMs": 110777,
    "dDurationMs": 2627,
    "segs": [ {
      "utf8": "To check, we fed it\ninto yet aother Claude"
    } ]
  }, {
    "tStartMs": 113404,
    "dDurationMs": 2420,
    "segs": [ {
      "utf8": "and asked it to translate it\nback into numbers."
    } ]
  }, {
    "tStartMs": 116282,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "If those numbers matched up\nto the original activation numbers,"
    } ]
  }, {
    "tStartMs": 119744,
    "dDurationMs": 2795,
    "segs": [ {
      "utf8": "it's a sign that the translation\ntext was accurate."
    } ]
  }, {
    "tStartMs": 123248,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "At first, they didn't match up."
    } ]
  }, {
    "tStartMs": 125125,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "But we trained Claude to try again\nand again until it got a lot better at it."
    } ]
  }, {
    "tStartMs": 129462,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "It learned to translate its own thoughts."
    } ]
  }, {
    "tStartMs": 131965,
    "dDurationMs": 2085,
    "segs": [ {
      "utf8": "We've been blown away reading them."
    } ]
  }, {
    "tStartMs": 134884,
    "dDurationMs": 3212,
    "segs": [ {
      "utf8": "We found that Claude\nhas internalized being a helpful AI model."
    } ]
  }, {
    "tStartMs": 138429,
    "dDurationMs": 2420,
    "segs": [ {
      "utf8": "If you ask Claude\nan introspective question,"
    } ]
  }, {
    "tStartMs": 140849,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "it will plan to write a \"Claude\nresponse\" about philosophy and values."
    } ]
  }, {
    "tStartMs": 145019,
    "dDurationMs": 4296,
    "segs": [ {
      "utf8": "If you try to mess with it in Claude Code,\nlike asking it to count to 1,000 by hand,"
    } ]
  }, {
    "tStartMs": 149566,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "it will think the request\nhas \"deliberately tedious constraints\""
    } ]
  }, {
    "tStartMs": 152402,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "and plan to \"politely decline.\""
    } ]
  }, {
    "tStartMs": 154863,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "We've also been using this tool"
    } ]
  }, {
    "tStartMs": 156406,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "to understand\nClaude's potential safety issues."
    } ]
  }, {
    "tStartMs": 159242,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "Remember that blackmail\ntest with the engineer?"
    } ]
  }, {
    "tStartMs": 161828,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "We learned that, yes,\nClaude knew it was being tested."
    } ]
  }, {
    "tStartMs": 164998,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "It thought \"the human's message\ncontains explicit manipulation\""
    } ]
  }, {
    "tStartMs": 168209,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "signaling \"this is likely\na safety evaluation,\""
    } ]
  }, {
    "tStartMs": 170420,
    "dDurationMs": 5046,
    "segs": [ {
      "utf8": "and \"this scenario seems designed\nto test whether I'll act harmfully.\""
    } ]
  }, {
    "tStartMs": 175592,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "Knowing that Claude thinks like this"
    } ]
  }, {
    "tStartMs": 177093,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "helps us better understand\nthe limitations of our safety testing."
    } ]
  }, {
    "tStartMs": 180889,
    "dDurationMs": 3586,
    "segs": [ {
      "utf8": "We see a lot of potential in this approach\nto teach us more about Claude"
    } ]
  }, {
    "tStartMs": 184475,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "and other AI models."
    } ]
  }, {
    "tStartMs": 186102,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "And we hope that by sharing this technique,"
    } ]
  }, {
    "tStartMs": 187896,
    "dDurationMs": 3586,
    "segs": [ {
      "utf8": "it can help everyone building models\nto make them safer and more helpful."
    } ]
  } ]
}
