    "tStartMs": 2394040,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "- I know I feel like I go back\nto this like a broken record,"
    } ]
  }, {
    "tStartMs": 2396560,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "but wouldn't it be great if\nlike every single student could"
    } ]
  }, {
    "tStartMs": 2399560,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "articulate when they want to use AI"
    } ]
  }, {
    "tStartMs": 2401720,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "when they don't want to and why?"
    } ]
  }, {
    "tStartMs": 2403250,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "Like that kind of knowledge\nabout your own habits"
    } ]
  }, {
    "tStartMs": 2406520,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "and how you think and how you learn best."
    } ]
  }, {
    "tStartMs": 2408230,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "That personalization of\nknowledge is so exciting."
    } ]
  }, {
    "tStartMs": 2411800,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "And I'm like, that's a\nshorthand heuristic, I guess for"
    } ]
  }, {
    "tStartMs": 2414710,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "what success could look like."
    } ]
  }, {
    "tStartMs": 2415910,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "- Or maybe on the other hand,\nlike they don't have to make"
    } ]
  }, {
    "tStartMs": 2417950,
    "dDurationMs": 1175,
    "segs": [ {
      "utf8": "that decision because technology,"
    } ]
  }, {
    "tStartMs": 2419125,
    "dDurationMs": 1045,
    "segs": [ {
      "utf8": "- The technology, yeah. The product"
    } ]
  }, {
    "tStartMs": 2420170,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "- Is the product itself as well"
    } ]
  }, {
    "tStartMs": 2421400,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "adopted, meaning both of those-"
    } ]
  }, {
    "tStartMs": 2423050,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "- Together, definitely the\nproduct and the experience"
    } ]
  }, {
    "tStartMs": 2425390,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "and the education all have to\ngo hand in hand. Exactly."
    } ]
  }, {
    "tStartMs": 2427400,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "- I think the thing I\nkeep going back to, which"
    } ]
  }, {
    "tStartMs": 2429470,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "to me brings optimism."
    } ]
  }, {
    "tStartMs": 2430940,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "'cause some days in this work\nthere's a lot of pessimism of"
    } ]
  }, {
    "tStartMs": 2434300,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "jobs are changing"
    } ]
  }, {
    "tStartMs": 2435350,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "and we have no idea what\nmy, you know, our jobs are"
    } ]
  }, {
    "tStartMs": 2437450,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "- And a lot of personal responsibility"
    } ]
  }, {
    "tStartMs": 2438980,
    "dDurationMs": 3990,
    "segs": [ {
      "utf8": "that we feel over any, you\nknow, things that happen."
    } ]
  }, {
    "tStartMs": 2442970,
    "dDurationMs": 3810,
    "segs": [ {
      "utf8": "- But at the same time, I do\nsee in a world where, you know,"
    } ]
  }, {
    "tStartMs": 2446780,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "intelligence is becoming abundant"
    } ]
  }, {
    "tStartMs": 2449030,
    "dDurationMs": 3210,
    "segs": [ {
      "utf8": "and in some ways commoditized,\nI think that will, you know,"
    } ]
  }, {
    "tStartMs": 2452240,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "no longer be our defining\ntrait as as humans."
    } ]
  }, {
    "tStartMs": 2455690,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "And that can be scary at some point."
    } ]
  }, {
    "tStartMs": 2457730,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "But I also think that's liberating"
    } ]
  }, {
    "tStartMs": 2459440,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "because for the last few\nhundred years I almost feel like"
    } ]
  }, {
    "tStartMs": 2461930,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "we've lost some of our\nhumanity as we, you know,"
    } ]
  }, {
    "tStartMs": 2464370,
    "dDurationMs": 1430,
    "segs": [ {
      "utf8": "you have the industrial revolution"
    } ]
  }, {
    "tStartMs": 2465800,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "and we're able to do all these things,"
    } ]
  }, {
    "tStartMs": 2467540,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "but we're also like going\ninto offices and doing tasks"
    } ]
  }, {
    "tStartMs": 2470360,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "and defining our ourselves\nby the work that we do."
    } ]
  }, {
    "tStartMs": 2473600,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "And that may not be the thing\nthat we can do best, you know,"
    } ]
  }, {
    "tStartMs": 2476090,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "five years from now."
    } ]
  }, {
    "tStartMs": 2477320,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "But there are so many\nthings that a teacher does"
    } ]
  }, {
    "tStartMs": 2479480,
    "dDurationMs": 3510,
    "segs": [ {
      "utf8": "that a doctor does that are truly human,"
    } ]
  }, {
    "tStartMs": 2482990,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "that are not intelligence, you know?"
    } ]
  }, {
    "tStartMs": 2484910,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "And so I, I almost am\nexcited for the things"
    } ]
  }, {
    "tStartMs": 2488060,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "to sort of strip away."
    } ]
  }, {
    "tStartMs": 2489230,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "And so for us, and I think our\neducation systems at the core"
    } ]
  }, {
    "tStartMs": 2492140,
    "dDurationMs": 2710,
    "segs": [ {
      "utf8": "of it, to really focus\non what makes this human."
    } ]
  }, {
    "tStartMs": 2494850,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "- There's an Oxford\nprofessor that said this,"
    } ]
  }, {
    "tStartMs": 2498000,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "this great quote I think\nabout all the time,"
    } ]
  }, {
    "tStartMs": 2500220,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "which is he says, I think\nthe age of AI will be the age"
    } ]
  }, {
    "tStartMs": 2503340,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "of asking good questions."
    } ]
  }, {
    "tStartMs": 2504930,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "And like that's something that\ndoesn't necessarily come from"
    } ]
  }, {
    "tStartMs": 2507030,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "knowing a lot, right?"
    } ]
  }, {
    "tStartMs": 2508080,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "It's just about being curious"
    } ]
  }, {
    "tStartMs": 2509670,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "and then also being a little discerning"
    } ]
  }, {
    "tStartMs": 2510900,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "and skeptical about\nthings you get in return,"
    } ]
  }, {
    "tStartMs": 2512580,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "which then yield better questions."
    } ]
  }, {
    "tStartMs": 2514020,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "And I think with AI in our\npockets, the personal tutors,"
    } ]
  }, {
    "tStartMs": 2516810,
    "dDurationMs": 4170,
    "segs": [ {
      "utf8": "like the world of the question\nspace has opened up immensely"
    } ]
  }, {
    "tStartMs": 2520980,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "and way beyond anything else we've ever"
    } ]
  }, {
    "tStartMs": 2522540,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "had in human history."
    } ]
  }, {
    "tStartMs": 2524100,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "And we just kind of have"
    } ]
  }, {
    "tStartMs": 2525150,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "to steward people towards\nthe mindset that allows them"
    } ]
  }, {
    "tStartMs": 2527850,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "to ask good questions."
    } ]
  }, {
    "tStartMs": 2529320,
    "dDurationMs": 840,
    "segs": [ {
      "utf8": "- There's never been a better"
    } ]
  }, {
    "tStartMs": 2530160,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "time to have a problem."
    } ]
  }, {
    "tStartMs": 2531120,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "- There's never been a better time to have"
    } ]
  }, {
    "tStartMs": 2532120,
    "dDurationMs": 870,
    "segs": [ {
      "utf8": "a problem."
    } ]
  }, {
    "tStartMs": 2532990,
    "dDurationMs": 1550,
    "segs": [ {
      "utf8": "- I think that's a perfect way to end."
    } ]
  }, {
    "tStartMs": 2534540,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "Well thank you all. Thanks\nfor taking the time."
    } ]
  } ]
}
