  }, {
    "tStartMs": 19290,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "and discuss with them\nways where we can amplify"
    } ]
  }, {
    "tStartMs": 22230,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "that knowledge they already have."
    } ]
  }, {
    "tStartMs": 24630,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "- Hi everyone. We're here to\ntalk about my favorite topic,"
    } ]
  }, {
    "tStartMs": 27930,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "which is AI and education."
    } ]
  }, {
    "tStartMs": 30270,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "My name is Drew Bent."
    } ]
  }, {
    "tStartMs": 31380,
    "dDurationMs": 3690,
    "segs": [ {
      "utf8": "I lead our work here in education\non beneficial deployments."
    } ]
  }, {
    "tStartMs": 35070,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "Formerly was a high school math teacher."
    } ]
  }, {
    "tStartMs": 37170,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "My parents are educators."
    } ]
  }, {
    "tStartMs": 38430,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I worked in education nonprofits"
    } ]
  }, {
    "tStartMs": 40110,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "and would definitely consider\nmyself a lifelong learner."
    } ]
  }, {
    "tStartMs": 42660,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "I'm joined here by my wonderful colleagues"
    } ]
  }, {
    "tStartMs": 44640,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "who work in education across the"
    } ]
  }, {
    "tStartMs": 46020,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "organization. Do you wanna start, Zoe?"
    } ]
  }, {
    "tStartMs": 48750,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "- Happy to. Yeah. Hi, I'm Zoe."
    } ]
  }, {
    "tStartMs": 50670,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I'm on our education\nteam here at Anthropic"
    } ]
  }, {
    "tStartMs": 53070,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "and I support all of our\nnon-technical audiences,"
    } ]
  }, {
    "tStartMs": 56010,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "including educating teachers"
    } ]
  }, {
    "tStartMs": 57750,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "and students about both our\nproducts and AI in general."
    } ]
  }, {
    "tStartMs": 60570,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "- Hi, I'm Maggie and I\nfounded and currently manage"
    } ]
  }, {
    "tStartMs": 63660,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "and support said education team,"
