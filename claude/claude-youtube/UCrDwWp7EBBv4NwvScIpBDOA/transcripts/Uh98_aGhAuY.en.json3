    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "which we fondly internally\ncall the Ministry of Education."
    } ]
  }, {
    "tStartMs": 69270,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "- Hi, I'm Ephraim. I'm a\nproduct engineering manager"
