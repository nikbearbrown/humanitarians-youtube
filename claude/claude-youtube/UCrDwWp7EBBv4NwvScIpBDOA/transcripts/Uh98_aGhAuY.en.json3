  "events": [ {
    "tStartMs": 210,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "- I would hate to see a future"
    } ]
  }, {
    "tStartMs": 1590,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "where teachers outsource to AI"
    } ]
  }, {
    "tStartMs": 4770,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "the parts that I think\nreally make good education,"
    } ]
  }, {
    "tStartMs": 7020,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "which is the connection pieces,"
    } ]
  }, {
    "tStartMs": 8550,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "when you really understand your students"
    } ]
  }, {
    "tStartMs": 10140,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "and can spend time with them,"
    } ]
  }, {
    "tStartMs": 11580,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "and AI can be used in so\nmany ways that allow teachers"
