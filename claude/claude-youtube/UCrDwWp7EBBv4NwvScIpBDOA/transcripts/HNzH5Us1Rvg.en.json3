    "segs": [ {
      "utf8": "normal SSO like you always would do and anytime \nthey use an MCP server from them on on out,  "
    } ]
  }, {
    "tStartMs": 1340080,
    "dDurationMs": 6240,
    "segs": [ {
      "utf8": "they will just be logged in and have access to the \ndata that you know the that is their data that the  "
