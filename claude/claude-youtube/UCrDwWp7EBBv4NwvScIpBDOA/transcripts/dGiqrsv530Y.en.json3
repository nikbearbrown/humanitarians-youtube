{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 345,
    "dDurationMs": 3397,
    "segs": [ {
      "utf8": "We've been experimenting with a new way\nfor AI to build software."
    } ]
  }, {
    "tStartMs": 4105,
    "dDurationMs": 2362,
    "segs": [ {
      "utf8": "It's called Imagine with Claude."
    } ]
  }, {
    "tStartMs": 7030,
    "dDurationMs": 2507,
    "segs": [ {
      "utf8": "Imagine with Claude is still building\nsoftware,"
    } ]
  }, {
    "tStartMs": 10118,
    "dDurationMs": 1817,
    "segs": [ {
      "utf8": "but we've cut out the middleman."
    } ]
  }, {
    "tStartMs": 12698,
    "dDurationMs": 3143,
    "segs": [ {
      "utf8": "Instead of writing code\nthat describes this text box,"
    } ]
  }, {
    "tStartMs": 16204,
    "dDurationMs": 2689,
    "segs": [ {
      "utf8": "Claude just makes the text box."
    } ]
  }, {
    "tStartMs": 19747,
    "dDurationMs": 4106,
    "segs": [ {
      "utf8": "We've given it access to software tools\nthat construct software directly"
    } ]
  }, {
    "tStartMs": 24543,
    "dDurationMs": 1453,
    "segs": [ {
      "utf8": "and substantially faster."
    } ]
  }, {
    "tStartMs": 27686,
    "dDurationMs": 3088,
    "segs": [ {
      "utf8": "Here, Claude isn't writing\ncode in the standard way."
    } ]
  }, {
    "tStartMs": 31137,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "It doesn't have to plan it\nall out in advance."
    } ]
  }, {
    "tStartMs": 34317,
    "dDurationMs": 3506,
    "segs": [ {
      "utf8": "Instead, it\ngenerates new software on the fly."
    } ]
  }, {
    "tStartMs": 39294,
    "dDurationMs": 3234,
    "segs": [ {
      "utf8": "When we click something here,\nit isn't running pre-written code."
    } ]
  }, {
    "tStartMs": 43255,
    "dDurationMs": 3542,
    "segs": [ {
      "utf8": "It's producing the new parts\nof the interface right there and then."
    } ]
  }, {
    "tStartMs": 47669,
    "dDurationMs": 2017,
    "segs": [ {
      "utf8": "As you can see\nfrom the thought process"
    } ]
  }, {
    "tStartMs": 49686,
    "dDurationMs": 2561,
    "segs": [ {
      "utf8": "Claude is working out \nfrom the overall context"
    } ]
  }, {
    "tStartMs": 52247,
    "dDurationMs": 1036,
    "segs": [ {
      "utf8": "what you want to see."
    } ]
  }, {
    "tStartMs": 54173,
    "dDurationMs": 1671,
    "segs": [ {
      "utf8": "The user has clicked on X"
    } ]
  }, {
    "tStartMs": 55844,
    "dDurationMs": 2089,
    "segs": [ {
      "utf8": "so that must mean\nthey want to see Y."
    } ]
  }, {
    "tStartMs": 58497,
    "dDurationMs": 2997,
    "segs": [ {
      "utf8": "It then produces it\nright before your eyes."
    } ]
  }, {
    "tStartMs": 62275,
    "dDurationMs": 3779,
    "segs": [ {
      "utf8": "On the surface, this might seem like\nonly a subtle distinction from what"
    } ]
  }, {
    "tStartMs": 66054,
    "dDurationMs": 945,
    "segs": [ {
      "utf8": "you've seen before."
    } ]
  }, {
    "tStartMs": 67562,
    "dDurationMs": 3088,
    "segs": [ {
      "utf8": "And the example\nwe've picked here is just for fun."
    } ]
  }, {
    "tStartMs": 70650,
    "dDurationMs": 3525,
    "segs": [ {
      "utf8": "But the underlying approach of this\nexperiment is quite different."
    } ]
  }, {
    "tStartMs": 74629,
    "dDurationMs": 3906,
    "segs": [ {
      "utf8": "This is software that generates itself\nin response to what you need."
    } ]
  }, {
    "tStartMs": 79189,
    "dDurationMs": 2325,
    "segs": [ {
      "utf8": "Rather than following \na predetermined script."
    } ]
  }, {
    "tStartMs": 82113,
    "dDurationMs": 4179,
    "segs": [ {
      "utf8": "In the future, will we still have to rely\non premade software"
    } ]
  }, {
    "tStartMs": 86292,
    "dDurationMs": 2125,
    "segs": [ {
      "utf8": "or will we be able\nto create "
    } ]
  }, {
    "tStartMs": 88417,
    "dDurationMs": 2689,
    "segs": [ {
      "utf8": "whatever software we want\nas soon as we need it?"
    } ]
  }, {
    "tStartMs": 91742,
    "dDurationMs": 4433,
    "segs": [ {
      "utf8": "With this new experiment, you can imagine\nthings being very different."
    } ]
  } ]
}
