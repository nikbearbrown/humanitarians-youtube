  "events": [ {
    "tStartMs": 6244,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Hi, I'm Alex."
    } ]
  }, {
    "tStartMs": 7077,
    "dDurationMs": 1833,
    "segs": [ {
      "utf8": "I lead Claude Relations here at Anthropic."
    } ]
  }, {
    "tStartMs": 8910,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "Today we're talking about\ndesign for Claude Code"
    } ]
  }, {
    "tStartMs": 11370,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "and I'm joined by my colleague Meaghan."
    } ]
  }, {
    "tStartMs": 13230,
    "dDurationMs": 893,
    "segs": [ {
      "utf8": "- Hi, my name is Meaghan"
    } ]
  }, {
    "tStartMs": 14123,
    "dDurationMs": 1897,
    "segs": [ {
      "utf8": "and I'm the design lead for Claude Code."
    } ]
  }, {
    "tStartMs": 16020,
    "dDurationMs": 3930,
    "segs": [ {
      "utf8": "- Meaghan, I wanna start with\nthe very unique form factor"
    } ]
  }, {
    "tStartMs": 19950,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "that Claude Code has."
    } ]
  }, {
    "tStartMs": 21150,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "So, we built this coding product"
    } ]
  }, {
    "tStartMs": 23160,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "and it lives within a terminal."
    } ]
  }, {
    "tStartMs": 24990,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "Can you tell me how we even got to that?"
    } ]
  }, {
    "tStartMs": 27600,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "- Yeah, yeah, definitely."
    } ]
  }, {
    "tStartMs": 28770,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "Well, if you've seen some\nof our previous videos,"
    } ]
  }, {
    "tStartMs": 30510,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "you know that Claude\nCode was a brain child"
    } ]
  }, {
    "tStartMs": 33600,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "of a few folks here at Anthropic"
    } ]
  }, {
    "tStartMs": 35100,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "who are really passionate\nabout Claude's ability"
    } ]
  }, {
    "tStartMs": 38550,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "to solve coding problems\nand help developers."
    } ]
  }, {
    "tStartMs": 41130,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "And, part of the initial decision for CLI"
    } ]
  }, {
    "tStartMs": 44040,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "was really just the\nease of the form factor"
    } ]
  }, {
    "tStartMs": 46350,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "to be able to build really quickly"
    } ]
  }, {
    "tStartMs": 48030,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "and to iterate on features\nand functionality."
    } ]
  }, {
    "tStartMs": 50550,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "But I think from there, really,"
    } ]
  }, {
    "tStartMs": 52620,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "kind of against honestly my expectations"
    } ]
  }, {
    "tStartMs": 54630,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "and all our expectations,\nit took a life of its own"
    } ]
  }, {
    "tStartMs": 58050,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "because it's just so versatile."
    } ]
  }, {
    "tStartMs": 60120,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "Like, a terminal is in\nevery developer's workflow."
    } ]
  }, {
    "tStartMs": 63570,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "Whether or not you're primarily in IDE"
    } ]
  }, {
    "tStartMs": 65430,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "or even if you're just like a Vim user,"
    } ]
  }, {
    "tStartMs": 67950,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "you're using terminal as part"
    } ]
  }, {
    "tStartMs": 69450,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "of your workflow in one shape or another."
    } ]
  }, {
    "tStartMs": 71550,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "And so, it lets you\nreally integrate directly"
    } ]
  }, {
    "tStartMs": 73950,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "into developer's workflow,"
    } ]
  }, {
    "tStartMs": 75060,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "where they are today without needing"
    } ]
  }, {
    "tStartMs": 76140,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "to adopt a new tool of any sort."
    } ]
  }, {
    "tStartMs": 78540,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "- I think that's like a really good point"
    } ]
  }, {
    "tStartMs": 79860,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "is like the terminal's kind\nof been a foundational piece"
    } ]
  }, {
    "tStartMs": 82110,
    "dDurationMs": 4530,
    "segs": [ {
      "utf8": "of software development since,\nman, since forever basically,"
    } ]
  }, {
    "tStartMs": 86640,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "as long as we've been doing this."
    } ]
  }, {
    "tStartMs": 87990,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "So it's almost natural to kind\nof embed the next generation"
    } ]
  }, {
    "tStartMs": 90750,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "of a coding product within it."
    } ]
  }, {
    "tStartMs": 92640,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "But Claude Code does some things"
    } ]
  }, {
    "tStartMs": 93960,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "that I didn't even know were\npossible with a terminal."
    } ]
  }, {
    "tStartMs": 96720,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "So, maybe like, walk me through"
    } ]
  }, {
    "tStartMs": 98070,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "what has kind of the history been"
    } ]
  }, {
    "tStartMs": 99480,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "of terminal products thus far,"
    } ]
  }, {
    "tStartMs": 101280,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "and how is Claude Code\nlike the next step there?"
    } ]
  }, {
    "tStartMs": 103620,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "- Yeah, this is something I'm personally,"
    } ]
  }, {
    "tStartMs": 105540,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "very, very passionate about."
    } ]
  }, {
    "tStartMs": 106680,
    "dDurationMs": 4260,
    "segs": [ {
      "utf8": "I think terminals are like the\nfirst user interface, right?"
    } ]
  }, {
    "tStartMs": 110940,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Like, they're the first\nways that people used"
    } ]
  }, {
    "tStartMs": 112740,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "to talk to computers."
    } ]
  }, {
    "tStartMs": 114030,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "They were text-only."
    } ]
  }, {
    "tStartMs": 115170,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "There were like very\nspecific commands you needed"
    } ]
  }, {
    "tStartMs": 116970,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "to know in order to be able to\ninterface with these devices."
    } ]
  }, {
    "tStartMs": 119790,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "And they're like a super-powered tool."
    } ]
  }, {
    "tStartMs": 122130,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "And then, kind of from there,"
    } ]
  }, {
    "tStartMs": 124140,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "we evolved into these\nreally rich web interfaces."
    } ]
  }, {
    "tStartMs": 127020,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "We had like all these beautiful web UI,"
    } ]
  }, {
    "tStartMs": 128790,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "we had like Tailwind, we had\nlike CSS, we had JavaScript,"
    } ]
  }, {
    "tStartMs": 131610,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "everything became very\nanimated and very polished."
    } ]
  }, {
    "tStartMs": 133950,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "But then when LLMs came out,"
    } ]
  }, {
    "tStartMs": 135420,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "we actually went all the way back"
    } ]
  }, {
    "tStartMs": 137190,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "to just chatting with a computer again."
    } ]
  }, {
    "tStartMs": 138990,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "Like, you didn't actually\nneed all these buttons,"
    } ]
  }, {
    "tStartMs": 140340,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "you just needed to chat."
    } ]
  }, {
    "tStartMs": 141600,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "And so I think terminal, interestingly,"
    } ]
  }, {
    "tStartMs": 143670,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "is actually the perfect\nform factor for an LLM."
    } ]
  }, {
    "tStartMs": 146550,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "'Cause you're giving text\nin, you're getting text out,"
    } ]
  }, {
    "tStartMs": 149490,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "and it just is like so native"
    } ]
  }, {
    "tStartMs": 152190,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "to how you think about using\nlike a command line interface"
    } ]
  }, {
    "tStartMs": 155250,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "that it was like a\nbeautiful marriage, I think,"
    } ]
  }, {
    "tStartMs": 156900,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "of like what the technology can do"
    } ]
  }, {
    "tStartMs": 158970,
    "dDurationMs": 990,
    "segs": [ {
      "utf8": "and what the product can do."
    } ]
  }, {
    "tStartMs": 159960,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "And then it just happened to be"
    } ]
  }, {
    "tStartMs": 161040,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "that developers also spend\ntheir time there, so it's great."
    } ]
  }, {
    "tStartMs": 163830,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- I see."
    } ]
  }, {
    "tStartMs": 164663,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "So we're almost like going\nfull circle to some degree,"
    } ]
  }, {
    "tStartMs": 168000,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "because the model allows\nus to do it in some sense"
    } ]
  }, {
    "tStartMs": 170280,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "and removes the need\nfor the UI abstractions"
    } ]
  }, {
    "tStartMs": 173160,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "that we've had to develop previously"
    } ]
  }, {
    "tStartMs": 174750,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "for different applications.\n- Mm hm. Mm hm."
    } ]
  }, {
    "tStartMs": 176310,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "Exactly. Exactly."
    } ]
  }, {
    "tStartMs": 177420,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "I also think big part"
    } ]
  }, {
    "tStartMs": 179490,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "of why I think Claude Code\nis successful is, you know,"
    } ]
  }, {
    "tStartMs": 182850,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "no one likes copying and pasting things,"
    } ]
  }, {
    "tStartMs": 184740,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "from like a web UI to\nlike your local file."
    } ]
  }, {
    "tStartMs": 187440,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "Like, I definitely do this all the time"
    } ]
  }, {
    "tStartMs": 189150,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "when I'm using Claude AI."
    } ]
  }, {
    "tStartMs": 190410,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "And so being able to be like\nnatively in the environment"
    } ]
  }, {
    "tStartMs": 192810,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "where everything lives"
    } ]
  }, {
    "tStartMs": 194430,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "is just such a rich\npart of the experience."
    } ]
  }, {
    "tStartMs": 197040,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "But it does come with some challenges."
    } ]
  }, {
    "tStartMs": 198240,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "You know, CLI is not necessarily"
    } ]
  }, {
    "tStartMs": 199440,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "the most rich interaction surface."
    } ]
  }, {
    "tStartMs": 201000,
    "dDurationMs": 870,
    "segs": [ {
      "utf8": "- Mm."
    } ]
  }, {
    "tStartMs": 201870,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "Let's talk more on that workflow piece"
    } ]
  }, {
    "tStartMs": 203460,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "because I remember very vividly"
    } ]
  }, {
    "tStartMs": 205170,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "when I was first using Claude\nand using language models"
    } ]
  }, {
    "tStartMs": 208440,
    "dDurationMs": 4230,
    "segs": [ {
      "utf8": "for programming, and I would\nbe on the website on claude.ai"
    } ]
  }, {
    "tStartMs": 212670,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "and type in a prompt and paste in a file,"
    } ]
  }, {
    "tStartMs": 214980,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "then all of a sudden I'd get a code output"
    } ]
  }, {
    "tStartMs": 216570,
    "dDurationMs": 3690,
    "segs": [ {
      "utf8": "and I have to copy it, find\nmy file on my local computer,"
    } ]
  }, {
    "tStartMs": 220260,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "paste it in, make the\nedits myself manually."
    } ]
  }, {
    "tStartMs": 223020,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "And now, we've kind of\ntaken out that piece"
    } ]
  }, {
    "tStartMs": 225900,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "of the developer workflow\nand gone straight"
    } ]
  }, {
    "tStartMs": 227700,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "from the prompt to the\ndirect edits on the file."
    } ]
  }, {
    "tStartMs": 230400,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "- Mm hm."
    } ]
  }, {
    "tStartMs": 231540,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "- Can you tell me a little bit more"
    } ]
  }, {
    "tStartMs": 232440,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "about how we're thinking\nabout future iterations"
    } ]
  }, {
    "tStartMs": 235050,
    "dDurationMs": 2357,
    "segs": [ {
      "utf8": "of this dev workflow and this\ndev loop within Claude Code?"
    } ]
  }, {
    "tStartMs": 237407,
    "dDurationMs": 943,
    "segs": [ {
      "utf8": "- Mm hm. Mm hm."
    } ]
  }, {
    "tStartMs": 238350,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "Absolutely."
    } ]
  }, {
    "tStartMs": 239183,
    "dDurationMs": 2317,
    "segs": [ {
      "utf8": "I think the way that I've\nbeen thinking about it"
    } ]
  }, {
    "tStartMs": 241500,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "within the team, and a lot\nof folks will talk about it,"
    } ]
  }, {
    "tStartMs": 243990,
    "dDurationMs": 3210,
    "segs": [ {
      "utf8": "is, you know, the developer\nworkflow initially started"
    } ]
  }, {
    "tStartMs": 247200,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "as writing lines of code."
    } ]
  }, {
    "tStartMs": 248940,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "Like you're at a word level,\nyou're at a function level"
    } ]
  }, {
    "tStartMs": 251010,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "and like that's where you spend time."
    } ]
  }, {
    "tStartMs": 252690,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "And then the first\nreally big AI development"
    } ]
  }, {
    "tStartMs": 254790,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "for coding was tab to auto complete."
    } ]
  }, {
    "tStartMs": 256590,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "But that's still not a line level of code."
    } ]
  }, {
    "tStartMs": 259440,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "When we get to kind of the\nfirst-generation of Claude Code,"
    } ]
  }, {
    "tStartMs": 262470,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "we're up-leveling it to\nlike full file changes"
    } ]
  }, {
    "tStartMs": 264870,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "or like full task changes,\nalmost like a PR level."
    } ]
  }, {
    "tStartMs": 267240,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "And of course, there are some things"
    } ]
  }, {
    "tStartMs": 268350,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "that Claude Code can do better or worse,"
    } ]
  }, {
    "tStartMs": 270180,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "but we're trying to kind\nof move in that direction."
    } ]
  }, {
    "tStartMs": 272490,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "As time goes on, as our\nmodels get more intelligent,"
    } ]
  }, {
    "tStartMs": 275520,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "as our capabilities get stronger,"
    } ]
  }, {
    "tStartMs": 277560,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "I think we're gonna be moving\nnot just from a specific task,"
    } ]
  }, {
    "tStartMs": 280290,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "but almost to like a project level,"
    } ]
  }, {
    "tStartMs": 282120,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "where you're orchestrating\nmultiple Claudes"
    } ]
  }, {
    "tStartMs": 284730,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "from multiple places in order"
    } ]
  }, {
    "tStartMs": 286290,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "to be able to accomplish something."
    } ]
  }, {
    "tStartMs": 287550,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "And I think the tasks\nwill be longer running"
    } ]
  }, {
    "tStartMs": 289980,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "and the Claude will be\na lot more autonomous."
    } ]
  }, {
    "tStartMs": 292140,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "And so, you'll just get into a place"
    } ]
  }, {
    "tStartMs": 294480,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "where I do believe eventually,"
    } ]
  }, {
    "tStartMs": 296520,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "well, we might outgrow the CLI,"
    } ]
  }, {
    "tStartMs": 298170,
    "dDurationMs": 3630,
    "segs": [ {
      "utf8": "but also you're operating at\na higher order of workflow"
    } ]
  }, {
    "tStartMs": 301800,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "than you ever were before as a developer."
    } ]
  }, {
    "tStartMs": 303630,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "- Mm, okay."
    } ]
  }, {
    "tStartMs": 304800,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "Related to the agent front,"
    } ]
  }, {
    "tStartMs": 305940,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "I know that we just\nrecently, a few weeks ago,"
    } ]
  }, {
    "tStartMs": 308010,
    "dDurationMs": 1737,
    "segs": [ {
      "utf8": "put out subagent a product."
    } ]
  }, {
    "tStartMs": 309747,
    "dDurationMs": 1263,
    "segs": [ {
      "utf8": "Can you talk more about that"
    } ]
  }, {
    "tStartMs": 311010,
    "dDurationMs": 3810,
    "segs": [ {
      "utf8": "and how this kind of\nparadigm of slash commands"
    } ]
  }, {
    "tStartMs": 314820,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "and subagent workflows and\nsome of the other features"
    } ]
  }, {
    "tStartMs": 318390,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "that we've shipped under\nthe hood of Claude Code,"
    } ]
  }, {
    "tStartMs": 319800,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "how do those all tie together?"
    } ]
  }, {
    "tStartMs": 321390,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "- Yeah, definitely."
    } ]
  }, {
    "tStartMs": 322500,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "So I think part of the\nreason terminal is so great"
    } ]
  }, {
    "tStartMs": 325410,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "is because it has a built-in architecture"
    } ]
  }, {
    "tStartMs": 328530,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "of how you control the interface, right?"
    } ]
  }, {
    "tStartMs": 330240,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "You have your flags that you\nput in as you launch Claude,"
    } ]
  }, {
    "tStartMs": 333210,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "and then you have your commands"
    } ]
  }, {
    "tStartMs": 334860,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "that you have within kind of a terminal."
    } ]
  }, {
    "tStartMs": 337320,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "And we introduced a very new paradigm,"
    } ]
  }, {
    "tStartMs": 339780,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "which is prompting in the terminal."
    } ]
  }, {
    "tStartMs": 341190,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "There was so much debate."
    } ]
  }, {
    "tStartMs": 342750,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "I even have a doc that I have with Boris"
    } ]
  }, {
    "tStartMs": 345300,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "from like I think November,\nDecember of last year"
    } ]
  }, {
    "tStartMs": 347520,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "of like, we can't put outlines in terminal"
    } ]
  }, {
    "tStartMs": 350640,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "because when you resize the window"
    } ]
  }, {
    "tStartMs": 352080,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "it's gonna break everything."
    } ]
  }, {
    "tStartMs": 354030,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "Every experience I've\never had with designing"
    } ]
  }, {
    "tStartMs": 355650,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "for CLIs before, I like avoid\noutlines like the plague"
    } ]
  }, {
    "tStartMs": 358650,
    "dDurationMs": 990,
    "segs": [ {
      "utf8": "because it breaks everything"
    } ]
  }, {
    "tStartMs": 359640,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "when you have that much-\n- What is an outline?"
    } ]
  }, {
    "tStartMs": 361140,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "- It's like the outline\naround the input box-"
    } ]
  }, {
    "tStartMs": 363450,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "- Oh, I see, yeah.\n- That you have right now."
    } ]
  }, {
    "tStartMs": 364350,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "You tend to avoid those in CLI design"
    } ]
  }, {
    "tStartMs": 366720,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "because when you resize,\nit's all just characters"
    } ]
  }, {
    "tStartMs": 369450,
    "dDurationMs": 930,
    "segs": [ {
      "utf8": "and spaces.\n- Right."
    } ]
  }, {
    "tStartMs": 370380,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "- And so it doesn't align properly."
    } ]
  }, {
    "tStartMs": 372120,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "But Boris had a vision and I was wrong."
    } ]
  }, {
    "tStartMs": 374310,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "Like, we found a great\nlibrary and a great interface"
    } ]
  }, {
    "tStartMs": 377100,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "and the team worked really\nhard to make it usable."
    } ]
  }, {
    "tStartMs": 380100,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "And so the combination of being able"
    } ]
  }, {
    "tStartMs": 381690,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "to separate your prompting,"
    } ]
  }, {
    "tStartMs": 383400,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "which is how you're talking to the model,"
    } ]
  }, {
    "tStartMs": 385260,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "and then the tools that\nyou have available,"
    } ]
  }, {
    "tStartMs": 386910,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "which is our slash commands,"
    } ]
  }, {
    "tStartMs": 388140,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "and the settings and the\nway you configure it,"
    } ]
  }, {
    "tStartMs": 390240,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "which is in our settings.json\nand our CLAUDE.md,"
    } ]
  }, {
    "tStartMs": 393330,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "I think that's kind of the architecture"
    } ]
  }, {
    "tStartMs": 395190,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "that I think powers Claude Code,"
    } ]
  }, {
    "tStartMs": 397020,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "but also is just part"
    } ]
  }, {
    "tStartMs": 399360,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "of the regular architecture\nof software development."
    } ]
  }, {
    "tStartMs": 400980,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "Like a README file is very similar,"
    } ]
  }, {
    "tStartMs": 402450,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "so it just pairs really beautifully."
    } ]
  }, {
    "tStartMs": 404100,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "- Mm."
    } ]
  }, {
    "tStartMs": 405120,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "How do we actually design new things"
    } ]
  }, {
    "tStartMs": 407730,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "like the outline box or\njust the visual aesthetics?"
    } ]
  }, {
    "tStartMs": 410490,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "Do we have design principles we follow?"
    } ]
  }, {
    "tStartMs": 412350,
    "dDurationMs": 3210,
    "segs": [ {
      "utf8": "Is there rules or, just walk\nme through that process."
    } ]
  }, {
    "tStartMs": 415560,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yeah, definitely."
    } ]
  }, {
    "tStartMs": 416393,
    "dDurationMs": 3937,
    "segs": [ {
      "utf8": "I would say everyone is an\ninventor here at Anthropic"
    } ]
  }, {
    "tStartMs": 420330,
    "dDurationMs": 930,
    "segs": [ {
      "utf8": "and at the Claude Code team."
    } ]
  }, {
    "tStartMs": 421260,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "So, for the most part, it's\na small team of like one"
    } ]
  }, {
    "tStartMs": 424530,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "or two engineers coming up with ideas"
    } ]
  }, {
    "tStartMs": 426270,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "and then prototyping them"
    } ]
  }, {
    "tStartMs": 427290,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "and then we rigorously\ntest 'em internally."
    } ]
  }, {
    "tStartMs": 430590,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "For the most part, they are used"
    } ]
  }, {
    "tStartMs": 432420,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "by all of, everyone at Anthropic,"
    } ]
  }, {
    "tStartMs": 434340,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "everyone uses Claude Code."
    } ]
  }, {
    "tStartMs": 435840,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "And so, that's where we\nget a lot of our feedback."
    } ]
  }, {
    "tStartMs": 438150,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "And then we'll typically\ndo a cycle of UX polish"
    } ]
  }, {
    "tStartMs": 441060,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "towards the end when we feel\nlike we have the right shape"
    } ]
  }, {
    "tStartMs": 444150,
    "dDurationMs": 1943,
    "segs": [ {
      "utf8": "of what this technology should be."
    } ]
  }, {
    "tStartMs": 446093,
    "dDurationMs": 1837,
    "segs": [ {
      "utf8": "Subagents was a really fast one,"
    } ]
  }, {
    "tStartMs": 447930,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "where it went from like an idea to lend"
    } ]
  }, {
    "tStartMs": 449550,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "and there was a little\nbit of design polish"
    } ]
  }, {
    "tStartMs": 451380,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "on like how we show a subagent"
    } ]
  }, {
    "tStartMs": 453060,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "and differentiate from like\na subagent versus Claude,"
    } ]
  }, {
    "tStartMs": 455940,
    "dDurationMs": 870,
    "segs": [ {
      "utf8": "how you set it up."
    } ]
  }, {
    "tStartMs": 456810,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "Same thing with MCP."
    } ]
  }, {
    "tStartMs": 458460,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "But the big principles I think that I hold"
    } ]
  }, {
    "tStartMs": 461040,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "and push for very dearly is, you know,"
    } ]
  }, {
    "tStartMs": 462990,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "a CLI is a very limited interface."
    } ]
  }, {
    "tStartMs": 464910,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "We need to keep it clean as possible,"
    } ]
  }, {
    "tStartMs": 467280,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "and so we wanna make sure\nthat we're not flooding it"
    } ]
  }, {
    "tStartMs": 469530,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "with a lot of information and\njust keeping it really focused"
    } ]
  }, {
    "tStartMs": 472320,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "on the task that you're doing."
    } ]
  }, {
    "tStartMs": 474300,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "The second is that we really\nwant the model to shine"
    } ]
  }, {
    "tStartMs": 477240,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "because at the end of the day,"
    } ]
  }, {
    "tStartMs": 478800,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "part of the reason CLI is so nice"
    } ]
  }, {
    "tStartMs": 480330,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "is that it's the thinnest wrapper possible"
    } ]
  }, {
    "tStartMs": 482820,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "around our models."
    } ]
  }, {
    "tStartMs": 483720,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "And so you just get access to\nthe raw capability of Claude"
    } ]
  }, {
    "tStartMs": 486510,
    "dDurationMs": 3540,
    "segs": [ {
      "utf8": "and that's honestly what\nmakes Claude Code so powerful."
    } ]
  }, {
    "tStartMs": 490050,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Mm."
    } ]
  }, {
    "tStartMs": 490883,
    "dDurationMs": 2347,
    "segs": [ {
      "utf8": "Do you have any favorite\nlittle design polishes"
    } ]
  }, {
    "tStartMs": 493230,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "or things that, touches in Claude Code?"
    } ]
  }, {
    "tStartMs": 495600,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "- I definitely do."
    } ]
  }, {
    "tStartMs": 496650,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "I really like the ASCII\nreticulating and thinking."
    } ]
  }, {
    "tStartMs": 499950,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "I think those are such a great point"
    } ]
  }, {
    "tStartMs": 501540,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "of personality for Claude."
    } ]
  }, {
    "tStartMs": 503670,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "And I also really, really\nlike the different modes,"
    } ]
  }, {
    "tStartMs": 506820,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "how we've like outlined if\nyou're in thinking mode,"
    } ]
  }, {
    "tStartMs": 509580,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "or planning mode, or auto-accept mode,"
    } ]
  }, {
    "tStartMs": 512040,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "I think it's just a very rich way"
    } ]
  }, {
    "tStartMs": 513510,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "to communicate complex information"
    } ]
  }, {
    "tStartMs": 515280,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "in a way that people can understand."
    } ]
  }, {
    "tStartMs": 516810,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- I agree."
    } ]
  }, {
    "tStartMs": 517643,
    "dDurationMs": 1417,
    "segs": [ {
      "utf8": "And I love the personality\ntouches as well."
    } ]
  }, {
    "tStartMs": 519060,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "It feels like, sometimes\nprogramming and the process"
    } ]
  }, {
    "tStartMs": 522540,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "of programming can be\nlike a robotic thing."
    } ]
  }, {
    "tStartMs": 524760,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "You know, you're dealing\nwith lines of code"
    } ]
  }, {
    "tStartMs": 526230,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "and lots of characters, but\nwhen you're using Claude Code,"
    } ]
  }, {
    "tStartMs": 528510,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "it's almost like a different experience"
    } ]
  }, {
    "tStartMs": 529980,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "and it kind of elicits a different emotion"
    } ]
  }, {
    "tStartMs": 532500,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "than just like if I'm in an IDE"
    } ]
  }, {
    "tStartMs": 534420,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "and I'm just typing\nline after line of code."
    } ]
  }, {
    "tStartMs": 536220,
    "dDurationMs": 930,
    "segs": [ {
      "utf8": "- Yeah, definitely, definitely."
    } ]
  }, {
    "tStartMs": 537150,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "I think there's actually a lot"
    } ]
  }, {
    "tStartMs": 537983,
    "dDurationMs": 1717,
    "segs": [ {
      "utf8": "of really rich things\nyou can do in terminal,"
    } ]
  }, {
    "tStartMs": 539700,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "and sometimes it's even\nabout pulling us back."
    } ]
  }, {
    "tStartMs": 541260,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "It's like, \"Oh, actually we\ndon't need to over design this."
    } ]
  }, {
    "tStartMs": 543030,
    "dDurationMs": 1801,
    "segs": [ {
      "utf8": "We can just let the\nmodel take care of it.\""
    } ]
  }, {
    "tStartMs": 544831,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- I see."
    } ]
  }, {
    "tStartMs": 545664,
    "dDurationMs": 1956,
    "segs": [ {
      "utf8": "- Because it is really\ngreat at it, honestly."
    } ]
  }, {
    "tStartMs": 547620,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "- That's, that's great."
    } ]
  }, {
    "tStartMs": 548790,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "I'm really curious to\nhear some of your tips"
    } ]
  }, {
    "tStartMs": 550950,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "and best practices for using Claude Code,"
    } ]
  }, {
    "tStartMs": 552480,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "especially as a designer"
    } ]
  }, {
    "tStartMs": 553740,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "and not a traditional technical person."
    } ]
  }, {
    "tStartMs": 556770,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "How do you best use\nClaude Code day-to-day?"
    } ]
  }, {
    "tStartMs": 559020,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "- I love this question."
    } ]
  }, {
    "tStartMs": 559980,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "It's something I'm personally\nvery passionate about."
    } ]
  }, {
    "tStartMs": 563340,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I am a product designer."
    } ]
  }, {
    "tStartMs": 565020,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "I will be the first to admit"
    } ]
  }, {
    "tStartMs": 566400,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "that I should not be writing any code"
    } ]
  }, {
    "tStartMs": 567720,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "and any code I write is\ndefinitely vibe coded"
    } ]
  }, {
    "tStartMs": 569520,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "and should be reviewed."
    } ]
  }, {
    "tStartMs": 570540,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "But Claude Code and\nall these coding agents"
    } ]
  }, {
    "tStartMs": 573420,
    "dDurationMs": 3630,
    "segs": [ {
      "utf8": "have what I consider\nunlocked a new skill set,"
    } ]
  }, {
    "tStartMs": 577050,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "or like a new skill tree\nfor non-technical folks."
    } ]
  }, {
    "tStartMs": 580020,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "Where before, I would\nneed to maybe request time"
    } ]
  }, {
    "tStartMs": 582990,
    "dDurationMs": 3330,
    "segs": [ {
      "utf8": "for a software engineer, or\nkind of let some things go"
    } ]
  }, {
    "tStartMs": 586320,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "if it didn't necessarily make it"
    } ]
  }, {
    "tStartMs": 587760,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "to the right level of priority."
    } ]
  }, {
    "tStartMs": 589320,
    "dDurationMs": 3780,
    "segs": [ {
      "utf8": "I now have a new set to\nreach into to do it myself."
    } ]
  }, {
    "tStartMs": 593100,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "And so, the two big axes\nthat you'll hear a lot,"
    } ]
  }, {
    "tStartMs": 596040,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "like designers talking about,"
    } ]
  }, {
    "tStartMs": 597660,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "the first one is the\ncost of an idea is zero."
    } ]
  }, {
    "tStartMs": 600930,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "You can prototype very, very quickly."
    } ]
  }, {
    "tStartMs": 603000,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "And I think that's interesting,"
    } ]
  }, {
    "tStartMs": 604110,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "but it's actually not the\nmost exciting unlock for me."
    } ]
  }, {
    "tStartMs": 606750,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "I think the more exciting unlock"
    } ]
  }, {
    "tStartMs": 607950,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "is I can actually push code to production."
    } ]
  }, {
    "tStartMs": 610680,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "I can make the changes that I want."
    } ]
  }, {
    "tStartMs": 611850,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "I'm in the live code base itself."
    } ]
  }, {
    "tStartMs": 613830,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "And so, some of the most common use cases"
    } ]
  }, {
    "tStartMs": 615420,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "that I do almost on the daily is"
    } ]
  }, {
    "tStartMs": 618180,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "if I'm designing a new feature,"
    } ]
  }, {
    "tStartMs": 620220,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "I'll actually brainstorm\nwith Claude Code at first."
    } ]
  }, {
    "tStartMs": 622770,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "I'll be like, \"What are the\nmost common use cases here?"
    } ]
  }, {
    "tStartMs": 626610,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "What are the edge states\nthat I should think about?"
    } ]
  }, {
    "tStartMs": 628560,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "How would you design this, maybe?\""
    } ]
  }, {
    "tStartMs": 630960,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "And then I'll do some\niterations from there."
    } ]
  }, {
    "tStartMs": 633600,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "I also ask Claude Code sometimes"
    } ]
  }, {
    "tStartMs": 635730,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "to help me scope designs\nthat I've proposed."
    } ]
  }, {
    "tStartMs": 638010,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "I'll like drag and drop it as an image."
    } ]
  }, {
    "tStartMs": 639630,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "I'll be like, \"Hey,"
    } ]
  }, {
    "tStartMs": 640463,
    "dDurationMs": 2017,
    "segs": [ {
      "utf8": "how long do you think\nit'll take to make this?\""
    } ]
  }, {
    "tStartMs": 642480,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "And Claude will give me\nestimates so I can, you know,"
    } ]
  }, {
    "tStartMs": 644610,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "friendly debate with the engineers,"
    } ]
  }, {
    "tStartMs": 646650,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "how long it'll actually\ntake to build something"
    } ]
  }, {
    "tStartMs": 648450,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "and we get to a good compromise."
    } ]
  }, {
    "tStartMs": 650100,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "And then the last one is, you know,"
    } ]
  }, {
    "tStartMs": 652410,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "when you're launching a new product,"
    } ]
  }, {
    "tStartMs": 654570,
    "dDurationMs": 4620,
    "segs": [ {
      "utf8": "you often don't really\nget to do the last 2%"
    } ]
  }, {
    "tStartMs": 659190,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "of design polish you always want to do."
    } ]
  }, {
    "tStartMs": 661200,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "And, that's no longer true,"
    } ]
  }, {
    "tStartMs": 664140,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "because I can just go in there\nonce the engineers are done"
    } ]
  }, {
    "tStartMs": 666360,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "and in the last day before launch,"
    } ]
  }, {
    "tStartMs": 667770,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "or even in the few days after launch,"
    } ]
  }, {
    "tStartMs": 669000,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "I will go up and clean up all those"
    } ]
  }, {
    "tStartMs": 670620,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "things that are P2s-\n- Wow. Yeah."
    } ]
  }, {
    "tStartMs": 672120,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "- That I really wanted\nto happen in the product."
    } ]
  }, {
    "tStartMs": 674160,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "- Wow, that's amazing."
    } ]
  }, {
    "tStartMs": 675450,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "I love that."
    } ]
  }, {
    "tStartMs": 676283,
    "dDurationMs": 1237,
    "segs": [ {
      "utf8": "And those are awesome tips."
    } ]
  }, {
    "tStartMs": 677520,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "It's kind of exciting to hear about"
    } ]
  }, {
    "tStartMs": 679440,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "this almost convergence\nalmost of like the designer"
    } ]
  }, {
    "tStartMs": 682140,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "and the engineer into\nthis design engineer,"
    } ]
  }, {
    "tStartMs": 685320,
    "dDurationMs": 990,
    "segs": [ {
      "utf8": "I guess in some sense,"
    } ]
  }, {
    "tStartMs": 686310,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "because of Claude Code and what it allows."
    } ]
  }, {
    "tStartMs": 688110,
    "dDurationMs": 990,
    "segs": [ {
      "utf8": "- Yeah, absolutely."
    } ]
  }, {
    "tStartMs": 689100,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "And I think one thing\nthat it's actually done,"
    } ]
  }, {
    "tStartMs": 691620,
    "dDurationMs": 3330,
    "segs": [ {
      "utf8": "surprisingly for me, is\nit's made my partnership"
    } ]
  }, {
    "tStartMs": 694950,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "with my engineers a lot\nbetter because there's a lot"
    } ]
  }, {
    "tStartMs": 697470,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "of things I honestly can't\ndo on my own right now."
    } ]
  }, {
    "tStartMs": 700140,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "But, even making a first attempt"
    } ]
  }, {
    "tStartMs": 702510,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "and then going and\nchatting with the engineer,"
    } ]
  }, {
    "tStartMs": 704070,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "it makes our collaboration\na lot stronger as well."
    } ]
  }, {
    "tStartMs": 707070,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "So it's not just like\ngiving you a new skill set,"
    } ]
  }, {
    "tStartMs": 708840,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "it's also helping you collaborate\nbetter with your partners,"
    } ]
  }, {
    "tStartMs": 711630,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "which I think is a really important part"
    } ]
  }, {
    "tStartMs": 713010,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "of this kinda whole cycle\nwe're building out right now."
    } ]
  }, {
    "tStartMs": 715410,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- I agree."
    } ]
  }, {
    "tStartMs": 716243,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "That's great."
    } ]
  }, {
    "tStartMs": 717076,
    "dDurationMs": 1064,
    "segs": [ {
      "utf8": "Well, Meaghan, this has been awesome."
    } ]
  }, {
    "tStartMs": 718140,
    "dDurationMs": 1850,
    "segs": [ {
      "utf8": "I really appreciate the conversation."
    } ]
  } ]
}
