  "events": [ {
    "tStartMs": 1584,
    "dDurationMs": 2545,
    "segs": [ {
      "utf8": "Claude for Chrome brings\nthe power of Sonnet 4.5,"
    } ]
  }, {
    "tStartMs": 4129,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "our state of the art model for computer\nuse directly to your browser."
    } ]
  }, {
    "tStartMs": 10635,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "In this example, \nClaude is helping with"
    } ]
  }, {
    "tStartMs": 12387,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "a home renovation."
    } ]
  }, {
    "tStartMs": 14514,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "It will organize your renovation budget,\nwhich is currently spread"
    } ]
  }, {
    "tStartMs": 17100,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "across a planning doc\nand several contractor email exchanges."
    } ]
  }, {
    "tStartMs": 22731,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "Once prompted, Claude gets to work"
    } ]
  }, {
    "tStartMs": 24399,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "to collect the right context."
    } ]
  }, {
    "tStartMs": 28278,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "In this case,\nfinding all the relevant emails"
    } ]
  }, {
    "tStartMs": 30488,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "and receipts you’ve requested."
    } ]
  }, {
    "tStartMs": 36286,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "Claude uses what it learns and"
    } ]
  }, {
    "tStartMs": 37620,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "actively works\nwith your spreadsheet."
    } ]
  }, {
    "tStartMs": 40623,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "Tracking down the missing numbers\nand updating your budget in real time."
    } ]
  }, {
    "tStartMs": 45128,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "Finally, Claude\nmakes it easy for you to share your plans"
    } ]
  }, {
    "tStartMs": 47589,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "with your partner\nby drafting an email for you."
    } ]
  }, {
    "tStartMs": 51301,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "But don't worry,\nyou're still in control of the final edits"
    } ]
  }, {
    "tStartMs": 53470,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "before you send that email."
    } ]
  }, {
    "tStartMs": 56264,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "We took many steps\nto build this product"
    } ]
  }, {
    "tStartMs": 57932,
    "dDurationMs": 1794,
    "segs": [ {
      "utf8": "with safety and \nsecurity at its core."
    } ]
  }, {
    "tStartMs": 60226,
    "dDurationMs": 2545,
    "segs": [ {
      "utf8": "For example,\nyou control what actions Claude can take"
    } ]
  }, {
    "tStartMs": 62771,
    "dDurationMs": 1751,
    "segs": [ {
      "utf8": "through granular permissions."
    } ]
  }, {
    "tStartMs": 64522,
    "dDurationMs": 3587,
    "segs": [ {
      "utf8": "We've also implemented protection\nagainst prompt injection attacks"
    } ]
  }, {
    "tStartMs": 68109,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "and added restrictions around\nwhat websites Claude can use."
    } ]
  }, {
    "tStartMs": 71571,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "And it always asks before taking\nsensitive actions like making purchases."
    } ]
  }, {
    "tStartMs": 75825,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "Bring Claude to your browser today."
    } ]
  } ]
}
