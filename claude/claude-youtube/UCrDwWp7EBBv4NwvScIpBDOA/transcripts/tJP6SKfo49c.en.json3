{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 208,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "This is\na legal lamp. That's what we call it."
    } ]
  }, {
    "tStartMs": 2335,
    "dDurationMs": 3921,
    "segs": [ {
      "utf8": "And I was working on a project\nto learn more about how Claude Code works."
    } ]
  }, {
    "tStartMs": 6631,
    "dDurationMs": 3754,
    "segs": [ {
      "utf8": "And so I was trying to\nthink of a fun project that would sort of"
    } ]
  }, {
    "tStartMs": 10635,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "make my desk come to life more."
    } ]
  }, {
    "tStartMs": 12220,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "And now I can type a message\nand ask this lamp to blink in Morse code."
    } ]
  }, {
    "tStartMs": 16266,
    "dDurationMs": 4129,
    "segs": [ {
      "utf8": "It says it's thinking it's going to do\nfour quick blinks and two quick blinks,"
    } ]
  }, {
    "tStartMs": 20395,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "which is H. I."
    } ]
  }, {
    "tStartMs": 25525,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "Abracadabra."
    } ]
  }, {
    "tStartMs": 27193,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "It's kind of magical. I'm not an engineer."
    } ]
  }, {
    "tStartMs": 29404,
    "dDurationMs": 2878,
    "segs": [ {
      "utf8": "I'm non-technical.\nI don't know how to code."
    } ]
  }, {
    "tStartMs": 32282,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "But with Claude Code,\nyou don't have to know how to code."
    } ]
  }, {
    "tStartMs": 35285,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "And you can just kind of talk to it\nin plain language. And."
    } ]
  }, {
    "tStartMs": 42417,
    "dDurationMs": 709,
    "segs": [ {
      "utf8": "No lawyer"
    } ]
  }, {
    "tStartMs": 43126,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "likes doing the same repetitive exercise\nover and over and over again."
    } ]
  }, {
    "tStartMs": 47255,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "The work can be dull."
    } ]
  }, {
    "tStartMs": 48882,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "You can make mistakes before Claude."
    } ]
  }, {
    "tStartMs": 51384,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "I had a ton of busywork."
    } ]
  }, {
    "tStartMs": 52927,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "Things I would put off\nto the end of the day, because I just knew"
    } ]
  }, {
    "tStartMs": 55263,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "it'd take a lot of time,\nbut not using the best parts of my brain."
    } ]
  }, {
    "tStartMs": 59267,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "So we put our heads together and realized\nwe might be able to use Claude to help"
    } ]
  }, {
    "tStartMs": 62937,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "get our best work done and build\nworkflows."
    } ]
  }, {
    "tStartMs": 65106,
    "dDurationMs": 4046,
    "segs": [ {
      "utf8": "It used to be that the marketing team\nwould reach out to me, maybe a day before"
    } ]
  }, {
    "tStartMs": 69152,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "a launch and say, hey, we've got this\nreally exciting launch happening tomorrow."
    } ]
  }, {
    "tStartMs": 72447,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "We're so sorry.\nThe blog post just came together."
    } ]
  }, {
    "tStartMs": 75033,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "We need you to quickly read this and flag\nanything that might be problematic."
    } ]
  }, {
    "tStartMs": 78244,
    "dDurationMs": 3754,
    "segs": [ {
      "utf8": "So, I asked,\nClaude wants to just build me a workflow."
    } ]
  }, {
    "tStartMs": 81998,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "Here's what I care about."
    } ]
  }, {
    "tStartMs": 83166,
    "dDurationMs": 3629,
    "segs": [ {
      "utf8": "And to my surprise, Claude\njust ran with it and set it up."
    } ]
  }, {
    "tStartMs": 87420,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "If I were a marketer and I needed to get\none of my blog posts reviewed,"
    } ]
  }, {
    "tStartMs": 91091,
    "dDurationMs": 2877,
    "segs": [ {
      "utf8": "I would open up this link\nto the Marketing Materials Software"
    } ]
  }, {
    "tStartMs": 93968,
    "dDurationMs": 2128,
    "segs": [ {
      "utf8": "review tool,\nwhich is pinned in my channel."
    } ]
  }, {
    "tStartMs": 96096,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "I would cut and paste."
    } ]
  }, {
    "tStartMs": 97972,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "So let me copy their blog post."
    } ]
  }, {
    "tStartMs": 100391,
    "dDurationMs": 2253,
    "segs": [ {
      "utf8": "I'm going to go back to the review tool."
    } ]
  }, {
    "tStartMs": 102644,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "I'm going to paste all that content\nand then I'm going to click"
    } ]
  }, {
    "tStartMs": 105605,
    "dDurationMs": 1543,
    "segs": [ {
      "utf8": "the Analyze Content button."
    } ]
  }, {
    "tStartMs": 107148,
    "dDurationMs": 4296,
    "segs": [ {
      "utf8": "And this is going to send Claude off\non its journey reviewing my material."
    } ]
  }, {
    "tStartMs": 112237,
    "dDurationMs": 667,
    "segs": [ {
      "utf8": "There we have it."
    } ]
  }, {
    "tStartMs": 112904,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "Review results."
    } ]
  }, {
    "tStartMs": 114155,
    "dDurationMs": 2378,
    "segs": [ {
      "utf8": "Claude is identified\nfive issues to address."
    } ]
  }, {
    "tStartMs": 116533,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "So it wants to make\nsure I focus on accuracy."
    } ]
  }, {
    "tStartMs": 120286,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "It wants to review the security claims,"
    } ]
  }, {
    "tStartMs": 123581,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "wants to make sure we have publicity\nrights on third"
    } ]
  }, {
    "tStartMs": 127001,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "party content,\nas well as partnership considerations."
    } ]
  }, {
    "tStartMs": 130755,
    "dDurationMs": 1126,
    "segs": [ {
      "utf8": "And it gave me props."
    } ]
  }, {
    "tStartMs": 131881,
    "dDurationMs": 3087,
    "segs": [ {
      "utf8": "It said what looks good\nclear the feature descriptions."
    } ]
  }, {
    "tStartMs": 135343,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "Comprehensive integration\ndetails, specific use cases."
    } ]
  }, {
    "tStartMs": 138805,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "Here are the items that require\nlegal tickets."
    } ]
  }, {
    "tStartMs": 140765,
    "dDurationMs": 542,
    "segs": [ {
      "utf8": "Review."
    } ]
  }, {
    "tStartMs": 141307,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "I'm going to click on Generate\nSlack message for legal team."
    } ]
  }, {
    "tStartMs": 144519,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "And Claude has now summarized the issues\nhere."
    } ]
  }, {
    "tStartMs": 147856,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "I'm going to click on Copy the Clipboard"
    } ]
  }, {
    "tStartMs": 150150,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "and I'm going to click\ngo to Legal Tickets to file on my ticket."
    } ]
  }, {
    "tStartMs": 153611,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "To tee it up for legal review,\nit identifies the most important issues."
    } ]
  }, {
    "tStartMs": 157615,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "It helps me prioritize."
    } ]
  }, {
    "tStartMs": 159117,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "Sort of has like a low, medium, high risk\nlevel signal."
    } ]
  }, {
    "tStartMs": 163121,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "That's based on a framework\nthat I gave it."
    } ]
  }, {
    "tStartMs": 165081,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "So it's kind of acting as my eyes\nand ears to that first pass."
    } ]
  }, {
    "tStartMs": 168710,
    "dDurationMs": 4171,
    "segs": [ {
      "utf8": "As we build these types of automations\nand in new workflows, I'm always trying"
    } ]
  }, {
    "tStartMs": 172881,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "to ensure that a human remains in the loop\nfrom the legal team."
    } ]
  }, {
    "tStartMs": 176843,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "We know that AI systems\ncan still hallucinate."
    } ]
  }, {
    "tStartMs": 179888,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "I'm still making sure\nI'm reviewing the work."
    } ]
  }, {
    "tStartMs": 182348,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "But this is really helping us move\nwith more speed and sort"
    } ]
  }, {
    "tStartMs": 184934,
    "dDurationMs": 3212,
    "segs": [ {
      "utf8": "of preemptively flagging things\nwithin the legal department."
    } ]
  }, {
    "tStartMs": 188146,
    "dDurationMs": 2044,
    "segs": [ {
      "utf8": "We're using Claude\nin so many different ways."
    } ]
  }, {
    "tStartMs": 190190,
    "dDurationMs": 4879,
    "segs": [ {
      "utf8": "So we're using it to do redlining\nexercises and commercial, matters."
    } ]
  }, {
    "tStartMs": 195069,
    "dDurationMs": 3754,
    "segs": [ {
      "utf8": "We're using Claude to help us, \nwith our conflict of interest"
    } ]
  }, {
    "tStartMs": 198823,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "policy and reviewing outside business\nactivity requests."
    } ]
  }, {
    "tStartMs": 201868,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "When people reach out to me and ask,\nhow do I get started?"
    } ]
  }, {
    "tStartMs": 205788,
    "dDurationMs": 3796,
    "segs": [ {
      "utf8": "I tell them to think of their most routine\nwork."
    } ]
  }, {
    "tStartMs": 209626,
    "dDurationMs": 3378,
    "segs": [ {
      "utf8": "Just open up Claude and give it a shot."
    } ]
  }, {
    "tStartMs": 213046,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "You really don't know what it's capable of\ndoing until you give it a shot."
    } ]
  } ]
}
