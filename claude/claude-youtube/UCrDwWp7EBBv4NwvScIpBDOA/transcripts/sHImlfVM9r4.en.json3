  }, {
    "tStartMs": 1215321,
    "dDurationMs": 2139,
    "segs": [ {
      "utf8": "you know, all of these\npractical tasks, right?"
    } ]
  }, {
    "tStartMs": 1217460,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "That are really exciting,"
    } ]
  }, {
    "tStartMs": 1218870,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "but more sort of surface level."
    } ]
  }, {
    "tStartMs": 1221540,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "I also wanna call out that"
    } ]
  }, {
    "tStartMs": 1223070,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "we're seeing an increasing\ntrend in, you know,"
