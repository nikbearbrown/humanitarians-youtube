  "events": [ {
    "tStartMs": 180,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "- It took us three months, ultimately,"
    } ]
  }, {
    "tStartMs": 1830,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "lots of people working\nday and night in the lab"
    } ]
  }, {
    "tStartMs": 3690,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "to fix the problem."
    } ]
  }, {
    "tStartMs": 4830,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "I posed this problem to Claude."
    } ]
  }, {
    "tStartMs": 6030,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "I said, \"Hey, what should\nwe do to get unstuck?\""
    } ]
  }, {
    "tStartMs": 8370,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "And just in one minute,\nyou know, one response,"
    } ]
  }, {
    "tStartMs": 10590,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "Claude actually just\none shotted the answer."
    } ]
  }, {
    "tStartMs": 13740,
    "dDurationMs": 903,
    "segs": [ {
      "utf8": "- Hi, I'm Jonah Cool."
    } ]
  }, {
    "tStartMs": 14643,
    "dDurationMs": 3297,
    "segs": [ {
      "utf8": "I am the Head of Life Sciences\nfocused on partnerships"
    } ]
  }, {
    "tStartMs": 17940,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "and deployment here at Anthropic."
    } ]
  }, {
    "tStartMs": 20070,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "- Hi, I'm Eric Kauderer-Abrams."
    } ]
  }, {
    "tStartMs": 21240,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "I'm the Head of Biology and\nLife Sciences here at Anthropic."
    } ]
  }, {
    "tStartMs": 24120,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "I'm focused on research\nand product development,"
    } ]
  }, {
    "tStartMs": 26280,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "and together we're trying to\nteach Claude to be a biologist."
    } ]
  }, {
    "tStartMs": 29700,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "- All right, Eric, let's talk science."
    } ]
  }, {
    "tStartMs": 30990,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "I'm really excited about this"
    } ]
  }, {
    "tStartMs": 32400,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "and also excited about\nthe fact that Anthropic"
    } ]
  }, {
    "tStartMs": 35160,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "and, you know, we're\nleaning into this space,"
    } ]
  }, {
    "tStartMs": 37470,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "and, you know, maybe the place to start"
    } ]
  }, {
    "tStartMs": 39090,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "is just thinking about\nwhy the life sciences,"
    } ]
  }, {
    "tStartMs": 41850,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "why Claude, and what\nAnthropic brings to, you know,"
    } ]
  }, {
    "tStartMs": 45030,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "what is already a really big ecosystem,"
    } ]
  }, {
    "tStartMs": 46980,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "but one that's moving really fast."
    } ]
  }, {
    "tStartMs": 49290,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "- Yeah, I think that's a\nreally important question."
    } ]
  }, {
    "tStartMs": 50670,
    "dDurationMs": 3510,
    "segs": [ {
      "utf8": "So I'll start with why are we\nfocused on the life sciences?"
    } ]
  }, {
    "tStartMs": 54180,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "And this goes right to\nthe heart of our mission."
    } ]
  }, {
    "tStartMs": 57480,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "I think it's something that a\nlot of people may not realize,"
    } ]
  }, {
    "tStartMs": 60060,
    "dDurationMs": 3330,
    "segs": [ {
      "utf8": "but when we talk about the\nbeneficial use cases of AI"
    } ]
  }, {
    "tStartMs": 63390,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "and all the amazing things\nthat we can do in the world"
    } ]
  }, {
    "tStartMs": 66090,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "with the frontier AI\nthat we're developing,"
    } ]
  }, {
    "tStartMs": 68160,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "actually the number one place"
    } ]
  }, {
    "tStartMs": 69780,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "that we at Anthropic are\nexcited about applying it is"
    } ]
  }, {
    "tStartMs": 72600,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "within biology and the\nlife sciences, right?"
    } ]
  }, {
    "tStartMs": 74310,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "If you read our foundational material"
    } ]
  }, {
    "tStartMs": 76440,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "and, you know, you talk to\npeople in the hallway here,"
    } ]
  }, {
    "tStartMs": 79350,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "that's the primary area\nwhere we're really focused"
    } ]
  }, {
    "tStartMs": 81960,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "on delivering the beneficial impact."
    } ]
  }, {
    "tStartMs": 84930,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "For me that's been a super\nexciting thing to come in"
    } ]
  }, {
    "tStartMs": 87870,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "and plug into is all\nof that pent up energy"
    } ]
  }, {
    "tStartMs": 90300,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "and excitement to apply everything"
    } ]
  }, {
    "tStartMs": 92220,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "that we have to this space."
    } ]
  }, {
    "tStartMs": 93900,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "And then starting to get more\nspecific in talking about"
    } ]
  }, {
    "tStartMs": 96930,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "why Claude, and how is\nour approach as Anthropic,"
    } ]
  }, {
    "tStartMs": 100200,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "you know, maybe different from\nsome of the other approaches"
    } ]
  }, {
    "tStartMs": 102210,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "that are out there."
    } ]
  }, {
    "tStartMs": 103680,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "I think there are two things\nthat that come to mind."
    } ]
  }, {
    "tStartMs": 105660,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "You know, Jonah, you and I"
    } ]
  }, {
    "tStartMs": 106620,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "have talked a lot about this,"
    } ]
  }, {
    "tStartMs": 107880,
    "dDurationMs": 4260,
    "segs": [ {
      "utf8": "but the first is that we're\ninterested in building tools"
    } ]
  }, {
    "tStartMs": 112140,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "that empower individual scientists"
    } ]
  }, {
    "tStartMs": 114600,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "and enhance the experience\nof being a scientist,"
    } ]
  }, {
    "tStartMs": 117120,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "going about your life, you know,"
    } ]
  }, {
    "tStartMs": 118260,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "doing all the work that\nyou're doing, right?"
    } ]
  }, {
    "tStartMs": 120180,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "So we want to give people\nthe same experience"
    } ]
  }, {
    "tStartMs": 121950,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "that software engineers\nhave had of, you know,"
    } ]
  }, {
    "tStartMs": 124560,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "having a brainstorming\npartner to work with"
    } ]
  }, {
    "tStartMs": 126600,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "and delegate tasks to\nthroughout the process."
    } ]
  }, {
    "tStartMs": 128730,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "We wanna bring that to\nbiologists in the lab"
    } ]
  }, {
    "tStartMs": 131670,
    "dDurationMs": 2094,
    "segs": [ {
      "utf8": "and on the computational side."
    } ]
  }, {
    "tStartMs": 133764,
    "dDurationMs": 3516,
    "segs": [ {
      "utf8": "And so our initial focus is\nreally about building tools"
    } ]
  }, {
    "tStartMs": 137280,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "that make scientists more productive."
    } ]
  }, {
    "tStartMs": 139440,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "It also makes science more fun."
    } ]
  }, {
    "tStartMs": 141360,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "Right, take away some of the\ngrunt work that, you know,"
    } ]
  }, {
    "tStartMs": 143700,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "everyone would rather get out of"
    } ]
  }, {
    "tStartMs": 145560,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "and allow you to focus more on"
    } ]
  }, {
    "tStartMs": 147090,
    "dDurationMs": 1713,
    "segs": [ {
      "utf8": "the creative high leverage side."
    } ]
  }, {
    "tStartMs": 149700,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "So that's the first part,\nand then the second one is"
    } ]
  }, {
    "tStartMs": 153060,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "we're really focused not\njust on the really exciting"
    } ]
  }, {
    "tStartMs": 155820,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "early stage discovery problems, right?"
    } ]
  }, {
    "tStartMs": 158220,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Molecule design and protein folding,"
    } ]
  }, {
    "tStartMs": 160020,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "and these, you know,\nincredibly impactful problems"
    } ]
  }, {
    "tStartMs": 161910,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "that many people in the\nfield have focused on."
    } ]
  }, {
    "tStartMs": 164580,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "But we want to address the whole spectrum"
    } ]
  }, {
    "tStartMs": 166860,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "from early stage discovery"
    } ]
  }, {
    "tStartMs": 168510,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "all the way through\ndevelopment and translation."
    } ]
  }, {
    "tStartMs": 171690,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "And so for us, that means, you know,"
    } ]
  }, {
    "tStartMs": 173400,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "breaking it down into the\nwhole world of different tasks"
    } ]
  }, {
    "tStartMs": 176370,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "that exist in the space."
    } ]
  }, {
    "tStartMs": 178620,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "Everything from, you know,\ndrafting and reviewing protocols"
    } ]
  }, {
    "tStartMs": 181410,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "and debugging them to performing\nbioinformatics analyses"
    } ]
  }, {
    "tStartMs": 184830,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "and writing up your results in slides"
    } ]
  }, {
    "tStartMs": 186930,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "and papers and that\nsort of a thing, right?"
    } ]
  }, {
    "tStartMs": 188430,
    "dDurationMs": 3153,
    "segs": [ {
      "utf8": "There's a whole world of tasks\nout there that are important,"
    } ]
  }, {
    "tStartMs": 192480,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "and we're taking a holistic\nview and addressing all of them."
    } ]
  }, {
    "tStartMs": 195360,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "- Yeah, I think it's a\nreally interesting time"
    } ]
  }, {
    "tStartMs": 198420,
    "dDurationMs": 3660,
    "segs": [ {
      "utf8": "to think about science and\nmaybe AI more generally."
    } ]
  }, {
    "tStartMs": 202080,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "And, you know, there's this\ninclination towards, you know,"
    } ]
  }, {
    "tStartMs": 204180,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "what problem will AI solve for me?"
    } ]
  }, {
    "tStartMs": 207030,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "But, you know, the way"
    } ]
  }, {
    "tStartMs": 208170,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "that I think we're thinking about it,"
    } ]
  }, {
    "tStartMs": 209640,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "the way that you just\nreally nicely described"
    } ]
  }, {
    "tStartMs": 211320,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "and the way that in \"Machines\nof Loving Grace\" is,"
    } ]
  }, {
    "tStartMs": 213780,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "maybe also thinking through"
    } ]
  }, {
    "tStartMs": 215190,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "that like slightly orthogonal\npoint, which is like,"
    } ]
  }, {
    "tStartMs": 218010,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "how do we change how we do science?"
    } ]
  }, {
    "tStartMs": 220740,
    "dDurationMs": 3930,
    "segs": [ {
      "utf8": "And that will then impact,\nyou know, solving, you know,"
    } ]
  }, {
    "tStartMs": 224670,
    "dDurationMs": 3990,
    "segs": [ {
      "utf8": "structures and molecules\nand tissues and imaging"
    } ]
  }, {
    "tStartMs": 228660,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "and starting to like\nthink through that world."
    } ]
  }, {
    "tStartMs": 231540,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "So, you know, with that in\nmind, maybe then to transition,"
    } ]
  }, {
    "tStartMs": 234180,
    "dDurationMs": 3540,
    "segs": [ {
      "utf8": "so, you know, we've seen\nthe power of Claude."
    } ]
  }, {
    "tStartMs": 237720,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "I think both of us have experienced this"
    } ]
  }, {
    "tStartMs": 239250,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "and like the delight"
    } ]
  }, {
    "tStartMs": 240360,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "and the joy in doing science with Claude"
    } ]
  }, {
    "tStartMs": 243630,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "and its current capabilities,"
    } ]
  }, {
    "tStartMs": 245610,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "but then also now starting to\nthink in the research group"
    } ]
  }, {
    "tStartMs": 248790,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "that you're leading"
    } ]
  }, {
    "tStartMs": 249623,
    "dDurationMs": 2227,
    "segs": [ {
      "utf8": "and how we advance those capabilities."
    } ]
  }, {
    "tStartMs": 251850,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "And so maybe for a minute we\ncan just chat a little bit"
    } ]
  }, {
    "tStartMs": 253950,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "about how kind of current\ncapabilities and ecosystems"
    } ]
  }, {
    "tStartMs": 257400,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "and maybe even like extended\ncontext through MCPs"
    } ]
  }, {
    "tStartMs": 260850,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "and life sciences start\nto create this base case"
    } ]
  }, {
    "tStartMs": 264030,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "and then your thoughts\non how we extend that"
    } ]
  }, {
    "tStartMs": 265680,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "and even like push it further,"
    } ]
  }, {
    "tStartMs": 266910,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "and you know, what that starts\nto look like and take shape."
    } ]
  }, {
    "tStartMs": 270480,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yeah, totally."
    } ]
  }, {
    "tStartMs": 271313,
    "dDurationMs": 1657,
    "segs": [ {
      "utf8": "So, you know, we've\ntalked about this a lot."
    } ]
  }, {
    "tStartMs": 272970,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "I think that, you know,\nit's important to crawl,"
    } ]
  }, {
    "tStartMs": 275400,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "walk, run in this space."
    } ]
  }, {
    "tStartMs": 276810,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "Right?"
    } ]
  }, {
    "tStartMs": 278695,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "There's a lot of things\nabout doing biology"
    } ]
  }, {
    "tStartMs": 280230,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "and having AI, you know,\nbe useful in science"
    } ]
  }, {
    "tStartMs": 283080,
    "dDurationMs": 1207,
    "segs": [ {
      "utf8": "that are different from\nhaving AI be useful-"
    } ]
  }, {
    "tStartMs": 284287,
    "dDurationMs": 1493,
    "segs": [ {
      "utf8": "- It is the AI space."
    } ]
  }, {
    "tStartMs": 285780,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So maybe you like to use a\nold running analogy, you know,"
    } ]
  }, {
    "tStartMs": 288060,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "you start fast,"
    } ]
  }, {
    "tStartMs": 289470,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "you pick it up in the\nmiddle and you sprint home."
    } ]
  }, {
    "tStartMs": 291390,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "So very little crawling,"
    } ]
  }, {
    "tStartMs": 292770,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "but just, you know,"
    } ]
  }, {
    "tStartMs": 293910,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "sprinting and then sprinting faster."
    } ]
  }, {
    "tStartMs": 295200,
    "dDurationMs": 2243,
    "segs": [ {
      "utf8": "- Sprinting, sprinting faster,\nthen flying in a rocket ship"
    } ]
  }, {
    "tStartMs": 297443,
    "dDurationMs": 2167,
    "segs": [ {
      "utf8": "is what we're going for here."
    } ]
  }, {
    "tStartMs": 299610,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "But you know,"
    } ]
  }, {
    "tStartMs": 300443,
    "dDurationMs": 2947,
    "segs": [ {
      "utf8": "the very base level is we\nneed Claude to be conversant"
    } ]
  }, {
    "tStartMs": 303390,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "with all of the tools"
    } ]
  }, {
    "tStartMs": 304223,
    "dDurationMs": 1597,
