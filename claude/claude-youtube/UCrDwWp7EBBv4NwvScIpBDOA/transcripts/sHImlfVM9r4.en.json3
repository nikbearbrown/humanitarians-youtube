  }, {
    "tStartMs": 1128420,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "or data analysis,"
    } ]
  }, {
    "tStartMs": 1129560,
    "dDurationMs": 3390,
    "segs": [ {
      "utf8": "it's really hard to\nhold all that expertise"
