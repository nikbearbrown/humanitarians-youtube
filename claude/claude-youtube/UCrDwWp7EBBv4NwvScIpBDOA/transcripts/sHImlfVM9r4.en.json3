    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "and our research roadmap"
    } ]
  }, {
    "tStartMs": 1209240,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "and things like that is,\nyou know, we focused a lot"
