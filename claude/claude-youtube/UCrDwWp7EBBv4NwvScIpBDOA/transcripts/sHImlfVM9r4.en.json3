  }, {
    "tStartMs": 801060,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "some of these really difficult"
    } ]
  }, {
    "tStartMs": 802260,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "R\u0026D problems we were trying to solve,"
    } ]
  }, {
    "tStartMs": 804000,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "would it have saved us?\""
    } ]
  }, {
    "tStartMs": 805290,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "And I'll never forget this"
    } ]
  }, {
    "tStartMs": 806760,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "because the very first\nhuge technical roadblock"
    } ]
  }, {
    "tStartMs": 809940,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "that we ran into when\nwe founded this company,"
    } ]
  }, {
    "tStartMs": 812280,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "there was a problem, we\nwere developing an assay,"
    } ]
  }, {
    "tStartMs": 814500,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "you know, trying to\ndetect in this case COVID."
    } ]
  }, {
    "tStartMs": 816870,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "And it wasn't working."
    } ]
  }, {
    "tStartMs": 819870,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "We were getting inhibited\nby the sample matrix"
    } ]
  }, {
    "tStartMs": 821700,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "and we couldn't figure it out, right?"
    } ]
  }, {
    "tStartMs": 822780,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "And it took us three months, ultimately,"
    } ]
  }, {
    "tStartMs": 825300,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "and, you know,"
    } ]
  }, {
    "tStartMs": 826133,
    "dDurationMs": 1357,
    "segs": [ {
      "utf8": "lots of people working\nday and night in the lab"
    } ]
  }, {
    "tStartMs": 827490,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "to fix the problem."
    } ]
  }, {
    "tStartMs": 829680,
    "dDurationMs": 2077,
    "segs": [ {
      "utf8": "And I posed this problem\nto Claude, I said,"
    } ]
  }, {
    "tStartMs": 831757,
    "dDurationMs": 3323,
    "segs": [ {
      "utf8": "\"Hey, we're trying to develop this assay,"
    } ]
  }, {
    "tStartMs": 835080,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "and we're seeing that the\nsample is inhibiting things,"
    } ]
  }, {
    "tStartMs": 838320,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "and what should we do to get unstuck?\""
    } ]
  }, {
    "tStartMs": 841110,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "And just in one minute,\nyou know, one response,"
    } ]
  }, {
    "tStartMs": 843330,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "Claude actually just\none shotted the answer,"
