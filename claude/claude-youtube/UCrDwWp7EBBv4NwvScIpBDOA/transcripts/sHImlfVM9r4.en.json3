    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "protocol optimization, you know,"
    } ]
  }, {
    "tStartMs": 879240,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "and an imperfect but helpful answer"
    } ]
  }, {
    "tStartMs": 882360,
    "dDurationMs": 1357,
    "segs": [ {
      "utf8": "is the sort of thing that we go to,"
