  }, {
    "tStartMs": 2051340,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "is I think there's still\nthis huge overhang,"
    } ]
  }, {
    "tStartMs": 2054340,
    "dDurationMs": 3330,
    "segs": [ {
      "utf8": "if you will, in terms of like\ncurrent capabilities and use,"
