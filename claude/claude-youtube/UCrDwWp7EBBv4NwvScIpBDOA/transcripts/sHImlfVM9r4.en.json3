  }, {
    "tStartMs": 1125210,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "and the complexity of biology,"
    } ]
  }, {
    "tStartMs": 1126620,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "whether it's that protocol optimization"
