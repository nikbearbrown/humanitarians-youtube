  }, {
    "tStartMs": 883717,
    "dDurationMs": 2363,
    "segs": [ {
      "utf8": "you know, the most trusted colleagues"
    } ]
  }, {
    "tStartMs": 886080,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "where they might say like,\n\"Eh, I don't know if,"
    } ]
  }, {
    "tStartMs": 888240,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "but like, this looks familiar.\""
    } ]
  }, {
    "tStartMs": 889770,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "Right? Like, I've seen\nthis problem at some point."
    } ]
  }, {
    "tStartMs": 891840,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "They're those kind of\nlike sage professors."
    } ]
  }, {
    "tStartMs": 894690,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "They're the like super sharp student,"
    } ]
  }, {
    "tStartMs": 896730,
    "dDurationMs": 1323,
    "segs": [ {
      "utf8": "you know, down the hall."
    } ]
  }, {
    "tStartMs": 898950,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "And again, it's not\nlooking for perfection,"
    } ]
  }, {
    "tStartMs": 901710,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "but it's looking to get unstuck."
    } ]
  }, {
    "tStartMs": 903420,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "It's looking to be helpful."
    } ]
  }, {
    "tStartMs": 904500,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "It's looking to just like keep you moving"
    } ]
  }, {
    "tStartMs": 906540,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "and like towards discovery,"
    } ]
  }, {
    "tStartMs": 907860,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "which is what we're\nall looking for, right?"
    } ]
  }, {
    "tStartMs": 910470,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "- Yeah, totally. Totally."
    } ]
  }, {
    "tStartMs": 911880,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "And I think the other area\nthat really jumped out for me"
    } ]
  }, {
    "tStartMs": 914280,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "early on was, you know,"
