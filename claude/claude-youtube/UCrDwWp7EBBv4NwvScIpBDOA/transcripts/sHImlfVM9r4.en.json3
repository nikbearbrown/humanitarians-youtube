  }, {
    "tStartMs": 1236120,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "and expression data and\nall sorts of things."
    } ]
  }, {
    "tStartMs": 1238460,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "And a trend that's really\ninteresting to watch is seeing,"
    } ]
  }, {
    "tStartMs": 1241310,
    "dDurationMs": 2520,
