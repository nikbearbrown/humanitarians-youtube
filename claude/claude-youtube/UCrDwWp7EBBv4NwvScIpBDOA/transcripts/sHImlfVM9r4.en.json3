  }, {
    "tStartMs": 2028390,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "Per unit that we can do, right?"
    } ]
  }, {
    "tStartMs": 2030910,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "In terms of the throughput\nof these systems."
    } ]
  }, {
    "tStartMs": 2032860,
    "dDurationMs": 3330,
    "segs": [ {
      "utf8": "So those are two themes that\nI'm increasingly excited about,"
    } ]
  }, {
    "tStartMs": 2036190,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "where, you know,"
    } ]
  }, {
    "tStartMs": 2037023,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "when you start thinking about"
    } ]
  }, {
    "tStartMs": 2037856,
    "dDurationMs": 1454,
    "segs": [ {
      "utf8": "how do we move beyond human capabilities"
    } ]
  }, {
    "tStartMs": 2039310,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "in these tasks, right?"
    } ]
  }, {
    "tStartMs": 2040360,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "At some point we're going to saturate"
    } ]
  }, {
    "tStartMs": 2041710,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "learning from human experts."
    } ]
  }, {
    "tStartMs": 2043450,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "The answer is to get\nthe data from the lab."
    } ]
  }, {
    "tStartMs": 2045340,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "- Yeah, I think this is a great theme."
    } ]
  }, {
    "tStartMs": 2048580,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "And the other thing that\nmaybe I would point to"
