  }, {
    "tStartMs": 1979340,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "and I'll review the data,\nright, in the morning.\""
    } ]
  }, {
    "tStartMs": 1981680,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "And so I think that's\ncritical for closing the loop"
    } ]
  }, {
    "tStartMs": 1984140,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "and enabling that acceleration\nthat we're talking about."
    } ]
  }, {
    "tStartMs": 1986960,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "And the other thing"
    } ]
  }, {
    "tStartMs": 1988400,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "that I think is a really important theme"
    } ]
  }, {
    "tStartMs": 1989930,
    "dDurationMs": 2618,
    "segs": [ {
      "utf8": "for our future research is in biology,"
    } ]
  }, {
    "tStartMs": 1992548,
    "dDurationMs": 3082,
    "segs": [ {
      "utf8": "as with any domain in science,\nwe have the opportunity"
    } ]
  }, {
    "tStartMs": 1995630,
    "dDurationMs": 3927,
    "segs": [ {
      "utf8": "to learn directly from real\ndata from nature, right?"
    } ]
  }, {
    "tStartMs": 1999557,
    "dDurationMs": 3603,
    "segs": [ {
      "utf8": "And so, on the one hand, we\ndo a lot of model training"
    } ]
  }, {
    "tStartMs": 2003160,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "and learning on annotations\nthat are created by humans"
    } ]
  }, {
    "tStartMs": 2006640,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "and other data sets"
    } ]
  }, {
    "tStartMs": 2007720,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "that are either curated or\ncreated by humans, right?"
    } ]
  }, {
    "tStartMs": 2009610,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "But there is an opportunity\nhere to really do"
    } ]
  }, {
    "tStartMs": 2012100,
    "dDurationMs": 1263,
    "segs": [ {
      "utf8": "sort of lab in the loop,"
    } ]
  }, {
    "tStartMs": 2014410,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "active learning from high\nthroughput bio measurements."
    } ]
  }, {
    "tStartMs": 2017500,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "And the other reason why\nbio's such a good fit for that"
    } ]
  }, {
    "tStartMs": 2019630,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "is we really, you know, are\nevery year on a scaling law"
