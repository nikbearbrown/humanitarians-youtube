  }, {
    "tStartMs": 782910,
    "dDurationMs": 1713,
    "segs": [ {
      "utf8": "And so for me, that moment was,"
    } ]
  }, {
    "tStartMs": 785640,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "at the time I was\nrunning a biotech company"
    } ]
  }, {
    "tStartMs": 788580,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "that I had founded, and I had\nthis idea that I wanted to try"
    } ]
  }, {
    "tStartMs": 792420,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "to see, \"Hey, if I had\nhad access to Claude"
    } ]
  }, {
    "tStartMs": 795540,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "when I was starting this\ncompany five years ago,"
    } ]
  }, {
    "tStartMs": 797580,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "how much time would it have saved us?"
