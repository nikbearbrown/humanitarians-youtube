  "events": [ {
    "tStartMs": 0,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "Hey, I'm Sholto."
    } ]
  }, {
    "tStartMs": 1084,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "I'm an engineer and researcher here\nat Anthropic."
    } ]
  }, {
    "tStartMs": 3545,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "Claude Opus 4.5 is our best model yet."
    } ]
  }, {
    "tStartMs": 5755,
    "dDurationMs": 1877,
    "segs": [ {
      "utf8": "It's the best in the world\nat coding,"
    } ]
  }, {
    "tStartMs": 7632,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "agentic tasks and everyday \nwork like spreadsheets."
    } ]
  }, {
    "tStartMs": 9884,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "But what's harder to show\nis how it just gets it."
    } ]
  }, {
    "tStartMs": 12595,
    "dDurationMs": 1377,
    "segs": [ {
      "utf8": "I trust this model more."
    } ]
  }, {
    "tStartMs": 13972,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "My time between interventions\nkeeps getting longer,"
    } ]
  }, {
    "tStartMs": 16558,
    "dDurationMs": 2252,
    "segs": [ {
      "utf8": "and I keep seeing colleagues\nsay it solved a bug that Sonnet"
    } ]
  }, {
    "tStartMs": 18810,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "never could have found."
    } ]
  }, {
    "tStartMs": 19978,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "The model is also more efficient"
    } ]
  }, {
    "tStartMs": 21438,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "because it knows when \nto think before acting, "
    } ]
  }, {
    "tStartMs": 23356,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "so that it makes the right change."
    } ]
  }, {
    "tStartMs": 25525,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "We’ve got this take home."
    } ]
  }, {
    "tStartMs": 26568,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "It's a two hour\nintensive engineering task."
    } ]
  }, {
    "tStartMs": 28987,
    "dDurationMs": 4296,
    "segs": [ {
      "utf8": "And in that time, the model scored higher\nthan any human ever has."
    } ]
  }, {
    "tStartMs": 33825,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "It’s also much better at front end."
    } ]
  }, {
    "tStartMs": 35035,
    "dDurationMs": 3294,
    "segs": [ {
      "utf8": "It's way better at vision, and that\nmakes it a lot better at using computers."
    } ]
  }, {
    "tStartMs": 38329,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "Opus 4.5 is available today."
    } ]
  }, {
    "tStartMs": 40915,
    "dDurationMs": 3254,
    "segs": [ {
      "utf8": "For the first time,\nit's on every major cloud platform."
    } ]
  }, {
    "tStartMs": 44169,
    "dDurationMs": 1209,
    "segs": [ {
      "utf8": "Let us know what you think."
    } ]
  } ]
}
