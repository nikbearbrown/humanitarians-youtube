{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 210,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "- Am I reading your status\nupdates then in your Slack"
    } ]
  }, {
    "tStartMs": 2760,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "and those are all Claude-generated?"
    } ]
  }, {
    "tStartMs": 4710,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "- Yeah, I'm never actually\nwriting anything anymore."
    } ]
  }, {
    "tStartMs": 7320,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "It's just all Claude.\n- It was just you reading"
    } ]
  }, {
    "tStartMs": 8220,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "Claude the whole time."
    } ]
  }, {
    "tStartMs": 9450,
    "dDurationMs": 1213,
    "segs": [ {
      "utf8": "Okay, good to know."
    } ]
  }, {
    "tStartMs": 14443,
    "dDurationMs": 1247,
    "segs": [ {
      "utf8": "- Mark."
    } ]
  }, {
    "tStartMs": 15690,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "- Hey, I'm Alex."
    } ]
  }, {
    "tStartMs": 16710,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I lead Claude Relations here at Anthropic."
    } ]
  }, {
    "tStartMs": 18990,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Today we're talking about\nMCP and the Claude API,"
    } ]
  }, {
    "tStartMs": 22110,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "and I'm joined by my colleagues."
    } ]
  }, {
    "tStartMs": 23580,
    "dDurationMs": 990,
    "segs": [ {
      "utf8": "- Hey, I'm Michael."
    } ]
  }, {
    "tStartMs": 24570,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "I'm an engineer on the API\nteam here at Anthropic."
    } ]
  }, {
    "tStartMs": 27060,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "- I'm John and I work on the\nModel Context Protocol team"
    } ]
  }, {
    "tStartMs": 29370,
    "dDurationMs": 990,
    "segs": [ {
      "utf8": "here at Anthropic."
    } ]
  }, {
    "tStartMs": 30360,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "- To kick us off here today,"
    } ]
  }, {
    "tStartMs": 32610,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "I really wanna give a high level overview"
    } ]
  }, {
    "tStartMs": 34170,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "of just what is MCP."
    } ]
  }, {
    "tStartMs": 36420,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "- MCP is the Model Context Protocol,"
    } ]
  }, {
    "tStartMs": 39510,
    "dDurationMs": 4650,
    "segs": [ {
      "utf8": "and it's a way of providing\nexternal context to models."
    } ]
  }, {
    "tStartMs": 44160,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And so if you have a chat bot"
    } ]
  }, {
    "tStartMs": 45840,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "and you're in a conversation,"
    } ]
  }, {
    "tStartMs": 47250,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "the history of your\nconversation is your context."
    } ]
  }, {
    "tStartMs": 48930,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "And the model only has the\nability to see everything"
    } ]
  }, {
    "tStartMs": 51390,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "that you've typed in,\nwhich is really useful"
    } ]
  }, {
    "tStartMs": 53340,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "for some kinds of tasks, like,"
    } ]
  }, {
    "tStartMs": 55650,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "help me solve this problem\nor write this thing."
    } ]
  }, {
    "tStartMs": 57750,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "But sometimes Claude\nneeds access to things"
    } ]
  }, {
    "tStartMs": 61170,
    "dDurationMs": 840,
    "segs": [ {
      "utf8": "outside of its box,"
    } ]
  }, {
    "tStartMs": 62010,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "like it needs to be able\nto talk to the internet,"
    } ]
  }, {
    "tStartMs": 64560,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "or it needs to be able to reach out"
    } ]
  }, {
    "tStartMs": 66450,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "to a travel agency to book your flight."
    } ]
  }, {
    "tStartMs": 68370,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And so that's kind of where MCP comes in."
    } ]
  }, {
    "tStartMs": 70290,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "It provides these external\ncontext to Claude,"
    } ]
  }, {
    "tStartMs": 72510,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "so that it can take actions\nfor you on your behalf"
    } ]
  }, {
    "tStartMs": 74850,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "in the outer world."
    } ]
  }, {
    "tStartMs": 76350,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "- Right, yeah, I've heard\na good analogy in the past"
    } ]
  }, {
    "tStartMs": 78780,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "of MCP being like the universal connector"
    } ]
  }, {
    "tStartMs": 82230,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "between applications and the model."
    } ]
  }, {
    "tStartMs": 84180,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "So a way for us to tie\nClaude into everything else"
    } ]
  }, {
    "tStartMs": 87300,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "that it might need access"
    } ]
  }, {
    "tStartMs": 88133,
    "dDurationMs": 3397,
    "segs": [ {
      "utf8": "to all the other data\nsources, tools, everything."
    } ]
  }, {
    "tStartMs": 91530,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yeah, definitely."
    } ]
  }, {
    "tStartMs": 92363,
    "dDurationMs": 2107,
    "segs": [ {
      "utf8": "- Out there on the internet, basically."
    } ]
  }, {
    "tStartMs": 94470,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Why did we build this?"
    } ]
  }, {
    "tStartMs": 95790,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "What was kind of the intention?"
    } ]
  }, {
    "tStartMs": 96870,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "I mean, it seems useful\nto have these connections,"
    } ]
  }, {
    "tStartMs": 99000,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "but why did we take that on specifically"
    } ]
  }, {
    "tStartMs": 102000,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "and why make it a universal\nstandard protocol?"
    } ]
  }, {
    "tStartMs": 104790,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "- So I think as we were starting"
    } ]
  }, {
    "tStartMs": 107010,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "to get further and\nfurther along in tool use"
    } ]
  }, {
    "tStartMs": 109680,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "and as Claude's capability,"
    } ]
  }, {
    "tStartMs": 112140,
    "dDurationMs": 870,
    "segs": [ {
      "utf8": "we were starting to notice"
    } ]
  }, {
    "tStartMs": 113010,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "that we were re-implementing\na lot of the same capabilities"
    } ]
  }, {
    "tStartMs": 115770,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "in various different contexts."
    } ]
  }, {
    "tStartMs": 117570,
    "dDurationMs": 3660,
    "segs": [ {
      "utf8": "So my assistant that I\nhad in my coding editor"
    } ]
  }, {
    "tStartMs": 121230,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "had to get a web search\ntool associated with it,"
    } ]
  }, {
    "tStartMs": 124650,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "but so did claude.ai"
    } ]
  }, {
    "tStartMs": 125940,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "and so did all these other services"
    } ]
  }, {
    "tStartMs": 127500,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "where we want Claude\nto be able to interact"
    } ]
  }, {
    "tStartMs": 129420,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "with the outside world."
    } ]
  }, {
    "tStartMs": 130740,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And we figured it would be good"
    } ]
  }, {
    "tStartMs": 132660,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "to have a single unified protocol"
    } ]
  }, {
    "tStartMs": 135450,
    "dDurationMs": 4590,
    "segs": [ {
      "utf8": "that we can implement a\nset of functionalities once"
    } ]
  }, {
    "tStartMs": 140040,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "and take that everywhere."
    } ]
  }, {
    "tStartMs": 142170,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "So build it once and configure everywhere."
    } ]
  }, {
    "tStartMs": 144660,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "So the same web search functionality"
    } ]
  }, {
    "tStartMs": 146520,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "that I might get on Claude Code"
    } ]
  }, {
    "tStartMs": 149040,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "will be the same web search functionality"
    } ]
  }, {
    "tStartMs": 150570,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "that I would get on Claude.ai."
    } ]
  }, {
    "tStartMs": 152460,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "- Okay, that makes sense."
    } ]
  }, {
    "tStartMs": 154560,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Creating that universal\ncompatibility basically"
    } ]
  }, {
    "tStartMs": 157680,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "when we have tons of applications"
    } ]
  }, {
    "tStartMs": 159210,
    "dDurationMs": 1953,
    "segs": [ {
      "utf8": "that might need these same connections."
    } ]
  }, {
    "tStartMs": 162570,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "Now, our approach to MCP\nspecifically with open sourcing,"
    } ]
  }, {
    "tStartMs": 167130,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "it was pretty different, I think,"
    } ]
  }, {
    "tStartMs": 168390,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "than a lot of other integration paths"
    } ]
  }, {
    "tStartMs": 170730,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "that other companies were\ngoing down at the time."
    } ]
  }, {
    "tStartMs": 173280,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "Why did we think to open source it?"
    } ]
  }, {
    "tStartMs": 174780,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "What was kind of the\ndriving factor behind that?"
    } ]
  }, {
    "tStartMs": 177240,
    "dDurationMs": 3660,
    "segs": [ {
      "utf8": "- I think there's a lot\nof value in open standards"
    } ]
  }, {
    "tStartMs": 180900,
    "dDurationMs": 2542,
    "segs": [ {
      "utf8": "to allow a wide network"
    } ]
  }, {
    "tStartMs": 183442,
    "dDurationMs": 3968,
    "segs": [ {
      "utf8": "of engineers, companies, individuals"
    } ]
  }, {
    "tStartMs": 187410,
    "dDurationMs": 4590,
    "segs": [ {
      "utf8": "to go and build an\necosystem around something."
    } ]
  }, {
    "tStartMs": 192000,
    "dDurationMs": 4260,
    "segs": [ {
      "utf8": "And we could have gone and\nbuilt the Claude app connector"
    } ]
  }, {
    "tStartMs": 196260,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "that allows you to tie things into Claude,"
    } ]
  }, {
    "tStartMs": 198120,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "but then you end up with a really kind of"
    } ]
  }, {
    "tStartMs": 200280,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "bad user experience for if\nyou're using multiple models."
    } ]
  }, {
    "tStartMs": 206100,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "If I'm a company like Asana"
    } ]
  }, {
    "tStartMs": 208380,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "and I want to go connect,"
    } ]
  }, {
    "tStartMs": 210120,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "do I have to go implement\nmy Claude connector"
    } ]
  }, {
    "tStartMs": 213090,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "and my open AI connector\nand my Grok connector"
    } ]
  }, {
    "tStartMs": 214920,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "and my Gemini connector,"
    } ]
  }, {
    "tStartMs": 215820,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "and that ends up being\nkind of a nightmare."
    } ]
  }, {
    "tStartMs": 217800,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "And one of the things\nthat we had noticed is"
    } ]
  }, {
    "tStartMs": 220350,
    "dDurationMs": 2563,
    "segs": [ {
      "utf8": "that models having access\nto external context"
    } ]
  }, {
    "tStartMs": 222913,
    "dDurationMs": 2207,
    "segs": [ {
      "utf8": "is kind of good for everyone."
    } ]
  }, {
    "tStartMs": 225120,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "It's like a rising tide floats\nall boats type of situation."
    } ]
  }, {
    "tStartMs": 227910,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "And we had this internal\nprotocol that was really valuable"
    } ]
  }, {
    "tStartMs": 233370,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "for us standardizing\nour model interactions."
    } ]
  }, {
    "tStartMs": 235980,
    "dDurationMs": 4260,
    "segs": [ {
      "utf8": "And so we went and open sourced\nit as a way of being like,"
    } ]
  }, {
    "tStartMs": 240240,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "hey, we found this useful,"
    } ]
  }, {
    "tStartMs": 242430,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "maybe the world would\nfind this useful also."
    } ]
  }, {
    "tStartMs": 244350,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "And it got incredibly\npopular, incredibly fast,"
    } ]
  }, {
    "tStartMs": 247230,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "it turns out a lot of people\nhad the same kind of need"
    } ]
  }, {
    "tStartMs": 250320,
    "dDurationMs": 3510,
    "segs": [ {
      "utf8": "and jumped on it and started\njust hacking together."
    } ]
  }, {
    "tStartMs": 253830,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "Even with the minimum support,"
    } ]
  }, {
    "tStartMs": 255060,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "people started hacking together"
    } ]
  }, {
    "tStartMs": 256650,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "really incredible dev environments."
    } ]
  }, {
    "tStartMs": 258900,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "And it kind of like boosted."
    } ]
  }, {
    "tStartMs": 260310,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "I think it was the fastest-growing"
    } ]
  }, {
    "tStartMs": 262890,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "open source protocol, in history."
    } ]
  }, {
    "tStartMs": 266040,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "- Wow.\n- It's been truly kind of"
    } ]
  }, {
    "tStartMs": 267990,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "stratospheric growth in there"
    } ]
  }, {
    "tStartMs": 269460,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "and there's a massive need for it."
    } ]
  }, {
    "tStartMs": 271410,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "Yeah, so we went and open sourced that,"
    } ]
  }, {
    "tStartMs": 272910,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "and since this has taken off,"
    } ]
  }, {
    "tStartMs": 275130,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "it's truly succeeded our wildest dreams"
    } ]
  }, {
    "tStartMs": 278850,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "when we're releasing this\nlittle specification."
    } ]
  }, {
    "tStartMs": 281160,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "And so we've done a lot of work\nas this is starting to move"
    } ]
  }, {
    "tStartMs": 284580,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "between a neat way for Anthropic,"
    } ]
  }, {
    "tStartMs": 287160,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "a project for Anthropic"
    } ]
  }, {
    "tStartMs": 288210,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "to go and get context to its models"
    } ]
  }, {
    "tStartMs": 290370,
    "dDurationMs": 3750,
    "segs": [ {
      "utf8": "into an industry-defining\nstandard-like ecosystem."
    } ]
  }, {
    "tStartMs": 294120,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "We've done a lot of work to go"
    } ]
  }, {
    "tStartMs": 295770,
    "dDurationMs": 4020,
    "segs": [ {
      "utf8": "and move that into a proper\nopen source foundation"
    } ]
  }, {
    "tStartMs": 299790,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "and work with all the other providers"
    } ]
  }, {
    "tStartMs": 301920,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "and make MCP something that's durable"
    } ]
  }, {
    "tStartMs": 304230,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "and is here for the long-term."
    } ]
  }, {
    "tStartMs": 306330,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "- What is the lay of the land\nactually on MCP right now,"
    } ]
  }, {
    "tStartMs": 308580,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "both in terms of the\nopen source community,"
    } ]
  }, {
    "tStartMs": 310800,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "but also the technical spec itself?"
    } ]
  }, {
    "tStartMs": 313590,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "It's been I guess almost a year,"
    } ]
  }, {
    "tStartMs": 316050,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "a little under a year since\nwe first announced it."
    } ]
  }, {
    "tStartMs": 318660,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "And I feel like a lot of folks\nstill have kind of intuitions"
    } ]
  }, {
    "tStartMs": 321390,
    "dDurationMs": 3630,
    "segs": [ {
      "utf8": "that were based in how it was,\nyou know, earlier this year"
    } ]
  }, {
    "tStartMs": 325020,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "and early 2025 or something around that."
    } ]
  }, {
    "tStartMs": 326910,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "But the protocols moving so\nfast and things are changing."
    } ]
  }, {
    "tStartMs": 329910,
    "dDurationMs": 3870,
    "segs": [ {
      "utf8": "What's the current state\nin your guys' mind of MCP?"
    } ]
  }, {
    "tStartMs": 333780,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "- I feel like a big aha\nmoment for me at least,"
    } ]
  }, {
    "tStartMs": 336960,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "was when we released remote MCP support."
    } ]
  }, {
    "tStartMs": 339810,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Some of the initial quirks of the protocol"
    } ]
  }, {
    "tStartMs": 341970,
    "dDurationMs": 3750,
    "segs": [ {
      "utf8": "were that you had to run\neverything effectively by yourself,"
    } ]
  }, {
    "tStartMs": 345720,
    "dDurationMs": 4260,
    "segs": [ {
      "utf8": "which prevented providers\nof MCP servers like Asana"
    } ]
  }, {
    "tStartMs": 349980,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "from being able to host their own servers"
    } ]
  }, {
    "tStartMs": 352980,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "that you could just\naccess very, very quickly."
    } ]
  }, {
    "tStartMs": 354930,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "And it made the setup process\nvery, very yeah, clunky."
    } ]
  }, {
    "tStartMs": 358050,
    "dDurationMs": 3210,
    "segs": [ {
      "utf8": "And I think that, yeah,\na very big step change"
    } ]
  }, {
    "tStartMs": 361260,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "in my opinion,"
    } ]
  }, {
    "tStartMs": 362093,
    "dDurationMs": 2077,
    "segs": [ {
      "utf8": "was when we kind of\nprovided first-class support"
    } ]
  }, {
    "tStartMs": 364170,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "for remote hosted MCP servers,"
    } ]
  }, {
    "tStartMs": 366900,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "that drastically reduced\nthe set of process,"
    } ]
  }, {
    "tStartMs": 369510,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "so that end users can just\nget started fairly quickly."
    } ]
  }, {
    "tStartMs": 372330,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "- And now we have a\nregistry of these servers,"
    } ]
  }, {
    "tStartMs": 374640,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "so people can actually\nupload these to the registry"
    } ]
  }, {
    "tStartMs": 377670,
    "dDurationMs": 3390,
    "segs": [ {
      "utf8": "and then we authorize them\nor we approve them and-"
    } ]
  }, {
    "tStartMs": 381060,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Yeah, totally."
    } ]
  }, {
    "tStartMs": 381893,
    "dDurationMs": 3857,
    "segs": [ {
      "utf8": "So the open source project"
    } ]
  }, {
    "tStartMs": 387000,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "has a, we've just released"
    } ]
  }, {
    "tStartMs": 388890,
    "dDurationMs": 2883,
    "segs": [ {
      "utf8": "a central registry of MCP servers."
    } ]
  }, {
    "tStartMs": 392760,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "In kind of keeping with\nthe open source ethos,"
    } ]
  }, {
    "tStartMs": 394680,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "we have both a registry"
    } ]
  }, {
    "tStartMs": 396810,
    "dDurationMs": 840,
    "segs": [ {
      "utf8": "that's hosted at"
    } ]
  }, {
    "tStartMs": 397650,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "the model contact protocol\norganization site,"
    } ]
  }, {
    "tStartMs": 400410,
    "dDurationMs": 3390,
    "segs": [ {
      "utf8": "and also a standard that\nallows other organizations"
    } ]
  }, {
    "tStartMs": 403800,
    "dDurationMs": 3063,
    "segs": [ {
      "utf8": "to extend the registry,\npull that information in."
    } ]
  }, {
    "tStartMs": 408030,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "And so we've seen massive growth of MCP,"
    } ]
  }, {
    "tStartMs": 412350,
    "dDurationMs": 4230,
    "segs": [ {
      "utf8": "GitHub MCP, Asana MCP,"
    } ]
  }, {
    "tStartMs": 416580,
    "dDurationMs": 990,
    "segs": [ {
      "utf8": "a lot of companies"
    } ]
  }, {
    "tStartMs": 417570,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "are building and\ndeploying these endpoints."
    } ]
  }, {
    "tStartMs": 420330,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "And so it's becoming easier\nto pull this in from a,"
    } ]
  }, {
    "tStartMs": 425640,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "in the past you would have to go"
    } ]
  }, {
    "tStartMs": 428100,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "and if you wanted to interact with GitHub,"
    } ]
  }, {
    "tStartMs": 430260,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "you'd have to go find\nsome random developer"
    } ]
  }, {
    "tStartMs": 433560,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "who would hack together a GitHub connector"
    } ]
  }, {
    "tStartMs": 435600,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "and then trust their Node.js install"
    } ]
  }, {
    "tStartMs": 439440,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "on your computer to go in."
    } ]
  }, {
    "tStartMs": 440580,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "And now you can just go hit\nthe official GitHub site,"
    } ]
  }, {
    "tStartMs": 444900,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "like I think it's mcp.github.com,"
    } ]
  }, {
    "tStartMs": 446760,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "you can put that into your\nClaude Code or Claude.ai"
    } ]
  }, {
    "tStartMs": 449700,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "and then extend Claude"
    } ]
  }, {
    "tStartMs": 451320,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "with the ability to interact with GitHub."
    } ]
  }, {
    "tStartMs": 453180,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "So it's really maturing in\na way that's really cool."
    } ]
  }, {
    "tStartMs": 455430,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- That's pretty cool."
    } ]
  }, {
    "tStartMs": 456263,
    "dDurationMs": 1567,
    "segs": [ {
      "utf8": "And I've been using the GitHub MCP"
    } ]
  }, {
    "tStartMs": 457830,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "for things in Claude Code as well,"
    } ]
  }, {
    "tStartMs": 459300,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "and it's nice to just have\nthat one your all endpoint"
    } ]
  }, {
    "tStartMs": 462210,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "that just plug in."
    } ]
  }, {
    "tStartMs": 463950,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "Is there any kind of fun,\nunique MCPs right now"
    } ]
  }, {
    "tStartMs": 466590,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "in the registry or outside of the registry"
    } ]
  }, {
    "tStartMs": 468990,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "that you guys have seen?"
    } ]
  }, {
    "tStartMs": 470280,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "- I think one that I think"
    } ]
  }, {
    "tStartMs": 472350,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "has been really, really\ninteresting to watch,"
    } ]
  }, {
    "tStartMs": 475110,
    "dDurationMs": 1323,
    "segs": [ {
      "utf8": "it's called Context 7."
    } ]
  }, {
    "tStartMs": 477360,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "So one of the biggest limitations"
    } ]
  }, {
    "tStartMs": 478980,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "of large language models"
    } ]
  }, {
    "tStartMs": 480000,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "is that they have a knowledge cutoff"
    } ]
  }, {
    "tStartMs": 481860,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "that's usually, you know,\ndelayed by a couple of months,"
    } ]
  }, {
    "tStartMs": 485160,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "which means that working with"
    } ]
  }, {
    "tStartMs": 486270,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "the latest and greatest packages\nas a software developer,"
    } ]
  }, {
    "tStartMs": 489390,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "sometimes difficult with LLMs,"
    } ]
  }, {
    "tStartMs": 490740,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "because they will just give\nyou outdated information."
    } ]
  }, {
    "tStartMs": 493170,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "And what Context 7 does\nis it takes care of"
    } ]
  }, {
    "tStartMs": 496410,
    "dDurationMs": 3330,
    "segs": [ {
      "utf8": "pulling documentation from these websites"
    } ]
  }, {
    "tStartMs": 499740,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "like Next.js's website"
    } ]
  }, {
    "tStartMs": 501030,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "or even our own API's website\nand keeping those up-to-date."
    } ]
  }, {
    "tStartMs": 504180,
    "dDurationMs": 840,
    "segs": [ {
      "utf8": "And all you have to do"
    } ]
  }, {
    "tStartMs": 505020,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "is configure your MCP connection once,"
    } ]
  }, {
    "tStartMs": 507840,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "and Claude will have the access to"
    } ]
  }, {
    "tStartMs": 509880,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "the latest information out there"
    } ]
  }, {
    "tStartMs": 511170,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "on whatever it is that\nyou're developing against."
    } ]
  }, {
    "tStartMs": 513960,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "- Mm, okay."
    } ]
  }, {
    "tStartMs": 515130,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "Yeah, I think I had heard of that."
    } ]
  }, {
    "tStartMs": 516720,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "So we're basically pulling in\nthe latest docs, everything,"
    } ]
  }, {
    "tStartMs": 519600,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "and I know right now we're\nalso in the mid-transition"
    } ]
  }, {
    "tStartMs": 522270,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "of a lot of folks making their\ndocs completely just raw text"
    } ]
  }, {
    "tStartMs": 525420,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "and accessible to LLMs."
    } ]
  }, {
    "tStartMs": 526980,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "So I'm assuming that's pulling from that"
    } ]
  }, {
    "tStartMs": 529050,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "same sort of information."
    } ]
  }, {
    "tStartMs": 530190,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "- Yeah, so this is like\nthe llms.txt format,"
    } ]
  }, {
    "tStartMs": 534030,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "which I've seen a lot of adoption of"
    } ]
  }, {
    "tStartMs": 537000,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "throughout the entire tech industry,"
    } ]
  }, {
    "tStartMs": 538170,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "which has been very exciting to see."
    } ]
  }, {
    "tStartMs": 539310,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "- That's cool."
    } ]
  }, {
    "tStartMs": 540810,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "Any from you, John?"
    } ]
  }, {
    "tStartMs": 541643,
    "dDurationMs": 1150,
    "segs": [ {
      "utf8": "- From from my end,"
    } ]
  }, {
    "tStartMs": 544470,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "I found it useful,"
    } ]
  }, {
    "tStartMs": 546450,
    "dDurationMs": 3630,
    "segs": [ {
      "utf8": "from my work as a software developer,"
    } ]
  }, {
    "tStartMs": 550080,
    "dDurationMs": 3990,
    "segs": [ {
      "utf8": "I really like Playwright as an MCP server,"
    } ]
  }, {
    "tStartMs": 554070,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "which allows Claude to go\nand interact with browsers"
    } ]
  }, {
    "tStartMs": 558270,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "as though it was a user clicking around."
    } ]
  }, {
    "tStartMs": 559620,
    "dDurationMs": 2493,
    "segs": [ {
      "utf8": "So if you're working on a website,"
    } ]
  }, {
    "tStartMs": 563130,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "Claude can read all your\nCSS and read your HTML,"
    } ]
  }, {
    "tStartMs": 565200,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "but it can't actually\nlook at your webpage."
    } ]
  }, {
    "tStartMs": 566790,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "But if you go and install\nthe Playwright MCP server,"
    } ]
  }, {
    "tStartMs": 569760,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "then you can have Claude\ngo look at your webpage"
    } ]
  }, {
    "tStartMs": 572220,
    "dDurationMs": 3780,
    "segs": [ {
      "utf8": "and give you advice on how\nto make it more beautiful"
    } ]
  }, {
    "tStartMs": 576000,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "or fix alignment issues."
    } ]
  }, {
    "tStartMs": 578040,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "- So it's like actually screenshots."
    } ]
  }, {
    "tStartMs": 579960,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "- Yeah, it's actually\nloading it up in a browser,"
    } ]
  }, {
    "tStartMs": 582120,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "browsing around using Playwright."
    } ]
  }, {
    "tStartMs": 584160,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "It's a Microsoft project that allows"
    } ]
  }, {
    "tStartMs": 589170,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "remote browser driving."
    } ]
  }, {
    "tStartMs": 590670,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "- What happens when you put that in a loop"
    } ]
  }, {
    "tStartMs": 592260,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "with something like Claude code?"
    } ]
  }, {
    "tStartMs": 593670,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "- Oh, you can just, you can get\nsome self-improvement loops."
    } ]
  }, {
    "tStartMs": 596730,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "If I tell Claude Code to go"
    } ]
  }, {
    "tStartMs": 598470,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "and fix an alignment problem in a header,"
    } ]
  }, {
    "tStartMs": 601260,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "it can go make some changes to my HTML,"
    } ]
  }, {
    "tStartMs": 604170,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "make some changes to my CSS,"
    } ]
  }, {
    "tStartMs": 606060,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "reload the page if necessary,\nthen go look at it again"
    } ]
  }, {
    "tStartMs": 608730,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "and be like, oh, everything looks better,"
    } ]
  }, {
    "tStartMs": 610500,
    "dDurationMs": 1875,
    "segs": [ {
      "utf8": "or that didn't fix it,"
    } ]
  }, {
    "tStartMs": 612375,
    "dDurationMs": 2595,
    "segs": [ {
      "utf8": "and it has the context of\nseeing both its changes"
    } ]
  }, {
    "tStartMs": 614970,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "and then actually being able to"
    } ]
  }, {
    "tStartMs": 616080,
    "dDurationMs": 2386,
    "segs": [ {
      "utf8": "take a screenshot of the website"
    } ]
  }, {
    "tStartMs": 618466,
    "dDurationMs": 2054,
    "segs": [ {
      "utf8": "and say, oh, this set of CSS changes"
    } ]
  }, {
    "tStartMs": 620520,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "actually led to this effect\nthat I didn't intend."
    } ]
  }, {
    "tStartMs": 623280,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "Let me roll that back\nand try a different way."
    } ]
  }, {
    "tStartMs": 625050,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "- Mm, it's a different\ntype of alignment problem."
    } ]
  }, {
    "tStartMs": 627240,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "- Yeah, the CSS alignment problem,"
    } ]
  }, {
    "tStartMs": 630660,
    "dDurationMs": 2103,
    "segs": [ {
      "utf8": "maybe it even need even a harder problem."
    } ]
  }, {
    "tStartMs": 634860,
    "dDurationMs": 1450,
    "segs": [ {
      "utf8": "Switching gears a little bit,"
    } ]
  }, {
    "tStartMs": 638190,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "if I'm a developer and I\nwanna use the the Claude API,"
    } ]
  }, {
    "tStartMs": 640530,
    "dDurationMs": 4020,
    "segs": [ {
      "utf8": "how can I use MCPs with our\nAPI and with Claude models?"
    } ]
  }, {
    "tStartMs": 644550,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "- So that's excellent question."
    } ]
  }, {
    "tStartMs": 646440,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "The canonical standard way of doing this"
    } ]
  }, {
    "tStartMs": 648690,
    "dDurationMs": 4650,
    "segs": [ {
      "utf8": "is to install the MCP\nSDK, set up your own loop,"
    } ]
  }, {
    "tStartMs": 653340,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "like you mentioned with Claude Code"
    } ]
  }, {
    "tStartMs": 655230,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "and handle connecting to any MCP server"
    } ]
  }, {
    "tStartMs": 657810,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "that you need to get connected to."
    } ]
  }, {
    "tStartMs": 659910,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "But it's essentially your responsibility"
    } ]
  }, {
    "tStartMs": 661500,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "as a software developer to put\ntogether all the glue work,"
    } ]
  }, {
    "tStartMs": 664380,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "which is great and it works."
    } ]
  }, {
    "tStartMs": 666270,
    "dDurationMs": 3290,
    "segs": [ {
      "utf8": "But what we recently released\ndirectly into the API"
    } ]
  }, {
    "tStartMs": 669560,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "as a native feature is\nthe MCP connector feature,"
    } ]
  }, {
    "tStartMs": 672840,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "which allows you to just specify"
    } ]
  }, {
    "tStartMs": 674400,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "where your remote MCPs\nlive, like mcp.github.com,"
    } ]
  }, {
    "tStartMs": 678360,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "and provide us with whatever\nauthorization information"
    } ]
  }, {
    "tStartMs": 681210,
    "dDurationMs": 3780,
    "segs": [ {
      "utf8": "and we can take care of that calling loop"
    } ]
  }, {
    "tStartMs": 684990,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "of executing the tools"
    } ]
  }, {
    "tStartMs": 686100,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "and getting the results fed\nback to the model for you."
    } ]
  }, {
    "tStartMs": 688500,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "So all you really have to\ndo is send a single API call"
    } ]
  }, {
    "tStartMs": 691020,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "that says like, give me\nmy latest pull requests."
    } ]
  }, {
    "tStartMs": 693870,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "and it will go ahead and\ntake care of that for you."
    } ]
  }, {
    "tStartMs": 696120,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- That's awesome, yeah,"
    } ]
  }, {
    "tStartMs": 696953,
    "dDurationMs": 1237,
    "segs": [ {
      "utf8": "I've been hearing from a lot of developers"
    } ]
  }, {
    "tStartMs": 698190,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "that they've just been able\nto delete tons of code,"
    } ]
  }, {
    "tStartMs": 700500,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "because they just have that\nso they don't have to handle"
    } ]
  }, {
    "tStartMs": 703140,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "all that back and forth themselves now,"
    } ]
  }, {
    "tStartMs": 705450,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "just like passing the\nURL and to the end point"
    } ]
  }, {
    "tStartMs": 707790,
    "dDurationMs": 2193,
    "segs": [ {
      "utf8": "and then you're kind of good to go."
    } ]
  }, {
    "tStartMs": 711210,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "What are some other tips\nfor developers using MCP?"
    } ]
  }, {
    "tStartMs": 714510,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "- I think that the main one\nthat I try to give developers"
    } ]
  }, {
    "tStartMs": 718710,
    "dDurationMs": 4830,
    "segs": [ {
      "utf8": "when I talk is that MCP servers and tools"
    } ]
  }, {
    "tStartMs": 723540,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "are really at its core prompts."
    } ]
  }, {
    "tStartMs": 725640,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And so we've kind of learned"
    } ]
  }, {
    "tStartMs": 727560,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "that if you're writing\nAI-powered applications,"
    } ]
  }, {
    "tStartMs": 730530,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "it's really important to\nbe careful and precise"
    } ]
  }, {
    "tStartMs": 732480,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "about the language that you use"
    } ]
  }, {
    "tStartMs": 733620,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "when you're prompting the model."
    } ]
  }, {
    "tStartMs": 735630,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "This extends to everything\nabout defining your MCP server,"
    } ]
  }, {
    "tStartMs": 740880,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "like defining your tool\nnames appropriately,"
    } ]
  }, {
    "tStartMs": 743460,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "giving them descriptions."
    } ]
  }, {
    "tStartMs": 745290,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Maybe your description\nhas a few short examples"
    } ]
  }, {
    "tStartMs": 748290,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "in the description of how to use it,"
    } ]
  }, {
    "tStartMs": 750450,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "giving appropriate parameter names."
    } ]
  }, {
    "tStartMs": 752940,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "This is all stuff that's gonna\naffect your model's behavior"
    } ]
  }, {
    "tStartMs": 756420,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "when it interacts with the MCP server."
    } ]
  }, {
    "tStartMs": 758310,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "An example though that I had was"
    } ]
  }, {
    "tStartMs": 760020,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "I was making an image generation server"
    } ]
  }, {
    "tStartMs": 761610,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "and I had a tool called Generate Image,"
    } ]
  }, {
    "tStartMs": 763770,
    "dDurationMs": 3630,
    "segs": [ {
      "utf8": "and then it had a field called\nDescription, and that's it."
    } ]
  }, {
    "tStartMs": 767400,
    "dDurationMs": 1447,
    "segs": [ {
      "utf8": "And then, you tell Claude like,"
    } ]
  }, {
    "tStartMs": 768847,
    "dDurationMs": 1733,
    "segs": [ {
      "utf8": "\"Hey, generate me an\nimage of a cute puppy,\""
    } ]
  }, {
    "tStartMs": 770580,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "and it'll go along, call the tool,"
    } ]
  }, {
    "tStartMs": 772830,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "be like, \"Description, cute puppy.\""
    } ]
  }, {
    "tStartMs": 775050,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "Great."
    } ]
  }, {
    "tStartMs": 776430,
    "dDurationMs": 927,
    "segs": [ {
      "utf8": "If you go and change that,"
    } ]
  }, {
    "tStartMs": 777357,
    "dDurationMs": 1266,
    "segs": [ {
      "utf8": "and you say like,"
    } ]
  }, {
    "tStartMs": 779587,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "\"This tool calls the XXX\ndiffusion model, version Y"
    } ]
  }, {
    "tStartMs": 784680,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "and should be prompted in\nthis style for best results,\""
    } ]
  }, {
    "tStartMs": 790710,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "use this kind of descriptive language,"
    } ]
  }, {
    "tStartMs": 792270,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "do all of this."
    } ]
  }, {
    "tStartMs": 793650,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "Claude has information about"
    } ]
  }, {
    "tStartMs": 794880,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "how to interact with these systems"
    } ]
  }, {
    "tStartMs": 796140,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "and it just needs to be told,"
    } ]
  }, {
    "tStartMs": 798030,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "oh great, I know that I'm\ntalking to a diffusion model now,"
    } ]
  }, {
    "tStartMs": 800130,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "I'm gonna change my language,"
    } ]
  }, {
    "tStartMs": 801240,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "what I'm gonna use in this prompt,"
    } ]
  }, {
    "tStartMs": 802650,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "and it's gonna go and instead\nof asking for a cute puppy,"
    } ]
  }, {
    "tStartMs": 805830,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "it's just gonna give\nyou a much more detailed"
    } ]
  }, {
    "tStartMs": 808470,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "diffusion model prompt that'll\ngive you much better results."
    } ]
  }, {
    "tStartMs": 811320,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "You get much better results\nfrom your MCP server"
    } ]
  }, {
    "tStartMs": 814290,
    "dDurationMs": 3660,
    "segs": [ {
      "utf8": "just by changing a few\nwords in your description"
    } ]
  }, {
    "tStartMs": 817950,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "or your prompt name."
    } ]
  }, {
    "tStartMs": 819240,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Just the same as you get better results"
    } ]
  }, {
    "tStartMs": 821160,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "writing pull requests"
    } ]
  }, {
    "tStartMs": 822840,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "or doing any sort of\nknowledge work with Claude"
    } ]
  }, {
    "tStartMs": 824520,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "that you would by tweaking those."
    } ]
  }, {
    "tStartMs": 827820,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "- I mean I myself forget\nthis all the time,"
    } ]
  }, {
    "tStartMs": 829950,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "that when you're dealing with a tool"
    } ]
  }, {
    "tStartMs": 832590,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "or some sort of description in isolation"
    } ]
  }, {
    "tStartMs": 834900,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "as you're working on a new feature"
    } ]
  }, {
    "tStartMs": 836790,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "for some, you know, AI app,"
    } ]
  }, {
    "tStartMs": 839820,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "it all gets pulled back\ninto the same prompt, right?"
    } ]
  }, {
    "tStartMs": 842190,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "And it's all just like one text\nstring at the end of the day"
    } ]
  }, {
    "tStartMs": 845160,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "that's getting fed into\nthe model in each request."
    } ]
  }, {
    "tStartMs": 847830,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "And yeah, that's good advice that like,"
    } ]
  }, {
    "tStartMs": 849600,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "hey, that's part of the prompt too."
    } ]
  }, {
    "tStartMs": 851700,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "The description that\nyou're writing in some JSON"
    } ]
  }, {
    "tStartMs": 853710,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "somewhere in your code is still gonna be"
    } ]
  }, {
    "tStartMs": 855900,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "pulled into that same prompt\nthat gets sent to Claude"
    } ]
  }, {
    "tStartMs": 858900,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "on the request."
    } ]
  }, {
    "tStartMs": 860550,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "Let's talk a little bit about\ncontext management as well"
    } ]
  }, {
    "tStartMs": 863160,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "and dealing with lots of\ntools and lots of results."
    } ]
  }, {
    "tStartMs": 865830,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I mean, this is a huge\nproblem for LLMs right now"
    } ]
  }, {
    "tStartMs": 868230,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "in terms of polluting the context."
    } ]
  }, {
    "tStartMs": 870630,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "Curious if you have any thoughts there"
    } ]
  }, {
    "tStartMs": 871890,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "on how developers should\nthink about that with MCP?"
    } ]
  }, {
    "tStartMs": 875010,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "- Yeah, so I think a big anti-pattern"
    } ]
  }, {
    "tStartMs": 877470,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "that we've seen a lot of developers make"
    } ]
  }, {
    "tStartMs": 879900,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "is just stuffing their MCP\nservers or their API requests"
    } ]
  }, {
    "tStartMs": 883980,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "with MCP servers with just tons of tools"
    } ]
  }, {
    "tStartMs": 886500,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "or tons of MCP servers,"
    } ]
  }, {
    "tStartMs": 888210,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "which not only gets expensive,"
    } ]
  }, {
    "tStartMs": 889890,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "because you're just generating tokens"
    } ]
  }, {
    "tStartMs": 891540,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "for every single one that you're adding,"
    } ]
  }, {
    "tStartMs": 893340,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "but also has a tendency\nof confusing the model."
    } ]
  }, {
    "tStartMs": 895950,
    "dDurationMs": 3210,
    "segs": [ {
      "utf8": "An example is if you\nconnect both your linear"
    } ]
  }, {
    "tStartMs": 899160,
    "dDurationMs": 2990,
    "segs": [ {
      "utf8": "and your Asana task management MCP servers"
    } ]
  }, {
    "tStartMs": 902150,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "in the same request,"
    } ]
  }, {
    "tStartMs": 903390,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "both of those might have a\nget project status MCP tool"
    } ]
  }, {
    "tStartMs": 908700,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "and the model will not have\nan implicit information"
    } ]
  }, {
    "tStartMs": 911190,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "about which one of them\nto use in which context."
    } ]
  }, {
    "tStartMs": 913320,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "But beyond that, you're just,"
    } ]
  }, {
    "tStartMs": 915000,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "yeah, you're essentially\nconfusing the model"
    } ]
  }, {
    "tStartMs": 917130,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "by giving it potentially\nconflicting information."
    } ]
  }, {
    "tStartMs": 919590,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "So just being very, very\ncareful and deterministic"
    } ]
  }, {
    "tStartMs": 923040,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "about which tools you add,"
    } ]
  }, {
    "tStartMs": 925620,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "making sure that they\nergonomics around them"
    } ]
  }, {
    "tStartMs": 927360,
    "dDurationMs": 870,
    "segs": [ {
      "utf8": "also makes sense"
    } ]
  }, {
    "tStartMs": 928230,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "and that using those\ntools feels natural to you"
    } ]
  }, {
    "tStartMs": 930870,
    "dDurationMs": 2103,
    "segs": [ {
      "utf8": "if you are getting to use them yourself."
    } ]
  }, {
    "tStartMs": 933810,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "But beyond that, making sure that you,"
    } ]
  }, {
    "tStartMs": 936180,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "yeah, just don't include any information"
    } ]
  }, {
    "tStartMs": 938580,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "that might not necessarily\nhelp with the current turn"
    } ]
  }, {
    "tStartMs": 941520,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "of user prompts."
    } ]
  }, {
    "tStartMs": 942720,
    "dDurationMs": 2350,
    "segs": [ {
      "utf8": "So sometimes older parts\nof the conversation"
    } ]
  }, {
    "tStartMs": 945930,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "that might involve very\nintroductory information,"
    } ]
  }, {
    "tStartMs": 947880,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "like, you know, what's the weather today?"
    } ]
  }, {
    "tStartMs": 950820,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Might not be as relevant\nmuch, much later on"
    } ]
  }, {
    "tStartMs": 952820,
    "dDurationMs": 1030,
    "segs": [ {
      "utf8": "in the conversation"
    } ]
  }, {
    "tStartMs": 953850,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "when you are moving on to the latest news"
    } ]
  }, {
    "tStartMs": 956460,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "or some other information\nthat you need from the model."
    } ]
  }, {
    "tStartMs": 958860,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "- Hm, I often get asked,"
    } ]
  }, {
    "tStartMs": 960690,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "how many tools can pass into Claude?"
    } ]
  }, {
    "tStartMs": 962340,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "Or how many MCP servers\ncan I hook up at one time?"
    } ]
  }, {
    "tStartMs": 965610,
    "dDurationMs": 3630,
    "segs": [ {
      "utf8": "And it seems like it's not\nso much a number question,"
    } ]
  }, {
    "tStartMs": 969240,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "rather, it's like a, how\ndistinct are the tools"
    } ]
  }, {
    "tStartMs": 972270,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "from each other and how\nwell-defined and scoped out."
    } ]
  }, {
    "tStartMs": 974820,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "Is that correct"
    } ]
  }, {
    "tStartMs": 975653,
    "dDurationMs": 3637,
    "segs": [ {
      "utf8": "or is there also kind of like\na absolute number of MCPs?"
    } ]
  }, {
    "tStartMs": 979290,
    "dDurationMs": 3900,
    "segs": [ {
      "utf8": "- I think you also end up\nwith an absolute number."
    } ]
  }, {
    "tStartMs": 983190,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "If your context window is X tokens,"
    } ]
  }, {
    "tStartMs": 985530,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "each server is gonna pull in a number"
    } ]
  }, {
    "tStartMs": 988290,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "of function definitions."
    } ]
  }, {
    "tStartMs": 989610,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Each of those is gonna eat it up."
    } ]
  }, {
    "tStartMs": 990690,
    "dDurationMs": 3750,
    "segs": [ {
      "utf8": "So you're gonna just start."
    } ]
  }, {
    "tStartMs": 994440,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "As you give LLMs more information,"
    } ]
  }, {
    "tStartMs": 996120,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "it makes it harder for them\nto make good decisions."
    } ]
  }, {
    "tStartMs": 998820,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "And so even though it will\nprobably work if you hook up"
    } ]
  }, {
    "tStartMs": 1002180,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "to a bunch of servers,"
    } ]
  }, {
    "tStartMs": 1004250,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "it'll probably work better if\nyou can give Claude a subset"
    } ]
  }, {
    "tStartMs": 1007100,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "that's relevant to the\ntask that it's looking at."
    } ]
  }, {
    "tStartMs": 1009920,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "One other point coming out here\nfrom what Michael was saying"
    } ]
  }, {
    "tStartMs": 1011990,
    "dDurationMs": 2463,
    "segs": [ {
      "utf8": "is if you're designing an MCP server,"
    } ]
  }, {
    "tStartMs": 1016010,
    "dDurationMs": 4950,
    "segs": [ {
      "utf8": "generally if you can have one\nor two tools in your server"
    } ]
  }, {
    "tStartMs": 1020960,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "versus having 15 or 20 tools,"
    } ]
  }, {
    "tStartMs": 1024560,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "it'll help the model a lot."
    } ]
  }, {
    "tStartMs": 1026840,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "And so it's sometimes"
    } ]
  }, {
    "tStartMs": 1031640,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "MCP interface development"
    } ]
  }, {
    "tStartMs": 1034640,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "is a bit different than API development"
    } ]
  }, {
    "tStartMs": 1037130,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "where we're feeding these into LLMs."
    } ]
  }, {
    "tStartMs": 1038870,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "And if you give a tool a description"
    } ]
  }, {
    "tStartMs": 1042950,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "that maybe takes some natural language"
    } ]
  }, {
    "tStartMs": 1044060,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "or has as part of filling\nout the parameters,"
    } ]
  }, {
    "tStartMs": 1046370,
    "dDurationMs": 1557,
    "segs": [ {
      "utf8": "the model's gonna make some decisions"
    } ]
  }, {
    "tStartMs": 1047927,
    "dDurationMs": 3933,
    "segs": [ {
      "utf8": "and generates some text,\nyou can maybe get away with"
    } ]
  }, {
    "tStartMs": 1051860,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "instead of an API where you'd be like,"
    } ]
  }, {
    "tStartMs": 1053810,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "get projects, get posts, get users."
    } ]
  }, {
    "tStartMs": 1056960,
    "dDurationMs": 3603,
    "segs": [ {
      "utf8": "You might just have a get info tool,"
    } ]
  }, {
    "tStartMs": 1061670,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "because you're calling LLM will be able to"
    } ]
  }, {
    "tStartMs": 1063890,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "look at your description"
    } ]
  }, {
    "tStartMs": 1065390,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "and fill out whatever\ninformation it needs."
    } ]
  }, {
    "tStartMs": 1067010,
    "dDurationMs": 4260,
    "segs": [ {
      "utf8": "And that way you can provide\na much smaller set of tools,"
    } ]
  }, {
    "tStartMs": 1071270,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "you will both play nicer\nwith other MCP servers"
    } ]
  }, {
    "tStartMs": 1073460,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "and you'll ensure that\nyour server gets called"
    } ]
  }, {
    "tStartMs": 1076490,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "more efficiently appropriately."
    } ]
  }, {
    "tStartMs": 1077990,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "- Right, so it's not always\na one-to-one translation."
    } ]
  }, {
    "tStartMs": 1080660,
    "dDurationMs": 3330,
    "segs": [ {
      "utf8": "There's different levels of\nabstraction that you can apply"
    } ]
  }, {
    "tStartMs": 1083990,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "and perhaps the API spec is\nnot the best-defined thing"
    } ]
  }, {
    "tStartMs": 1088430,
    "dDurationMs": 2043,
    "segs": [ {
      "utf8": "for the model to take in either, yeah."
    } ]
  }, {
    "tStartMs": 1092240,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "So you guys live and breathe MCP"
    } ]
  }, {
    "tStartMs": 1094310,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "all day every day, basically."
    } ]
  }, {
    "tStartMs": 1096440,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "How are you guys using\nit, whether it's at work"
    } ]
  }, {
    "tStartMs": 1098840,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "or whether it's at home or\nside project or anything else?"
    } ]
  }, {
    "tStartMs": 1103040,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "I know the example of Playwright,"
    } ]
  }, {
    "tStartMs": 1104540,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "but is there other ways"
    } ]
  }, {
    "tStartMs": 1105500,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "that you guys are experimenting\nwith MCP on the side?"
    } ]
  }, {
    "tStartMs": 1107660,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "- One of the biggest use cases\nthat I've found personally"
    } ]
  }, {
    "tStartMs": 1109640,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "is Anthropic is often\nan information highway."
    } ]
  }, {
    "tStartMs": 1112880,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "There's just so much\ninformation all over the place"
    } ]
  }, {
    "tStartMs": 1115310,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "between our Slack and our\ndocs and our code base"
    } ]
  }, {
    "tStartMs": 1118400,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "and getting the latest\nstatus on how the project"
    } ]
  }, {
    "tStartMs": 1121550,
    "dDurationMs": 3210,
    "segs": [ {
      "utf8": "that I'm currently on is going\nis not often very, very easy"
    } ]
  }, {
    "tStartMs": 1124760,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "to understand from just a single source."
    } ]
  }, {
    "tStartMs": 1127400,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "So what I've gotten in the habit of doing"
    } ]
  }, {
    "tStartMs": 1129230,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "is I will either on Claude\nAR or on Claude code"
    } ]
  }, {
    "tStartMs": 1132230,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "set up my MCP servers to connect"
    } ]
  }, {
    "tStartMs": 1134000,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "to all these various locations"
    } ]
  }, {
    "tStartMs": 1135710,
    "dDurationMs": 1447,
    "segs": [ {
      "utf8": "and I'll just ask it,"
    } ]
  }, {
    "tStartMs": 1137157,
    "dDurationMs": 3263,
    "segs": [ {
      "utf8": "\"Hey, here's a couple of\nexamples of past project updates"
    } ]
  }, {
    "tStartMs": 1140420,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "that I've written myself."
    } ]
  }, {
    "tStartMs": 1141620,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "Can you go find information\nfrom the last week"
    } ]
  }, {
    "tStartMs": 1144410,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "and generate a status update\nusing the same exact format?\""
    } ]
  }, {
    "tStartMs": 1148730,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "And I would say that\nthe success rate on that"
    } ]
  }, {
    "tStartMs": 1151730,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "is much, much higher than\nI originally thought."
    } ]
  }, {
    "tStartMs": 1153620,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "- Am I reading your status\nupdates then in your Slack"
    } ]
  }, {
    "tStartMs": 1156200,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "and those are all Claude-generated?"
    } ]
  }, {
    "tStartMs": 1157760,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "- Yeah, I'm never actually\nwriting anything anymore."
    } ]
  }, {
    "tStartMs": 1160760,
    "dDurationMs": 900,
    "segs": [ {
      "utf8": "It's just all Claude.\n- It was just you reading"
    } ]
  }, {
    "tStartMs": 1161660,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "Claude the whole time."
    } ]
  }, {
    "tStartMs": 1162830,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "Okay, good to know."
    } ]
  }, {
    "tStartMs": 1164420,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "How about you John?"
    } ]
  }, {
    "tStartMs": 1165650,
    "dDurationMs": 4380,
    "segs": [ {
      "utf8": "- I found a couple of\nangles from hacking around"
    } ]
  }, {
    "tStartMs": 1170030,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "my home hardware."
    } ]
  }, {
    "tStartMs": 1171290,
    "dDurationMs": 4530,
    "segs": [ {
      "utf8": "I have some MCP servers\nrunning on my home network"
    } ]
  }, {
    "tStartMs": 1175820,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "that can control things around my house."
    } ]
  }, {
    "tStartMs": 1178220,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "And so I can go and in a\nconversation with Claude,"
    } ]
  }, {
    "tStartMs": 1180680,
    "dDurationMs": 4530,
    "segs": [ {
      "utf8": "be like, \"Hey, did I leave my\ndoor unlocked this morning?\""
    } ]
  }, {
    "tStartMs": 1185210,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "And Claude can say, \"Yeah, your\ndoor is currently unlocked,"
    } ]
  }, {
    "tStartMs": 1188180,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "would you like me to lock it for you?\""
    } ]
  }, {
    "tStartMs": 1189320,
    "dDurationMs": 2787,
    "segs": [ {
      "utf8": "And come back and be like,\n\"Yeah, that'd be great.\""
    } ]
  }, {
    "tStartMs": 1193220,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "That sort of thing's really useful,"
    } ]
  }, {
    "tStartMs": 1195170,
    "dDurationMs": 1430,
    "segs": [ {
      "utf8": "kind of fun to play with it."
    } ]
  }, {
    "tStartMs": 1196600,
    "dDurationMs": 2230,
    "segs": [ {
      "utf8": "It kind of feels like a sneak peek"
    } ]
  }, {
    "tStartMs": 1198830,
    "dDurationMs": 4380,
    "segs": [ {
      "utf8": "into what the future\nworld might look like."
    } ]
  }, {
    "tStartMs": 1203210,
    "dDurationMs": 4050,
    "segs": [ {
      "utf8": "There's kind of a magical\nfeeling with MCP servers,"
    } ]
  }, {
    "tStartMs": 1207260,
    "dDurationMs": 3210,
    "segs": [ {
      "utf8": "because you get these sort of"
    } ]
  }, {
    "tStartMs": 1210470,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "emergent properties from adding them"
    } ]
  }, {
    "tStartMs": 1212870,
    "dDurationMs": 3903,
    "segs": [ {
      "utf8": "that you might not expect."
    } ]
  }, {
    "tStartMs": 1218540,
    "dDurationMs": 2170,
    "segs": [ {
      "utf8": "An example of this is"
    } ]
  }, {
    "tStartMs": 1221900,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "when we were very first\ntime we started playing"
    } ]
  }, {
    "tStartMs": 1223670,
    "dDurationMs": 4890,
    "segs": [ {
      "utf8": "with MCP servers, I built\na knowledge graph server"
    } ]
  }, {
    "tStartMs": 1228560,
    "dDurationMs": 2535,
    "segs": [ {
      "utf8": "with some of my colleagues\nhere at Anthropic."
    } ]
  }, {
    "tStartMs": 1231095,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "- A knowledge graph in this case is?"
    } ]
  }, {
    "tStartMs": 1232695,
    "dDurationMs": 1515,
    "segs": [ {
      "utf8": "- A knowledge graph, meaning"
    } ]
  }, {
    "tStartMs": 1235310,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "we wanted to give Claude\nthe ability to take memories"
    } ]
  }, {
    "tStartMs": 1238190,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "and form connections between memories."
    } ]
  }, {
    "tStartMs": 1240260,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "And so it's an MCP server\nthat had two tools."
    } ]
  }, {
    "tStartMs": 1243050,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "It's a create memory tool"
    } ]
  }, {
    "tStartMs": 1244610,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "and a connect memory to other memory tool"
    } ]
  }, {
    "tStartMs": 1247130,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "and the simplest possible interface."
    } ]
  }, {
    "tStartMs": 1249440,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "And we hooked this up to Claude,"
    } ]
  }, {
    "tStartMs": 1251660,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "and suddenly you'd have\nconversations with Claude"
    } ]
  }, {
    "tStartMs": 1254060,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "and it would enter\ninvestigative journalist mode"
    } ]
  }, {
    "tStartMs": 1256940,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "where I'd say like, \"I play piano.\""
    } ]
  }, {
    "tStartMs": 1259940,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "And Claude would be like,"
    } ]
  }, {
    "tStartMs": 1260773,
    "dDurationMs": 1327,
    "segs": [ {
      "utf8": "\"That's amazing, what\ndo you like to play?\""
    } ]
  }, {
    "tStartMs": 1262100,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "And it's, I'm like, \"I\nlike to play Rachmaninoff.\""
    } ]
  }, {
    "tStartMs": 1264050,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "And it's like, \"Is there anything"
    } ]
  }, {
    "tStartMs": 1266180,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "that's your favorite there?\""
    } ]
  }, {
    "tStartMs": 1267620,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "And I'd look at the knowledge graph"
    } ]
  }, {
    "tStartMs": 1269120,
    "dDurationMs": 2317,
    "segs": [ {
      "utf8": "and Claude is going and\nscribbling down and be like,"
    } ]
  }, {
    "tStartMs": 1271437,
    "dDurationMs": 2153,
    "segs": [ {
      "utf8": "\"User has sophisticated\nclassical music taste,\""
    } ]
  }, {
    "tStartMs": 1273590,
    "dDurationMs": 3425,
    "segs": [ {
      "utf8": "and it's trying to find,\nit's skilled in instruments"
    } ]
  }, {
    "tStartMs": 1277015,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "and that's just from such a\nsmall change that you provided."
    } ]
  }, {
    "tStartMs": 1282770,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "And one of the really cool things"
    } ]
  }, {
    "tStartMs": 1284630,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "with having MCP as a protocol"
    } ]
  }, {
    "tStartMs": 1286550,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "is if you hook in your Gmail server"
    } ]
  }, {
    "tStartMs": 1290630,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "with your home automation server,"
    } ]
  }, {
    "tStartMs": 1293210,
    "dDurationMs": 4470,
    "segs": [ {
      "utf8": "then maybe you can go\nand Claude can figure out"
    } ]
  }, {
    "tStartMs": 1297680,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "some way to solve a\nproblem that you ask it,"
    } ]
  }, {
    "tStartMs": 1299360,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "by connecting those two together"
    } ]
  }, {
    "tStartMs": 1300530,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "you might never have thought of."
    } ]
  }, {
    "tStartMs": 1301730,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "- Right, yeah, there's kind\nof that fuzzy in between"
    } ]
  }, {
    "tStartMs": 1304850,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "when these things all get hooked together"
    } ]
  }, {
    "tStartMs": 1306650,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "where pair that with Claude's\nkinda general intelligence"
    } ]
  }, {
    "tStartMs": 1309920,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "and interesting things can happen."
    } ]
  }, {
    "tStartMs": 1312020,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "- And it's like one of the\ncore differences between MCP"
    } ]
  }, {
    "tStartMs": 1314810,
    "dDurationMs": 3510,
    "segs": [ {
      "utf8": "and traditional-structured APIs"
    } ]
  }, {
    "tStartMs": 1318320,
    "dDurationMs": 3390,
    "segs": [ {
      "utf8": "where because everything is so fuzzy"
    } ]
  }, {
    "tStartMs": 1321710,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "and because the LLMs are smart enough"
    } ]
  }, {
    "tStartMs": 1323360,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "to just kind of smush it together,"
    } ]
  }, {
    "tStartMs": 1325730,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "you care a lot less about contracts."
    } ]
  }, {
    "tStartMs": 1327950,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "There's this interesting property"
    } ]
  }, {
    "tStartMs": 1329060,
    "dDurationMs": 4380,
    "segs": [ {
      "utf8": "where if I have an MCP server\nfor interacting with Gmail"
    } ]
  }, {
    "tStartMs": 1333440,
    "dDurationMs": 4170,
    "segs": [ {
      "utf8": "and then I go and I do some evals"
    } ]
  }, {
    "tStartMs": 1337610,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "and I find a better set\nof tools and descriptions"
    } ]
  }, {
    "tStartMs": 1339800,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "to interact with Gmail"
    } ]
  }, {
    "tStartMs": 1341030,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "and it changes it from 15 tools\nwith a set of descriptions"
    } ]
  }, {
    "tStartMs": 1343820,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "to two tools with the other one,"
    } ]
  }, {
    "tStartMs": 1345710,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "I don't have to go and\nroll out a new version"
    } ]
  }, {
    "tStartMs": 1347960,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "of my API for that."
    } ]
  }, {
    "tStartMs": 1348793,
    "dDurationMs": 2047,
    "segs": [ {
      "utf8": "If you're changing your API\nin a massive way like that-"
    } ]
  }, {
    "tStartMs": 1350840,
    "dDurationMs": 1770,
    "segs": [ {
