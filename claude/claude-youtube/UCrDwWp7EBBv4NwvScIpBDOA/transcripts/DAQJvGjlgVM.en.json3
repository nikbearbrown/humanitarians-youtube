  "events": [ {
    "tStartMs": 300,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "- These developers tend to like to run"
    } ]
  }, {
    "tStartMs": 1890,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "multiple Claude sessions at once,"
    } ]
  }, {
    "tStartMs": 4020,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "and they've started calling\nthis multi-Clauding."
    } ]
  }, {
    "tStartMs": 7020,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "So you might see sessions"
    } ]
  }, {
    "tStartMs": 8340,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "where people have like six Claudes open"
    } ]
  }, {
    "tStartMs": 10890,
    "dDurationMs": 1803,
    "segs": [ {
      "utf8": "on their computer at the same time."
    } ]
  }, {
    "tStartMs": 16380,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Hey, I'm Alex."
    } ]
  }, {
    "tStartMs": 17213,
    "dDurationMs": 2107,
    "segs": [ {
      "utf8": "I lead Claude Relations here at Anthropic."
    } ]
  }, {
    "tStartMs": 19320,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "Today we're gonna be\ntalking about Claude Code,"
    } ]
  }, {
    "tStartMs": 21210,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "and I'm joined by my colleague Cat."
    } ]
  }, {
    "tStartMs": 22920,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "- Hey, I'm Cat."
    } ]
  }, {
    "tStartMs": 24030,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "I'm the product manager for Claude Code."
    } ]
  }, {
    "tStartMs": 26280,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "- Cat, I wanna kick this\noff just talking about"
    } ]
  }, {
    "tStartMs": 27810,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "the insane rate of\nshipping in Claude Code."
    } ]
  }, {
    "tStartMs": 30480,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "It feels like literally every time"
    } ]
  }, {
    "tStartMs": 31800,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "I open it up in my terminal,"
    } ]
  }, {
    "tStartMs": 33330,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "there's a new product or a new feature,"
    } ]
  }, {
    "tStartMs": 35400,
    "dDurationMs": 1732,
    "segs": [ {
      "utf8": "something for me to use."
    } ]
  }, {
    "tStartMs": 37132,
    "dDurationMs": 2348,
    "segs": [ {
      "utf8": "Can you walk me through\nwhat the process looks like"
    } ]
  }, {
    "tStartMs": 39480,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "of the team going from an idea"
    } ]
  }, {
    "tStartMs": 41190,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "to actually shipping\nsomething to end users?"
    } ]
  }, {
    "tStartMs": 44100,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "- Yeah, so the Claude Code team is full"
    } ]
  }, {
    "tStartMs": 45870,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "of very product-minded engineers"
    } ]
  }, {
    "tStartMs": 47940,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "and a lot of these features\nare just built bottom-up."
    } ]
  }, {
    "tStartMs": 50520,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "It's like you're a developer"
    } ]
  }, {
    "tStartMs": 52200,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "and you really wish you had this thing,"
    } ]
  }, {
    "tStartMs": 54420,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "and then you build it for yourself."
    } ]
  }, {
    "tStartMs": 56190,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "And the way that our process works"
    } ]
  }, {
    "tStartMs": 57840,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "is instead of writing a doc,"
    } ]
  }, {
    "tStartMs": 59520,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "it's so fast to use Claude Code"
    } ]
  }, {
    "tStartMs": 61320,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "to prototype a feature"
    } ]
  }, {
    "tStartMs": 63000,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "that most of the time people\njust prototype the feature"
    } ]
  }, {
    "tStartMs": 66360,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "and then they ship it\ninternally to \"Ants\"."
    } ]
  }, {
    "tStartMs": 68430,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "And if the reception is really positive,"
    } ]
  }, {
    "tStartMs": 70500,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "then that's a very strong signal"
    } ]
  }, {
    "tStartMs": 72210,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "that the external world will like it too."
    } ]
  }, {
    "tStartMs": 73920,
    "dDurationMs": 3540,
    "segs": [ {
      "utf8": "And that's actually our bar\nfor shipping it externally."
    } ]
  }, {
    "tStartMs": 77460,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "And then of course there's always features"
    } ]
  }, {
    "tStartMs": 79200,
    "dDurationMs": 1846,
    "segs": [ {
      "utf8": "that like aren't exactly right"
    } ]
  }, {
    "tStartMs": 81046,
    "dDurationMs": 1664,
    "segs": [ {
      "utf8": "that need some tweaking."
    } ]
  }, {
    "tStartMs": 82710,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "And if we feel like, okay,\n\"Ants\" aren't really using it"
    } ]
  }, {
    "tStartMs": 85980,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "that much, then we just go\nback to the drawing board"
    } ]
  }, {
    "tStartMs": 88290,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "and we say like, okay,"
    } ]
  }, {
    "tStartMs": 89610,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "what else could we change about this?"
    } ]
  }, {
    "tStartMs": 91290,
    "dDurationMs": 1893,
    "segs": [ {
      "utf8": "- And when we say \"Ants,\" do\nwe mean Anthropic employees?"
    } ]
  }, {
    "tStartMs": 93183,
    "dDurationMs": 1781,
    "segs": [ {
      "utf8": "- Yes, yes.\n- Yeah."
    } ]
  }, {
    "tStartMs": 94964,
    "dDurationMs": 1876,
    "segs": [ {
      "utf8": "That's really fascinating."
    } ]
  }, {
    "tStartMs": 96840,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "I've never seen a product have as strong"
    } ]
  }, {
    "tStartMs": 99030,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "of like a \"dogfooding\"\nloop as Claude Code."
    } ]
  }, {
    "tStartMs": 101640,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "Do you think that's\nsomething we purposely did"
    } ]
  }, {
    "tStartMs": 104940,
    "dDurationMs": 1187,
    "segs": [ {
      "utf8": "or that just kind of naturally arise"
    } ]
  }, {
    "tStartMs": 106127,
    "dDurationMs": 2173,
    "segs": [ {
      "utf8": "from the product itself?"
    } ]
  }, {
    "tStartMs": 108300,
    "dDurationMs": 1253,
    "segs": [ {
      "utf8": "- It is quite intentional,"
    } ]
  }, {
    "tStartMs": 109553,
    "dDurationMs": 2977,
    "segs": [ {
      "utf8": "and it's also a really important reason"
    } ]
  }, {
    "tStartMs": 112530,
    "dDurationMs": 1773,
    "segs": [ {
      "utf8": "why Claude Code works so well."
    } ]
  }, {
    "tStartMs": 115746,
    "dDurationMs": 4123,
    "segs": [ {
      "utf8": "Because it's so easy to prototype\nfeatures on Claude Code,"
    } ]
  }, {
    "tStartMs": 119869,
    "dDurationMs": 3923,
    "segs": [ {
      "utf8": "we do push people to\nprototype as much as possible,"
    } ]
  }, {
    "tStartMs": 123792,
    "dDurationMs": 2118,
    "segs": [ {
      "utf8": "but it's hard to reason about"
    } ]
  }, {
    "tStartMs": 125910,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "like exactly how a\ndeveloper will use a tool"
    } ]
  }, {
    "tStartMs": 129360,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "because developers are so heterogeneous"
    } ]
  }, {
    "tStartMs": 131610,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "in their workflows."
    } ]
  }, {
    "tStartMs": 132750,
    "dDurationMs": 2610,
    "segs": [ {
      "utf8": "So oftentimes, even if\nyou theoretically know"
    } ]
  }, {
    "tStartMs": 135360,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "you wanna do something,"
    } ]
  }, {
    "tStartMs": 136380,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "like even if you theoretically know"
    } ]
  }, {
    "tStartMs": 138390,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "that you wanna build an IDE integration,"
    } ]
  }, {
    "tStartMs": 140550,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "there's still a range\nof like potential ways"
    } ]
  }, {
    "tStartMs": 143010,
    "dDurationMs": 1020,
    "segs": [ {
      "utf8": "you could go about it."
    } ]
  }, {
    "tStartMs": 144030,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "And often prototyping is the only way"
    } ]
  }, {
    "tStartMs": 145740,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "that you can really feel how the product"
    } ]
  }, {
    "tStartMs": 148470,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "will actually be in your workflow."
    } ]
  }, {
    "tStartMs": 150360,
    "dDurationMs": 1803,
    "segs": [ {
      "utf8": "So yeah, it's through the\nprocess of \"dogfooding\""
    } ]
  }, {
    "tStartMs": 152163,
    "dDurationMs": 3267,
    "segs": [ {
      "utf8": "that we decide what version of\na feature we decide to ship."
    } ]
  }, {
    "tStartMs": 155430,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- I see."
    } ]
  }, {
    "tStartMs": 156263,
    "dDurationMs": 1777,
    "segs": [ {
      "utf8": "And there's something about the,"
    } ]
  }, {
    "tStartMs": 158040,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "almost like the flexibility"
    } ]
  }, {
    "tStartMs": 159330,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "but also the constraints\nof the terminal too"
    } ]
  }, {
    "tStartMs": 161190,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "that allows for easy addition\nof like new features,"
    } ]
  }, {
    "tStartMs": 165390,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "which I've kind of\nnoticed where it's like,"
    } ]
  }, {
    "tStartMs": 167040,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "because we have the primitives built out"
    } ]
  }, {
    "tStartMs": 169020,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "of like slash commands and things,"
    } ]
  }, {
    "tStartMs": 170430,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "it's easy to add another\none on top of that."
    } ]
  }, {
    "tStartMs": 173280,
    "dDurationMs": 2553,
    "segs": [ {
      "utf8": "- Yeah, it's totally\ndesigned to be customizable."
    } ]
  }, {
    "tStartMs": 176970,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "And because so many developers"
    } ]
  }, {
    "tStartMs": 178830,
    "dDurationMs": 2088,
    "segs": [ {
      "utf8": "are familiar with the terminal,"
    } ]
  }, {
    "tStartMs": 180918,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "it makes like new feature\nonboarding super straightforward,"
    } ]
  }, {
    "tStartMs": 186624,
    "dDurationMs": 3426,
    "segs": [ {
      "utf8": "because for example, for\na feature like hooks,"
    } ]
  }, {
    "tStartMs": 190050,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "which lets you add a bit of determinism"
    } ]
  }, {
    "tStartMs": 192240,
    "dDurationMs": 2458,
    "segs": [ {
      "utf8": "around Claude Code events,"
    } ]
  }, {
    "tStartMs": 194698,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "because every developer\nknows how to write a script,"
    } ]
  }, {
    "tStartMs": 199740,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "and really at the end of the day,"
    } ]
  }, {
    "tStartMs": 201450,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "all a hook is, is a script."
    } ]
  }, {
    "tStartMs": 203610,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "And so you don't need to\nlearn a new technology"
    } ]
  }, {
    "tStartMs": 205830,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "to customize Claude Code."
    } ]
  }, {
    "tStartMs": 207450,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "You write this script that\nyou already know how to do"
    } ]
  }, {
    "tStartMs": 210330,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "and then you add it to one\nof the Claude Code events"
    } ]
  }, {
    "tStartMs": 213420,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "and now you have some determinism."
    } ]
  }, {
    "tStartMs": 215400,
    "dDurationMs": 1711,
    "segs": [ {
      "utf8": "- We're really trying to meet customers"
    } ]
  }, {
    "tStartMs": 217111,
    "dDurationMs": 2295,
    "segs": [ {
      "utf8": "or developers where they are"
    } ]
  }, {
    "tStartMs": 219406,
    "dDurationMs": 2222,
    "segs": [ {
      "utf8": "with this tool.\n- Definitely."
    } ]
  }, {
    "tStartMs": 221628,
    "dDurationMs": 1962,
    "segs": [ {
      "utf8": "- Switching gears slightly,"
    } ]
  }, {
    "tStartMs": 223590,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "so alongside this insane rate of shipping"
    } ]
  }, {
    "tStartMs": 225660,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "is also the insane growth\nrate of Claude Code"
    } ]
  }, {
    "tStartMs": 228210,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "with developers everywhere."
    } ]
  }, {
    "tStartMs": 231270,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Can you walk me through\nwhat that's been like"
    } ]
  }, {
    "tStartMs": 233070,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "to kind of be on this rocket ship"
    } ]
  }, {
    "tStartMs": 234480,
    "dDurationMs": 2750,
    "segs": [ {
      "utf8": "and how are we seeing various developers,"
    } ]
  }, {
    "tStartMs": 237230,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "whether it's at startups or individuals"
    } ]
  }, {
    "tStartMs": 239430,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "or at even large enterprises, use Claude?"
    } ]
  }, {
    "tStartMs": 241980,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "- So one of the magical\nthings about Claude Code"
    } ]
  }, {
    "tStartMs": 243960,
    "dDurationMs": 3390,
    "segs": [ {
      "utf8": "is that the onboarding is so smooth."
    } ]
  }, {
    "tStartMs": 247350,
    "dDurationMs": 2469,
    "segs": [ {
      "utf8": "After you do the NPM install,"
    } ]
  }, {
    "tStartMs": 249819,
    "dDurationMs": 2661,
    "segs": [ {
      "utf8": "Claude Code kind of just\nlike works out of the box"
    } ]
  }, {
    "tStartMs": 252480,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "without any configuration."
    } ]
  }, {
    "tStartMs": 253950,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "And this is true whether\nyou are an indie developer"
    } ]
  }, {
    "tStartMs": 257220,
    "dDurationMs": 4140,
    "segs": [ {
      "utf8": "through to if you're an\nengineer at a Fortune 500."
    } ]
  }, {
    "tStartMs": 261360,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "I think this is the\nmagic behind Claude Code."
    } ]
  }, {
    "tStartMs": 263580,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "Because it has access to\nall of the local tools"
    } ]
  }, {
    "tStartMs": 267000,
    "dDurationMs": 1497,
    "segs": [ {
      "utf8": "and files that you have,"
    } ]
  }, {
    "tStartMs": 268497,
    "dDurationMs": 2703,
    "segs": [ {
      "utf8": "you have this like very clear mental model"
    } ]
  }, {
    "tStartMs": 271200,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "for what Claude Code is capable of."
    } ]
  }, {
    "tStartMs": 273510,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "We do see different use\ncase patterns though"
    } ]
  }, {
    "tStartMs": 276690,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "between smaller companies and larger ones."
    } ]
  }, {
    "tStartMs": 279240,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "We find that engineers\nat smaller companies"
    } ]
  }, {
    "tStartMs": 281100,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "tend to run Claude more autonomously"
    } ]
  }, {
    "tStartMs": 283620,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "using things like \"auto-accept mode,\""
    } ]
  }, {
    "tStartMs": 286080,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "which lets Claude make edits by itself"
    } ]
  }, {
    "tStartMs": 288360,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "without approval of each one."
    } ]
  }, {
    "tStartMs": 290670,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "We also find that these developers"
    } ]
  }, {
    "tStartMs": 292680,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "tend to like to run multiple\nClaude sessions at once,"
    } ]
  }, {
    "tStartMs": 295650,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "and they've started calling\nthis multi-Clauding."
    } ]
  }, {
    "tStartMs": 298680,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "So you might see sessions"
    } ]
  }, {
    "tStartMs": 300000,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "where people have like six Claudes open"
    } ]
  }, {
    "tStartMs": 302580,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "on their computer at the same time."
    } ]
  }, {
    "tStartMs": 304410,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "Maybe each of them are in\na different Git workspace"
    } ]
  }, {
    "tStartMs": 307290,
    "dDurationMs": 2488,
    "segs": [ {
      "utf8": "or in a different copy of the Git repo,"
    } ]
  }, {
    "tStartMs": 309778,
    "dDurationMs": 3392,
    "segs": [ {
      "utf8": "and they're just like\nmanaging each of them."
    } ]
  }, {
    "tStartMs": 313170,
    "dDurationMs": 3141,
    "segs": [ {
      "utf8": "Whenever anyone stops\nand asks for feedback,"
    } ]
  }, {
    "tStartMs": 316311,
    "dDurationMs": 2409,
    "segs": [ {
      "utf8": "they'll jump in there and then send it off"
    } ]
  }, {
    "tStartMs": 318720,
    "dDurationMs": 1550,
    "segs": [ {
      "utf8": "and let it continue running."
    } ]
  }, {
    "tStartMs": 320270,
    "dDurationMs": 2050,
    "segs": [ {
      "utf8": "And on the other end of the spectrum"
    } ]
  }, {
    "tStartMs": 322320,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "for larger companies,"
    } ]
  }, {
    "tStartMs": 323430,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "we find that engineers really\nlike to use \"plan mode.\""
    } ]
  }, {
    "tStartMs": 326730,
    "dDurationMs": 2696,
    "segs": [ {
      "utf8": "So \"plan mode\" is a way for developers"
    } ]
  }, {
    "tStartMs": 329426,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "to tell Claude Code to take a second,"
    } ]
  }, {
    "tStartMs": 332546,
    "dDurationMs": 1594,
    "segs": [ {
      "utf8": "explore the code base,"
    } ]
  }, {
    "tStartMs": 334140,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "understand the architecture,"
    } ]
  }, {
    "tStartMs": 335940,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "and create an engineering plan"
    } ]
  }, {
    "tStartMs": 338130,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "before actually jumping\ninto the code itself."
    } ]
  }, {
    "tStartMs": 340920,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "And so we find that this is really useful"
    } ]
  }, {
    "tStartMs": 343680,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "for harder tasks and more complex changes."
    } ]
  }, {
    "tStartMs": 347100,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "- So going back to multi-Clauding"
    } ]
  }, {
    "tStartMs": 348990,
    "dDurationMs": 2450,
    "segs": [ {
      "utf8": "just 'cause I think that's\na fascinating concept."
    } ]
  }, {
    "tStartMs": 352530,
    "dDurationMs": 2398,
    "segs": [ {
      "utf8": "I'm sure we kind of imagined folks"
    } ]
  }, {
    "tStartMs": 354928,
    "dDurationMs": 1742,
    "segs": [ {
      "utf8": "wanting to do things like that,"
    } ]
  }, {
    "tStartMs": 356670,
    "dDurationMs": 2428,
    "segs": [ {
      "utf8": "but it was like somewhat surprising."
    } ]
  }, {
    "tStartMs": 359098,
    "dDurationMs": 3092,
    "segs": [ {
      "utf8": "Is there other things\nin that domain of like,"
    } ]
  }, {
    "tStartMs": 362190,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "oh wow, this is a usage pattern"
    } ]
  }, {
    "tStartMs": 364410,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "that we really did not expect"
    } ]
  }, {
    "tStartMs": 366060,
    "dDurationMs": 1740,
    "segs": [ {
      "utf8": "that have kind of popped up organically"
    } ]
  }, {
    "tStartMs": 367800,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "and we've shifted our\nroadmap around a little bit?"
    } ]
  }, {
    "tStartMs": 370500,
    "dDurationMs": 2702,
    "segs": [ {
      "utf8": "- Yeah, I think multi-Clauding\nis the biggest one"
    } ]
  }, {
    "tStartMs": 373202,
    "dDurationMs": 1768,
    "segs": [ {
      "utf8": "because this is something that we thought"
    } ]
  }, {
    "tStartMs": 374970,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "was just a power user feature"
    } ]
  }, {
    "tStartMs": 377280,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "that like a few people would wanna do."
    } ]
  }, {
    "tStartMs": 379260,
    "dDurationMs": 2452,
    "segs": [ {
      "utf8": "But in fact this is\nactually a really common way"
    } ]
  }, {
    "tStartMs": 381712,
    "dDurationMs": 2066,
    "segs": [ {
      "utf8": "in which people use Claude."
    } ]
  }, {
    "tStartMs": 383778,
    "dDurationMs": 1452,
    "segs": [ {
      "utf8": "And so for example,"
    } ]
  }, {
    "tStartMs": 385230,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "they might have one Claude instance"
    } ]
  }, {
    "tStartMs": 386940,
    "dDurationMs": 2228,
    "segs": [ {
      "utf8": "where they only ask questions"
    } ]
  }, {
    "tStartMs": 389168,
    "dDurationMs": 1972,
    "segs": [ {
      "utf8": "and this one doesn't edit code."
    } ]
  }, {
    "tStartMs": 391140,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "That way they can have\nanother Claude instance"
    } ]
  }, {
    "tStartMs": 392760,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "in the same repo that does edit code"
    } ]
  }, {
    "tStartMs": 395670,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "and these two don't\ninterfere with each other."
    } ]
  }, {
    "tStartMs": 397590,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Other things that we've seen"
    } ]
  }, {
    "tStartMs": 398670,
    "dDurationMs": 2740,
    "segs": [ {
      "utf8": "are people really like\nto customize Claude Code"
    } ]
  }, {
    "tStartMs": 401410,
    "dDurationMs": 3410,
    "segs": [ {
      "utf8": "to handle specialized tasks."
    } ]
  }, {
    "tStartMs": 404820,
    "dDurationMs": 4830,
    "segs": [ {
      "utf8": "So we've seen people build\nlike SRE agents on Claude Code,"
    } ]
  }, {
    "tStartMs": 409650,
    "dDurationMs": 3900,
    "segs": [ {
      "utf8": "security agents, incident response agents."
    } ]
  }, {
    "tStartMs": 413550,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "And what that made us realize"
    } ]
  }, {
    "tStartMs": 415080,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "is that integrations are so important"
    } ]
  }, {
    "tStartMs": 417510,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "for making sure Claude Code works well."
    } ]
  }, {
    "tStartMs": 419370,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "And so we've been encouraging people"
    } ]
  }, {
    "tStartMs": 420660,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "to spend more time to\ntell Claude Code about,"
    } ]
  }, {
    "tStartMs": 424260,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "hey, these are the CLI\ntools we commonly use"
    } ]
  }, {
    "tStartMs": 427530,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "or to set up remote MCP servers"
    } ]
  }, {
    "tStartMs": 429750,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "to get access to logs and\nticket management software."
    } ]
  }, {
    "tStartMs": 432390,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "- When these engineers are\ncustomizing Claude Code,"
    } ]
  }, {
    "tStartMs": 434460,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "does that mean they're creating sub-agents"
    } ]
  }, {
    "tStartMs": 437760,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "or are they creating markdown files"
    } ]
  }, {
    "tStartMs": 440430,
    "dDurationMs": 1590,
    "segs": [ {
      "utf8": "like CLAUDE.md files?"
    } ]
  }, {
    "tStartMs": 442020,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "How exactly are they creating these"
    } ]
  }, {
    "tStartMs": 443730,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "different types of agents?"
    } ]
  }, {
    "tStartMs": 445350,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "- Yeah, I think the most common ways"
    } ]
  }, {
    "tStartMs": 447030,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "that we've seen people customize"
    } ]
  }, {
    "tStartMs": 448590,
    "dDurationMs": 3420,
    "segs": [ {
      "utf8": "is by investing a lot\ninto the CLAUDE.md file."
    } ]
  }, {
    "tStartMs": 452010,
    "dDurationMs": 3750,
    "segs": [ {
      "utf8": "So the CLAUDE.md file is\nour concept of memory."
    } ]
  }, {
    "tStartMs": 455760,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "And so it's the best place for you"
    } ]
  }, {
    "tStartMs": 457560,
    "dDurationMs": 3792,
    "segs": [ {
      "utf8": "to tell Claude Code about\nwhat your team's goals are,"
    } ]
  }, {
    "tStartMs": 461352,
    "dDurationMs": 2598,
    "segs": [ {
      "utf8": "how the code is architected,"
    } ]
  }, {
    "tStartMs": 463950,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "any gotchas in the code base,"
    } ]
  }, {
    "tStartMs": 467100,
    "dDurationMs": 1830,
    "segs": [ {
      "utf8": "any best practices."
    } ]
  }, {
    "tStartMs": 468930,
    "dDurationMs": 2910,
    "segs": [ {
      "utf8": "And investing in CLAUDE.md"
    } ]
  }, {
    "tStartMs": 471840,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "we've heard dramatically improves"
    } ]
  }, {
    "tStartMs": 473880,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "the quality of the output."
    } ]
  }, {
    "tStartMs": 475800,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "The other way that people\ncustomize Claude Code"
    } ]
  }, {
    "tStartMs": 477780,
    "dDurationMs": 3090,
    "segs": [ {
      "utf8": "is by adding custom slash commands."
    } ]
  }, {
    "tStartMs": 480870,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "So if there's a prompt\nthat you're always typing,"
    } ]
  }, {
    "tStartMs": 483630,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "you can add that into\nthe custom slash commands"
    } ]
  }, {
    "tStartMs": 485820,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "and you could also check these in"
    } ]
  }, {
    "tStartMs": 487200,
    "dDurationMs": 2340,
    "segs": [ {
      "utf8": "so that you share them\nwith the rest of your team."
    } ]
  }, {
    "tStartMs": 489540,
    "dDurationMs": 3030,
    "segs": [ {
      "utf8": "And then you can also add custom hooks."
    } ]
  }, {
    "tStartMs": 492570,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "So if for example,"
    } ]
  }, {
    "tStartMs": 494280,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "you want Claude Code to run lints"
    } ]
  }, {
    "tStartMs": 497340,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "before it makes a commit,"
    } ]
  }, {
    "tStartMs": 499230,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "this is something that's great for a hook."
    } ]
  }, {
    "tStartMs": 501030,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "If you want Claude Code to\nsend you a Slack notification"
    } ]
  }, {
    "tStartMs": 504000,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "every time it's done working,"
    } ]
  }, {
    "tStartMs": 505950,
    "dDurationMs": 1620,
    "segs": [ {
      "utf8": "this is actually the original inspiration"
    } ]
  }, {
    "tStartMs": 507570,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "for making hooks."
    } ]
  }, {
    "tStartMs": 509040,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "And so these are all customizations"
    } ]
  }, {
    "tStartMs": 511260,
    "dDurationMs": 1605,
    "segs": [ {
      "utf8": "that people are building today."
    } ]
  }, {
    "tStartMs": 512865,
    "dDurationMs": 1633,
    "segs": [ {
      "utf8": "- Tell me more about,"
    } ]
  }, {
    "tStartMs": 514498,
    "dDurationMs": 1169,
    "segs": [ {
      "utf8": "what is the Claude Code SDK?"
    } ]
  }, {
    "tStartMs": 515667,
    "dDurationMs": 1863,
    "segs": [ {
      "utf8": "- The Claude Code SDK is a great way"
    } ]
  }, {
    "tStartMs": 517530,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "to build general agents."
    } ]
  }, {
    "tStartMs": 518970,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "The Claude Code SDK gives you access"
    } ]
  }, {
    "tStartMs": 522030,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "to all of the core building\nblocks of an agent,"
    } ]
  }, {
    "tStartMs": 524400,
    "dDurationMs": 2850,
    "segs": [ {
      "utf8": "including you can bring\nyour own system prompt,"
    } ]
  }, {
    "tStartMs": 527250,
    "dDurationMs": 2324,
    "segs": [ {
      "utf8": "you can bring your own custom tools,"
    } ]
  }, {
    "tStartMs": 529574,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "and what you get from the\nSDK is a core agentic loop"
    } ]
  }, {
    "tStartMs": 534900,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "where we handle the user turns"
    } ]
  }, {
    "tStartMs": 537840,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "and we handle executing\nthe tool calls for you."
    } ]
  }, {
    "tStartMs": 540510,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "You get to use our\nexisting permission system"
    } ]
  }, {
    "tStartMs": 542910,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "so that you don't need to\nbuild one from scratch."
    } ]
  }, {
    "tStartMs": 545160,
    "dDurationMs": 3390,
    "segs": [ {
      "utf8": "And we also handle interacting\nwith the underlying API."
    } ]
  }, {
    "tStartMs": 548550,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "So we make sure that we have backoff"
    } ]
  }, {
    "tStartMs": 551610,
    "dDurationMs": 2370,
    "segs": [ {
      "utf8": "if there's any API errors."
    } ]
  }, {
    "tStartMs": 553980,
    "dDurationMs": 2100,
    "segs": [ {
      "utf8": "We very aggressively prompt cache"
    } ]
  }, {
    "tStartMs": 556080,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "to make sure that your\nrequests are token-efficient."
    } ]
  }, {
    "tStartMs": 559440,
    "dDurationMs": 2869,
    "segs": [ {
      "utf8": "If you are prototyping\nbuilding an agent from scratch,"
    } ]
  }, {
    "tStartMs": 562309,
    "dDurationMs": 1841,
    "segs": [ {
      "utf8": "if you use the Claude Code SDK,"
    } ]
  }, {
    "tStartMs": 564150,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "you can get up and running with something"
    } ]
  }, {
    "tStartMs": 566010,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "pretty powerful within\nlike 30 minutes or so."
    } ]
  }, {
    "tStartMs": 569250,
    "dDurationMs": 2913,
    "segs": [ {
      "utf8": "We've been seeing people build\nreally cool things with it."
    } ]
  }, {
    "tStartMs": 573120,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "We open-sourced our Claude\nCode on GitHub integration,"
    } ]
  }, {
    "tStartMs": 576600,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "which is completely built on the SDK,"
    } ]
  }, {
    "tStartMs": 579000,
    "dDurationMs": 3407,
    "segs": [ {
      "utf8": "and we've seen people build\nsecurity agents on it,"
    } ]
  }, {
    "tStartMs": 582407,
    "dDurationMs": 3793,
    "segs": [ {
      "utf8": "SRE agents, incident response agents."
    } ]
  }, {
    "tStartMs": 586200,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "And these are just\nwithin the coding domain."
    } ]
  }, {
    "tStartMs": 588180,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "Outside of coding, we've seen people"
    } ]
  }, {
    "tStartMs": 589710,
    "dDurationMs": 3900,
    "segs": [ {
      "utf8": "prototype legal agents, compliance agents."
    } ]
  }, {
    "tStartMs": 593610,
    "dDurationMs": 2656,
    "segs": [ {
      "utf8": "This is very much intended\nto be a general SDK"
    } ]
  }, {
    "tStartMs": 596266,
    "dDurationMs": 1694,
    "segs": [ {
      "utf8": "for all your agent needs."
    } ]
  }, {
    "tStartMs": 597960,
    "dDurationMs": 1410,
    "segs": [ {
      "utf8": "- The SDK is pretty amazing to me."
    } ]
  }, {
    "tStartMs": 599370,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "I feel like we've lived in\nthe single request API world"
    } ]
  }, {
    "tStartMs": 604050,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "for so long."
    } ]
  }, {
    "tStartMs": 605160,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "And now we're moving to like\na next level abstraction"
    } ]
  }, {
    "tStartMs": 608400,
    "dDurationMs": 2130,
    "segs": [ {
      "utf8": "almost where we're gonna handle"
    } ]
  }, {
    "tStartMs": 610530,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "all the nitty-gritty of\nthe things you mentioned."
    } ]
  }, {
    "tStartMs": 613350,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "Where is the SDK headed?"
    } ]
  }, {
    "tStartMs": 615269,
    "dDurationMs": 1921,
    "segs": [ {
      "utf8": "What's next there?"
    } ]
  }, {
    "tStartMs": 617190,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "- We're really excited about the SDK"
    } ]
  }, {
    "tStartMs": 619230,
    "dDurationMs": 4849,
    "segs": [ {
      "utf8": "as the next way to unlock\nanother generation of agents."
    } ]
  }, {
    "tStartMs": 624079,
    "dDurationMs": 2081,
    "segs": [ {
      "utf8": "We're investing very heavily"
    } ]
  }, {
    "tStartMs": 626160,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "in making sure the SDK is best-in-class"
    } ]
  }, {
    "tStartMs": 628140,
    "dDurationMs": 1143,
    "segs": [ {
      "utf8": "for building agents."
    } ]
  }, {
    "tStartMs": 630390,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "So all of the nice features"
    } ]
  }, {
    "tStartMs": 632430,
    "dDurationMs": 1530,
    "segs": [ {
      "utf8": "that you have in Claude Code"
    } ]
  }, {
    "tStartMs": 633960,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "will be available out\nof the box in the SDK,"
    } ]
  }, {
    "tStartMs": 636540,
    "dDurationMs": 2580,
    "segs": [ {
      "utf8": "and you can pick and choose\nwhich ones you wanna keep."
    } ]
  }, {
    "tStartMs": 639120,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So for example, if you want your agent"
    } ]
  }, {
    "tStartMs": 641400,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "to be able to have a to-do list, great."
    } ]
  }, {
    "tStartMs": 643320,
    "dDurationMs": 2940,
    "segs": [ {
      "utf8": "You have the to-do list\ntool out of the box."
    } ]
  }, {
    "tStartMs": 646260,
    "dDurationMs": 1230,
    "segs": [ {
      "utf8": "If you don't want that,"
    } ]
  }, {
    "tStartMs": 647490,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "it's really easy to just delete that tool."
    } ]
  }, {
    "tStartMs": 650010,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "If your agent needs to\nedit files, for example,"
    } ]
  }, {
    "tStartMs": 653160,
    "dDurationMs": 2790,
    "segs": [ {
      "utf8": "to update its memory, you\nget that out of the box."
    } ]
  }, {
    "tStartMs": 655950,
    "dDurationMs": 4562,
    "segs": [ {
      "utf8": "And if you decide, okay,\nmine won't edit files"
    } ]
  }, {
    "tStartMs": 660512,
    "dDurationMs": 2578,
    "segs": [ {
      "utf8": "or it'll edit files in a different way,"
    } ]
  }, {
    "tStartMs": 663090,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "you can just bring your\nown implementation."
    } ]
  }, {
    "tStartMs": 665310,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "- Okay, so it's extremely customizable,"
    } ]
  }, {
    "tStartMs": 668040,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "basically general purpose in the sense"
    } ]
  }, {
    "tStartMs": 669990,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "that you could swap out the system prompt"
    } ]
  }, {
    "tStartMs": 671670,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "or the tools for your own implementations."
    } ]
  }, {
    "tStartMs": 673560,
    "dDurationMs": 1450,
    "segs": [ {
      "utf8": "And they just nicely slot in"
    } ]
  }, {
    "tStartMs": 675010,
    "dDurationMs": 1670,
    "segs": [ {
      "utf8": "to whatever thing you're building for,"
    } ]
  }, {
    "tStartMs": 676680,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "whether it's in an entirely\ndifferent domain than code."
    } ]
  }, {
    "tStartMs": 679680,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "Right?\n- Yeah, totally."
    } ]
  }, {
    "tStartMs": 680640,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I'm really excited to see what\npeople hack on top of this."
    } ]
  }, {
    "tStartMs": 682920,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "I think like especially for people"
    } ]
  }, {
    "tStartMs": 685170,
    "dDurationMs": 3150,
    "segs": [ {
      "utf8": "who are just trying to prototype an agent,"
    } ]
  }, {
    "tStartMs": 688320,
    "dDurationMs": 2304,
    "segs": [ {
      "utf8": "this is like, I think\nby far the fastest way"
    } ]
  }, {
    "tStartMs": 690624,
    "dDurationMs": 1296,
    "segs": [ {
      "utf8": "to get started."
    } ]
  }, {
    "tStartMs": 691920,
    "dDurationMs": 3210,
    "segs": [ {
      "utf8": "Like we really spent almost a year"
    } ]
  }, {
    "tStartMs": 695130,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "perfecting this harness,"
    } ]
  }, {
    "tStartMs": 696600,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "and this is the same harness\nthat Claude Code runs on."
    } ]
  }, {
    "tStartMs": 699270,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "And so if you want to just jump"
    } ]
  }, {
    "tStartMs": 701940,
    "dDurationMs": 4410,
    "segs": [ {
      "utf8": "right into the specific\nintegrations that your agent needs"
    } ]
  }, {
    "tStartMs": 706350,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "and you wanna jump right into like"
    } ]
  }, {
    "tStartMs": 708840,
    "dDurationMs": 1950,
    "segs": [ {
      "utf8": "just working on the system prompt"
    } ]
  }, {
    "tStartMs": 710790,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "to share context about the\nproblems faced with the agent,"
    } ]
  }, {
    "tStartMs": 714510,
    "dDurationMs": 3180,
    "segs": [ {
      "utf8": "and you don't wanna deal\nwith the agent loop,"
    } ]
  }, {
    "tStartMs": 717690,
    "dDurationMs": 2490,
    "segs": [ {
      "utf8": "this is like the best way to circumvent"
    } ]
  }, {
    "tStartMs": 720180,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "all the general purpose harness"
    } ]
  }, {
    "tStartMs": 722340,
    "dDurationMs": 3540,
    "segs": [ {
      "utf8": "and just add your like\nspecial sauce to it."
    } ]
  }, {
    "tStartMs": 725880,
    "dDurationMs": 1290,
    "segs": [ {
      "utf8": "- Hmm, all right."
    } ]
  }, {
    "tStartMs": 727170,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "Well, you heard it here."
    } ]
  }, {
    "tStartMs": 728003,
    "dDurationMs": 1807,
    "segs": [ {
      "utf8": "You gotta go build on the SDK."
    } ]
  }, {
    "tStartMs": 729810,
    "dDurationMs": 960,
    "segs": [ {
      "utf8": "Before we wrap up here,"
    } ]
  }, {
    "tStartMs": 730770,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "I'm really curious to hear your own tips"
    } ]
  }, {
    "tStartMs": 732960,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "for how you use Claude Code,"
    } ]
  }, {
    "tStartMs": 734760,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "and what are some best practices"
    } ]
  }, {
    "tStartMs": 736080,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "we can share with developers?"
    } ]
  }, {
    "tStartMs": 737640,
    "dDurationMs": 4411,
    "segs": [ {
      "utf8": "- When you work with Claude\nCode or any agentic tool,"
    } ]
  }, {
    "tStartMs": 742051,
    "dDurationMs": 1949,
    "segs": [ {
      "utf8": "I think the most important thing"
    } ]
  }, {
    "tStartMs": 744000,
    "dDurationMs": 4891,
    "segs": [ {
      "utf8": "is to clearly communicate what\nyour goals are to the tool."
    } ]
  }, {
    "tStartMs": 748891,
    "dDurationMs": 2189,
    "segs": [ {
      "utf8": "I think a lot of people\nthink that prompting"
    } ]
  }, {
    "tStartMs": 751080,
    "dDurationMs": 4190,
    "segs": [ {
      "utf8": "is this like magical\nthing, but it really isn't."
    } ]
  }, {
    "tStartMs": 755270,
    "dDurationMs": 2401,
    "segs": [ {
      "utf8": "It's very much about, okay,"
    } ]
  }, {
    "tStartMs": 757671,
    "dDurationMs": 3639,
    "segs": [ {
      "utf8": "did I clearly articulate\nwhat my purpose is?"
    } ]
  }, {
    "tStartMs": 761310,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Like what my purpose with this task is,"
    } ]
  }, {
    "tStartMs": 764070,
    "dDurationMs": 3820,
    "segs": [ {
      "utf8": "how I'm evaluating the output of the task,"
    } ]
  }, {
    "tStartMs": 767890,
    "dDurationMs": 3350,
    "segs": [ {
      "utf8": "any constraints in the design system."
    } ]
  }, {
    "tStartMs": 771240,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "And I think usually"
    } ]
  }, {
    "tStartMs": 773310,
    "dDurationMs": 3060,
    "segs": [ {
      "utf8": "when you can clearly\ncommunicate these things,"
    } ]
  }, {
    "tStartMs": 776370,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Claude Code will either be able to do them"
    } ]
  }, {
    "tStartMs": 778530,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "or just tell you that\nlike, \"Okay, this thing,"
    } ]
  }, {
    "tStartMs": 781050,
    "dDurationMs": 2220,
    "segs": [ {
      "utf8": "like I'm not able to do because A, B, C"
    } ]
  }, {
    "tStartMs": 783270,
    "dDurationMs": 3330,
    "segs": [ {
      "utf8": "and do you wanna try\nlike D, E, F instead?\""
    } ]
  }, {
    "tStartMs": 786600,
    "dDurationMs": 1380,
    "segs": [ {
      "utf8": "- So it's all about the communication"
    } ]
  }, {
    "tStartMs": 787980,
    "dDurationMs": 2700,
    "segs": [ {
      "utf8": "just as if you're working\nwith another engineer."
    } ]
  }, {
    "tStartMs": 790680,
    "dDurationMs": 840,
    "segs": [ {
      "utf8": "- Yeah, totally."
    } ]
  }, {
    "tStartMs": 791520,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "And another thing is if you notice"
    } ]
  }, {
    "tStartMs": 794400,
    "dDurationMs": 1837,
    "segs": [ {
      "utf8": "that Claude Code did something weird,"
    } ]
  }, {
    "tStartMs": 796237,
    "dDurationMs": 3953,
    "segs": [ {
      "utf8": "you could actually just ask\nit why it wanted to do that."
    } ]
  }, {
    "tStartMs": 800190,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "And it might tell you something like,"
    } ]
  }, {
    "tStartMs": 801840,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "oh, okay, there was something\nin CLAUDE.md that said this,"
    } ]
  }, {
    "tStartMs": 804300,
    "dDurationMs": 2070,
    "segs": [ {
      "utf8": "or I read something in this file"
    } ]
  }, {
    "tStartMs": 806370,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "that like gave me this like impression."
    } ]
  }, {
    "tStartMs": 808920,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "And then that way you can actually use"
    } ]
  }, {
    "tStartMs": 810960,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "like talking to Claude as a way to debug."
    } ]
  }, {
    "tStartMs": 813780,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "It doesn't always work,"
    } ]
  }, {
    "tStartMs": 815340,
    "dDurationMs": 2430,
    "segs": [ {
      "utf8": "but I think it's definitely worth trying."
    } ]
  }, {
    "tStartMs": 817770,
    "dDurationMs": 1890,
    "segs": [ {
      "utf8": "And it's like a common\ntechnique that we use."
    } ]
  }, {
    "tStartMs": 819660,
    "dDurationMs": 2381,
    "segs": [ {
      "utf8": "- You use Claude Code\nto debug Claude Code."
    } ]
  }, {
    "tStartMs": 822041,
    "dDurationMs": 1249,
    "segs": [ {
      "utf8": "I love it.\n- Yeah, yeah."
    } ]
  }, {
    "tStartMs": 823290,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "Like the same way that\nwhen working with a human,"
    } ]
  }, {
    "tStartMs": 825930,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "if they say something\nthat you didn't expect,"
    } ]
  }, {
    "tStartMs": 827370,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "you might feel like, \"Oh, interesting."
    } ]
  }, {
    "tStartMs": 828690,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "Like, what gave you that impression?"
    } ]
  }, {
    "tStartMs": 830670,
    "dDurationMs": 1770,
    "segs": [ {
      "utf8": "Or why did you think this?\""
    } ]
  }, {
    "tStartMs": 832440,
    "dDurationMs": 1860,
    "segs": [ {
      "utf8": "And I think you can do\nthe same with agents too."
    } ]
  }, {
    "tStartMs": 834300,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "- That's fascinating."
    } ]
  }, {
    "tStartMs": 835620,
    "dDurationMs": 1140,
    "segs": [ {
      "utf8": "Well, Cat, this has been great."
    } ]
  }, {
    "tStartMs": 836760,
    "dDurationMs": 1060,
    "segs": [ {
      "utf8": "Really, we appreciate the time."
    } ]
  }, {
    "tStartMs": 837820,
    "dDurationMs": 1747,
    "segs": [ {
      "utf8": "Thank you.\n- Thanks for having me."
    } ]
  } ]
}
