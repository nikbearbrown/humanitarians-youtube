{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 0,
    "dDurationMs": 4420,
    "segs": [ {
      "utf8": "Most people who use software\nevery day don't think about bugs."
    } ]
  }, {
    "tStartMs": 4840,
    "dDurationMs": 3792,
    "segs": [ {
      "utf8": "They don't think about\nwhat can happen if the software"
    } ]
  }, {
    "tStartMs": 8650,
    "dDurationMs": 3190,
    "segs": [ {
      "utf8": "that they depend upon\nsuddenly is less secure."
    } ]
  }, {
    "tStartMs": 12400,
    "dDurationMs": 3822,
    "segs": [ {
      "utf8": "That's something that software developers\nhave to deal with every single day."
    } ]
  }, {
    "tStartMs": 19850,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "Software has always had flaws\nand vulnerabilities."
    } ]
  }, {
    "tStartMs": 22352,
    "dDurationMs": 1042,
    "segs": [ {
      "utf8": "That's not new."
    } ]
  }, {
    "tStartMs": 23436,
    "dDurationMs": 4838,
    "segs": [ {
      "utf8": "For an average person,\nthe bugs are, by and large,"
    } ]
  }, {
    "tStartMs": 28274,
    "dDurationMs": 2710,
    "segs": [ {
      "utf8": "not something they notice\non a daily basis, because if they do,"
    } ]
  }, {
    "tStartMs": 30984,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "they get fixed."
    } ]
  }, {
    "tStartMs": 32068,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "But then every so often,\nthere are vulnerabilities"
    } ]
  }, {
    "tStartMs": 34760,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "that have real severe impacts."
    } ]
  }, {
    "tStartMs": 36720,
    "dDurationMs": 5151,
    "segs": [ {
      "utf8": "Like one single bug\nthat works its way into shared software"
    } ]
  }, {
    "tStartMs": 41871,
    "dDurationMs": 3329,
    "segs": [ {
      "utf8": "that many, many, many\ndifferent products or websites use."
    } ]
  }, {
    "tStartMs": 45520,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "One issue just gets\nmagnified out around the world."
    } ]
  }, {
    "tStartMs": 48880,
    "dDurationMs": 2650,
    "segs": [ {
      "utf8": "Historically, finding\nand patching vulnerabilities"
    } ]
  }, {
    "tStartMs": 51585,
    "dDurationMs": 3695,
    "segs": [ {
      "utf8": "has been a slow, time-consuming,\nand expensive process."
    } ]
  }, {
    "tStartMs": 55400,
    "dDurationMs": 6680,
    "segs": [ {
      "utf8": "If LLMs are now able to write code,\nat the level of some of the greatest"
    } ]
  }, {
    "tStartMs": 62080,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "software developers in the world,"
    } ]
  }, {
    "tStartMs": 64360,
    "dDurationMs": 3155,
    "segs": [ {
      "utf8": "it can also be used to find bugs"
    } ]
  }, {
    "tStartMs": 67598,
    "dDurationMs": 2442,
    "segs": [ {
      "utf8": "and exploit that software\nequally effectively."
    } ]
  }, {
    "tStartMs": 70200,
    "dDurationMs": 4029,
    "segs": [ {
      "utf8": "These models have capabilities\nwhich are raising the bar"
    } ]
  }, {
    "tStartMs": 74229,
    "dDurationMs": 2293,
    "segs": [ {
      "utf8": "from a cybersecurity point of view"
    } ]
  }, {
    "tStartMs": 76731,
    "dDurationMs": 6069,
    "segs": [ {
      "utf8": "with their ability to help defenders\nas well as potentially help adversaries."
    } ]
  }, {
    "tStartMs": 83000,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "We recently developed a new model,\nClaude Mythos Preview."
    } ]
  }, {
    "tStartMs": 87680,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "Early on, it was clear to us\nthat this model"
    } ]
  }, {
    "tStartMs": 90200,
    "dDurationMs": 3336,
    "segs": [ {
      "utf8": "was going to be meaningfully better\nat cybersecurity capabilities."
    } ]
  }, {
    "tStartMs": 93720,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "There's a high accelerating exponential,\nbut along that exponential,"
    } ]
  }, {
    "tStartMs": 98160,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "there are points of significance."
    } ]
  }, {
    "tStartMs": 100709,
    "dDurationMs": 3169,
    "segs": [ {
      "utf8": "Claude Mythos Preview\nis a particularly big jump"
    } ]
  }, {
    "tStartMs": 103962,
    "dDurationMs": 1158,
    "segs": [ {
      "utf8": "along that point."
    } ]
  }, {
    "tStartMs": 105120,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "We haven't trained it\nspecifically to be good at cyber."
    } ]
  }, {
    "tStartMs": 108299,
    "dDurationMs": 3044,
    "segs": [ {
      "utf8": "We trained it to be good at code,\nbut as a side effect"
    } ]
  }, {
    "tStartMs": 111421,
    "dDurationMs": 2499,
    "segs": [ {
      "utf8": "of being good at code,\nit's also good at cyber."
    } ]
  }, {
    "tStartMs": 113920,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "The model that we're experimenting with\nis by and large as good"
    } ]
  }, {
    "tStartMs": 119160,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "as a professional human at identifying bugs."
    } ]
  }, {
    "tStartMs": 123061,
    "dDurationMs": 1817,
    "segs": [ {
      "utf8": "It's good for us\nbecause we can find"
    } ]
  }, {
    "tStartMs": 124937,
    "dDurationMs": 2383,
    "segs": [ {
      "utf8": "more vulnerabilities sooner\nand we can fix them."
    } ]
  }, {
    "tStartMs": 127440,
    "dDurationMs": 2919,
    "segs": [ {
      "utf8": "It has the ability to chain\ntogether vulnerabilities."
    } ]
  }, {
    "tStartMs": 130442,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "What this means\nis you find two vulnerabilities,"
    } ]
  }, {
    "tStartMs": 132986,
    "dDurationMs": 3134,
    "segs": [ {
      "utf8": "either of which doesn't really get you\nvery much independently,"
    } ]
  }, {
    "tStartMs": 136120,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "but this model is able to create exploits\nout of three, four,"
    } ]
  }, {
    "tStartMs": 139560,
    "dDurationMs": 2558,
    "segs": [ {
      "utf8": "sometimes five vulnerabilities\nthat in sequence"
    } ]
  }, {
    "tStartMs": 142202,
    "dDurationMs": 2558,
    "segs": [ {
      "utf8": "give you some very sophisticated\nend outcome."
    } ]
  }, {
    "tStartMs": 144800,
    "dDurationMs": 3338,
    "segs": [ {
      "utf8": "And we think that this model\ncan do this really well"
    } ]
  }, {
    "tStartMs": 148207,
    "dDurationMs": 2593,
    "segs": [ {
      "utf8": "because we noticed that this model\nis very autonomous."
    } ]
  }, {
    "tStartMs": 150800,
    "dDurationMs": 4496,
    "segs": [ {
      "utf8": "It's just generally better at pursuing\nreally long-range tasks"
    } ]
  }, {
    "tStartMs": 155338,
    "dDurationMs": 3544,
    "segs": [ {
      "utf8": "that are kind of like the tasks\nthat a human security researcher"
    } ]
  }, {
    "tStartMs": 158882,
    "dDurationMs": 2998,
    "segs": [ {
      "utf8": "would do throughout the course\nof an entire day."
    } ]
  }, {
    "tStartMs": 161880,
    "dDurationMs": 3424,
    "segs": [ {
      "utf8": "Obviously, capabilities in a model\nlike this could do harm"
    } ]
  }, {
    "tStartMs": 165304,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "if in the wrong hands,"
    } ]
  }, {
    "tStartMs": 166880,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "and so we won't be\nreleasing this model widely."
    } ]
  }, {
    "tStartMs": 169640,
    "dDurationMs": 3379,
    "segs": [ {
      "utf8": "More powerful models are going to come\nfrom us and from others,"
    } ]
  }, {
    "tStartMs": 173186,
    "dDurationMs": 3211,
    "segs": [ {
      "utf8": "and so we do need a plan\nto respond to this."
    } ]
  }, {
    "tStartMs": 176397,
    "dDurationMs": 3123,
    "segs": [ {
      "utf8": "That's why we're launching\nwhat we're calling Project Glasswing,"
    } ]
  }, {
    "tStartMs": 179520,
    "dDurationMs": 2863,
    "segs": [ {
      "utf8": "where we partner\nwith a number of the organizations"
    } ]
  }, {
    "tStartMs": 182402,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "that power some of the world's\nmost critical code"
    } ]
  }, {
    "tStartMs": 184904,
    "dDurationMs": 2877,
    "segs": [ {
      "utf8": "to put the model into their hands\nto allow them"
    } ]
  }, {
    "tStartMs": 187800,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "to look at how they can use models\nlike this to bring down risk"
    } ]
  }, {
    "tStartMs": 191360,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "and protect everyone."
    } ]
  }, {
    "tStartMs": 192480,
    "dDurationMs": 3016,
    "segs": [ {
      "utf8": "And by giving these software developers"
    } ]
  }, {
    "tStartMs": 195800,
    "dDurationMs": 3491,
    "segs": [ {
      "utf8": "advanced tools before anyone else,"
    } ]
  }, {
    "tStartMs": 199416,
    "dDurationMs": 2824,
    "segs": [ {
      "utf8": "it gives all of us\na collective headstart."
    } ]
  }, {
    "tStartMs": 202680,
    "dDurationMs": 2825,
    "segs": [ {
      "utf8": "It allows us to find things\nthat we couldn't find before,"
    } ]
  }, {
    "tStartMs": 205755,
    "dDurationMs": 4879,
    "segs": [ {
      "utf8": "and it helps us fix these things\nmuch more quickly."
    } ]
  }, {
    "tStartMs": 210634,
    "dDurationMs": 2710,
    "segs": [ {
      "utf8": "Working with our partners,\nwe've been finding vulnerabilities"
    } ]
  }, {
    "tStartMs": 213344,
    "dDurationMs": 2856,
    "segs": [ {
      "utf8": "across essentially every major platform."
    } ]
  }, {
    "tStartMs": 216400,
    "dDurationMs": 3325,
    "segs": [ {
      "utf8": "I found more bugs\nin the last couple of weeks than I found"
    } ]
  }, {
    "tStartMs": 219725,
    "dDurationMs": 1595,
    "segs": [ {
      "utf8": "in the rest of my life combined."
    } ]
  }, {
    "tStartMs": 221320,
    "dDurationMs": 3367,
    "segs": [ {
      "utf8": "We used the model to scan\na bunch of open-source code"
    } ]
  }, {
    "tStartMs": 224687,
    "dDurationMs": 3391,
    "segs": [ {
      "utf8": "and the thing that we went for first\nwas operating systems"
    } ]
  }, {
    "tStartMs": 228148,
    "dDurationMs": 2172,
    "segs": [ {
      "utf8": "because this is the code that underlies"
    } ]
  }, {
    "tStartMs": 230320,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "the entire internet infrastructure."
    } ]
  }, {
    "tStartMs": 232480,
    "dDurationMs": 3925,
    "segs": [ {
      "utf8": "For OpenBSD,\nwe found a bug that's been present"
    } ]
  }, {
    "tStartMs": 236489,
    "dDurationMs": 5588,
    "segs": [ {
      "utf8": "for 27 years, where I can send\na couple of pieces of data"
    } ]
  }, {
    "tStartMs": 242083,
    "dDurationMs": 2837,
    "segs": [ {
      "utf8": "to any OpenBSD server\nand crash it."
    } ]
  }, {
    "tStartMs": 245040,
    "dDurationMs": 3292,
    "segs": [ {
      "utf8": "On Linux, we found a number\nof vulnerabilities"
    } ]
  }, {
    "tStartMs": 248499,
    "dDurationMs": 4861,
    "segs": [ {
      "utf8": "where, as a user with no permissions,\nI can elevate myself to the administrator"
    } ]
  }, {
    "tStartMs": 253461,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "by just running some binary on my machine."
    } ]
  }, {
    "tStartMs": 255922,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "For each of these bugs,\nwe told the maintainers"
    } ]
  }, {
    "tStartMs": 258299,
    "dDurationMs": 3357,
    "segs": [ {
      "utf8": "who actually run the software about them,\nand they went and fixed them"
    } ]
  }, {
    "tStartMs": 261676,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "and have deployed the patches\nso that anyone who runs this software"
    } ]
  }, {
    "tStartMs": 264470,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "is no longer vulnerable to these attacks."
    } ]
  }, {
    "tStartMs": 267080,
    "dDurationMs": 2937,
    "segs": [ {
      "utf8": "For a developer who tirelessly\nmaintains software,"
    } ]
  }, {
    "tStartMs": 270183,
    "dDurationMs": 4462,
    "segs": [ {
      "utf8": "a model that can help them\ndiscover vulnerabilities in their own code"
    } ]
  }, {
    "tStartMs": 274646,
    "dDurationMs": 2835,
    "segs": [ {
      "utf8": "and fix them before they can be exploited,"
    } ]
  }, {
    "tStartMs": 278000,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "that is an invaluable tool."
    } ]
  }, {
    "tStartMs": 280640,
    "dDurationMs": 2523,
    "segs": [ {
      "utf8": "We've spoken to officials\nacross the US government,"
    } ]
  }, {
    "tStartMs": 283194,
    "dDurationMs": 4337,
    "segs": [ {
      "utf8": "and we've offered to work with them\nand collaborate to assess the risks"
    } ]
  }, {
    "tStartMs": 287531,
    "dDurationMs": 3389,
    "segs": [ {
      "utf8": "of these models and to help defend\nagainst the risks of these models."
    } ]
  }, {
    "tStartMs": 290920,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "Everything that we do in our lives now\ndepends on software."
    } ]
  }, {
    "tStartMs": 294954,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "Software ate the world."
    } ]
  }, {
    "tStartMs": 296800,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "Every analog aspect of our life is\nsomehow represented in the digital domain."
    } ]
  }, {
    "tStartMs": 302502,
    "dDurationMs": 3938,
    "segs": [ {
      "utf8": "And so all of our daily lives run\non the idea that we can rely on"
    } ]
  }, {
    "tStartMs": 306440,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "the systems that power them."
    } ]
  }, {
    "tStartMs": 308120,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "Cybersecurity is the security\nof our society."
    } ]
  }, {
    "tStartMs": 311320,
    "dDurationMs": 4843,
    "segs": [ {
      "utf8": "It is essential that we come together\nand work together across industry"
    } ]
  }, {
    "tStartMs": 316180,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "to help build\nbetter defensive capabilities."
    } ]
  }, {
    "tStartMs": 318766,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "No single organization\nsees the whole picture"
    } ]
  }, {
    "tStartMs": 321143,
    "dDurationMs": 1626,
    "segs": [ {
      "utf8": "and can tackle this on their own."
    } ]
  }, {
    "tStartMs": 322840,
    "dDurationMs": 2931,
    "segs": [ {
      "utf8": "This is not going to be done\nas part of a few week program."
    } ]
  }, {
    "tStartMs": 325840,
    "dDurationMs": 3851,
    "segs": [ {
      "utf8": "This is going to be the work\nof certainly months, perhaps years."
    } ]
  }, {
    "tStartMs": 329800,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "But what I do hope\nis at the end of this,"
    } ]
  }, {
    "tStartMs": 332360,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "we can be in a position\nwhere the world's software,"
    } ]
  }, {
    "tStartMs": 335321,
    "dDurationMs": 3079,
    "segs": [ {
      "utf8": "its customer data,\nits financial transactions,"
    } ]
  }, {
    "tStartMs": 338400,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "its critical infrastructure\nare safer than they were before."
    } ]
  } ]
}
