{
  "metadata": {
    "slug": "claude-liam-combining-plugins",
    "title": "Claude, In Concert",
    "subtitle": "Combining Plugins",
    "channel": "claude-liam",
    "persona": "Liam",
    "folderLabel": "@NikBearBrown",
    "audience": "Practitioners and makers following the channel's Claude workflows",
    "register": "Teardown",
    "engine": "kokoro",
    "voice": "am_onyx",
    "palette": "claude",
    "typography": { "serif": "EB Garamond", "ui": "system sans", "mono": "SF Mono" },
    "model_chip": { "model": "Fable 5", "effort": "High" },
    "source": "books/anthropics/books/claude-cowork-plugins/chapters/ch13-combining-plugins.txt",
    "derived_from": "claude-cowork-plugins.md (Ch.13)",
    "genre": "deep-explainer",
    "one_idea": "The real power isn't one plugin, it's a stack — research feeds marketing, data feeds product, sales feeds finance; combining plugins gives a solo operator the coordinated coverage of a whole team, as long as you keep each hand-off intentional.",
    "duration_estimate_s": 330,
    "lane_histogram_target": { "VOX": "20-25%", "MANIM": "25-40%", "REMOTION": "30-45%", "CARD": "remainder" }
  },
  "beats": [
    {
      "id": "B00", "act": "COLD OPEN", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Sawubona, Liam",
      "props": { "command": "If I install several plugins, do I have to tell Claude which one to use?", "runningText": "thinking…", "output": ["No — Claude reads the request", "and reaches for whatever fits."] },
      "narration_text": "Sawubona — this is Liam, in for Bear. Install more than one plugin and you never have to say which. Claude reads the request and reaches for whatever fits. The real power was never one plugin. It's the stack.",
      "spark_line": "One plugin → a stack."
    },

    { "id": "C01", "act": "ACT I", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "How a Stack Works" }, "narration_text": "First, how the stack actually works.", "spark_line": "How a Stack Works" },
    {
      "id": "B01", "act": "ACT I", "lane": "REMOTION", "scene": "LayerStack",
      "narration_text": "With several plugins active, you don't route anything by hand. Claude infers from context. The whole stack is available at once, and the request itself decides which layers wake up.",
      "show": "Stacked translucent plugin layers hold on the stage; a request lands and only the relevant layers illuminate.",
      "viz": { "pattern": "LayerStack", "layers": ["marketing", "sales", "research", "data"], "active": "request-decided" },
      "spark_line": "The stack, all at once."
    },
    {
      "id": "B02", "act": "ACT I", "lane": "MANIM", "scene": "manim/branch_route_request.mp4",
      "narration_text": "Ask a marketing question, the marketing skills switch on. Ask a sales question mid-conversation, the sales plugin engages. You change the subject; Claude changes tools — no announcement required.",
      "show": "One question stream branches to the matching domain node each time the topic changes.",
      "viz": { "pattern": "branch", "in": "one request stream", "workers": 2, "out": "matched domain" },
      "spark_line": "Ask routes to skill."
    },
    {
      "id": "B03", "act": "ACT I", "lane": "MANIM", "scene": "manim/accumulate_both_contribute.mp4",
      "narration_text": "Ask something that spans both, and both contribute. Claude coordinates across the domains and hands you one coherent answer — even though several specialized skill sets built it behind the scenes.",
      "show": "Two domain streams flow in and accumulate into a single merged output block.",
      "viz": { "pattern": "accumulate", "steps": ["marketing contributes", "sales contributes", "one coherent answer"] },
      "spark_line": "Two domains, one answer."
    },
    {
      "id": "B04", "act": "ACT I", "lane": "VOX", "scene": "media/B04.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.45] },
      "narration_text": "For a solo operator, that feels less like software and more like a bench of specialists on call — a whole team's coverage, answering in a single voice.",
      "show": "A still of one person at a desk ringed by a whole team's worth of work; slow push-in.",
      "spark_line": "A team in one voice.",
      "pantry_note": "Tier 1 illustrative: one person at a desk surrounded by the output of many specialists (charts, briefs, contracts). Documentary duotone. No real logos or faces of note."
    },
    {
      "id": "B05", "act": "ACT I", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "And if you want a specific mix, just name it. Look at this from a marketing and a sales angle — and Claude applies both frameworks on purpose, instead of you hoping it guesses.",
      "show": "Two named angle chips resolve onto the stage: Marketing · Sales.",
      "viz": { "pattern": "ChipGrid", "chips": ["Marketing angle", "Sales angle"] },
      "spark_line": "Or just name them."
    },

    { "id": "C02", "act": "ACT II", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Research Feeds Marketing" }, "narration_text": "The first hand-off: research into marketing.", "spark_line": "Research Feeds Marketing" },
    {
      "id": "B06", "act": "ACT II", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "Say you're launching a new service and want positioning grounded in reality, not guesswork. First the research skills survey the landscape — who else is out there, how they position, and where the gaps sit.",
      "show": "SourceFlow: competitor tiles flow in from the left; the empty gaps between them are highlighted.",
      "viz": { "pattern": "SourceFlow", "source": "the competitive landscape", "target": "the open gaps" },
      "spark_line": "Survey the landscape."
    },
    {
      "id": "B07", "act": "ACT II", "lane": "MANIM", "scene": "manim/accumulate_research_into_marketing.mp4",
      "narration_text": "Then those findings hand off to marketing, which builds positioning into the exact gaps the research just found — value propositions and differentiators aimed at open ground.",
      "show": "Research findings accumulate, then feed a positioning block that snaps into the highlighted gap.",
      "viz": { "pattern": "accumulate", "steps": ["research findings", "gaps identified", "positioning built"] },
      "spark_line": "Findings become position."
    },
    {
      "id": "B08", "act": "ACT II", "lane": "VOX", "scene": "media/B08.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.62, 0.5] },
      "narration_text": "The result is a stance that stands apart instead of blending in — distinct, not another me-too voice in a crowded market.",
      "show": "A still of one distinct figure standing apart from a uniform, faceless crowd; slow push toward the standout.",
      "spark_line": "Distinct, not me-too.",
      "pantry_note": "Tier 1 illustrative: a single figure in warm accent apart from a grey uniform crowd. Documentary duotone; terracotta reserved for the standout."
    },
    {
      "id": "B09", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/grounded-vs-generic",
      "narration_text": "Alone, research hands you intelligence and marketing hands you messaging — but messaging with nothing under it. Together the message is grounded. That's the difference between strategic and generic.",
      "show": "Two panels — floating message vs. anchored message — collapse into one grounded stack.",
      "spark_line": "Grounded, not generic."
    },

    { "id": "C03", "act": "ACT III", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Research Feeds Sales" }, "narration_text": "The same hand-off, aimed at a meeting.", "spark_line": "Research Feeds Sales" },
    {
      "id": "B10", "act": "ACT III", "lane": "VOX", "scene": "media/B10.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.4, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.4, "y": 0.5, "scale": 1.5 }, "objects": [ { "id": "operator", "x": 0.4, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "You've got a meeting with a prospect, and you want to walk in better prepared than anyone they've talked to.",
      "show": "A person pauses at the threshold of a meeting room, a folder in hand — composed, ready. Slow push toward the door.",
      "spark_line": "Walk in prepared.",
      "pantry_note": "Tier 1 illustrative: a person at a meeting-room doorway holding a folder. Documentary duotone. First beat of vox_run R1."
    },
    {
      "id": "B11", "act": "ACT III", "lane": "VOX", "scene": "media/B11.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.6, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.6, "y": 0.5, "scale": 1.7 }, "objects": [ { "id": "operator", "x": 0.58, "y": 0.48, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "Research digs the background — what they build, who their customers are, recent signals. Sales turns it into a brief: your angle, the objections to expect, and what to lead with.",
      "show": "Continuous move into the same room — now seated across the table, brief in hand. Same room grammar as B10.",
      "spark_line": "Their world, your angle.",
      "pantry_note": "Tier 1 illustrative: same duotone treatment; the operator now seated at the table reviewing a brief. Continuity with B10 (vox_run R1)."
    },
    {
      "id": "B12", "act": "ACT III", "lane": "MANIM", "scene": "manim/branch_signals_to_brief.mp4",
      "narration_text": "Under it, research produces the raw signals — recent news, hiring patterns, competitive position — and sales translates each signal into a move. Intelligence you actually know how to use.",
      "show": "Signal nodes fan out, then each branches into a matching line of the sales brief.",
      "viz": { "pattern": "branch", "in": "raw signals", "workers": 3, "out": "brief moves" },
      "spark_line": "Signals into moves."
    },
    {
      "id": "B13", "act": "ACT III", "lane": "REMOTION", "scene": "illustration/two-halves",
      "narration_text": "A brief without research is surface prep. Research without sales framing is intelligence you can't act on. Together you understand both their world and your opening within it.",
      "show": "Two halves — surface vs. depth — slide together and lock into one whole.",
      "spark_line": "Both sides, understood."
    },

    { "id": "C04", "act": "ACT IV", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Loop Closes" }, "narration_text": "Two more hand-offs that close a loop.", "spark_line": "The Loop Closes" },
    {
      "id": "B14", "act": "ACT IV", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "Data into marketing: feed six months of performance in — engagement, traffic, conversions by piece and by channel — and let marketing build next quarter's calendar around what actually moved the needle.",
      "show": "SourceFlow: performance metrics stream in on the left; a content calendar assembles on the right.",
      "viz": { "pattern": "SourceFlow", "source": "performance data", "target": "next quarter's calendar" },
      "spark_line": "Data builds the calendar."
    },
    {
      "id": "B15", "act": "ACT IV", "lane": "MANIM", "scene": "manim/branch_tickets_to_specs.mp4",
      "narration_text": "Support into product: the support skills mine your tickets for the pain that hits the most people hardest; product turns the top three into buildable specs. You build against documented need.",
      "show": "Many ticket nodes narrow to a top-three cluster; each of the three expands into a spec card.",
      "viz": { "pattern": "branch", "in": "many tickets", "workers": 3, "out": "buildable specs" },
      "spark_line": "Tickets into specs."
    },
    {
      "id": "B16", "act": "ACT IV", "lane": "VOX", "scene": "media/B16.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "It's the shift from building what feels cool, or planning what you enjoy making, to working directly against what the evidence in front of you already says.",
      "show": "A still of a maker at a workbench building against a wall of pinned, real notes; slow push toward the pinned evidence.",
      "spark_line": "Evidence, not guesswork.",
      "pantry_note": "Tier 1 illustrative: a maker at a bench working beside a board of pinned notes/tickets. Documentary duotone."
    },
    {
      "id": "B17", "act": "ACT IV", "lane": "REMOTION", "scene": "illustration/informed-vs-instinct",
      "narration_text": "Without the data, a solo operator plans on instinct. With it, creative energy points at the work that actually performs — the same effort, aimed better.",
      "show": "A scatter of instinct-arrows resolves into one focused vector pointing at a target.",
      "spark_line": "Same effort, aimed better."
    },
    {
      "id": "B18", "act": "ACT IV", "lane": "MANIM", "scene": "manim/accumulate_loop_closes.mp4",
      "narration_text": "Both hand-offs share one shape: measurement feeds making. Data feeds the calendar, support feeds the roadmap — the loop between what customers do and what you build finally closes.",
      "show": "A cycle completes — measure → make → measure — the ends joining into a closed loop.",
      "viz": { "pattern": "accumulate", "steps": ["measure", "make", "measure again", "loop closes"] },
      "spark_line": "Measurement feeds making."
    },

    { "id": "C05", "act": "ACT V", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Deal Preparation" }, "narration_text": "The highest-stakes hand-off: a contract.", "spark_line": "Deal Preparation" },
    {
      "id": "B19", "act": "ACT V", "lane": "REMOTION", "scene": "LayerStack",
      "narration_text": "A contract lands and you prep to negotiate. Two plugins stack on it at once: sales pulls up the whole relationship — prior conversations, the deal context; legal reviews the terms against its risk frameworks.",
      "show": "A single contract plate with two overlay layers stacking on it: a relationship layer and a risk layer.",
      "viz": { "pattern": "LayerStack", "layers": ["sales: relationship", "legal: risk"], "over": "the contract" },
      "spark_line": "Two layers on one deal."
    },
    {
      "id": "B20", "act": "ACT V", "lane": "MANIM", "scene": "manim/accumulate_merge_brief.mp4",
      "narration_text": "Legal flags the clauses that are unusual for a deal this size; sales frames the leverage you hold. The two merge into a single negotiation brief — what to push on, what's standard, and where you're strong.",
      "show": "The relationship layer and the risk layer accumulate and merge into one negotiation-brief block.",
      "viz": { "pattern": "accumulate", "steps": ["relationship read", "risk read", "one negotiation brief"] },
      "spark_line": "Two reads, one brief."
    },
    {
      "id": "B21", "act": "ACT V", "lane": "VOX", "scene": "media/B21.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.55] },
      "narration_text": "You sit down understanding both the commercial relationship and the contractual fine print at the same time — negotiating from complete awareness instead of half of it.",
      "show": "A still of two parties at a negotiation table, papers between them; slow push toward the papers.",
      "spark_line": "Complete awareness.",
      "pantry_note": "Tier 1 illustrative: two people across a negotiation table with a contract between them. Documentary duotone."
    },
    {
      "id": "B22", "act": "ACT V", "lane": "REMOTION", "scene": "illustration/blind-spots",
      "narration_text": "Contract review in isolation misses the business context. Sales prep with no legal eye misses the risk. Stacked, neither blind spot survives.",
      "show": "Two blind-spot circles overlap until the gap between them disappears entirely.",
      "spark_line": "No blind spots left."
    },

    { "id": "C06", "act": "ACT VI", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Keep the Hand-off Intentional" }, "narration_text": "One rule holds the whole stack together.", "spark_line": "Keep the Hand-off Intentional" },
    {
      "id": "B23", "act": "ACT VI", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Four habits keep combinations sharp. Name the domains you want. Start simple — get fluent with one plugin before you orchestrate several. Document the combinations that work. And notice the gaps.",
      "show": "Four chips resolve in turn: Name the Domains · Start Simple · Document What Works · Notice the Gaps.",
      "viz": { "pattern": "ChipGrid", "chips": ["Name the domains", "Start simple", "Document what works", "Notice the gaps"] },
      "spark_line": "Four habits."
    },
    {
      "id": "B24", "act": "ACT VI", "lane": "MANIM", "scene": "manim/accumulate_workflow_to_plugin.mp4",
      "narration_text": "When a two-plugin flow keeps earning its keep — prospect research into outreach, say — write it down. Better, capture the whole workflow as a custom plugin, so it runs from a single command.",
      "show": "A repeated multi-step flow collapses down into one command chip.",
      "viz": { "pattern": "accumulate", "steps": ["repeat the flow", "document it", "one custom command"] },
      "spark_line": "A workflow, one command."
    },
    {
      "id": "B25", "act": "ACT VI", "lane": "VOX", "scene": "media/B25.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.5] },
      "narration_text": "And when you wish a combination could do something it can't — data flowing straight into the roadmap — that's not a dead end. It's a signal. The integration points are still being built.",
      "show": "A still of a hand reaching toward the gap between two connected blocks; a terracotta arc draws on to bridge the missing link.",
      "spark_line": "Mind the gaps.",
      "pantry_note": "Tier 1 illustrative: a hand reaching across a gap between two linked blocks. Documentary duotone; the bridging arc is added at previz."
    },
    { "id": "B26", "act": "ACT VI", "lane": "CARD", "scene": "SparkBeat", "narration_text": "One plugin is a specialist. A stack, with every hand-off intentional, is a coordinated team.", "spark_line": "One stack, a team." },

    {
      "id": "V01", "act": "CLOSE", "lane": "REMOTION", "scene": "ClaudeVerdictArtifact",
      "lead_silence_s": 0.5,
      "narration_text": "Let's recap with Claude. The power isn't one plugin — it's the stack. Claude infers which skills a request needs and coordinates across them into one coherent answer. Research feeds marketing, research feeds sales, data feeds product, sales feeds legal — a solo operator gets a whole team's coverage. The only rule: keep each hand-off intentional — name the domains, document what works, and mind the gaps.",
      "props": { "artifactLines": [ "The power is the stack, not one plugin", "Claude infers the domains and coordinates across them", "Research feeds marketing and sales; data feeds product; sales feeds legal", "One operator, a whole team's coverage", "Keep every hand-off intentional — name, document, mind the gaps" ] },
      "spark_line": "The verdict."
    },
    {
      "id": "H01", "act": "CLOSE", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Your turn.",
      "props": { "command": "I'm about to make a real move — a launch, a pitch, or a build. Work it from two angles: (1) research the landscape first and pull out the findings that matter, then (2) hand those findings to marketing to build positioning into the gaps you found. At the end, show me exactly where the combined answer beats either angle working alone.", "runningText": "paste this into Claude…" },
      "narration_text": "Your turn. Paste this into Claude: I'm about to make a real move — a launch, a pitch, or a build. Work it from two angles — research the landscape first and pull the findings that matter, then hand those findings to marketing to build positioning into the gaps you found. Then show me exactly where the combined answer beats either angle alone. Name the two domains, watch the hand-off happen, and you'll feel the stack do what no single plugin could.",
      "spark_line": "Run your first stack."
    },
    {
      "id": "O01", "act": "CLOSE", "lane": "CARD", "scene": "ClaudeTitleOutro",
      "narration_text": "Claude, In Concert. Liam — in for Bear.",
      "props": { "title": "Claude, In Concert", "handle": "@NikBearBrown", "subline": "Combining Plugins" },
      "spark_line": "Claude, In Concert"
    }
  ]
}
