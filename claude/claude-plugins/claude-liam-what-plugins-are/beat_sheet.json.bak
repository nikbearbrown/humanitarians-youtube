{
  "metadata": {
    "slug": "claude-liam-what-plugins-are",
    "title": "Claude, Equipped",
    "subtitle": "What a Cowork Plugin Actually Is",
    "channel": "claude-liam",
    "persona": "Kore",
    "folderLabel": "@HumanitariansAI",
    "audience": "Practitioners and makers following the channel's Claude workflows",
    "register": "Teardown",
    "engine": "kokoro",
    "voice": "af_kore",
    "palette": "claude",
    "typography": { "serif": "EB Garamond", "ui": "system sans", "mono": "SF Mono" },
    "model_chip": { "model": "Fable 5", "effort": "High" },
    "source": "books/anthropics/books/claude-cowork-plugins/chapters/ch01-what-plugins-are.txt",
    "derived_from": "claude-cowork-plugins.md (Ch.1)",
    "genre": "deep-explainer",
    "one_idea": "A plugin turns the generalist into an equipped specialist — expertise plus the tools, the shortcuts, and the autonomy — but it is still a tool, not the professional.",
    "duration_estimate_s": 300,
    "lane_histogram_target": { "VOX": "20-25%", "MANIM": "25-40%", "REMOTION": "30-45%", "CARD": "remainder" }
  },
  "beats": [
    {
      "id": "B00", "act": "COLD OPEN", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Hola, Kore",
      "props": { "command": "What does a Cowork plugin actually do to Claude?", "runningText": "thinking…", "output": ["It stops being a smart generalist", "and becomes an equipped specialist."] },
      "narration_text": "Hola — this is Kore, in for Humanitarians AI. Install a plugin and Claude stops being a clever generalist and becomes an equipped specialist. Here's what that actually means, and where the line is.",
      "spark_line": "Generalist → specialist."
    },

    { "id": "C01", "act": "ACT I", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Generalist" }, "narration_text": "Start with what you already have.", "spark_line": "The Generalist" },
    {
      "id": "B01", "act": "ACT I", "lane": "REMOTION", "scene": "PredictCard",
      "narration_text": "Claude without plugins is a capable generalist. It can discuss any topic and apply broad knowledge to your situation. Useful — but it's a smart friend helping with your taxes. They'll try. They're not an accountant.",
      "show": "A single wide, shallow field of knowledge — broad but thin.",
      "spark_line": "Broad, but shallow."
    },
    {
      "id": "B02", "act": "ACT I", "lane": "MANIM", "scene": "manim/scale_shallow_vs_deep.mp4",
      "narration_text": "A plugin makes Claude the accountant — or the marketer, the sales researcher, the contract reviewer. It trades a mile of shallow knowledge for a well that goes deep in one domain.",
      "show": "A wide shallow bar collapses into a single deep column as the words land.",
      "viz": { "pattern": "scale", "from": "broad/shallow", "to": "narrow/deep" },
      "spark_line": "One well, dug deep."
    },

    { "id": "C02", "act": "ACT II", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Four Components" }, "narration_text": "Under the hood, a plugin can carry four things.", "spark_line": "The Four Components" },
    {
      "id": "B03", "act": "ACT II", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Skills, connectors, commands, and subagents. Not every plugin uses all four — but together they're why installing a plugin is nothing like writing a better prompt.",
      "show": "Four labeled chips resolve onto the stage: Skills · Connectors · Commands · Subagents.",
      "viz": { "pattern": "ChipGrid", "chips": ["Skills", "Connectors", "Commands", "Subagents"] },
      "spark_line": "Four parts, one package."
    },
    {
      "id": "B04", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/skills-auto-activate",
      "narration_text": "Skills are the expertise — methodical frameworks, not generic tips. They switch on automatically when they're relevant. Ask a marketing question with marketing installed, and Claude just reaches for them.",
      "show": "A dormant framework icon lights up the instant a matching question arrives.",
      "spark_line": "Expertise, auto-armed."
    },
    {
      "id": "B05", "act": "ACT II", "lane": "VOX", "scene": "media/B05.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.45] },
      "narration_text": "Connectors are the reach. The sales plugin into your CRM, the data plugin into your spreadsheets — so Claude works on your actual business data, not hypothetical examples.",
      "show": "A still of connective lines running from an app into a data store; slow push-in.",
      "spark_line": "Reach into your tools.",
      "pantry_note": "Tier 1 illustrative: abstract 'connector' plate — lines linking an app window to a database/spreadsheet. No real logos."
    },
    {
      "id": "B06", "act": "ACT II", "lane": "REMOTION", "scene": "code-block",
      "narration_text": "Commands are the shortcuts. Slash-prospect-brief, and sales researches a company. Slash-audit, and marketing tears apart a page. Type slash inside Cowork to see them all.",
      "show": "Onda code-block: a composer line typing '/prospect-brief acme.com' then '/seo-audit'.",
      "props": { "code": "/prospect-brief acme.com\n/seo-audit https://acme.com" },
      "spark_line": "One slash, one job."
    },
    {
      "id": "B07", "act": "ACT II", "lane": "MANIM", "scene": "manim/subagents_fan_out.mp4",
      "narration_text": "Subagents are the autonomy. Ask finance to build a model, and it quietly coordinates the steps — gather, structure, run scenarios, compile — so you get one clean result instead of a jumble.",
      "show": "One request fans out into four worker nodes that merge back into a single output.",
      "viz": { "pattern": "branch", "in": "one ask", "workers": 4, "out": "one result" },
      "spark_line": "Many steps, one answer."
    },
    { "id": "B08", "act": "ACT II", "lane": "CARD", "scene": "SparkBeat", "narration_text": "Skills are the expertise. The plugin is the fully-equipped specialist — expertise plus the tools.", "spark_line": "Expertise plus tools." },

    { "id": "C03", "act": "ACT III", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "General → Specific" }, "narration_text": "Here's the shift that earns its keep.", "spark_line": "General → Specific" },
    {
      "id": "B09", "act": "ACT III", "lane": "MANIM", "scene": "manim/divergence_general_to_specific.mp4",
      "narration_text": "Without plugins, Claude knows sales in the abstract, understands finance, can discuss contract law. Broad knowledge, shallow for any real job. With a plugin, that general knowledge becomes contextual capability.",
      "show": "A diffuse cloud of 'general knowledge' resolves into a sharp, specific vector.",
      "viz": { "pattern": "divergence", "from": "general knowledge", "to": "specific capability" },
      "spark_line": "Knowing → doing."
    },
    {
      "id": "B10", "act": "ACT III", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "The sales plugin doesn't just know about sales — it researches your prospect through your tools. Legal reviews the actual contract you're about to sign. Marketing drafts in your brand voice, from your style guide.",
      "show": "Your tools flow in on the left; the plugin acts on them on the right — SourceFlow.",
      "viz": { "pattern": "SourceFlow", "source": "your tools + your data", "target": "the plugin's action" },
      "spark_line": "Your data, not examples."
    },
    {
      "id": "B11", "act": "ACT III", "lane": "VOX", "scene": "media/B11.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.38, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.38, "y": 0.5, "scale": 1.6 }, "objects": [ { "id": "reader", "x": 0.35, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "It's the difference between asking a friend who reads a lot what to watch for in a contract…",
      "show": "A person at a desk buried in books — the well-read friend. Slow push toward them.",
      "spark_line": "The well-read friend.",
      "pantry_note": "Tier 1 illustrative: a person surrounded by stacked books, documentary duotone."
    },
    {
      "id": "B12", "act": "ACT III", "lane": "VOX", "scene": "media/B12.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.62, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.62, "y": 0.5, "scale": 1.8 }, "objects": [ { "id": "pro", "x": 0.6, "y": 0.48, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "…and asking someone who reviews contracts professionally. That's the whole reason a plugin is worth your time.",
      "show": "Continuous move to a second desk — the professional mid-markup on a contract. Same room grammar as B11.",
      "spark_line": "The professional.",
      "pantry_note": "Tier 1 illustrative: same duotone treatment; a professional marking up a contract. Continuity with B11 (vox_run R1)."
    },

    { "id": "C04", "act": "ACT IV", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Free, Open, Yours" }, "narration_text": "Three facts about how they're built.", "spark_line": "Free, Open, Yours" },
    {
      "id": "B13", "act": "ACT IV", "lane": "REMOTION", "scene": "illustration/open-source-triptych",
      "narration_text": "Anthropic released these as open source. For you that mostly means free — no charge beyond your paid plan. But open buys three more things: transparency instead of a black box, community fixes over time, and the ability to adjust a plugin that almost fits.",
      "show": "Three panels light in turn: Transparent · Community · Customizable.",
      "viz": { "pattern": "triptych", "panels": ["Transparent", "Community", "Customizable"] },
      "spark_line": "Open, so it bends."
    },
    {
      "id": "B14", "act": "ACT IV", "lane": "MANIM", "scene": "manim/threshold_stock_vs_configured.mp4",
      "narration_text": "Out of the box, the sales plugin is useful. Configured with your process, your qualifying criteria, your positioning, it's dramatically more powerful. Customization is the next chapter — but it's where the real gain hides.",
      "show": "A 'stock' meter sits mid-scale, then jumps past a threshold to 'configured'.",
      "viz": { "pattern": "threshold", "before": "out of the box", "after": "configured" },
      "spark_line": "Configured hits harder."
    },

    { "id": "C05", "act": "ACT V", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "What They Can't Do" }, "narration_text": "Now the honest part.", "spark_line": "What They Can't Do" },
    {
      "id": "B15", "act": "ACT V", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Four limits, stated plainly. Plugins don't hand Claude perfect judgment. They don't bypass its knowledge boundaries. They work only inside your existing access — your credentials, your permissions, nothing new. And they're tools, not replacements.",
      "show": "Four caution chips resolve: No judgment · No new knowledge · Your access only · Tool, not replacement.",
      "viz": { "pattern": "ChipGrid", "chips": ["No perfect judgment", "No new knowledge", "Your access only", "Tool, not replacement"] },
      "spark_line": "Four hard limits."
    },
    {
      "id": "B16", "act": "ACT V", "lane": "VOX", "scene": "media/B16.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.45] },
      "narration_text": "Legal flags a scary clause; it can't weigh it against the deal. Finance builds the model; it can't tell you the assumptions fit your industry. Human judgment stays on the consequential calls. That caveat isn't a disclaimer to skip — it's the instructions.",
      "show": "A still of a person at the decision point; a terracotta ring draws on around 'the human'.",
      "spark_line": "You keep the judgment.",
      "pantry_note": "Tier 1 illustrative: a person pausing over a signed page; ring annotation added at previz."
    },

    { "id": "C06", "act": "ACT VI", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Choosing Yours" }, "narration_text": "So which do you install?", "spark_line": "Choosing Yours" },
    {
      "id": "B17", "act": "ACT VI", "lane": "MANIM", "scene": "manim/accumulate_choose_plugins.mp4",
      "narration_text": "You don't need the whole catalog; most people run two or three. Start with your primary function — whatever you spend your day on. Add your biggest bottleneck — the thing you know you should do but don't. Then keep productivity running underneath as the foundation.",
      "show": "Three tiles stack in order: Primary → Bottleneck → Productivity foundation.",
      "viz": { "pattern": "accumulate", "steps": ["Primary function", "Biggest bottleneck", "Productivity foundation"] },
      "spark_line": "Two or three. Start focused."
    },

    {
      "id": "V01", "act": "CLOSE", "lane": "REMOTION", "scene": "ClaudeVerdictArtifact",
      "lead_silence_s": 0.5,
      "narration_text": "Let's recap with Claude. A plugin bundles four things — skills, connectors, commands, subagents — into one installable specialist. It turns broad, shallow knowledge into deep, contextual capability on your own data. It's free and open, so it bends to your business. And it's still a tool: it keeps the expertise, you keep the judgment.",
      "props": { "artifactLines": [ "Four parts: skills, connectors, commands, subagents", "Broad knowledge → deep, contextual capability", "Runs on your tools and your access — nothing new", "Free and open, so it customizes", "A tool, not the professional — you keep the judgment" ] },
      "spark_line": "The verdict."
    },
    {
      "id": "H01", "act": "CLOSE", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Your turn.",
      "props": { "command": "I run a small business and I'm new to Cowork plugins. Walk me through choosing my first two: (1) ask me what I spend most of my day on, (2) name the one function I keep neglecting, then (3) tell me which plugin to install first, which to add second, and one way to customize each for my business.", "runningText": "paste this into Claude…" },
      "narration_text": "Your turn. Paste this into Claude: I run a small business and I'm new to Cowork plugins — walk me through choosing my first two. Ask what I do all day, name the function I keep neglecting, then tell me which plugin to install first, which second, and one way to customize each. It turns this chapter into a setup made for your actual work — run it and watch what it asks you.",
      "spark_line": "Choose your first two."
    },
    {
      "id": "O01", "act": "CLOSE", "lane": "CARD", "scene": "ClaudeTitleOutro",
      "narration_text": "Claude, Equipped.",
      "props": { "title": "Claude, Equipped", "handle": "@HumanitariansAI", "subline": "What a Cowork plugin actually is" },
      "spark_line": "Claude, Equipped"
    }
  ]
}
