{
  "metadata": {
    "slug": "claude-liam-installing-plugins",
    "title": "Claude, Configured",
    "subtitle": "Installing and Customizing Plugins",
    "channel": "claude-liam",
    "persona": "Kore",
    "folderLabel": "@HumanitariansAI",
    "audience": "Practitioners and makers following the channel's Claude workflows",
    "register": "Teardown",
    "engine": "kokoro",
    "voice": "af_kore",
    "palette": "claude",
    "typography": { "serif": "EB Garamond", "ui": "system sans", "mono": "SF Mono" },
    "model_chip": { "model": "Fable 5", "effort": "High" },
    "source": "books/anthropics/books/claude-cowork-plugins/chapters/ch02-installing-customizing.txt",
    "derived_from": "claude-cowork-plugins.md (Ch.2)",
    "genre": "deep-explainer",
    "one_idea": "Installing a plugin is trivial — browse, click, done; the leverage is customizing it, teaching the plugin your voice, your process, and your terms in a plain-language conversation until generic defaults become output built for your business.",
    "duration_estimate_s": 330,
    "lane_histogram_target": { "VOX": "20-25%", "MANIM": "25-40%", "REMOTION": "30-45%", "CARD": "remainder" }
  },
  "beats": [
    {
      "id": "B00", "act": "COLD OPEN", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Bonjour, Kore",
      "props": { "command": "Installing a plugin is easy. So where's the actual work?", "runningText": "thinking…", "output": ["The install takes seconds.", "The leverage is in customizing it."] },
      "narration_text": "Bonjour — this is Kore, in for Humanitarians AI. Installing a Cowork plugin is trivial: browse, click, done. The real work — and the real payoff — is teaching it your business. Here's where the leverage actually lives.",
      "spark_line": "Install → customize."
    },

    { "id": "C01", "act": "ACT I", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Installing Is Easy" }, "narration_text": "First, the part that barely counts as work.", "spark_line": "Installing Is Easy" },
    {
      "id": "B01", "act": "ACT I", "lane": "REMOTION", "scene": "illustration/plugin-library-grid",
      "narration_text": "Open the plugin section and you get a library — an official collection plus community additions. Each listing tells you what it does, what domain it covers, what it includes. Browse by function; find the ones that fit your work.",
      "show": "A grid of plugin cards fills the stage; a function filter sweeps through and narrows them to the few that match a job.",
      "viz": { "pattern": "grid-filter", "field": "plugin catalog", "narrow_to": "matches your work" },
      "spark_line": "Browse by function."
    },
    {
      "id": "B02", "act": "ACT I", "lane": "MANIM", "scene": "manim/accumulate_install_steps.mp4",
      "narration_text": "Click install. It downloads, activates, and it's ready — no setup wizard, no configuration file. If you've ever added an app from a store, you already have the whole skill. That's genuinely it.",
      "show": "Three stages light in sequence — Download, Activate, Ready — then collapse into one check.",
      "viz": { "pattern": "accumulate", "steps": ["Download", "Activate", "Ready"] },
      "spark_line": "Click. Done."
    },
    {
      "id": "B03", "act": "ACT I", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Once it's in, its capabilities just appear in your sessions. Skills switch on when they're relevant. Slash commands show up in your command menu. Connectors sit ready to configure. Nothing to wire up first.",
      "show": "Three chips resolve onto the stage in narration order: Skills · Commands · Connectors — each lighting as it's named.",
      "viz": { "pattern": "ChipGrid", "chips": ["Skills auto-activate", "Commands in the menu", "Connectors ready"] },
      "spark_line": "Capabilities just appear."
    },
    {
      "id": "B04", "act": "ACT I", "lane": "VOX", "scene": "media/B04.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "Someone shares a plugin — a colleague's workflow, a community creation you found online. It arrives as a file. Click upload, pick it, and Cowork handles the rest. Same two minutes as any install.",
      "show": "A still of a handed-over file dropping toward an upload slot; slow push toward the drop point.",
      "spark_line": "Shared plugins upload too.",
      "pantry_note": "Tier 1 illustrative: a file/drive being passed or dropped into a slot; documentary duotone. No real logos or people."
    },

    { "id": "C02", "act": "ACT II", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Making It Yours" }, "narration_text": "Now the part that actually matters.", "spark_line": "Making It Yours" },
    {
      "id": "B05", "act": "ACT II", "lane": "MANIM", "scene": "manim/divergence_generic_vs_yours.mp4",
      "narration_text": "Out of the box, a plugin runs on sensible defaults — generic best practices for its domain. Useful. But you don't do generic work. You have your own process, your own terminology, your own way in.",
      "show": "A flat 'generic default' track sits mid-frame; a second track labeled 'your work' pulls away from it and diverges.",
      "viz": { "pattern": "divergence", "from": "generic defaults", "to": "your work" },
      "spark_line": "You don't do generic."
    },
    {
      "id": "B06", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/config-to-conversation",
      "narration_text": "Click customize and Cowork doesn't open a settings panel — it starts a conversation. It asks about your workflow, your preferences, your tools. You answer in plain language. The plugin adjusts its behavior from what you said.",
      "show": "A rigid settings panel of sliders dissolves into a back-and-forth exchange — question, plain-language answer, adjust.",
      "viz": { "pattern": "transform", "from": "config panel", "to": "plain-language conversation" },
      "spark_line": "A conversation, not config."
    },
    {
      "id": "B07", "act": "ACT II", "lane": "MANIM", "scene": "manim/loop_ask_answer_calibrate.mp4",
      "narration_text": "The pattern never changes: Claude asks, you answer, the plugin calibrates. Ask again, answer again, it tightens. It's the same loop whether you spend two questions or twenty.",
      "show": "A three-node cycle turns — Ask → Answer → Calibrate — tightening inward with each pass.",
      "viz": { "pattern": "loop", "nodes": ["Ask", "Answer", "Calibrate"] },
      "spark_line": "Ask, answer, calibrate."
    },
    {
      "id": "B08", "act": "ACT II", "lane": "VOX", "scene": "media/B08.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "How far you take it is your call. Install and run the defaults — fine, still useful. Or spend a few minutes and get something that feels built for your business. It scales with how central that domain is to your day.",
      "show": "A still of a tuning dial mid-turn; a terracotta mark tracks how far it's been turned.",
      "spark_line": "Your call, your depth.",
      "pantry_note": "Tier 1 illustrative: a hand on a tuning knob or mixing fader, documentary duotone; terracotta mark added at previz."
    },

    { "id": "C03", "act": "ACT III", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "A Real Customization" }, "narration_text": "Watch one actually happen.", "spark_line": "A Real Customization" },
    {
      "id": "B09", "act": "ACT III", "lane": "REMOTION", "scene": "illustration/customize-qa",
      "narration_text": "You install marketing and click customize. First question: what does your business do, and who are your customers? You answer — a web design studio, clients are small professional-services firms with no in-house marketing.",
      "show": "A single question card resolves at top; a plain-language answer types in beneath it, line by line.",
      "viz": { "pattern": "qa-exchange", "q": "What do you do? Who are your customers?", "a": "Web design studio · small pro-services firms" },
      "spark_line": "What do you do?"
    },
    {
      "id": "B10", "act": "ACT III", "lane": "VOX", "scene": "media/B10.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.4, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.4, "y": 0.5, "scale": 1.6 }, "objects": [ { "id": "studio", "x": 0.4, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "This is the studio — one person, a few screens, real clients waiting on real sites. Not a hypothetical persona the plugin invented. The business it's about to learn is yours.",
      "show": "A still of a small one-person design studio at work; slow push in toward the desk.",
      "spark_line": "This is the studio.",
      "pantry_note": "Tier 1 illustrative: a small one-person design studio, monitors with layouts; documentary duotone. Continuity into B11 (vox_run R1)."
    },
    {
      "id": "B11", "act": "ACT III", "lane": "VOX", "scene": "media/B11.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.6, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.6, "y": 0.5, "scale": 1.8 }, "objects": [ { "id": "clients", "x": 0.6, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "And these are the clients it now understands — accountants, lawyers, financial advisors who need a modern site but have no marketing team. That's who every draft will be written for.",
      "show": "Continuous move from the studio to the clients — small professional offices — same room grammar as B10.",
      "spark_line": "And these are the clients.",
      "pantry_note": "Tier 1 illustrative: small professional-services offices (accountant/advisor), same duotone treatment; continuity with B10 (vox_run R1)."
    },
    {
      "id": "B12", "act": "ACT III", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "A few more answers — voice is professional but approachable, no jargon; formats are LinkedIn posts and a monthly newsletter. The plugin locks all of it in: right audience, right voice, right formats.",
      "show": "Three answer-chips snap into a settings frame — Voice · Audience · Formats — each filling from the spoken answer.",
      "viz": { "pattern": "ChipGrid", "chips": ["Voice: approachable", "Audience: pro-services", "Formats: posts + newsletter"] },
      "spark_line": "Voice, audience, formats."
    },
    {
      "id": "B13", "act": "ACT III", "lane": "MANIM", "scene": "manim/divergence_generic_vs_tuned.mp4",
      "narration_text": "Now the output diverges. Ask for a content calendar and you get posts and newsletter topics — not viral video scripts and press releases. A competitive scan targets other web studios, not enterprise agencies. Generic advice becomes advice from someone who knows your business.",
      "show": "One request splits into two branches — a generic branch grays out while the tuned branch sharpens and stays.",
      "viz": { "pattern": "divergence", "from": "generic output", "to": "tuned output" },
      "spark_line": "Generic → tuned."
    },

    { "id": "C04", "act": "ACT IV", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Connecting Your Tools" }, "narration_text": "Some plugins want more than words.", "spark_line": "Connecting Your Tools" },
    {
      "id": "B14", "act": "ACT IV", "lane": "REMOTION", "scene": "illustration/self-contained-vs-connected",
      "narration_text": "Some plugins are self-contained — the productivity plugin works out of the box, connected to nothing. Others get dramatically more useful the moment you plug them into the tools you already run.",
      "show": "Two plugin tiles: one sealed and complete; the other grows connection lines out to external tools and brightens.",
      "viz": { "pattern": "compare", "left": "self-contained", "right": "connected" },
      "spark_line": "Some need connecting."
    },
    {
      "id": "B15", "act": "ACT IV", "lane": "MANIM", "scene": "manim/threshold_public_vs_connected.mp4",
      "narration_text": "The sales plugin researches a prospect from public information alone — decent. Connect it to your CRM and it pulls your relationship history, deal status, and every past conversation into the work. The reach jumps.",
      "show": "A short reach-bar labeled 'public info' extends past a threshold to 'your CRM' as the connection lands.",
      "viz": { "pattern": "threshold", "before": "public info only", "after": "connected to your CRM" },
      "spark_line": "Connected reaches further."
    },
    {
      "id": "B16", "act": "ACT IV", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "Same shape for data. Give it files and it works with what you provide. Connect it to your database or warehouse and it queries your actual business data directly — no exporting, no copying, live.",
      "show": "A stack of static files on the left flows into a live database cylinder on the right — SourceFlow.",
      "viz": { "pattern": "SourceFlow", "source": "files you provide", "target": "your live database" },
      "spark_line": "Files → live data."
    },
    {
      "id": "B17", "act": "ACT IV", "lane": "VOX", "scene": "media/B17.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.45] },
      "narration_text": "Connecting is the standard login flow — authorize access the same way you'd link any third-party app. And it's optional: start without connections, add them later when you can see the value.",
      "show": "A still of an authorize handshake; a terracotta ring draws on around the grant as it's spoken.",
      "spark_line": "Authorize, then reach.",
      "pantry_note": "Tier 1 illustrative: an authorize/permission moment — a key, handshake, or grant screen; documentary duotone; ring annotation added at previz."
    },

    { "id": "C05", "act": "ACT V", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Living With Them" }, "narration_text": "A few notes for the long run.", "spark_line": "Living With Them" },
    {
      "id": "B18", "act": "ACT V", "lane": "MANIM", "scene": "manim/toggle_disable_preserved.mp4",
      "narration_text": "Want Claude to focus? Disable a plugin without removing it — your customization and configuration are preserved, waiting. Flip it back on when you need it. Nothing you taught it is lost.",
      "show": "A toggle switches off; the plugin dims but its stored config stays visible and intact beneath it.",
      "viz": { "pattern": "toggle", "state": "disabled", "preserved": "config kept" },
      "spark_line": "Off without erasing."
    },
    {
      "id": "B19", "act": "ACT V", "lane": "REMOTION", "scene": "illustration/plugin-updates",
      "narration_text": "Plugins improve over time — Anthropic and the community add features and fix issues, and Cowork handles the updates. Worth checking in occasionally to see what's new that you might actually use.",
      "show": "A plugin card gains new capability rows across successive versions, each fading in from the bottom.",
      "viz": { "pattern": "versioned-growth", "adds": ["feature", "fix", "refinement"] },
      "spark_line": "They keep improving."
    },
    {
      "id": "B20", "act": "ACT V", "lane": "MANIM", "scene": "manim/scale_active_vs_shelved.mp4",
      "narration_text": "Loading up on plugins doesn't slow Claude down or confuse it — but in practice most people keep two or three active. The rest stay installed and disabled, ready the moment a job calls for them.",
      "show": "A dozen tiles present; two or three brighten to 'active' while the rest recede to a ready shelf.",
      "viz": { "pattern": "scale", "active": "two or three", "shelved": "the rest, ready" },
      "spark_line": "Two or three, active."
    },
    {
      "id": "B21", "act": "ACT V", "lane": "VOX", "scene": "media/B21.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "One catch worth knowing: your plugins and everything you taught them live on your machine. Work on a second computer and you set them up again there. The customization is personal — it doesn't follow you automatically.",
      "show": "A still of a single laptop on a desk; the plugin config sits anchored to that one machine.",
      "spark_line": "Local to your machine.",
      "pantry_note": "Tier 1 illustrative: a single laptop on a desk, personal workspace; documentary duotone."
    },
    {
      "id": "B22", "act": "ACT V", "lane": "REMOTION", "scene": "code-block",
      "narration_text": "After installing, run one test. Type a slash to list the plugin's commands, or just ask it to do the domain job — help me build a content calendar for next month. A live plugin answers noticeably more structured and domain-aware.",
      "show": "Onda code-block: a composer types '/' to reveal the plugin's commands, then a plain request for a content calendar.",
      "props": { "code": "/  → list marketing commands\nHelp me build a content calendar for next month." },
      "spark_line": "Test it once."
    },
    { "id": "B23", "act": "ACT V", "lane": "CARD", "scene": "SparkBeat", "narration_text": "So: installing is the easy part — seconds of work. The leverage is customizing, connecting, and pruning until generic output becomes yours.", "spark_line": "Custom is the leverage." },

    {
      "id": "V01", "act": "CLOSE", "lane": "REMOTION", "scene": "ClaudeVerdictArtifact",
      "lead_silence_s": 0.5,
      "narration_text": "Let's recap with Claude. Installing a plugin is trivial — browse, click, ready. The value comes after: customize it in a plain-language conversation until it knows your voice, your process, your terms. Connect the ones that want your live tools; leave the self-contained ones alone. Keep two or three active, and remember it all lives on your machine. Generic defaults are the floor — you decide how far past them to go.",
      "props": { "artifactLines": [ "Install is trivial: browse → click → ready", "Customize by conversation — your voice, process, terms", "Connect the plugins that want your live tools", "Enable and disable freely; customization is preserved", "It lives on your machine, and defaults are just the floor" ] },
      "spark_line": "The verdict."
    },
    {
      "id": "H01", "act": "CLOSE", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Your turn.",
      "props": { "command": "I just installed a Cowork plugin and I want to customize it for my business instead of running the defaults. Interview me the way the customize conversation would: (1) ask me what my business does and who my customers are, (2) ask about my brand voice, my content formats, and the terminology I use, then (3) summarize the exact settings you'd apply and show me one before-and-after example of how a typical output changes once it's tuned to me.", "runningText": "paste this into Claude…" },
      "narration_text": "Your turn. Paste this into Claude: I just installed a plugin and I want to customize it for my business instead of running the defaults — interview me the way the customize conversation would. Ask what my business does and who my customers are, ask about my voice, my formats, and my terminology, then summarize the exact settings you'd apply and show one before-and-after of how my output changes. It runs this whole chapter on your actual business — watch what it asks, and watch the generic answer turn into yours.",
      "spark_line": "Customize it live."
    },
    {
      "id": "O01", "act": "CLOSE", "lane": "CARD", "scene": "ClaudeTitleOutro",
      "narration_text": "Claude, Configured. Kore, in for Humanitarians AI.",
      "props": { "title": "Claude, Configured", "handle": "@HumanitariansAI", "subline": "Installing and customizing plugins" },
      "spark_line": "Claude, Configured"
    }
  ]
}
