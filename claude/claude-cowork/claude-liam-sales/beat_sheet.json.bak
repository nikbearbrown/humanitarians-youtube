{
  "metadata": {
    "slug": "claude-liam-sales",
    "title": "Claude, Closing",
    "subtitle": "The Sales Plugin",
    "channel": "claude-liam",
    "persona": "Kore",
    "folderLabel": "@HumanitariansAI",
    "audience": "Practitioners and makers following the channel's Claude workflows",
    "register": "Teardown",
    "engine": "kokoro",
    "voice": "af_kore",
    "palette": "claude",
    "typography": { "serif": "EB Garamond", "ui": "system sans", "mono": "SF Mono" },
    "model_chip": { "model": "Fable 5", "effort": "High" },
    "source": "books/anthropics/books/claude-cowork-plugins/chapters/ch05-sales.txt",
    "derived_from": "claude-cowork-plugins.md (Ch.5)",
    "genre": "deep-explainer",
    "one_idea": "The sales plugin meets you where you are — not built only for a big SaaS sales org with a Salesforce admin. It researches a prospect from public information, preps you for the conversation, tracks where deals stand, and drafts personalized follow-ups; configured with your process it stops being generic. It's a research-and-prep accelerator, not a closer — the relationship is still yours.",
    "duration_estimate_s": 300,
    "lane_histogram_target": { "VOX": "20-25%", "MANIM": "25-40%", "REMOTION": "30-45%", "CARD": "remainder" }
  },
  "beats": [
    {
      "id": "B00", "act": "COLD OPEN", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Konnichiwa, Kore",
      "props": { "command": "Do I have to be a salesperson to use the sales plugin?", "runningText": "thinking…", "output": ["No — it meets you where you are.", "It researches, preps, and drafts. You still close."] },
      "narration_text": "Konnichiwa — this is Kore, in for Humanitarians AI. Most people who reach for the sales plugin don't call themselves salespeople. It meets you where you are — it researches a prospect, preps the conversation, and drafts the follow-up. The closing stays yours.",
      "spark_line": "You still close."
    },

    { "id": "C01", "act": "ACT I", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Meets You Where You Are" }, "narration_text": "Start with who it's actually for.", "spark_line": "Who it's for" },
    {
      "id": "B01", "act": "ACT I", "lane": "REMOTION", "scene": "PredictCard",
      "narration_text": "Consultants. Freelancers. Agency owners. Builders. People who need clients but never studied pipeline management and never wanted to. If that's you, the sales plugin was built with you in mind.",
      "show": "A row of everyday-work roles resolves onto the stage — not one of them labeled 'salesperson'.",
      "spark_line": "Not salespeople."
    },
    {
      "id": "B02", "act": "ACT I", "lane": "MANIM", "scene": "manim/range_solo_to_org.mp4",
      "narration_text": "It isn't built only for a SaaS sales team with a Salesforce admin — though it handles that too. It's useful the moment you need to research a prospect, prep a conversation, or follow up after one.",
      "show": "A spectrum bar runs from a lone operator to a full sales org; the plugin's coverage band spans the entire range.",
      "viz": { "pattern": "range", "from": "solo operator", "to": "full sales org" },
      "spark_line": "Solo to org."
    },
    {
      "id": "B03", "act": "ACT I", "lane": "VOX", "scene": "media/B03.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "Picture the freelancer at the kitchen table with a lead they don't know how to work. No CRM, no playbook, no manager. That's exactly where this starts.",
      "show": "A documentary still of a solo worker at a laptop, notes scattered; slow push-in.",
      "spark_line": "At the table.",
      "pantry_note": "Tier 1 illustrative: a lone person working at a laptop at a home table, papers around them, documentary duotone. No real person, no logos."
    },

    { "id": "C02", "act": "ACT II", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "What It Does" }, "narration_text": "Five kinds of help, plainly.", "spark_line": "What it does" },
    {
      "id": "B04", "act": "ACT II", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Prospect research. Meeting prep. Follow-up drafting. Pipeline awareness. Outreach. Five things — and every one of them is work you're probably doing badly, doing late, or not doing at all.",
      "show": "Five labeled chips resolve onto the stage: Research · Prep · Follow-up · Pipeline · Outreach.",
      "viz": { "pattern": "ChipGrid", "chips": ["Research", "Prep", "Follow-up", "Pipeline", "Outreach"] },
      "spark_line": "Five kinds of help."
    },
    {
      "id": "B05", "act": "ACT II", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "Point Claude at a company or a person and get a structured briefing — what they do, recent news, needs you could address, key contacts. It works from public information alone, and gets richer when you connect a CRM.",
      "show": "Public sources flow in on the left; a one-page briefing assembles on the right — SourceFlow.",
      "viz": { "pattern": "SourceFlow", "source": "public info + your CRM", "target": "a structured briefing" },
      "spark_line": "A structured briefing."
    },
    {
      "id": "B06", "act": "ACT II", "lane": "MANIM", "scene": "manim/accumulate_prep_sheet.mp4",
      "narration_text": "For any client conversation, it builds a prep sheet — the relevant context, talking points worth raising, questions worth asking. And if you've kept notes from before, it weaves them in.",
      "show": "Three layers stack into a single prep sheet: context, then talking points, then questions.",
      "viz": { "pattern": "accumulate", "steps": ["Context", "Talking points", "Questions"] },
      "spark_line": "Prepped, not winging it."
    },
    {
      "id": "B07", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/notes-to-message",
      "narration_text": "After the call, you hand it your notes and it drafts the follow-up. Not a template — a message that references specific things you discussed and proposes a concrete next step.",
      "show": "A block of rough notes transforms into a tailored message; a generic 'template' version fades out beside it.",
      "spark_line": "Not a template."
    },
    {
      "id": "B08", "act": "ACT II", "lane": "MANIM", "scene": "manim/scatter_to_pipeline.mp4",
      "narration_text": "And even if your pipeline is a spreadsheet, or just a list in your head, it helps you see where everything stands — who's waiting on you, and what's gone quiet.",
      "show": "Scattered sticky-note prospects snap into ordered pipeline columns.",
      "viz": { "pattern": "sort", "from": "scattered prospects", "to": "ordered pipeline" },
      "spark_line": "Where things stand."
    },
    { "id": "B09", "act": "ACT II", "lane": "CARD", "scene": "SparkBeat", "narration_text": "Research. Prep. Follow up.", "spark_line": "Research. Prep. Follow up." },

    { "id": "C03", "act": "ACT III", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "A Call, End to End" }, "narration_text": "Watch one deal move through it.", "spark_line": "One call through" },
    {
      "id": "B10", "act": "ACT III", "lane": "REMOTION", "scene": "code-block",
      "narration_text": "You've got a discovery call in an hour with an agency you barely know. So you ask: research Meridian Design Studio — what they do, who they serve, recent news, and what they might need from someone like me.",
      "show": "Onda code-block: a composer line typing the prospect-brief request.",
      "props": { "code": "/prospect-brief Meridian Design Studio\n— what they do, who they serve, recent news\n— and what they might need from me" },
      "spark_line": "An hour out."
    },
    {
      "id": "B11", "act": "ACT III", "lane": "MANIM", "scene": "manim/assemble_briefing.mp4",
      "narration_text": "A minute later you've got a one-page briefing you can scan in five. You walk in informed instead of improvising — and honestly, that one move probably justifies the whole plugin for anyone who takes client meetings.",
      "show": "Briefing panels assemble into a single page; a five-minute scan sweep passes across it.",
      "viz": { "pattern": "assemble", "parts": ["what they do", "recent news", "likely needs", "key contacts"], "into": "one page" },
      "spark_line": "Walk in informed."
    },
    {
      "id": "B12", "act": "ACT III", "lane": "VOX", "scene": "media/B12.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.45, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.45, "y": 0.5, "scale": 1.7 }, "objects": [ { "id": "table", "x": 0.5, "y": 0.55, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "Now you're in the room. Present, not scrambling — because the research is already done. The plugin doesn't sit at the table with you. It got you ready for it.",
      "show": "A documentary still of two people mid-conversation across a table; slow push toward them.",
      "spark_line": "In the room.",
      "pantry_note": "Tier 1 illustrative: two people talking across a table in a meeting, documentary duotone. Continuity head of vox_run R1. No real people, no logos."
    },
    {
      "id": "B13", "act": "ACT III", "lane": "VOX", "scene": "media/B13.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.55, 0.5], "vox_run": "R1" },
      "narration_text": "The call ends. While it's fresh, you dump what happened — their timeline, their real concern, who actually decides. Five minutes of notes, captured now instead of forgotten by Friday.",
      "show": "Continuous move to the same person, now alone after the meeting, typing quick notes. Same room grammar as B12.",
      "spark_line": "Capture it fresh.",
      "pantry_note": "Tier 1 illustrative: one person alone at the same table afterward, typing notes on a laptop. Continuity tail of vox_run R1 (matches B12 room + duotone)."
    },
    {
      "id": "B14", "act": "ACT III", "lane": "MANIM", "scene": "manim/threshold_three_days_to_five_minutes.mp4",
      "narration_text": "From those notes it drafts a follow-up that hits every point and suggests a logical next step, in a professional but warm tone. The email that would've sat on your to-do list for three days is done in five minutes.",
      "show": "A 'three days' bar collapses past a threshold to a small 'five minutes'.",
      "viz": { "pattern": "threshold", "before": "three days on the list", "after": "five minutes, sent" },
      "spark_line": "Three days to five."
    },

    { "id": "C04", "act": "ACT IV", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Keeping the Pipeline Honest" }, "narration_text": "Now zoom out to everything in flight.", "spark_line": "The whole pipeline" },
    {
      "id": "B15", "act": "ACT IV", "lane": "MANIM", "scene": "manim/sort_pipeline_review.mp4",
      "narration_text": "Hand it your prospect list and ask the hard questions. Which conversations need a nudge? What's gone cold? Where should this week's energy go? It reads the pipeline and tells you.",
      "show": "Pipeline rows sort into three lanes: 'follow up', 'gone cold', 'this week'.",
      "viz": { "pattern": "sort", "into": ["needs follow-up", "gone cold", "this week"] },
      "spark_line": "What's gone cold?"
    },
    {
      "id": "B16", "act": "ACT IV", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "Need new names? Ask it to scout a market — say, agencies in a region that might need what you offer — and it comes back with a list that has context, not just company names. You decide who's worth pursuing.",
      "show": "A market query flows in on the left; a contextualized shortlist assembles on the right.",
      "viz": { "pattern": "SourceFlow", "source": "a market question", "target": "a shortlist with context" },
      "spark_line": "Names with context."
    },
    {
      "id": "B17", "act": "ACT IV", "lane": "REMOTION", "scene": "illustration/cold-outreach-personal",
      "narration_text": "And when you reach out cold, it drafts something that references their actual situation and offers a conversation — not a hard sell. Personal enough to feel human, structured enough to communicate value.",
      "show": "A short outreach message forms, anchored to a specific detail about the recipient; a spammy 'template' version dissolves beside it.",
      "spark_line": "Human, not spammy."
    },
    {
      "id": "B18", "act": "ACT IV", "lane": "VOX", "scene": "media/B18.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.45] },
      "narration_text": "It's like having a sales manager who keeps you honest about follow-through — without the awkwardness of actually having a sales manager.",
      "show": "A documentary still of an empty manager's chair beside a working desk; a terracotta ring draws on around the empty chair.",
      "spark_line": "Honest, no manager.",
      "pantry_note": "Tier 1 illustrative: an empty office chair next to an occupied working desk; ring annotation added at previz. No real people, no logos."
    },

    { "id": "C05", "act": "ACT V", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Configured, Not Generic" }, "narration_text": "This is where it stops being generic.", "spark_line": "Make it yours" },
    {
      "id": "B19", "act": "ACT V", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Install it from the sidebar and it's useful immediately. But tell it three things — what you sell, how your process works, who your ideal client is — and it stops guessing and starts sounding like you.",
      "show": "Three chips resolve: What you sell · Your process · Your ideal client.",
      "viz": { "pattern": "ChipGrid", "chips": ["What you sell", "Your process", "Your ideal client"] },
      "spark_line": "Tell it three things."
    },
    {
      "id": "B20", "act": "ACT V", "lane": "MANIM", "scene": "manim/threshold_stock_vs_configured.mp4",
      "narration_text": "Connect a CRM — even a free one, or a spreadsheet — and its research gets richer still. But it isn't required. The plugin works with whatever you give it. Give it more, it gives you more.",
      "show": "A 'stock' meter jumps past a threshold to 'configured' as inputs attach.",
      "viz": { "pattern": "threshold", "before": "out of the box", "after": "configured with your data" },
      "spark_line": "Give more, get more."
    },

    { "id": "C06", "act": "ACT VI", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Prep, Not a Closer" }, "narration_text": "One line to keep straight.", "spark_line": "The honest part" },
    {
      "id": "B21", "act": "ACT VI", "lane": "MANIM", "scene": "manim/accumulate_wins.mp4",
      "narration_text": "When you close a deal, tell it what worked — what resonated, which objection came up, what sealed it. Over time that builds institutional knowledge that sharpens every future suggestion.",
      "show": "Each closed-deal note accretes into a growing 'what works' store.",
      "viz": { "pattern": "accumulate", "steps": ["what resonated", "the objection", "what sealed it"] },
      "spark_line": "Feed it your wins."
    },
    {
      "id": "B22", "act": "ACT VI", "lane": "VOX", "scene": "media/B22.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "But don't let it automate the relationship. It's excellent at preparation and follow-through. It is not a replacement for being genuinely present in the conversation itself.",
      "show": "A documentary still of a warm, real moment across a table — eye contact, a handshake; slow push-in.",
      "spark_line": "Be present.",
      "pantry_note": "Tier 1 illustrative: two people shaking hands or in warm eye contact across a table, documentary duotone. No real people, no logos."
    },
    {
      "id": "B23", "act": "ACT VI", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Hand it the admin instead — the activity logging, the note formatting, the follow-up scheduling. The chores you know you should do and skip when you're busy. Let it carry those so you can focus on people.",
      "show": "Three chips resolve: Activity logging · Note formatting · Follow-up scheduling.",
      "viz": { "pattern": "ChipGrid", "chips": ["Activity logging", "Note formatting", "Follow-up scheduling"] },
      "spark_line": "It takes the chores."
    },
    {
      "id": "B24", "act": "ACT VI", "lane": "VOX", "scene": "media/B24.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.55] },
      "narration_text": "And keep your notes current. It can only work with what it knows — sparse notes make sparse briefings. Those five minutes after each call pay dividends in every conversation after.",
      "show": "A documentary still of a hand jotting a quick note in a well-kept notebook; close, tactile framing.",
      "spark_line": "Keep it current.",
      "pantry_note": "Tier 1 illustrative: a close shot of a hand writing in a notebook beside a laptop, documentary duotone. No real people, no logos."
    },

    {
      "id": "V01", "act": "CLOSE", "lane": "REMOTION", "scene": "ClaudeVerdictArtifact",
      "lead_silence_s": 0.5,
      "narration_text": "Let's recap with Claude. The sales plugin meets you where you are — no sales team required. It researches prospects from public information, preps you for the conversation, tracks where every deal stands, and drafts follow-ups that sound like you. Configured with your process, it stops being generic. But it's a research-and-prep accelerator, not a closer — the relationship stays yours.",
      "props": { "artifactLines": [ "Meets you where you are — no sales org required", "Researches prospects, preps calls, drafts follow-ups", "Tracks the pipeline — even a spreadsheet or a mental list", "Configured with your process, it stops being generic", "A prep accelerator, not a closer — the relationship is yours" ] },
      "spark_line": "The verdict."
    },
    {
      "id": "H01", "act": "CLOSE", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Your turn.",
      "props": { "command": "I have a client conversation coming up. Here's who it's with: [company or person]. Research them from public information — what they do, recent news, and what they might need from someone who offers [what you do]. Then give me a one-page prep sheet: the context I should know, three talking points, and three questions to ask. End with the one thing most likely to move this conversation forward.", "runningText": "paste this into Claude…" },
      "narration_text": "Your turn. Paste this into Claude: I have a client conversation coming up — here's who it's with. Research them from public information, then give me a one-page prep sheet — the context, three talking points, three questions to ask — and the one thing most likely to move it forward. Fill in your prospect and your offer, run it, and you'll walk into your next call the way this whole chapter is about: prepared.",
      "spark_line": "Prep your next call."
    },
    {
      "id": "O01", "act": "CLOSE", "lane": "CARD", "scene": "ClaudeTitleOutro",
      "narration_text": "Claude, Closing. Kore, in for Humanitarians AI.",
      "props": { "title": "Claude, Closing", "handle": "@HumanitariansAI", "subline": "The Sales Plugin" },
      "spark_line": "Claude, Closing"
    }
  ]
}
