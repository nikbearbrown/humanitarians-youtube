{
  "metadata": {
    "slug": "claude-liam-marketing",
    "title": "Claude, On Message",
    "subtitle": "The Marketing Plugin",
    "channel": "claude-liam",
    "persona": "Liam",
    "folderLabel": "@NikBearBrown",
    "audience": "Practitioners and makers following the channel's Claude workflows",
    "register": "Teardown",
    "engine": "kokoro",
    "voice": "am_onyx",
    "palette": "claude",
    "typography": { "serif": "EB Garamond", "ui": "system sans", "mono": "SF Mono" },
    "model_chip": { "model": "Fable 5", "effort": "High" },
    "source": "books/anthropics/books/claude-cowork-plugins/chapters/ch04-marketing.txt",
    "derived_from": "claude-cowork-plugins.md (Ch.4)",
    "genre": "deep-explainer",
    "one_idea": "The marketing plugin turns Claude into a marketing collaborator that knows campaign strategy, content calendars, and competitive positioning; customizing it with your brand voice, audience, and positioning is what saves hours — it won't replace the CMO, but it beats a brief scrawled between meetings.",
    "duration_estimate_s": 320,
    "lane_histogram_target": { "VOX": "20-25%", "MANIM": "25-40%", "REMOTION": "30-45%", "CARD": "remainder" }
  },
  "beats": [
    {
      "id": "B00", "act": "COLD OPEN", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Hallo, Liam",
      "props": { "command": "What does the marketing plugin actually change about working with Claude?", "runningText": "thinking…", "output": ["Claude stops just generating content", "and starts collaborating on the campaign."] },
      "narration_text": "Hallo — this is Liam, in for Bear. Install the marketing plugin and Claude stops being a content vending machine and becomes a marketing collaborator — one that plans, analyzes, and refines, not just drafts. Here's what that buys you, and where the line is.",
      "spark_line": "Content → collaborator."
    },

    { "id": "C01", "act": "ACT I", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Collaborator" }, "narration_text": "Start with what marketing actually is.", "spark_line": "The Collaborator" },
    {
      "id": "B01", "act": "ACT I", "lane": "REMOTION", "scene": "PredictCard",
      "narration_text": "If you're running a business, you're running marketing — whether or not you'd ever call yourself a marketer. Content needs making, campaigns need planning, competitors need watching. Somewhere in the middle, you decide what to say, to whom, and where.",
      "show": "A single figure wearing several hats in turn — maker, planner, watcher — the unavoidable marketer.",
      "spark_line": "You're the marketer."
    },
    {
      "id": "B02", "act": "ACT I", "lane": "MANIM", "scene": "manim/loop_generate_to_strategy.mp4",
      "narration_text": "Most tools stop at 'write me a blog post.' The marketing plugin can draft — but the point is that it plans, analyzes, and refines. It understands strategy, not just content generation. That's a different kind of help.",
      "show": "A thin one-shot 'generate' arrow extends into a wider recurring loop: plan → analyze → refine.",
      "viz": { "pattern": "loop", "from": "one-shot generate", "to": "plan → analyze → refine" },
      "spark_line": "Strategy, not just words."
    },
    {
      "id": "B03", "act": "ACT I", "lane": "VOX", "scene": "media/B03.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.45] },
      "narration_text": "The alternative is the brief you scrawl between meetings — half a thought, handed to whoever's free. A collaborator that already knows your brand changes that math entirely.",
      "show": "A still of a hurried, scrawled sticky-note brief on a cluttered desk; slow push-in.",
      "spark_line": "The scrawled brief.",
      "pantry_note": "Tier 1 illustrative: a hastily scrawled note / sticky on a busy desk, documentary duotone. No real brands or logos."
    },

    { "id": "C02", "act": "ACT II", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "What It Does" }, "narration_text": "Five things it actually does.", "spark_line": "What It Does" },
    {
      "id": "B04", "act": "ACT II", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Five capabilities under one install: creating content, planning campaigns, reading competitors, interpreting performance, and holding your brand consistent. Not five apps — five sides of one collaborator.",
      "show": "Five labeled chips resolve onto the stage: Content · Campaigns · Competitors · Performance · Consistency.",
      "viz": { "pattern": "ChipGrid", "chips": ["Content", "Campaigns", "Competitors", "Performance", "Consistency"] },
      "spark_line": "Five sides, one hire."
    },
    {
      "id": "B05", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/structured-content",
      "narration_text": "Content creation isn't just 'write me a post.' It's structured development — briefs, outlines, drafts, and variations. Email sequences, social calendars, landing-page copy, ad variants, each shaped by your configured voice and audience.",
      "show": "One brief branches into an outline, a draft, and three variations fanning out in order.",
      "spark_line": "Briefs to variations."
    },
    {
      "id": "B06", "act": "ACT II", "lane": "MANIM", "scene": "manim/flow_brief_to_plan.mp4",
      "narration_text": "Campaign planning runs from the initial brief to channel strategy. Tell it what you're launching, who you're reaching, and what you want them to do — it helps you build the messaging framework, choose channels, and plan the execution.",
      "show": "A brief node flows rightward, assembling into messaging → channels → execution — a plan building itself.",
      "viz": { "pattern": "accumulate", "steps": ["Brief", "Messaging framework", "Channels", "Execution"] },
      "spark_line": "Brief to plan."
    },
    {
      "id": "B07", "act": "ACT II", "lane": "VOX", "scene": "media/B07.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.5] },
      "narration_text": "It also watches the competition — how rivals position themselves, who they're talking to, what they claim. Then it finds the gap: the angle they're all ignoring, the audience nobody's addressing.",
      "show": "A still of competitor pages pinned to a board; a terracotta ring draws on around the empty space between them.",
      "spark_line": "Find the gap.",
      "pantry_note": "Tier 1 illustrative: a wall / board of pinned generic web pages, duotone; the 'gap' ring annotation added at previz. No real logos or brand names."
    },
    {
      "id": "B08", "act": "ACT II", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "Connect your analytics and it reads the campaign data with you. Not just 'here are the numbers,' but 'here's what the numbers suggest you do next.' Interpretation, not another dashboard.",
      "show": "Metric streams flow in on the left; on the right they resolve into a plain-language 'so do this' line — SourceFlow.",
      "viz": { "pattern": "SourceFlow", "source": "your analytics data", "target": "what to do next" },
      "spark_line": "Numbers into next steps."
    },
    {
      "id": "B09", "act": "ACT II", "lane": "MANIM", "scene": "manim/align_brand_voice.mp4",
      "narration_text": "And it holds the line on brand. Configure your voice, tone, and terminology once, and it enforces them across everything it produces — which matters most exactly when you're shipping volume and consistency starts to slip.",
      "show": "Many scattered, misaligned content tiles snap into a clean grid under one 'voice' rule.",
      "viz": { "pattern": "align", "from": "scattered tiles", "to": "one aligned grid" },
      "spark_line": "One voice, everywhere."
    },

    { "id": "C03", "act": "ACT III", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Fifteen Minutes" }, "narration_text": "The setup that pays for itself.", "spark_line": "The Fifteen Minutes" },
    {
      "id": "B10", "act": "ACT III", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Out of the box it works. But the real gain hides in customization — and customization is three inputs: your brand voice, your audience, and what you actually sell.",
      "show": "Three chips resolve: Brand voice · Audience · Products.",
      "viz": { "pattern": "ChipGrid", "chips": ["Brand voice", "Audience", "Products"] },
      "spark_line": "Three inputs."
    },
    {
      "id": "B11", "act": "ACT III", "lane": "MANIM", "scene": "manim/divergence_vague_to_specific.mp4",
      "narration_text": "Specificity is the lever. 'Professionals' is nearly useless. 'Small-business owners considering AI tools but not technical' — that's something it can aim at. The narrower you describe the target, the sharper everything downstream.",
      "show": "A broad vague blob labeled 'professionals' contracts to a sharp point labeled with a specific audience.",
      "viz": { "pattern": "divergence", "from": "vague audience", "to": "specific audience" },
      "spark_line": "Narrow beats vague."
    },
    {
      "id": "B12", "act": "ACT III", "lane": "REMOTION", "scene": "code-block",
      "narration_text": "Voice is calibrated by example, not description. Show it a few paragraphs you've written in your tone, and tell it who you're reaching. It calibrates to that — not to a generic house style.",
      "show": "Onda code-block: a customize call being filled with a pasted voice sample and an audience line.",
      "props": { "code": "/customize brand\n  voice: \"warm, direct, no jargon — like this: …\"\n  audience: \"freelance designers weighing AI tools\"" },
      "spark_line": "Show, don't tell."
    },
    {
      "id": "B13", "act": "ACT III", "lane": "MANIM", "scene": "manim/threshold_stock_vs_configured.mp4",
      "narration_text": "Fifteen minutes of this changes the output. Content comes back closer to your voice, ideas grounded in your real business, competitive analysis focused on the players who actually matter. Eighty-percent-right on the first draft beats fifty-percent-right, by a lot.",
      "show": "A 'stock' meter sits mid-scale, then jumps past a threshold to 'configured' as first-draft quality climbs.",
      "viz": { "pattern": "threshold", "before": "out of the box", "after": "configured" },
      "spark_line": "Configured hits harder."
    },

    { "id": "C04", "act": "ACT IV", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "In the Work" }, "narration_text": "Watch it in five workflows.", "spark_line": "In the Work" },
    {
      "id": "B14", "act": "ACT IV", "lane": "REMOTION", "scene": "illustration/content-calendar",
      "narration_text": "Instead of staring at a blank month, you say: build me a calendar — two posts a week, a weekly newsletter, two blog pieces, for this audience, on these themes. It returns a structured calendar with a specific idea in every slot. You're editing a plan, not inventing one.",
      "show": "A blank month grid fills slot by slot with titled content cards.",
      "spark_line": "Fill the blank month."
    },
    {
      "id": "B15", "act": "ACT IV", "lane": "VOX", "scene": "media/B15.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.35, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.35, "y": 0.5, "scale": 1.5 }, "objects": [ { "id": "email-1", "x": 0.32, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "Say you're launching a new service next month. You ask for a five-email sequence, aimed at subscribers who know you but have never bought anything.",
      "show": "A still of a first email draft on a laptop; a slow push begins across a row of drafts.",
      "spark_line": "The launch sequence.",
      "pantry_note": "Tier 1 illustrative: a stylized email/inbox draft on a laptop, duotone. Continuity with B16 (vox_run R1). No real brands."
    },
    {
      "id": "B16", "act": "ACT IV", "lane": "VOX", "scene": "media/B16.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.68, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.68, "y": 0.5, "scale": 1.7 }, "objects": [ { "id": "email-5", "x": 0.66, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "It drafts the whole arc — subject lines, body copy, calls to action — each email building on the one before. You add the personal anecdotes it can't know, and the sequence is ready to load.",
      "show": "Continuous pan across the row from email one to email five, each building; same room grammar as B15.",
      "spark_line": "Each on the last.",
      "pantry_note": "Tier 1 illustrative: the same email row extended to a full five-step sequence, duotone; continuity with B15 (vox_run R1)."
    },
    {
      "id": "B17", "act": "ACT IV", "lane": "MANIM", "scene": "manim/fanout_repurpose.mp4",
      "narration_text": "Repurposing is the tedious work everyone skips. One long blog post becomes five social posts, a newsletter intro, and a short video script — from a single source. This is where it saves real hours.",
      "show": "One document node fans out into five social posts, a newsletter, and a script.",
      "viz": { "pattern": "branch", "in": "one blog post", "workers": 7, "out": "many formats" },
      "spark_line": "One source, many cuts."
    },
    {
      "id": "B18", "act": "ACT IV", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "And the monthly reckoning: which pieces landed, which fell flat, is there a pattern? Feed it your metrics — connected or pasted — and it goes past the numbers to what they mean for next month's strategy.",
      "show": "A month of metric tiles flows in and resolves into a short 'the pattern is…' readout.",
      "viz": { "pattern": "SourceFlow", "source": "this month's metrics", "target": "the pattern + what it means" },
      "spark_line": "What the pattern means."
    },
    { "id": "B19", "act": "ACT IV", "lane": "CARD", "scene": "SparkBeat", "narration_text": "Across all five, the shift is the same: you're editing a plan, not staring at a blank page.", "spark_line": "Editing, not starting." },

    { "id": "C05", "act": "ACT V", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "How to Wield It" }, "narration_text": "Four ways to use it well.", "spark_line": "How to Wield It" },
    {
      "id": "B20", "act": "ACT V", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Four habits separate the people who get value from the people who get slop: frontload your brand configuration, ask for variations, delegate the formats you hate, and review everything.",
      "show": "Four chips resolve: Frontload config · Ask for variations · Delegate the tedious · Review everything.",
      "viz": { "pattern": "ChipGrid", "chips": ["Frontload config", "Ask for variations", "Delegate the tedious", "Review everything"] },
      "spark_line": "Four habits."
    },
    {
      "id": "B21", "act": "ACT V", "lane": "VOX", "scene": "media/B21.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "Everyone has formats they dread — captions, subject lines, meta descriptions. Hand those over specifically, and keep your creative energy for the work only you can do.",
      "show": "A still of a person at a desk as a stack of repetitive small-format busywork lifts away.",
      "spark_line": "Delegate the dread.",
      "pantry_note": "Tier 1 illustrative: a person at a desk relieved of a pile of small repetitive tasks, documentary duotone."
    },
    {
      "id": "B22", "act": "ACT V", "lane": "MANIM", "scene": "manim/fanout_five_angles.mp4",
      "narration_text": "And ask for options, not answers. 'Give me five angles on this headline' beats 'write me a headline' almost every time — the plugin is at its best producing a spread you choose from, not one guess.",
      "show": "A single headline node multiplies into five distinct angle variants.",
      "viz": { "pattern": "branch", "in": "one headline", "workers": 5, "out": "five angles" },
      "spark_line": "Options, not answers."
    },
    {
      "id": "B23", "act": "ACT V", "lane": "VOX", "scene": "media/B23.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.45] },
      "narration_text": "But review everything that goes public. It drafts well; your touch is what makes the work yours. It won't replace your CMO — it just means you're never again starting from a brief scrawled between meetings. You keep the judgment; it takes the grind.",
      "show": "A still of a person reviewing a printed page before publishing; a terracotta ring draws on around the human's sign-off.",
      "spark_line": "You keep the judgment.",
      "pantry_note": "Tier 1 illustrative: a person marking up / reviewing a printed page before it ships; ring annotation added at previz."
    },

    {
      "id": "V01", "act": "CLOSE", "lane": "REMOTION", "scene": "ClaudeVerdictArtifact",
      "lead_silence_s": 0.5,
      "narration_text": "Let's recap with Claude. The marketing plugin makes Claude a collaborator, not a copywriter — it plans, analyzes, and refines across content, campaigns, competitors, performance, and brand. Fifteen minutes configuring your voice, your audience, and your positioning is what turns first drafts from fifty-percent-right to eighty. Use it for variations and for the formats you hate — and review everything that ships. It won't replace the CMO. It beats a brief scrawled between meetings.",
      "props": { "artifactLines": [ "A collaborator, not a copywriter — it plans, not just drafts", "Five sides: content · campaigns · competitors · performance · brand", "Configure voice + audience + positioning — 80% right, not 50%", "Ask for variations; delegate the formats you hate", "You keep the judgment — it beats a brief scrawled between meetings" ] },
      "spark_line": "The verdict."
    },
    {
      "id": "H01", "act": "CLOSE", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Your turn.",
      "props": { "command": "I run a small business and just installed the marketing plugin. Before drafting anything, interview me: (1) ask me to paste two or three paragraphs I've written so you can learn my brand voice, (2) ask who my audience is and push me to get specific, (3) ask what I sell and what makes it different. Then summarize my brand voice, audience, and positioning back to me as a short config I can save — and name the first campaign we should build together.", "runningText": "paste this into Claude…" },
      "narration_text": "Your turn. Paste this into Claude: I just installed the marketing plugin — before drafting anything, interview me. Ask for a few paragraphs I've written so you can learn my voice, ask who my audience is and push me to get specific, ask what I sell and what makes it different. Then hand me back a short brand config to save, and name the first campaign we should build. That's the fifteen minutes this whole chapter is about — run it before you ask for a single draft. That's the chapter. Liam, in for Bear.",
      "spark_line": "Do the fifteen minutes."
    },
    {
      "id": "O01", "act": "CLOSE", "lane": "CARD", "scene": "ClaudeTitleOutro",
      "narration_text": "Claude, On Message.",
      "props": { "title": "Claude, On Message", "handle": "@NikBearBrown", "subline": "The Marketing Plugin" },
      "spark_line": "Claude, On Message"
    }
  ]
}
