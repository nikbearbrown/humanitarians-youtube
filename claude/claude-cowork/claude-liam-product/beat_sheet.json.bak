{
  "metadata": {
    "slug": "claude-liam-product",
    "title": "Claude, Shipping",
    "subtitle": "The Product Plugin",
    "channel": "claude-liam",
    "persona": "Kore",
    "folderLabel": "@HumanitariansAI",
    "audience": "Practitioners and makers following the channel's Claude workflows",
    "register": "Teardown",
    "engine": "kokoro",
    "voice": "af_kore",
    "palette": "claude",
    "typography": { "serif": "EB Garamond", "ui": "system sans", "mono": "SF Mono" },
    "model_chip": { "model": "Fable 5", "effort": "High" },
    "source": "books/anthropics/books/claude-cowork-plugins/chapters/ch09-product.txt",
    "derived_from": "claude-cowork-plugins.md (Ch.9)",
    "genre": "deep-explainer",
    "one_idea": "The product plugin helps you build and ship — turning scattered feedback and analytics into prioritized decisions (specs, roadmaps, release notes) — but prioritization is a judgment call the plugin accelerates, not one it makes for you.",
    "duration_estimate_s": 330,
    "lane_histogram_target": { "VOX": "20-25%", "MANIM": "25-40%", "REMOTION": "30-45%", "CARD": "remainder" }
  },
  "beats": [
    {
      "id": "B00", "act": "COLD OPEN", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Annyeong, Kore",
      "props": { "command": "I'm building something solo. How do I decide what to build next?", "runningText": "thinking…", "output": ["It turns scattered feedback and analytics", "into a prioritized shortlist — but the call stays yours."] },
      "narration_text": "Annyeong — this is Kore, in for Humanitarians AI. You're building something: an app, a course, a membership site. The product plugin takes scattered feedback and analytics and turns them into a prioritized shortlist of what to build next. Here's how it works — and where it hands the decision back to you.",
      "spark_line": "What next, decided."
    },

    { "id": "C01", "act": "ACT I", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Missing Product Team" }, "narration_text": "Start with what a solo builder is missing.", "spark_line": "The Missing Product Team" },
    {
      "id": "B01", "act": "ACT I", "lane": "REMOTION", "scene": "PredictCard",
      "narration_text": "Big teams have a product manager — the person who asks who this is for, what problem it solves, and what you're deliberately not building. Build solo and nobody asks those questions. The product plugin is that discipline, installed.",
      "show": "A planning table with one empty chair; the chair labels itself 'Product' and lights terracotta.",
      "spark_line": "The role you lack."
    },
    {
      "id": "B02", "act": "ACT I", "lane": "VOX", "scene": "media/B02.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "Picture the solo builder. Ten ideas on sticky notes, a few hours a week to build, and a steady pull toward whatever's most fun to make. That pull is the problem — fun and important are rarely the same feature.",
      "show": "A cluttered desk buried in sticky-note ideas around a single laptop; slow push in.",
      "spark_line": "Ten ideas, no team.",
      "pantry_note": "Tier 1 illustrative: a solo builder's cluttered desk, sticky notes and one laptop, documentary duotone. No real product UI."
    },
    {
      "id": "B03", "act": "ACT I", "lane": "MANIM", "scene": "manim/divergence_interesting_vs_right.mp4",
      "narration_text": "Left alone, you build the interesting thing — the clever feature that excites you. Discipline points the other way: the right thing, the one that actually moves the product for the most users. The plugin keeps pulling the vector back toward right.",
      "show": "One vector splits: a bright 'interesting' arc peels away while a corrected 'right' arc is pulled back on course.",
      "viz": { "pattern": "divergence", "from": "the interesting thing", "to": "the right thing" },
      "spark_line": "Interesting vs right."
    },
    {
      "id": "B04", "act": "ACT I", "lane": "REMOTION", "scene": "illustration/structured-thinking-partner",
      "narration_text": "It works as the structured thinking partner you don't have on your own. It doesn't just agree with you — it pushes back, asks the awkward question, and makes you justify the plan before you sink a week into it.",
      "show": "A second presence resolves across the desk and floats a question mark the builder has to answer.",
      "spark_line": "It pushes back."
    },
    {
      "id": "B05", "act": "ACT I", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Four questions a good product manager always asks. Who is this for? What problem does it solve? How will you know it's working? And what are you not building — and why?",
      "show": "Four labeled chips resolve onto the stage in order.",
      "viz": { "pattern": "ChipGrid", "chips": ["Who's it for?", "What problem?", "How measure it?", "What NOT to build?"] },
      "spark_line": "Four hard questions."
    },

    { "id": "C02", "act": "ACT II", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "What It Makes" }, "narration_text": "What all that discipline actually produces.", "spark_line": "What It Makes" },
    {
      "id": "B06", "act": "ACT II", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "The discipline lands as documents you can act on. Feature specs. User stories. Feedback synthesis. A roadmap. Release notes. Not paperwork for its own sake — these are the artifacts that keep you from building blind.",
      "show": "Five chips resolve as a row of deliverables.",
      "viz": { "pattern": "ChipGrid", "chips": ["Specs", "User stories", "Synthesis", "Roadmap", "Release notes"] },
      "spark_line": "Five things it ships."
    },
    {
      "id": "B07", "act": "ACT II", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "Give it a rough idea — add booking to my site, people pick a slot and get a confirmation — and it returns a real spec: what the feature does, who it's for, the user flow, the edge cases, and how you'll know it's done.",
      "show": "A loose idea flows in on the left; a structured spec assembles on the right, section by section.",
      "viz": { "pattern": "SourceFlow", "source": "a rough idea", "target": "a structured spec" },
      "spark_line": "Idea becomes spec."
    },
    {
      "id": "B08", "act": "ACT II", "lane": "VOX", "scene": "media/B08.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.45, 0.55] },
      "narration_text": "That spec is the thing that saves you. It forces the edge case — what happens when two people book the same slot — out into the open before you're halfway through the code and blindsided by it.",
      "show": "A printed one-page spec on a desk, marked up in pen; slow drift across the page.",
      "spark_line": "Decide before you code.",
      "pantry_note": "Tier 1 illustrative: a printed spec / one-pager on a desk with pen marks, documentary duotone."
    },

    { "id": "C03", "act": "ACT III", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Break It Into Stories" }, "narration_text": "A spec is still too big to build in one sitting.", "spark_line": "Break It Into Stories" },
    {
      "id": "B09", "act": "ACT III", "lane": "MANIM", "scene": "manim/branch_want_to_stories.mp4",
      "narration_text": "So it breaks the feature down. 'I want users to book calls' fans out into small, testable pieces: see the open slots, pick one, enter your details, get a confirmation, reschedule if needed. Each one buildable in a single focused session.",
      "show": "One 'want' node fans into five discrete story nodes, each stamped 'testable'.",
      "viz": { "pattern": "branch", "in": "one want", "workers": 5, "out": "buildable stories" },
      "spark_line": "One want, many stories."
    },
    {
      "id": "B10", "act": "ACT III", "lane": "REMOTION", "scene": "code-block",
      "narration_text": "Written out, it reads like a checklist you can execute against — one story per line, each with a clear definition of done. You build story by story, testing as you go, instead of trying to ship the whole thing at once.",
      "show": "Onda code-block: a user-story checklist types in line by line, each with an acceptance-criteria comment.",
      "props": { "code": "- [ ] User sees available time slots\n- [ ] User selects a slot\n- [ ] User submits contact info\n- [ ] User receives a confirmation\n- [ ] User can reschedule\n# done = each story ships and passes its check" },
      "spark_line": "Build story by story."
    },
    {
      "id": "B11", "act": "ACT III", "lane": "MANIM", "scene": "manim/accumulate_story_by_story.mp4",
      "narration_text": "And the stories stack. Ship one, confirm it works, move to the next — the feature accretes from small wins instead of arriving as one risky big-bang launch that either works or doesn't.",
      "show": "Story tiles stack one at a time into a finished feature bar; each locks green as it lands.",
      "viz": { "pattern": "accumulate", "steps": ["See slots", "Pick one", "Confirm", "Reschedule"] },
      "spark_line": "Small wins accrue."
    },

    { "id": "C04", "act": "ACT IV", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "What Should I Build Next" }, "narration_text": "Now the conversation that earns its keep.", "spark_line": "What Should I Build Next" },
    {
      "id": "B12", "act": "ACT IV", "lane": "MANIM", "scene": "manim/scale_ideas_vs_hours.mp4",
      "narration_text": "Here's the real bottleneck. Ten features you could build, and a fixed slice of hours a month to build them. You cannot do all ten. Something has to be first, something has to wait, and something should probably never get built at all.",
      "show": "A tall stack of ten idea bars set against a short, fixed 'hours you have' bar; the mismatch is the point.",
      "viz": { "pattern": "scale", "from": "ten ideas", "to": "the hours you actually have" },
      "spark_line": "Ten ideas, few hours."
    },
    {
      "id": "B13", "act": "ACT IV", "lane": "MANIM", "scene": "manim/rank_feedback_frequency_severity.mp4",
      "narration_text": "First it synthesizes. Point it at three months of feedback emails, surveys, and support tickets, and it reads all of it — then ranks the patterns by how often they come up and how much they hurt. The analysis small teams skip because it's tedious.",
      "show": "A pile of raw feedback items sorts into ranked bars, each sized by frequency and tinted by severity.",
      "viz": { "pattern": "accumulate", "rank_by": ["frequency", "severity"], "from": "raw feedback", "to": "ranked patterns" },
      "spark_line": "Feedback, ranked."
    },
    {
      "id": "B14", "act": "ACT IV", "lane": "VOX", "scene": "media/B14.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.45], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.4, "y": 0.5, "scale": 1.6 }, "objects": [ { "id": "note", "x": 0.4, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "Because the trap is loudness. A folder of feedback is a wall of voices — and the voice that shouts the most always feels like the most urgent thing to fix.",
      "show": "A wall of pinned feedback notes and printed emails; slow push toward the busiest corner.",
      "spark_line": "A wall of voices.",
      "pantry_note": "Tier 1 illustrative: a corkboard wall of feedback notes and emails, documentary duotone. Continuity start of vox_run R1."
    },
    {
      "id": "B15", "act": "ACT IV", "lane": "VOX", "scene": "media/B15.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.4, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.4, "y": 0.5, "scale": 2.1 }, "objects": [ { "id": "note", "x": 0.4, "y": 0.5, "scale": 1.3, "opacity": 1 } ] } },
      "narration_text": "But the plugin counts instead of listening for volume. The loudest request often isn't the most common need — and it surfaces the quiet pattern a dozen users quietly share, the one you'd have missed straining to hear the shout.",
      "show": "Continuous push into a single recurring note on the same wall; the room grammar matches B14.",
      "spark_line": "Common beats loud.",
      "pantry_note": "Tier 1 illustrative: same corkboard, pushed in on one recurring note; ring annotation added at previz. Continuity end of vox_run R1."
    },
    {
      "id": "B16", "act": "ACT IV", "lane": "MANIM", "scene": "manim/compare_loudest_vs_common.mp4",
      "narration_text": "Loudest voice against most common need — two different bars. Optimize for the loud one and you build for a handful; optimize for the common one and you build for the many. The plugin makes you see both before you choose.",
      "show": "Two bars rise side by side: a tall, narrow 'loudest' bar and a shorter but far wider 'most common' bar.",
      "viz": { "pattern": "compare", "a": "loudest voice", "b": "most common need" },
      "spark_line": "Loud isn't common."
    },

    { "id": "C05", "act": "ACT V", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Ship It, Remember Why" }, "narration_text": "You shipped it. Two things left to do.", "spark_line": "Ship It, Remember Why" },
    {
      "id": "B17", "act": "ACT V", "lane": "MANIM", "scene": "manim/transform_builder_to_user.mp4",
      "narration_text": "Release notes. You wrote 'optimized the rendering pipeline.' Nobody outside your own head cares. It rewrites that into what the user actually feels: your dashboard now loads in under a second. Same change, told from their side.",
      "show": "A builder-speak phrase morphs, word by word, into its user-benefit version on the same line.",
      "viz": { "pattern": "transform", "from": "builder-speak", "to": "user benefit" },
      "spark_line": "Their side, not yours."
    },
    {
      "id": "B18", "act": "ACT V", "lane": "VOX", "scene": "media/B18.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.55, 0.5] },
      "narration_text": "Because a release note isn't a changelog for you — it's a reason for them to notice you shipped. Written from the user's perspective, it turns a quiet bug fix into a small moment of 'oh, they actually heard me.'",
      "show": "A person reading an app update on a screen, expression softening; gentle drift.",
      "spark_line": "Give them a reason.",
      "pantry_note": "Tier 1 illustrative: a person reading an app update / release note on a screen, documentary duotone. No real product branding."
    },
    {
      "id": "B19", "act": "ACT V", "lane": "REMOTION", "scene": "illustration/decision-doc-tradeoffs",
      "narration_text": "Then document the decision. Choosing between building your own login system or leaning on an outside service? It lays out the trade-offs — cost, complexity, flexibility, upkeep — in one clean comparison, and you make the call.",
      "show": "A two-column trade-off ledger assembles: build vs. buy across four rows, weights settling into place.",
      "spark_line": "Write down the why."
    },
    {
      "id": "B20", "act": "ACT V", "lane": "REMOTION", "scene": "PredictCard",
      "narration_text": "That document is a gift to future-you. Six months on, when you wonder why you went this way, the reasons are written down — not a mystery you have to reverse-engineer. Every undocumented decision is a future argument with yourself.",
      "show": "The same ledger, dust-settled, reopened months later — the 'why' still legible, a terracotta bookmark on the choice.",
      "spark_line": "A gift to future-you."
    },

    { "id": "C06", "act": "ACT VI", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Who Makes the Call" }, "narration_text": "One line you can't outsource.", "spark_line": "Who Makes the Call" },
    {
      "id": "B21", "act": "ACT VI", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Be precise about what it does. It gathers the feedback, structures the spec, ranks the options, and drafts the notes. Four kinds of grunt work, done fast and done well.",
      "show": "Four chips resolve as a row of verbs the plugin owns.",
      "viz": { "pattern": "ChipGrid", "chips": ["Gather", "Structure", "Rank", "Draft"] },
      "spark_line": "It does the grunt work."
    },
    {
      "id": "B22", "act": "ACT VI", "lane": "MANIM", "scene": "manim/converge_rank_then_human.mp4",
      "narration_text": "But ranking is not deciding. It can tell you this feature scores higher on impact and feasibility — it cannot know your bet, your users, or your gut about where the product is going. It narrows the options; the pick is yours.",
      "show": "Many options converge into a ranked shortlist, then pause at a human-shaped gate before one is chosen.",
      "viz": { "pattern": "branch", "in": "ranked options", "workers": 1, "out": "your decision", "gate": "human" },
      "spark_line": "Ranks, doesn't decide."
    },
    {
      "id": "B23", "act": "ACT VI", "lane": "VOX", "scene": "media/B23.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.5] },
      "narration_text": "So it hands you a shortlist, not a verdict. The prioritization is a judgment call — and the human at the desk still makes it. That caveat isn't fine print to skip. It's the whole point.",
      "show": "A builder at a desk pausing over a printed shortlist; a terracotta ring draws on around the person.",
      "spark_line": "You keep the call.",
      "pantry_note": "Tier 1 illustrative: a builder at a desk over a shortlist, pausing; ring annotation added at previz."
    },
    { "id": "B24", "act": "ACT VI", "lane": "CARD", "scene": "SparkBeat", "narration_text": "It accelerates the call. You still make it.", "spark_line": "Accelerate, don't abdicate." },

    {
      "id": "V01", "act": "CLOSE", "lane": "REMOTION", "scene": "ClaudeVerdictArtifact",
      "lead_silence_s": 0.5,
      "narration_text": "Let's recap with Claude. The product plugin is the product manager a solo builder never had. It turns rough ideas into specs and buildable stories. It synthesizes scattered feedback into a ranked shortlist — separating the loudest voice from the most common need. It writes release notes and records your decisions for future-you. And it stops at the line that matters: it ranks the options, but the call is yours.",
      "props": { "artifactLines": [ "The product discipline a solo builder lacks", "Rough ideas → specs → buildable user stories", "Scattered feedback → a ranked shortlist", "Release notes and decisions, written for future-you", "It ranks the options — you make the call" ] },
      "spark_line": "The verdict."
    },
    {
      "id": "H01", "act": "CLOSE", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Your turn.",
      "props": { "command": "I'm building my product solo and I have more feature ideas than time. Here are the features I'm considering for the next quarter: [list them]. I have about [N] hours a month to build. My users are mostly [who they are and what they use it for]. Help me prioritize: (1) which should I build first, (2) which can wait, and (3) which is a distraction dressed up as a good idea — and for each, tell me why.", "runningText": "paste this into Claude…" },
      "narration_text": "Your turn. Paste this into Claude: I'm building my product solo and I have more feature ideas than time — here are the ones I'm considering this quarter, here's roughly how many hours a month I actually have, and here's who my users are and what they use it for. Then ask it to sort them: what to build first, what can wait, and what's a distraction dressed up as a good idea — with the reason for each. Watch how it makes you name your constraints out loud; that's where the real prioritizing happens. Run it, then push back on its ranking. The argument is the point.",
      "spark_line": "Prioritize your quarter."
    },
    {
      "id": "O01", "act": "CLOSE", "lane": "CARD", "scene": "ClaudeTitleOutro",
      "narration_text": "Claude, Shipping. Kore, in for Humanitarians AI.",
      "props": { "title": "Claude, Shipping", "handle": "@HumanitariansAI", "subline": "The Product Plugin" },
      "spark_line": "Claude, Shipping"
    }
  ]
}
