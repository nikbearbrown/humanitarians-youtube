{
  "metadata": {
    "slug": "claude-liam-support",
    "title": "Claude, On Call",
    "subtitle": "The Support Plugin",
    "channel": "claude-liam",
    "persona": "Kore",
    "folderLabel": "@HumanitariansAI",
    "audience": "Practitioners and makers following the channel's Claude workflows",
    "register": "Teardown",
    "engine": "kokoro",
    "voice": "af_kore",
    "palette": "claude",
    "typography": { "serif": "EB Garamond", "ui": "system sans", "mono": "SF Mono" },
    "model_chip": { "model": "Fable 5", "effort": "High" },
    "source": "books/anthropics/books/claude-cowork-plugins/chapters/ch10-support.txt",
    "derived_from": "claude-cowork-plugins.md (Ch.10 — Support)",
    "genre": "deep-explainer",
    "one_idea": "If you have customers you have support; the support plugin drafts consistent, on-brand responses and turns recurring questions into reusable answers — a force multiplier for a small team, with the human staying on the judgment calls and the angry-customer edge cases.",
    "duration_estimate_s": 240,
    "lane_histogram_target": { "VOX": "20-25%", "MANIM": "25-40%", "REMOTION": "30-45%", "CARD": "remainder" }
  },
  "beats": [
    {
      "id": "B00", "act": "COLD OPEN", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Jambo, Kore",
      "props": { "command": "I run support solo. Can Claude actually lighten the load, or just add a queue to double-check?", "runningText": "thinking…", "output": ["It drafts consistent, on-brand replies", "and turns repeat questions into answers you write once."] },
      "narration_text": "Jambo — this is Kore, in for Humanitarians AI. If you have customers, you have support — and it doesn't wait. Install the support plugin and Claude triages the queue, drafts on-brand replies, and turns the questions you keep answering into answers you write once. Here's how it works, and where you stay on the line.",
      "spark_line": "Support, on call."
    },

    { "id": "C01", "act": "ACT I", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Reactive Burden" }, "narration_text": "Start with the problem everyone with customers already has.", "spark_line": "The Reactive Burden" },
    {
      "id": "B01", "act": "ACT I", "lane": "VOX", "scene": "media/B01.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.45] },
      "narration_text": "One truth first: if you have customers, you have support. It arrives whether you're ready or not — a queue that fills overnight, questions that don't wait until morning. Left alone, it eats your day in fragments.",
      "show": "A still of an inbox glowing in a dark room after hours; slow push toward the unread queue.",
      "spark_line": "Customers mean support.",
      "pantry_note": "Tier 1 illustrative: a lit screen or inbox in a dark room, after-hours, documentary duotone. No real UI, no logos."
    },
    {
      "id": "B02", "act": "ACT I", "lane": "MANIM", "scene": "manim/transform_burden_to_process.mp4",
      "narration_text": "The support plugin turns that burden into a process. For a solo operator, it's the difference between reacting all day and running a system that handles the queue for you.",
      "show": "A chaotic scatter of incoming tickets resolves into a single ordered pipeline that flows off-screen.",
      "viz": { "pattern": "transform", "from": "reactive scatter", "to": "ordered process" },
      "spark_line": "Chaos → process."
    },
    {
      "id": "B03", "act": "ACT I", "lane": "MANIM", "scene": "manim/converge_voices_to_one.mp4",
      "narration_text": "For a small team, it does something else: it makes one consistent voice. Instead of five people answering five different ways, every reply carries the same tone and the same facts.",
      "show": "Five differently-styled reply bubbles converge and snap into a single unified voice.",
      "viz": { "pattern": "converge", "from": "five voices", "to": "one voice" },
      "spark_line": "Five voices, one."
    },

    { "id": "C02", "act": "ACT II", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "What It Does" }, "narration_text": "Under the hood, it does four concrete jobs.", "spark_line": "What It Does" },
    {
      "id": "B04", "act": "ACT II", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Triage the queue. Draft the replies. Build a knowledge base. And read sentiment — who's calm, and who's about to walk. Not magic; four jobs it does well.",
      "show": "Four labeled chips resolve onto the stage: Triage · Draft · Knowledge base · Sentiment.",
      "viz": { "pattern": "ChipGrid", "chips": ["Triage", "Draft", "Knowledge base", "Sentiment"] },
      "spark_line": "Four jobs, one plugin."
    },
    {
      "id": "B05", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/triage-three-lanes",
      "narration_text": "Triage first. As requests land, it sorts them: what needs you now, what can wait, and what's a known issue with a standard answer. The queue stops being a wall and becomes a sorted list.",
      "show": "An incoming pile fans into three labeled lanes — Now · Later · Known — each lit in turn.",
      "spark_line": "Sort the wall.",
      "props": { "lanes": ["Now", "Later", "Known answer"] }
    },
    {
      "id": "B06", "act": "ACT II", "lane": "MANIM", "scene": "manim/converge_draft_inputs.mp4",
      "narration_text": "Then drafting. It generates replies that are helpful, on-brand, and fit the moment — pulling from your configured tone, your knowledge base, and the specific request in front of it. A first draft, not a form letter.",
      "show": "Three input streams — tone, knowledge base, this request — converge into one drafted reply.",
      "viz": { "pattern": "converge", "inputs": ["your tone", "knowledge base", "this request"], "out": "a drafted reply" },
      "spark_line": "Draft, on-brand."
    },
    {
      "id": "B07", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/sentiment-flag",
      "narration_text": "Third, sentiment. Not every request is equal — it flags the frustrated and the at-risk, the customer who needs a human now. It points your attention at the messages that actually need it.",
      "show": "A grid of neutral message cards; one is ringed and lifted in terracotta — the at-risk customer.",
      "spark_line": "Find the ones who matter.",
      "props": { "highlight": "at-risk", "accent": "#D97757" }
    },
    {
      "id": "B08", "act": "ACT II", "lane": "VOX", "scene": "media/B08.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "And fourth, it builds a knowledge base. Every question you've ever answered is raw material; the plugin finds the common ones and drafts a structured FAQ you can publish. Your scattered experience becomes a help center.",
      "show": "A still of loose notes and message scraps gathered into one bound reference; slow push-in.",
      "spark_line": "Experience, structured.",
      "pantry_note": "Tier 1 illustrative: scattered sticky-notes / paper scraps gathering toward a bound manual or FAQ binder. No real UI."
    },
    {
      "id": "B09", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/connect-support-inbox",
      "narration_text": "For richer help, it connects to the support tools you already use — reading from your existing inbox instead of a blank slate. It works on your real conversations, not hypothetical ones.",
      "show": "A connective line runs from the plugin into an existing support inbox; tickets flow in. No named product logos.",
      "spark_line": "Reach into your inbox.",
      "props": { "note": "generic support-inbox glyph only; no vendor names on screen" }
    },
    {
      "id": "B10", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/configure-tone-escalation",
      "narration_text": "One setup step makes it yours. You configure the tone — warm, efficient, or both — and you set escalation triggers: the words and situations that skip the standard answer and route straight to you. You decide what always reaches a human.",
      "show": "A tone dial settles between 'warm' and 'efficient'; a row of trigger keywords reroutes a ticket toward 'you'.",
      "spark_line": "Set the tone, set the tripwires.",
      "props": { "tone": ["warm", "efficient"], "escalation": "keywords route to the human" }
    },

    { "id": "C03", "act": "ACT III", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "A Day on Support" }, "narration_text": "Here's what an ordinary day actually looks like.", "spark_line": "A Day on Support" },
    {
      "id": "B11", "act": "ACT III", "lane": "REMOTION", "scene": "code-block",
      "narration_text": "Morning. You hand it the overnight queue and ask the three questions that matter: what's urgent, what's routine, and what can I answer in a line? Claude categorizes, drafts the easy ones, and flags the rest for you.",
      "show": "Onda code-block: the composer typing the morning-triage prompt.",
      "props": { "code": "Here are the support messages from the last 12 hours.\nWhat's urgent? What's routine?\nWhat can I answer with a quick reply?" },
      "spark_line": "Morning triage."
    },
    {
      "id": "B12", "act": "ACT III", "lane": "MANIM", "scene": "manim/compress_time_triage.mp4",
      "narration_text": "The payoff is time. Your first thirty focused minutes handle what a morning of context-switching might otherwise stretch into two lost hours.",
      "show": "A long fragmented bar labeled 'two hours' collapses into one tight block labeled 'thirty minutes'.",
      "viz": { "pattern": "compress", "from": "two hours, fragmented", "to": "thirty focused minutes" },
      "spark_line": "Two hours → thirty minutes."
    },
    {
      "id": "B13", "act": "ACT III", "lane": "VOX", "scene": "media/B13.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.4, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.4, "y": 0.5, "scale": 1.7 }, "objects": [ { "id": "customer", "x": 0.38, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "Now a hard one. A customer's payment has failed three times. They've been with you two years, and they're angry. You ask for a reply that's empathetic, addresses the failure, and offers a concrete fix.",
      "show": "A still — a person at a screen showing a declined-payment notice; slow push toward the detail.",
      "spark_line": "Three failed payments.",
      "pantry_note": "Tier 1 illustrative: a frustrated person at a laptop with a generic 'declined' notice on screen; documentary duotone. No real brand UI. Start of vox_run R1."
    },
    {
      "id": "B14", "act": "ACT III", "lane": "VOX", "scene": "media/B14.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.6, 0.5], "vox_run": "R1" },
      "narration_text": "Claude drafts in your tone — it acknowledges the frustration, explains the issue, and proposes a path forward. You read it, add a personal line, and send. The plugin caught the tone; you caught the context.",
      "show": "Continuous pull-back from the same scene to the composed reply resting on the desk; same room grammar as B13.",
      "spark_line": "You add the human line.",
      "pantry_note": "Tier 1 illustrative: same duotone treatment; a composed reply / letter on the same desk. Continuity with B13 (vox_run R1, final beat)."
    },
    {
      "id": "B15", "act": "ACT III", "lane": "MANIM", "scene": "manim/accumulate_faq_patterns.mp4",
      "narration_text": "Third moment: building the docs. Based on the requests you've handled this quarter, what are the ten questions that come up most? Claude finds the patterns and drafts the answers; you check them and publish.",
      "show": "A stream of past tickets accumulates; the repeated questions rise and rank to the top ten.",
      "viz": { "pattern": "accumulate", "from": "your support history", "to": "the ranked top questions" },
      "spark_line": "The top ten, drafted."
    },
    {
      "id": "B16", "act": "ACT III", "lane": "REMOTION", "scene": "SourceFlow",
      "narration_text": "And every entry pays forward. Each FAQ answer you publish is one question you never field again — support volume that quietly falls instead of climbing.",
      "show": "Support history flows in on the left; published FAQ entries on the right divert future tickets away.",
      "viz": { "pattern": "SourceFlow", "source": "your support history", "target": "published FAQ that deflects future tickets" },
      "spark_line": "Answer once, reuse forever."
    },

    { "id": "C04", "act": "ACT IV", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "You Stay on the Line" }, "narration_text": "Three rules keep all of this honest.", "spark_line": "You Stay on the Line" },
    {
      "id": "B17", "act": "ACT IV", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Draft, don't autosend. Build the knowledge base a little at a time. And read the patterns — because what customers keep struggling with is product feedback in disguise.",
      "show": "Three caution chips resolve: Draft, don't autosend · Build progressively · Patterns are feedback.",
      "viz": { "pattern": "ChipGrid", "chips": ["Draft, don't autosend", "Build progressively", "Patterns are feedback"] },
      "spark_line": "Three rules."
    },
    {
      "id": "B18", "act": "ACT IV", "lane": "VOX", "scene": "media/B18.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.48] },
      "narration_text": "Draft, don't autosend, is the load-bearing one. Claude catches the right tone and content; your judgment catches the context it can't see — the angry customer, the exception, the account you know is fragile. Review before it goes.",
      "show": "A still of a person reading a drafted reply, hand paused near send; a terracotta underline draws on beneath 'review'.",
      "spark_line": "Read before you send.",
      "pantry_note": "Tier 1 illustrative: a person reviewing a message on screen, hand hovering near send; underline annotation added at previz. No real UI."
    },
    {
      "id": "B19", "act": "ACT IV", "lane": "MANIM", "scene": "manim/loop_patterns_to_product.mp4",
      "narration_text": "And watch the patterns. The plugin shows you what customers repeatedly can't figure out — and each recurring question is a signal about what to fix upstream, so the request stops coming at all. Support becomes a feed into the product.",
      "show": "Recurring support requests cluster, then one arrow turns back toward 'the product' and the cluster thins.",
      "viz": { "pattern": "loop", "from": "recurring requests", "to": "a product fix that removes them" },
      "spark_line": "Every repeat is a signal."
    },
    { "id": "B20", "act": "ACT IV", "lane": "CARD", "scene": "SparkBeat", "narration_text": "The plugin drafts. You decide what sends. That's the whole contract.", "spark_line": "Draft. Decide. Send." },

    {
      "id": "V01", "act": "CLOSE", "lane": "REMOTION", "scene": "ClaudeVerdictArtifact",
      "lead_silence_s": 0.5,
      "narration_text": "Let's recap with Claude. If you have customers, you have support — and the plugin turns it from a reactive burden into a process. It does four jobs: triage the queue, draft on-brand replies, build a knowledge base, and read sentiment. It makes recurring questions into reusable answers, so volume falls instead of climbing. And it drafts — you decide: you review before anything sends, and you keep the angry-customer edge cases and the judgment calls.",
      "props": { "artifactLines": [ "Have customers? You have support — burden or process", "Four jobs: triage, draft, build the knowledge base, read sentiment", "Consistent, on-brand replies from your tone and history", "Recurring questions become reusable answers — volume falls", "You stay on the line: review before send, own the hard calls" ] },
      "spark_line": "The verdict."
    },
    {
      "id": "H01", "act": "CLOSE", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Your turn.",
      "props": { "command": "I run support for a small business and want to set up the support plugin. First, ask me three things: the five questions my customers ask most, the tone my replies should carry, and the situations that must always reach me personally. Then draft FAQ answers for those five, a reusable response template in my tone, and a short list of escalation triggers I should configure.", "runningText": "paste this into Claude…" },
      "narration_text": "Your turn. Paste this into Claude: I run support for a small business and want to set up the support plugin. Have it ask you three things first — the five questions your customers ask most, the tone your replies should carry, and the situations that must always reach you personally. Then it drafts FAQ answers for those five, a reusable template in your voice, and the escalation triggers to configure. It turns this chapter into your actual support setup — run it and watch what it asks. Kore, in for Humanitarians AI.",
      "spark_line": "Set up your support."
    },
    {
      "id": "O01", "act": "CLOSE", "lane": "CARD", "scene": "ClaudeTitleOutro",
      "narration_text": "Claude, On Call.",
      "props": { "title": "Claude, On Call", "handle": "@HumanitariansAI", "subline": "The Support Plugin" },
      "spark_line": "Claude, On Call"
    }
  ]
}
