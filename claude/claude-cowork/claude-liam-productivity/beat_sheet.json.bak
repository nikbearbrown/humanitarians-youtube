{
  "metadata": {
    "slug": "claude-liam-productivity",
    "title": "Claude, In Order",
    "subtitle": "The Productivity Plugin",
    "channel": "claude-liam",
    "persona": "Liam",
    "folderLabel": "@NikBearBrown",
    "audience": "Practitioners and makers following the channel's Claude workflows",
    "register": "Teardown",
    "engine": "kokoro",
    "voice": "am_onyx",
    "palette": "claude",
    "typography": { "serif": "EB Garamond", "ui": "system sans", "mono": "SF Mono" },
    "model_chip": { "model": "Fable 5", "effort": "High" },
    "source": "books/anthropics/books/claude-cowork-plugins/chapters/ch03-productivity.txt",
    "derived_from": "claude-cowork-plugins.md (Ch.3)",
    "genre": "deep-explainer",
    "one_idea": "The productivity plugin is the generalist of the collection — it specializes in you: applying prioritization frameworks to daily workflow (task tracking, meeting prep, email triage, note synthesis), working immediately out of the box with no connections, getting sharper the more Claude knows about how you work; most people keep it on permanently as the foundation layer under their domain plugins.",
    "duration_estimate_s": 360,
    "lane_histogram_target": { "VOX": "20-25%", "MANIM": "25-40%", "REMOTION": "30-45%", "CARD": "remainder" }
  },
  "beats": [
    {
      "id": "B00", "act": "COLD OPEN", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Ciao, Liam",
      "props": { "command": "Which Cowork plugin should I turn on first?", "runningText": "thinking…", "output": ["The productivity plugin.", "The generalist that runs under everything else."] },
      "narration_text": "Ciao — this is Liam, in for Bear. Most Cowork plugins specialize in a domain. One specializes in you — your tasks, your meetings, your inbox, your day. It's the one people install first and almost never turn off. Here's what it actually does, and why it earns that spot.",
      "spark_line": "Specializes in you."
    },

    { "id": "C01", "act": "ACT I", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Generalist" }, "narration_text": "First, the odd one out.", "spark_line": "The Generalist" },
    {
      "id": "B01", "act": "ACT I", "lane": "REMOTION", "scene": "PredictCard",
      "narration_text": "Every other plugin in the collection picks a domain — sales, legal, finance. The productivity plugin picks a subject too. That subject is you: the daily churn of tasks, meetings, messages, and competing priorities that is your actual job.",
      "show": "A row of domain labels resolves, then one card flips from a domain name to a plain silhouette labeled 'You'.",
      "spark_line": "It picks you."
    },
    {
      "id": "B02", "act": "ACT I", "lane": "MANIM", "scene": "manim/divergence_outward_vs_inward.mp4",
      "narration_text": "Here's the shape of the difference. A domain plugin points outward — deep into one field you work in. Productivity points inward — at the day you work through. Same engine, opposite aim.",
      "show": "Arrows fan outward to labeled domain fields; then one arrow reverses and turns inward toward a single center point.",
      "viz": { "pattern": "divergence", "from": "outward — into a field", "to": "inward — at your day" },
      "spark_line": "Outward vs inward."
    },
    {
      "id": "B03", "act": "ACT I", "lane": "REMOTION", "scene": "illustration/orbits-of-the-day",
      "narration_text": "So it doesn't make Claude an expert in something. It makes Claude fluent in you — how your day is structured, what you owe people, what's on fire right now. That's why most people install it first.",
      "show": "Tasks, meetings, messages, and deadlines orbit a single center, then snap into one ordered ring.",
      "spark_line": "Fluent in you."
    },

    { "id": "C02", "act": "ACT II", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "What It Does" }, "narration_text": "What does that actually buy you?", "spark_line": "What It Does" },
    {
      "id": "B04", "act": "ACT II", "lane": "REMOTION", "scene": "ChipGrid",
      "narration_text": "Five moves, mostly. Track tasks. Prep for meetings. Triage email. Stay aware of your schedule. Synthesize your notes. Not five apps — five things Claude can now do inside the conversation you're already having.",
      "show": "Five chips resolve onto the stage in narration order: Tasks · Meetings · Email · Schedule · Notes.",
      "viz": { "pattern": "ChipGrid", "chips": ["Tasks", "Meetings", "Email", "Schedule", "Notes"] },
      "spark_line": "Five moves."
    },
    {
      "id": "B05", "act": "ACT II", "lane": "REMOTION", "scene": "illustration/talk-to-structured",
      "narration_text": "Task management is the base. Tell Claude what you need to do in plain language — it structures it. Tell it what's urgent — it sequences your day. No forms, no fields; you talk, it organizes.",
      "show": "A loose spoken sentence of to-dos snaps into an ordered, ranked checklist as the words land.",
      "spark_line": "You talk, it organizes."
    },
    {
      "id": "B06", "act": "ACT II", "lane": "VOX", "scene": "media/B06.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "Note synthesis is the quiet one. Information scattered across conversations, documents, and meetings gets pulled into one coherent summary — the stuff you'd normally lose between tabs.",
      "show": "A desk strewn with loose notes and printouts; a slow push in as they gather toward a single stack.",
      "spark_line": "Scattered → summary.",
      "pantry_note": "Tier 1 illustrative: a desk covered in sticky notes, notebook pages and printouts being gathered into one stack; documentary duotone. No real legible text, no logos."
    },
    { "id": "B07", "act": "ACT II", "lane": "CARD", "scene": "SparkBeat", "narration_text": "One caution up front: this isn't a new to-do app, and it doesn't replace your calendar. It's connective tissue — it makes Claude better at helping you work the tools you already have.", "spark_line": "Connective tissue." },

    { "id": "C03", "act": "ACT III", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "Out of the Box" }, "narration_text": "How much setup? Almost none.", "spark_line": "Out of the Box" },
    {
      "id": "B08", "act": "ACT III", "lane": "REMOTION", "scene": "illustration/install-to-live",
      "narration_text": "The productivity plugin works the second you install it. No accounts to link, no connectors to authorize — install it from the sidebar and it's live. That's rare in this collection, and it's the reason it's a safe first install.",
      "show": "An install toggle flips and the plugin lights up immediately — no connection lines required, unlike the domain plugins beside it.",
      "spark_line": "Live on install."
    },
    {
      "id": "B09", "act": "ACT III", "lane": "MANIM", "scene": "manim/threshold_calendar_optional.mp4",
      "narration_text": "One optional add-on: your calendar. Without it, the plugin is still useful — it just can't see your time. Connect one and Claude crosses a line: now it knows what's committed, what's free, and where your focus blocks can go.",
      "show": "A 'useful' meter sits mid-scale; a calendar connects and the meter jumps past a threshold marked 'time-aware'.",
      "viz": { "pattern": "threshold", "before": "useful, time-blind", "after": "time-aware" },
      "spark_line": "Calendar = time-sense."
    },
    {
      "id": "B10", "act": "ACT III", "lane": "REMOTION", "scene": "illustration/connect-flow",
      "narration_text": "Connecting is the standard flow — click connect, sign in, grant access — the same three steps as any app on your phone. Once it's in, your schedule becomes context Claude factors into every recommendation it makes.",
      "show": "Three steps light in sequence — Connect → Sign in → Grant — then a calendar merges into the ongoing conversation.",
      "spark_line": "Connect, sign in, grant."
    },

    { "id": "C04", "act": "ACT IV", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Workflows" }, "narration_text": "Now the part that makes converts.", "spark_line": "The Workflows" },
    {
      "id": "B11", "act": "ACT IV", "lane": "VOX", "scene": "media/B11.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.55, 0.45] },
      "narration_text": "Picture the first move of the day. Before the tabs, before the noise — you open Cowork and just ask what your day looks like.",
      "show": "A person in early light opening a laptop, coffee at hand; a slow ease-in push toward the screen.",
      "spark_line": "First thing, ask.",
      "pantry_note": "Tier 1 illustrative: a person at a kitchen or home desk in early morning light, coffee, opening a laptop; warm duotone. Generic, no real UI on screen."
    },
    {
      "id": "B12", "act": "ACT IV", "lane": "REMOTION", "scene": "code-block",
      "narration_text": "The prompt is nothing fancy. What's my day look like? I have a client call at ten and a proposal due Friday — what should I prioritize? Plain speech, real constraints.",
      "show": "Onda code-block types the morning-briefing prompt line by line into the composer.",
      "props": { "code": "What's my day look like?\nI have a client call at 10 and a proposal due Friday.\nWhat should I prioritize?" },
      "spark_line": "Just ask your day."
    },
    {
      "id": "B13", "act": "ACT IV", "lane": "MANIM", "scene": "manim/accumulate_schedule_to_plan.mp4",
      "narration_text": "If your calendar's connected, Claude fuses three streams — your schedule, the priorities you just named, and tasks left over from earlier conversations — into one actionable plan. Not a to-do list. A plan for the day, sequenced.",
      "show": "Three inbound streams — schedule, priorities, leftover tasks — merge and stack into a single ordered plan.",
      "viz": { "pattern": "accumulate", "steps": ["schedule", "stated priorities", "pending tasks", "→ one plan"] },
      "spark_line": "Three streams, one plan."
    },
    {
      "id": "B14", "act": "ACT IV", "lane": "VOX", "scene": "media/B14.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.4, 0.5], "vox_run": "R1",
        "handoff": { "camera": { "x": 0.4, "y": 0.5, "scale": 1.6 }, "objects": [ { "id": "prepper", "x": 0.38, "y": 0.5, "scale": 1.0, "opacity": 1 } ] } },
      "narration_text": "Second workflow. Before a meeting that matters, you ask Claude to prepare you — and it pulls context from your files, past conversations, and general knowledge into a briefing.",
      "show": "A person at a desk reading a one-page briefing before a meeting; slow push. Same room grammar continues into B15.",
      "spark_line": "Prep before the room.",
      "pantry_note": "Tier 1 illustrative: a person at a desk reviewing a one-page briefing before a meeting; duotone. Continuity into B15 (vox_run R1)."
    },
    {
      "id": "B15", "act": "ACT IV", "lane": "VOX", "scene": "media/B15.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.62, 0.5], "vox_run": "R1" },
      "narration_text": "You walk in already knowing who they are, what they want, and what to raise. And the more context Cowork has accumulated about that client, the sharper the briefing gets.",
      "show": "Continuous move as the same person rises and steps toward a meeting-room doorway, briefing in hand — same room as B14.",
      "spark_line": "Walk in ready.",
      "pantry_note": "Tier 1 illustrative: same person rising and entering a meeting room, briefing in hand; identical duotone treatment. Continuity with B14 (vox_run R1)."
    },
    {
      "id": "B16", "act": "ACT IV", "lane": "MANIM", "scene": "manim/threshold_inbox_triage.mp4",
      "narration_text": "Third: the inbox. Point it at a wall of unread mail and it sorts by urgency — what needs a reply today, what can wait, what to archive — and drafts the easy ones for you to approve. Careful processing collapses into quick review.",
      "show": "A dense block of unread items fans out and sorts into three lanes — Today · Later · Archive — with a few 'draft' chips clipping onto the Today lane. No counts on screen.",
      "viz": { "pattern": "threshold", "before": "one undifferentiated inbox", "after": "Today · Later · Archive" },
      "spark_line": "Sort, draft, review."
    },
    {
      "id": "B17", "act": "ACT IV", "lane": "VOX", "scene": "media/B17.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "drawon", "focus": [0.5, 0.55] },
      "narration_text": "And the small one that saves you daily: capture without breaking flow. Something comes up mid-task — you say, add a follow-up with Sarah, due Thursday. It's logged, and you never left what you were doing.",
      "show": "A hand jots a quick note beside a working screen without looking up; a terracotta ring draws on around the captured task as it files itself.",
      "spark_line": "Capture, don't switch.",
      "pantry_note": "Tier 1 illustrative: a hand jotting a quick note beside a laptop mid-task, eyes still on the screen; duotone. Ring annotation added at previz."
    },

    { "id": "C05", "act": "ACT V", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "It Learns You" }, "narration_text": "It's not static. It learns your shape.", "spark_line": "It Learns You" },
    {
      "id": "B18", "act": "ACT V", "lane": "MANIM", "scene": "manim/branch_your_method_adopted.mp4",
      "narration_text": "Tell Claude how you already work and it adapts — it doesn't impose a method. Say you prioritize with an urgency-versus-importance matrix, and that's how it lays your options out: four quadrants, your rule, not its default.",
      "show": "A flat task list splits and branches into a four-quadrant grid; each item flies into its square.",
      "viz": { "pattern": "branch", "in": "one flat list", "workers": 4, "out": "four quadrants" },
      "spark_line": "Your method, adopted."
    },
    {
      "id": "B19", "act": "ACT V", "lane": "MANIM", "scene": "manim/accumulate_context_over_time.mp4",
      "narration_text": "And it compounds. The more Claude knows about your recurring commitments, ongoing projects, and working patterns, the more useful it gets. You don't front-load any of it — it accrues naturally, one conversation at a time.",
      "show": "A usefulness curve rises as small context marks accumulate along a timeline of sessions.",
      "viz": { "pattern": "accumulate", "steps": ["session 1", "session 2", "…", "compounding context"] },
      "spark_line": "It compounds."
    },
    {
      "id": "B20", "act": "ACT V", "lane": "REMOTION", "scene": "code-block",
      "narration_text": "The shortcut for that is global instructions — persistent context that applies to every session. Your role, your typical week, how you like information presented. Set it once; Claude remembers. Paired with this plugin, it's a force multiplier.",
      "show": "Onda code-block writes a short global-instructions block; a pin icon then fixes it across a row of session frames.",
      "props": { "code": "Role: freelance designer, solo.\nWeek: client work Mon–Thu, admin Fri.\nFormat: lead with the priority, then the why." },
      "spark_line": "Set once, remembered."
    },

    { "id": "C06", "act": "ACT VI", "lane": "CARD", "scene": "SegmentCard", "props": { "title": "The Foundation Layer" }, "narration_text": "So where does it sit?", "spark_line": "The Foundation Layer" },
    {
      "id": "B21", "act": "ACT VI", "lane": "REMOTION", "scene": "illustration/LayerStack",
      "narration_text": "Think in layers. Your domain plugins — sales, legal, whatever you run — sit on top. Productivity sits underneath all of them, holding the day together while they do the specialist work.",
      "show": "A layer stack builds bottom-up: a wide base plate labeled Productivity, domain plates settling on top of it.",
      "viz": { "pattern": "LayerStack", "base": "Productivity", "layers": ["a domain plugin", "another domain plugin"] },
      "spark_line": "Underneath it all."
    },
    {
      "id": "B22", "act": "ACT VI", "lane": "MANIM", "scene": "manim/accumulate_base_holds.mp4",
      "narration_text": "That's why it stays on. You swap specialists in and out as the work changes — but the base holds, session after session, carrying your tasks and context forward. It's the one you never turn off.",
      "show": "Top specialist plates cycle and change while the base plate stays lit; a session timeline advances beneath it.",
      "viz": { "pattern": "accumulate", "steps": ["swap specialist", "swap again", "base holds", "context carries forward"] },
      "spark_line": "The base holds."
    },
    {
      "id": "B23", "act": "ACT VI", "lane": "VOX", "scene": "media/B23.png",
      "shot": { "type": "STILL", "source": "ai", "motion": "kenburns", "focus": [0.5, 0.5] },
      "narration_text": "In practice it feels less like an app and more like a desk that's already tidy when you sit down — everything you left mid-thought still where you need it.",
      "show": "A calm, ordered workspace at the start of a day; a slow settle-in push.",
      "spark_line": "A tidy desk.",
      "pantry_note": "Tier 1 illustrative: a tidy, ordered desk/workspace at the start of a day, everything in its place; duotone. The always-on base."
    },
    {
      "id": "B24", "act": "ACT VI", "lane": "MANIM", "scene": "manim/accumulate_operating_system.mp4",
      "narration_text": "Add it up and you get the pitch in the title. One generalist under a few specialists, and Claude stops answering questions and starts running your day. That's the operating system.",
      "show": "The full stack resolves and labels itself 'Daily Operating System'; the base plate pulses once in terracotta.",
      "viz": { "pattern": "accumulate", "steps": ["generalist base", "+ specialists", "= daily operating system"] },
      "spark_line": "Your operating system."
    },

    {
      "id": "V01", "act": "CLOSE", "lane": "REMOTION", "scene": "ClaudeVerdictArtifact",
      "lead_silence_s": 0.5,
      "narration_text": "Let's recap with Claude. The productivity plugin is the generalist — it specializes in you, not a domain: tasks, meeting prep, email triage, note synthesis. It works the moment you install it, with no connections required. Connect a calendar and tell it how you work, and it sharpens. And it's the foundation layer — most people keep it on permanently, underneath their specialists.",
      "props": { "artifactLines": [ "The generalist — it specializes in you, not a domain", "Task tracking, meeting prep, email triage, note synthesis", "Works the moment you install it — no connections required", "Connect a calendar, tell it your method — it sharpens", "The foundation layer — kept on permanently under the specialists" ] },
      "spark_line": "The verdict."
    },
    {
      "id": "H01", "act": "CLOSE", "lane": "ASK", "scene": "ClaudeComposerAsk",
      "greeting": "Your turn.",
      "props": { "command": "I just installed the productivity plugin and I want it to run my day. (1) Ask me what I spend most of my time on and where my time leaks. (2) Ask how I already prioritize — deadlines, an urgency-importance matrix, whatever I use. (3) Then draft me a morning-briefing routine and a Friday weekly-review routine built around my real schedule, and tell me the one thing to put in global instructions so you remember it every session.", "runningText": "paste this into Claude…" },
      "narration_text": "Your turn. Paste this into Claude: I just installed the productivity plugin and I want it to run my day. Ask me what I spend most of my time on and where my time leaks. Ask how I already prioritize. Then draft me a morning-briefing routine and a Friday weekly-review routine around my real schedule — and tell me the one thing to put in global instructions so you remember it every session. That last part is the whole trick: it turns a one-off chat into a standing setup. Run it, and watch which questions it asks before it answers.",
      "spark_line": "Make it run your day."
    },
    {
      "id": "O01", "act": "CLOSE", "lane": "CARD", "scene": "ClaudeTitleOutro",
      "narration_text": "Claude, In Order. Liam, in for Bear.",
      "props": { "title": "Claude, In Order", "handle": "@NikBearBrown", "subline": "The Productivity Plugin" },
      "spark_line": "Claude, In Order"
    }
  ]
}
