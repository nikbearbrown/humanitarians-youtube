  {
   "beat_id": "B02",
   "estimated_duration_s": 10,
   "narration_text": "Start with two uncoupled states. As an external parameter changes, one energy rises and the other falls. With no communication between them, the lines cross cleanly.",
   "shot": {
    "type": "GRAPHIC",
    "source": "own",
    "motion": "trace"
   },
   "audio_file": "mp3/beat-B02.mp3",
